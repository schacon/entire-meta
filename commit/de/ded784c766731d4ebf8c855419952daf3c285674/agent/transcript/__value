ed(ctx context.Context, opts UpdateCommittedOptions) error {\\n  1101→\\tif opts.CheckpointID.IsEmpty() {\\n  1102→\\t\\treturn errors.New(\\\"invalid update options: checkpoint ID is required\\\")\\n  1103→\\t}\\n  1104→\\n  1105→\\t// Ensure sessions branch exists\\n  1106→\\tif err := s.ensureSessionsBranch(); err != nil {\\n  1107→\\t\\treturn fmt.Errorf(\\\"failed to ensure sessions branch: %w\\\", err)\\n  1108→\\t}\\n  1109→\\n  1110→\\t// Get current branch tip and flatten tree\\n  1111→\\tref, entries, err := s.getSessionsBranchEntries()\\n  1112→\\tif err != nil {\\n  1113→\\t\\treturn err\\n  1114→\\t}\\n  1115→\\n  1116→\\t// Read root CheckpointSummary to find the session slot\\n  1117→\\tbasePath := opts.CheckpointID.Path() + \\\"/\\\"\\n  1118→\\trootMetadataPath := basePath + paths.MetadataFileName\\n  1119→\\tentry, exists := entries[rootMetadataPath]\\n  1120→\\tif !exists {\\n  1121→\\t\\treturn ErrCheckpointNotFound\\n  1122→\\t}\\n  1123→\\n  1124→\\tcheckpointSummary, err := s.readSummaryFromBlob(entry.Hash)\\n  1125→\\tif err != nil {\\n  1126→\\t\\treturn fmt.Errorf(\\\"failed to read checkpoint summary: %w\\\", err)\\n  1127→\\t}\\n  1128→\\tif len(checkpointSummary.Sessions) == 0 {\\n  1129→\\t\\treturn ErrCheckpointNotFound\\n  1130→\\t}\\n  1131→\\n  1132→\\t// Find session index matching opts.SessionID\\n  1133→\\tsessionIndex := -1\\n  1134→\\tfor i := range len(checkpointSummary.Sessions) {\\n  1135→\\t\\tmetaPath := fmt.Sprintf(\\\"%s%d/%s\\\", basePath, i, paths.MetadataFileName)\\n  1136→\\t\\tif metaEntry, metaExists := entries[metaPath]; metaExists {\\n  1137→\\t\\t\\tmeta, metaErr := s.readMetadataFromBlob(metaEntry.Hash)\\n  1138→\\t\\t\\tif metaErr == nil && meta.SessionID == opts.SessionID {\\n  1139→\\t\\t\\t\\tsessionIndex = i\\n  1140→\\t\\t\\t\\tbreak\\n  1141→\\t\\t\\t}\\n  1142→\\t\\t}\\n  1143→\\t}\\n  1144→\\tif sessionIndex == -1 {\\n  1145→\\t\\t// Fall back to latest session; log so mismatches are diagnosable.\\n  1146→\\t\\tsessionIndex = len(checkpointSummary.Sessions) - 1\\n  1147→\\t\\tlogging.Debug(ctx, \\\"UpdateCommitted: session ID not found, falling back to latest\\\",\\n  1148→\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n  1149→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", string(opts.CheckpointID)),\\n  1150→\\t\\t\\tslog.Int(\\\"fallback_index\\\", sessionIndex),\\n  1151→\\t\\t)\\n  1152→\\t}\\n  1153→\\n  1154→\\tsessionPath := fmt.Sprintf(\\\"%s%d/\\\", basePath, sessionIndex)\\n  1155→\\n  1156→\\t// Replace transcript (full replace, not append)\\n  1157→\\t// Apply redaction as safety net (caller should redact, but we ensure it here)\\n  1158→\\tif len(opts.Transcript) > 0 {\\n  1159→\\t\\ttranscript, err := redact.JSONLBytes(opts.Transcript)\\n  1160→\\t\\tif err != nil {\\n  1161→\\t\\t\\treturn fmt.Errorf(\\\"failed to redact transcript secrets: %w\\\", err)\\n  1162→\\t\\t}\\n  1163→\\t\\tif err := s.replaceTranscript(transcript, opts.Agent, sessionPath, entries); err != nil {\\n  1164→\\t\\t\\treturn fmt.Errorf(\\\"failed to replace transcript: %w\\\", err)\\n  1165→\\t\\t}\\n  1166→\\t}\\n  1167→\\n  1168→\\t// Replace prompts (apply redaction as safety net)\\n  1169→\\tif len(opts.Prompts) > 0 {\\n  1170→\\t\\tpromptContent := redact.String(strings.Join(opts.Prompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\"))\\n  1171→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(promptContent))\\n  1172→\\t\\tif err != nil {\\n  1173→\\t\\t\\treturn fmt.Errorf(\\\"failed to create prompt blob: %w\\\", err)\\n  1174→\\t\\t}\\n  1175→\\t\\tentries[sessionPath+paths.PromptFileName] = object.TreeEntry{\\n  1176→\\t\\t\\tName: sessionPath + paths.PromptFileName,\\n  1177→\\t\\t\\tMode: filemode.Regular,\\n  1178→\\t\\t\\tHash: blobHash,\\n  1179→\\t\\t}\\n  1180→\\t}\\n  1181→\\n  1182→\\t// Replace context (apply redaction as safety net)\\n  1183→\\tif len(opts.Context) > 0 {\\n  1184→\\t\\tcontextBlob, err := CreateBlobFromContent(s.repo, redact.Bytes(opts.Context))\\n  1185→\\t\\tif err != nil {\\n  1186→\\t\\t\\treturn fmt.Errorf(\\\"failed to create context blob: %w\\\", err)\\n  1187→\\t\\t}\\n  1188→\\t\\tentries[sessionPath+paths.ContextFileName] = object.TreeEntry{\\n  1189→\\t\\t\\tName: sessionPath + paths.ContextFileName,\\n  1190→\\t\\t\\tMode: filemode.Regular,\\n  1191→\\t\\t\\tHash: contextBlob,\\n  1192→\\t\\t}\\n  1193→\\t}\\n  1194→\\n  1195→\\t// Build and commit\\n  1196→\\tnewTreeHash, err := BuildTreeFromEntries(s.repo, entries)\\n  1197→\\tif err != nil {\\n  1198→\\t\\treturn err\\n  1199→\\t}\\n  1200→\\n  1201→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1202→\\tcommitMsg := fmt.Sprintf(\\\"Finalize transcript for Checkpoint: %s\\\", opts.CheckpointID)\\n  1203→\\tnewCommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n  1204→\\tif err != nil {\\n  1205→\\t\\treturn err\\n  1206→\\t}\\n  1207→\\n  1208→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1209→\\tnewRef := plumbing.NewHashReference(refName, newCommitHash)\\n  1210→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1211→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1212→\\t}\\n  1213→\\n  1214→\\treturn nil\\n  1215→}\\n  1216→\\n  1217→// replaceTranscript writes the full transcript content, replacing any existing transcript.\\n  1218→// Also removes any chunk files from a previous write and updates the content hash.\\n  1219→func (s *GitStore) replaceTranscript(transcript []byte, agentType agent.AgentType, sessionPath string, entries map[string]object.TreeEntry) error {\\n  1220→\\t// Remove existing transcript files (base + any chunks)\\n  1221→\\ttranscriptBase := sessionPath + paths.TranscriptFileName\\n  1222→\\tfor key := range entries {\\n  1223→\\t\\tif key == transcriptBase || strings.HasPrefix(key, transcriptBase+\\\".\\\") {\\n  1224→\\t\\t\\tdelete(entries, key)\\n  1225→\\t\\t}\\n  1226→\\t}\\n  1227→\\n  1228→\\t// Chunk the transcript (matches writeTranscript behavior)\\n  1229→\\tchunks, err := agent.ChunkTranscript(transcript, agentType)\\n  1230→\\tif err != nil {\\n  1231→\\t\\treturn fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n  1232→\\t}\\n  1233→\\n  1234→\\t// Write chunk files\\n  1235→\\tfor i, chunk := range chunks {\\n  1236→\\t\\tchunkPath := sessionPath + agent.ChunkFileName(paths.TranscriptFileName, i)\\n  1237→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, chunk)\\n  1238→\\t\\tif err != nil {\\n  1239→\\t\\t\\treturn fmt.Errorf(\\\"failed to create transcript blob: %w\\\", err)\\n  1240→\\t\\t}\\n  1241→\\t\\tentries[chunkPath] = object.TreeEntry{\\n  1242→\\t\\t\\tName: chunkPath,\\n  1243→\\t\\t\\tMode: filemode.Regular,\\n  1244→\\t\\t\\tHash: blobHash,\\n  1245→\\t\\t}\\n  1246→\\t}\\n  1247→\\n  1248→\\t// Update content hash\\n  1249→\\tcontentHash := fmt.Sprintf(\\\"sha256:%x\\\", sha256.Sum256(transcript))\\n  1250→\\thashBlob, err := CreateBlobFromContent(s.repo, []byte(contentHash))\\n  1251→\\tif err != nil {\\n  1252→\\t\\treturn fmt.Errorf(\\\"failed to create content hash blob: %w\\\", err)\\n  1253→\\t}\\n  1254→\\thashPath := sessionPath + paths.ContentHashFileName\\n  1255→\\tentries[hashPath] = object.TreeEntry{\\n  1256→\\t\\tName: hashPath,\\n  1257→\\t\\tMode: filemode.Regular,\\n  1258→\\t\\tHash: hashBlob,\\n  1259→\\t}\\n  1260→\\n  1261→\\treturn nil\\n  1262→}\\n  1263→\\n  1264→// ensureSessionsBranch ensures the entire/checkpoints/v1 branch exists.\\n  1265→func (s *GitStore) ensureSessionsBranch() error {\\n  1266→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1267→\\t_, err := s.repo.Reference(refName, true)\\n  1268→\\tif err == nil {\\n  1269→\\t\\treturn nil // Branch exists\\n  1270→\\t}\\n  1271→\\n  1272→\\t// Create orphan branch with empty tree\\n  1273→\\temptyTreeHash, err := BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n  1274→\\tif err != nil {\\n  1275→\\t\\treturn err\\n  1276→\\t}\\n  1277→\\n  1278→\\tauthorName, authorEmail := GetGitAuthorFromRepo(s.repo)\\n  1279→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize sessions branch\\\", authorName, authorEmail)\\n  1280→\\tif err != nil {\\n  1281→\\t\\treturn err\\n  1282→\\t}\\n  1283→\\n  1284→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n  1285→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n  1286→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n  1287→\\t}\\n  1288→\\treturn nil\\n  1289→}\\n  1290→\\n  1291→// getSessionsBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n  1292→// Falls back to origin/entire/checkpoints/v1 if the local branch doesn't exist.\\n  1293→func (s *GitStore) getSessionsBranchTree() (*object.Tree, error) {\\n  1294→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n  1295→\\tref, err := s.repo.Reference(refName, true)\\n  1296→\\tif err != nil {\\n  1297→\\t\\t// Local branch doesn't exist, try remote-tracking branch\\n  1298→\\t\\tremoteRefName := plumbing.NewRemoteReferenceName(\\\"origin\\\", paths.MetadataBranchName)\\n  1299→\\t\\tref, err = s.repo.Reference(remoteRefName, true)\\n  1300→\\t\\tif err != nil {\\n  1301→\\t\\t\\treturn nil, fmt.Errorf(\\\"sessions branch not found: %w\\\", err)\\n  1302→\\t\\t}\\n  1303→\\t}\\n  1304→\\n  1305→\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n  1306→\\tif err != nil {\\n  1307→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n  1308→\\t}\\n  1309→\\n  1310→\\ttree, err := commit.Tree()\\n  1311→\\tif err != nil {\\n  1312→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n  1313→\\t}\\n  1314→\\n  1315→\\treturn tree, nil\\n  1316→}\\n  1317→\\n  1318→// CreateBlobFromContent creates a blob object from in-memory content.\\n  1319→// Exported for use by strategy package (session_test.go)\\n  1320→func CreateBlobFromContent(repo *git.Repository, content []byte) (plumbing.Hash, error) {\\n  1321→\\tobj := repo.Storer.NewEncodedObject()\\n  1322→\\tobj.SetType(plumbing.BlobObject)\\n  1323→\\tobj.SetSize(int64(len(content)))\\n  1324→\\n  1325→\\twriter, err := obj.Writer()\\n  1326→\\tif err != nil {\\n  1327→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n  1328→\\t}\\n  1329→\\n  1330→\\t_, err = writer.Write(content)\\n  1331→\\tif err != nil {\\n  1332→\\t\\t_ = writer.Close()\\n  1333→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n  1334→\\t}\\n  1335→\\tif err := writer.Close(); err != nil {\\n  1336→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n  1337→\\t}\\n  1338→\\n  1339→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1340→\\tif err != nil {\\n  1341→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n  1342→\\t}\\n  1343→\\treturn hash, nil\\n  1344→}\\n  1345→\\n  1346→// copyMetadataDir copies all files from a directory to the checkpoint path.\\n  1347→// Used to include additional metadata files like task checkpoints, subagent transcripts, etc.\\n  1348→func (s *GitStore) copyMetadataDir(metadataDir, basePath string, entries map[string]object.TreeEntry) error {\\n  1349→\\terr := filepath.Walk(metadataDir, func(path string, info os.FileInfo, err error) error {\\n  1350→\\t\\tif err != nil {\\n  1351→\\t\\t\\treturn err\\n  1352→\\t\\t}\\n  1353→\\n  1354→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n  1355→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n  1356→\\t\\t// then be captured in the checkpoint and stored in git history.\\n  1357→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n  1358→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n  1359→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n  1360→\\t\\t// directories and would recurse into them otherwise.\\n  1361→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n  1362→\\t\\tif lstatErr != nil {\\n  1363→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n  1364→\\t\\t}\\n  1365→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n  1366→\\t\\t\\tif info.IsDir() {\\n  1367→\\t\\t\\t\\treturn filepath.SkipDir\\n  1368→\\t\\t\\t}\\n  1369→\\t\\t\\treturn nil\\n  1370→\\t\\t}\\n  1371→\\n  1372→\\t\\tif info.IsDir() {\\n  1373→\\t\\t\\treturn nil\\n  1374→\\t\\t}\\n  1375→\\n  1376→\\t\\t// Get relative path within metadata dir\\n  1377→\\t\\trelPath, err := filepath.Rel(metadataDir, path)\\n  1378→\\t\\tif err != nil {\\n  1379→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n  1380→\\t\\t}\\n  1381→\\n  1382→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n  1383→\\t\\tif strings.HasPrefix(relPath, \\\"..\\\") {\\n  1384→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relPath)\\n  1385→\\t\\t}\\n  1386→\\n  1387→\\t\\t// Create blob from file with secrets redaction\\n  1388→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(s.repo, path, relPath)\\n  1389→\\t\\tif err != nil {\\n  1390→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n  1391→\\t\\t}\\n  1392→\\n  1393→\\t\\t// Store at checkpoint path (use forward slashes for git tree compatibility on Windows)\\n  1394→\\t\\tfullPath := basePath + filepath.ToSlash(relPath)\\n  1395→\\t\\tentries[fullPath] = object.TreeEntry{\\n  1396→\\t\\t\\tName: fullPath,\\n  1397→\\t\\t\\tMode: mode,\\n  1398→\\t\\t\\tHash: blobHash,\\n  1399→\\t\\t}\\n  1400→\\n  1401→\\t\\treturn nil\\n  1402→\\t})\\n  1403→\\tif err != nil {\\n  1404→\\t\\treturn fmt.Errorf(\\\"failed to walk metadata directory: %w\\\", err)\\n  1405→\\t}\\n  1406→\\treturn nil\\n  1407→}\\n  1408→\\n  1409→// createRedactedBlobFromFile reads a file, applies secrets redaction, and creates a git blob.\\n  1410→// JSONL files get JSONL-aware redaction; all other files get plain string redaction.\\n  1411→func createRedactedBlobFromFile(repo *git.Repository, filePath, treePath string) (plumbing.Hash, filemode.FileMode, error) {\\n  1412→\\tinfo, err := os.Stat(filePath)\\n  1413→\\tif err != nil {\\n  1414→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n  1415→\\t}\\n  1416→\\n  1417→\\tmode := filemode.Regular\\n  1418→\\tif info.Mode()&0o111 != 0 {\\n  1419→\\t\\tmode = filemode.Executable\\n  1420→\\t}\\n  1421→\\n  1422→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the metadata directory\\n  1423→\\tif err != nil {\\n  1424→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n  1425→\\t}\\n  1426→\\n  1427→\\t// Skip redaction for binary files — they can't contain text secrets and\\n  1428→\\t// running string replacement on them would corrupt the data.\\n  1429→\\tisBin, binErr := binary.IsBinary(bytes.NewReader(content))\\n  1430→\\tif binErr != nil || isBin {\\n  1431→\\t\\thash, err := CreateBlobFromContent(repo, content)\\n  1432→\\t\\tif err != nil {\\n  1433→\\t\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1434→\\t\\t}\\n  1435→\\t\\treturn hash, mode, nil\\n  1436→\\t}\\n  1437→\\n  1438→\\tif strings.HasSuffix(treePath, \\\".jsonl\\\") {\\n  1439→\\t\\tredacted, jsonlErr := redact.JSONLBytes(content)\\n  1440→\\t\\tif jsonlErr != nil {\\n  1441→\\t\\t\\tredacted = redact.Bytes(content)\\n  1442→\\t\\t}\\n  1443→\\t\\tcontent = redacted\\n  1444→\\t} else {\\n  1445→\\t\\tcontent = redact.Bytes(content)\\n  1446→\\t}\\n  1447→\\n  1448→\\thash, err := CreateBlobFromContent(repo, content)\\n  1449→\\tif err != nil {\\n  1450→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to create blob: %w\\\", err)\\n  1451→\\t}\\n  1452→\\treturn hash, mode, nil\\n  1453→}\\n  1454→\\n  1455→// GetGitAuthorFromRepo retrieves the git user.name and user.email,\\n  1456→// checking both the repository-local config and the global ~/.gitconfig.\\n  1457→func GetGitAuthorFromRepo(repo *git.Repository) (name, email string) {\\n  1458→\\t// Get repository config (includes local settings)\\n  1459→\\tcfg, err := repo.Config()\\n  1460→\\tif err == nil {\\n  1461→\\t\\tname = cfg.User.Name\\n  1462→\\t\\temail = cfg.User.Email\\n  1463→\\t}\\n  1464→\\n  1465→\\t// If not found in local config, try global config\\n  1466→\\tif name == \\\"\\\" || email == \\\"\\\" {\\n  1467→\\t\\tglobalCfg, err := config.LoadConfig(config.GlobalScope)\\n  1468→\\t\\tif err == nil {\\n  1469→\\t\\t\\tif name == \\\"\\\" {\\n  1470→\\t\\t\\t\\tname = globalCfg.User.Name\\n  1471→\\t\\t\\t}\\n  1472→\\t\\t\\tif email == \\\"\\\" {\\n  1473→\\t\\t\\t\\temail = globalCfg.User.Email\\n  1474→\\t\\t\\t}\\n  1475→\\t\\t}\\n  1476→\\t}\\n  1477→\\n  1478→\\t// Provide sensible defaults if git user is not configured\\n  1479→\\tif name == \\\"\\\" {\\n  1480→\\t\\tname = \\\"Unknown\\\"\\n  1481→\\t}\\n  1482→\\tif email == \\\"\\\" {\\n  1483→\\t\\temail = \\\"unknown@local\\\"\\n  1484→\\t}\\n  1485→\\n  1486→\\treturn name, email\\n  1487→}\\n  1488→\\n  1489→// readTranscriptFromTree reads a transcript from a git tree, handling both chunked and non-chunked formats.\\n  1490→// It checks for chunk files first (.001, .002, etc.), then falls back to the base file.\\n  1491→// The agentType is used for reassembling chunks in the correct format.\\n  1492→func readTranscriptFromTree(tree *object.Tree, agentType agent.AgentType) ([]byte, error) {\\n  1493→\\t// Collect all transcript-related files\\n  1494→\\tvar chunkFiles []string\\n  1495→\\tvar hasBaseFile bool\\n  1496→\\n  1497→\\tfor _, entry := range tree.Entries {\\n  1498→\\