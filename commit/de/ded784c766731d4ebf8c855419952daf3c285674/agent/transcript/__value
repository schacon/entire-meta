→\\treturn runner.SimulatePostTodo(input)\\n   365→}\\n   366→\\n   367→// ClearSessionState removes the session state file for the given session ID.\\n   368→// This simulates what happens when a user commits their changes (session is \\\"completed\\\").\\n   369→// Used in tests to allow sequential sessions to run without triggering concurrent session warnings.\\n   370→func (env *TestEnv) ClearSessionState(sessionID string) error {\\n   371→\\tenv.T.Helper()\\n   372→\\n   373→\\t// Session state is stored in .git/entire-sessions/<session-id>.json\\n   374→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   375→\\n   376→\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n   377→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   378→\\t}\\n   379→\\treturn nil\\n   380→}\\n   381→\\n   382→// HookOutput contains the result of running a hook.\\n   383→type HookOutput struct {\\n   384→\\tStdout []byte\\n   385→\\tStderr []byte\\n   386→\\tErr    error\\n   387→}\\n   388→\\n   389→// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\n   390→func (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   391→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   392→\\tcmd.Dir = r.RepoDir\\n   393→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   394→\\tcmd.Env = append(os.Environ(),\\n   395→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   396→\\t)\\n   397→\\n   398→\\tvar stdout, stderr bytes.Buffer\\n   399→\\tcmd.Stdout = &stdout\\n   400→\\tcmd.Stderr = &stderr\\n   401→\\n   402→\\terr := cmd.Run()\\n   403→\\treturn HookOutput{\\n   404→\\t\\tStdout: stdout.Bytes(),\\n   405→\\t\\tStderr: stderr.Bytes(),\\n   406→\\t\\tErr:    err,\\n   407→\\t}\\n   408→}\\n   409→\\n   410→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit 