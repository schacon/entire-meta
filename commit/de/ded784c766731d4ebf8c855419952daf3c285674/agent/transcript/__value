GetCheckpointIDFromCommitMessage(commitSHA string) string {\\n  1333→\\tenv.T.Helper()\\n  1334→\\n  1335→\\tmsg := env.GetCommitMessage(commitSHA)\\n  1336→\\tcpID, found := trailers.ParseCheckpoint(msg)\\n  1337→\\tif !found {\\n  1338→\\t\\treturn \\\"\\\"\\n  1339→\\t}\\n  1340→\\treturn cpID.String()\\n  1341→}\\n  1342→\\n  1343→// GetLatestCheckpointIDFromHistory walks backwards from HEAD on the active branch\\n  1344→// and returns the checkpoint ID from the first commit that has an Entire-Checkpoint trailer.\\n  1345→// This verifies that condensation actually happened (commit has trailer) without relying\\n  1346→// on timestamp-based matching.\\n  1347→func (env *TestEnv) GetLatestCheckpointIDFromHistory() string {\\n  1348→\\tenv.T.Helper()\\n  1349→\\n  1350→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  1351→\\tif err != nil {\\n  1352→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n  1353→\\t}\\n  1354→\\n  1355→\\thead, err := repo.Head()\\n  1356→\\tif err != nil {\\n  1357→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n  1358→\\t}\\n  1359→\\n  1360→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n  1361→\\tif err != nil {\\n  1362→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n  1363→\\t}\\n  1364→\\n  1365→\\tvar checkpointID string\\n  1366→\\t//nolint:errcheck // ForEach callback handles errors\\n  1367→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n  1368→\\t\\tif cpID, found := trailers.ParseCheckpoint(c.Message); found {\\n  1369→\\t\\t\\tcheckpointID = cpID.String()\\n  1370→\\t\\t\\treturn errors.New(\\\"stop iteration\\\") // Found it, stop\\n  1371→\\t\\t}\\n  1372→\\t\\treturn nil\\n  1373→\\t})\\n  1374→\\n  1375→\\tif checkpointID == \\\"\\\" {\\n  1376→\\t\\tenv.T.Fatalf(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n  1377→\\t}\\n  1378→\\n  1379→\\treturn checkpointID\\n  1380→}\\n  1381→\\n  1382→// ShardedCheckpointPath returns the sharded path for a checkpoint ID.\\n  1383→// Format: <id[:2]>/<id[2:]>\\n  1384→// Delegates to id.CheckpointID.Path() for consistency.\\n  1385→func ShardedCheckpointPath(checkpointID string) string {\\n  1386→\\treturn id.CheckpointID(checkpointID).Path()\\n  1387→}\\n  1388→\\n  1389→// SessionFilePath returns the path to a session file within a checkpoint.\\n  1390→// Session files are stored in numbered subdirectories using 0-based indexing (e.g., 0/full.jsonl).\\n  1391→// This function constructs the path for the first (default) session.\\n  1392→func SessionFilePath(checkpointID string, fileName string) string {\\n  1393→\\treturn id.CheckpointID(checkpointID).Path() + \\\"/0/\\\" + fileName\\n  1394→}\\n  1395→\\n  1396→// CheckpointSummaryPath returns the path to the root metadata.json (CheckpointSummary) for a checkpoint.\\n  1397→func CheckpointSummaryPath(checkpointID string) string {\\n  1398→\\treturn id.CheckpointID(checkpointID).Path() + \\\"/\\\" + paths.MetadataFileName\\n  1399→}\\n  1400→\\n  1401→// SessionMetadataPath returns the path to the session-level metadata.json for a checkpoint.\\n  1402→func SessionMetadataPath(checkpointID string) string {\\n  1403→\\treturn SessionFilePath(checkpointID, paths.MetadataFileName)\\n  1404→}\\n  1405→\\n  1406→// CheckpointValidation contains expected values for checkpoint validation.\\n  1407→type CheckpointValidation struct {\\n  1408→\\t// CheckpointID is the expected checkpoint ID\\n  1409→\\tCheckpointID string\\n  1410→\\n  1411→\\t// SessionID is the expected session ID\\n  1412→\\tSessionID string\\n  1413→\\n  1414→\\t// Strategy is the expected strategy name\\n  1415→\\tStrategy string\\n  1416→\\n  1417→\\t// FilesTouched are the expected files in files_touched\\n  1418→\\tFilesTouched []string\\n  1419→\\n  1420→\\t// ExpectedPrompts are strings that should appear in prompt.txt\\n  1421→\\tExpectedPrompts []string\\n  1422→\\n  1423→\\t// ExpectedTranscriptContent are strings that should appear 