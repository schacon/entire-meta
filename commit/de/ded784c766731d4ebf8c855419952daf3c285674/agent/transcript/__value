ging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: new file has no significant overlap (reverted & replaced)\\\",\\n   315→\\t\\t\\tslog.String(\\\"file\\\", stagedPath),\\n   316→\\t\\t\\tslog.String(\\\"staged_hash\\\", stagedHash.String()),\\n   317→\\t\\t\\tslog.String(\\\"shadow_hash\\\", shadowFile.Hash.String()),\\n   318→\\t\\t)\\n   319→\\t}\\n   320→\\n   321→\\tlogging.Debug(logCtx, \\\"stagedFilesOverlapWithContent: no overlapping files found\\\",\\n   322→\\t\\tslog.Int(\\\"staged_files\\\", len(stagedFiles)),\\n   323→\\t\\tslog.Int(\\\"files_touched\\\", len(filesTouched)),\\n   324→\\t)\\n   325→\\treturn false\\n   326→}\\n   327→\\n   328→// hasOverlappingFiles checks if any file in stagedFiles appears in filesTouched.\\n   329→// This is a fallback when content-aware comparison isn't possible.\\n   330→func hasOverlappingFiles(stagedFiles, filesTouched []string) bool {\\n   331→\\ttouchedSet := make(map[string]bool)\\n   332→\\tfor _, f := range filesTouched {\\n   333→\\t\\ttouchedSet[f] = true\\n   334→\\t}\\n   335→\\n   336→\\tfor _, staged := range stagedFiles {\\n   337→\\t\\tif touchedSet[staged] {\\n   338→\\t\\t\\treturn true\\n   339→\\t\\t}\\n   340→\\t}\\n   341→\\treturn false\\n   342→}\\n   343→\\n   344→// filesWithRemainingAgentChanges returns files from filesTouched that still have\\n   345→// uncommitted agent changes. This is used for carry-forward after partial commits.\\n   346→//\\n   347→// A file has remaining agent changes if:\\n   348→//   - It wasn't committed at all (not in committedFiles), OR\\n   349→//   - It was committed but the committed content doesn't match the shadow branch\\n   350→//     (user committed partial changes, e.g., via git add -p)\\n   351→//\\n   352→// Falls back to file-level subtraction if shadow branch is unavailable.\\n   353→func filesWithRemainingAgentChanges(\\n   354→\\trepo *git.Repository,\\n   355→\\tshadowBranchName string,\\n   356→\\theadCommit *object.Commit,\\n   357→\\tfilesT