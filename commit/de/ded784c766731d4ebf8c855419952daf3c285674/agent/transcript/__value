// (nothing to delete).\\n    17→func runOpenCodeSessionDelete(sessionID string) error {\\n    18→\\tctx, cancel := context.WithTimeout(context.Background(), openCodeCommandTimeout)\\n    19→\\tdefer cancel()\\n    20→\\n    21→\\tcmd := exec.CommandContext(ctx, \\\"opencode\\\", \\\"session\\\", \\\"delete\\\", sessionID)\\n    22→\\toutput, err := cmd.CombinedOutput()\\n    23→\\tif err != nil {\\n    24→\\t\\tif ctx.Err() == context.DeadlineExceeded {\\n    25→\\t\\t\\treturn fmt.Errorf(\\\"opencode session delete timed out after %s\\\", openCodeCommandTimeout)\\n    26→\\t\\t}\\n    27→\\t\\t// Treat \\\"Session not found\\\" as success — nothing to delete.\\n    28→\\t\\tif strings.Contains(string(output), \\\"Session not found\\\") {\\n    29→\\t\\t\\treturn nil\\n    30→\\t\\t}\\n    31→\\t\\treturn fmt.Errorf(\\\"opencode session delete failed: %w (output: %s)\\\", err, string(output))\\n    32→\\t}\\n    33→\\treturn nil\\n    34→}\\n    35→\\n    36→// runOpenCodeImport runs `opencode import <file>` to import a session into\\n    37→// OpenCode's database. The import preserves the original session ID\\n    38→// from the export file.\\n    39→func runOpenCodeImport(exportFilePath string) error {\\n    40→\\tctx, cancel := context.WithTimeout(context.Background(), openCodeCommandTimeout)\\n    41→\\tdefer cancel()\\n    42→\\n    43→\\tcmd := exec.CommandContext(ctx, \\\"opencode\\\", \\\"import\\\", exportFilePath)\\n    44→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n    45→\\t\\tif ctx.Err() == context.DeadlineExceeded {\\n    46→\\t\\t\\treturn fmt.Errorf(\\\"opencode import timed out after %s\\\", openCodeCommandTimeout)\\n    47→\\t\\t}\\n    48→\\t\\treturn fmt.Errorf(\\\"opencode import failed: %w (output: %s)\\\", err, string(output))\\n    49→\\t}\\n    50→\\n    51→\\treturn nil\\n    52→}\\n    53→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provid