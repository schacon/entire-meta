 cleaned\\n   544→\\t\\t}\\n   545→\\t\\treturn nil\\n   546→\\t}\\n   547→\\n   548→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   549→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   550→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   551→\\t\\tif err == nil && len(prompts) > 0 {\\n   552→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   553→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   554→\\t\\t\\tfor _, prompt := range prompts {\\n   555→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   556→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   557→\\t\\t\\t\\t}\\n   558→\\t\\t\\t}\\n   559→\\t\\t\\treturn cleaned\\n   560→\\t\\t}\\n   561→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   562→\\t\\tif agentType == agent.AgentTypeGemini {\\n   563→\\t\\t\\treturn nil\\n   564→\\t\\t}\\n   565→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   566→\\t}\\n   567→\\n   568→\\t// Claude Code and other JSONL-based agents\\n   569→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   570→}\\n   571→\\n   572→// calculateTokenUsage calculates token usage from raw transcript data.\\n   573→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   574→// where the current checkpoint began, allowing calculation for only the portion\\n   575→// of the transcript since the last checkpoint.\\n   576→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   577→\\tif len(data) == 0 {\\n   578→\\t\\treturn &agent.TokenUsage{}\\n   579→\\t}\\n   580→\\n   581→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   582→\\tif agentType == agent.AgentTypeOpenCode {\\n   583→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   584→\\t}\\n   585→\\n   586→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   587→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   588→\\t\\t// Attempt to parse as Gemini JSON\\n   589→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   590→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   591→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   592→\\t\\t}\\n   593→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   594→\\t\\tif agentType == agent.AgentTypeGemini {\\n   595→\\t\\t\\treturn &agent.TokenUsage{}\\n   596→\\t\\t}\\n   597→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   598→\\t}\\n   599→\\n   600→\\t// Claude Code and other JSONL-based agents\\n   601→\\tlines, err := transcript.ParseFromBytes(data)\\n   602→\\tif err != nil || len(lines) == 0 {\\n   603→\\t\\treturn &agent.TokenUsage{}\\n   604→\\t}\\n   605→\\t// Slice transcript lines to only include checkpoint portion\\n   606→\\tif startOffset > 0 && startOffset < len(lines) {\\n   607→\\t\\tlines = lines[startOffset:]\\n   608→\\t}\\n   609→\\treturn claudecode.CalculateTokenUsage(lines)\\n   610→}\\n   611→\\n   612→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   613→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   614→func extractUserPromptsFromLines(lines []string) []string {\\n   615→\\tvar prompts []string\\n   616→\\tfor _, line := range lines {\\n   617→\\t\\tline = strings.TrimSpace(line)\\n   618→\\t\\tif line == \\\"\\\" {\\n   619→\\t\\t\\tcontinue\\n   620→\\t\\t}\\n   621→\\n   622→\\t\\tvar entry map[string]interface{}\\n   623→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   624→\\t\\t\\tcontinue\\n   625→\\t\\t}\\n   626→\\n   627→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   628→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   629→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   630→\\t\\t\\tcontinue\\n   631→\\t\\t}\\n   632→\\n   633→\\t\\t// Extract message content\\n   634→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   635→\\t\\tif !ok {\\n   636→\\t\\t\\tcontinue\\n   637→\\t\\t}\\n   638→\\n   639→\\t\\t// Handle string content\\n   640→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   641→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   642→\\t\\t\\tif cleaned != \\\"\\\" {\\n   643→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   644→\\t\\t\\t}\\n   645→\\t\\t\\tcontinue\\n   646→\\t\\t}\\n   647→\\n   648→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   649→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   650→\\t\\t\\tvar texts []string\\n   651→\\t\\t\\tfor _, item := range arr {\\n   652→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   653→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   654→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   655→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   656→\\t\\t\\t\\t\\t\\t}\\n   657→\\t\\t\\t\\t\\t}\\n   658→\\t\\t\\t\\t}\\n   659→\\t\\t\\t}\\n   660→\\t\\t\\tif len(texts) > 0 {\\n   661→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   662→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   663→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   664→\\t\\t\\t\\t}\\n   665→\\t\\t\\t}\\n   666→\\t\\t}\\n   667→\\t}\\n   668→\\treturn prompts\\n   669→}\\n   670→\\n   671→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   672→func generateContextFromPrompts(prompts []string) []byte {\\n   673→\\tif len(prompts) == 0 {\\n   674→\\t\\treturn nil\\n   675→\\t}\\n   676→\\n   677→\\tvar buf strings.Builder\\n   678→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   679→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   680→\\n   681→\\tfor i, prompt := range prompts {\\n   682→\\t\\t// Truncate very long prompts for readability\\n   683→\\t\\tdisplayPrompt := prompt\\n   684→\\t\\tif len(displayPrompt) > 500 {\\n   685→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   686→\\t\\t}\\n   687→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   688→\\t\\tbuf.WriteString(displayPrompt)\\n   689→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   690→\\t}\\n   691→\\n   692→\\treturn []byte(buf.String())\\n   693→}\\n   694→\\n   695→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   696→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   697→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   698→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   699→\\n   700→\\t// Load session state\\n   701→\\tstate, err := s.loadSessionState(sessionID)\\n   702→\\tif err != nil {\\n   703→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   704→\\t}\\n   705→\\tif state == nil {\\n   706→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   707→\\t}\\n   708→\\n   709→\\t// Open repository\\n   710→\\trepo, err := OpenRepository()\\n   711→\\tif err != nil {\\n   712→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   713→\\t}\\n   714→\\n   715→\\t// Generate a checkpoint ID\\n   716→\\tcheckpointID, err := id.Generate()\\n   717→\\tif err != nil {\\n   718→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   719→\\t}\\n   720→\\n   721→\\t// Check if shadow branch exists (required for condensation)\\n   722→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   723→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   724→\\t_, refErr := repo.Reference(refName, true)\\n   725→\\thasShadowBranch := refErr == nil\\n   726→\\n   727→\\tif !hasShadowBranch {\\n   728→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   729→\\t\\t// Just clean up the state file.\\n   730→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   731→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   732→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   733→\\t\\t)\\n   734→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   735→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   736→\\t\\t}\\n   737→\\t\\treturn nil\\n   738→\\t}\\n   739→\\n   740→\\t// Condense the session\\n   741→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   742→\\tif err != nil {\\n   743→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   744→\\t}\\n   745→\\n   746→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   747→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   748→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   749→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   750→\\t)\\n   751→\\n   752→\\t// Update session state: reset step count and transition to idle\\n   753→\\tstate.StepCount = 0\\n   754→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   755→\\tstate.Phase = session.PhaseIdle\\n   756→\\tstate.LastCheckpointID = checkpointID\\n   757→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   758→\\tstate.PromptAttributions = nil\\n   759→\\tstate.PendingPromptAttribution = nil\\n   760→\\n   761→\\tif err := s.saveSessionState(state); err != nil {\\n   762→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   763→\\t}\\n   764→\\n