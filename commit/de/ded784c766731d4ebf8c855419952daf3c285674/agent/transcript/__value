eckpointSummary not found at %s\\\", summaryPath)\\n  1466→\\t}\\n  1467→\\n  1468→\\tvar summary checkpoint.CheckpointSummary\\n  1469→\\tif err := json.Unmarshal([]byte(content), &summary); err != nil {\\n  1470→\\t\\tenv.T.Fatalf(\\\"Failed to parse CheckpointSummary: %v\\\\nContent: %s\\\", err, content)\\n  1471→\\t}\\n  1472→\\n  1473→\\t// Validate checkpoint_id\\n  1474→\\tif summary.CheckpointID.String() != v.CheckpointID {\\n  1475→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.CheckpointID = %q, want %q\\\", summary.CheckpointID, v.CheckpointID)\\n  1476→\\t}\\n  1477→\\n  1478→\\t// Validate strategy\\n  1479→\\tif v.Strategy != \\\"\\\" && summary.Strategy != v.Strategy {\\n  1480→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.Strategy = %q, want %q\\\", summary.Strategy, v.Strategy)\\n  1481→\\t}\\n  1482→\\n  1483→\\t// Validate sessions array is populated\\n  1484→\\tif len(summary.Sessions) == 0 {\\n  1485→\\t\\tenv.T.Error(\\\"CheckpointSummary.Sessions should have at least one entry\\\")\\n  1486→\\t}\\n  1487→\\n  1488→\\t// Validate files_touched\\n  1489→\\tif len(v.FilesTouched) > 0 {\\n  1490→\\t\\ttouchedSet := make(map[string]bool)\\n  1491→\\t\\tfor _, f := range summary.FilesTouched {\\n  1492→\\t\\t\\ttouchedSet[f] = true\\n  1493→\\t\\t}\\n  1494→\\t\\tfor _, expected := range v.FilesTouched {\\n  1495→\\t\\t\\tif !touchedSet[expected] {\\n  1496→\\t\\t\\t\\tenv.T.Errorf(\\\"CheckpointSummary.FilesTouched missing %q, got %v\\\", expected, summary.FilesTouched)\\n  1497→\\t\\t\\t}\\n  1498→\\t\\t}\\n  1499→\\t}\\n  1500→\\n  1501→\\t// Validate checkpoints_count\\n  1502→\\tif v.CheckpointsCount > 0 && summary.CheckpointsCount != v.CheckpointsCount {\\n  1503→\\t\\tenv.T.Errorf(\\\"CheckpointSummary.CheckpointsCount = %d, want %d\\\", summary.CheckpointsCount, v.CheckpointsCount)\\n  1504→\\t}\\n  1505→}\\n  1506→\\n  1507→// validateSessionMetadata validates the session-level metadata.json (CommittedMetadata).\\n  1508→func (env *TestEnv) validateSessionMetadata(v CheckpointValidation) {\\n  1509→\\tenv.T.Helper()\\n  1510→\\n  1511→\\tmetadataPath := SessionMetadataPath(v.CheckpointID)\\n  1512→\\tcontent, found := env.ReadFileFromBranch(paths.MetadataBranchName, metadataPath)\\n  1513→\\tif !found {\\n  1514→\\t\\tenv.T.Fatalf(\\\"Session metadata not found at %s\\\", metadataPath)\\n  1515→\\t}\\n  1516→\\n  1517→\\tvar metadata checkpoint.CommittedMetadata\\n  1518→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n  1519→\\t\\tenv.T.Fatalf(\\\"Failed to parse CommittedMetadata: %v\\\\nContent: %s\\\", err, content)\\n  1520→\\t}\\n  1521→\\n  1522→\\t// Validate checkpoint_id\\n  1523→\\tif metadata.CheckpointID.String() != v.CheckpointID {\\n  1524→\\t\\tenv.T.Errorf(\\\"CommittedMetadata.CheckpointID = %q, want %q\\\", metadata.CheckpointID, v.CheckpointID)\\n  1525→\\t}\\n  1526→\\n  1527→\\t// Validate session_id\\n  1528→\\tif v.SessionID != \\\"\\\" && metadata.SessionID != v.SessionID {\\n  1529→\\t\\tenv.T.Errorf(\\\"CommittedMetadata.SessionID = %q, want %q\\\", metadata.SessionID, v.SessionID)\\n  1530→\\t}\\n  1531→\\n  1532→\\t// Validate strategy\\n  1533→\\tif v.Strategy != \\\"\\\" && metadata.Strategy != v.Strategy {\\n  1534→\\t\\tenv.T.Errorf(\\\"CommittedMetadata.Strategy = %q, want %q\\\", metadata.Strategy, v.Strategy)\\n  1535→\\t}\\n  1536→\\n  1537→\\t// Validate created_at is not zero\\n  1538→\\tif metadata.CreatedAt.IsZero() {\\n  1539→\\t\\tenv.T.Error(\\\"CommittedMetadata.CreatedAt should not be zero\\\")\\n  1540→\\t}\\n  1541→\\n  1542→\\t// Validate files_touched\\n  1543→\\tif len(v.FilesTouched) > 0 {\\n  1544→\\t\\ttouchedSet := make(map[string]bool)\\n  1545→\\t\\tfor _, f := range metadata.FilesTouched {\\n  1546→\\t\\t\\ttouchedSet[f] = true\\n  1547→\\t\\t}\\n  1548→\\t\\tfor _, expected := range v.FilesTouched {\\n  1549→\\t\\t\\tif !touchedSet[expected] {\\n  1550→\\t\\t\\t\\tenv.T.Errorf(\\\"CommittedMetadata.FilesTouched missing %q, got %v\