esNotCondenseOldSession verifies that when\\n    13→// an old session has carry-forward files and a NEW session commits unrelated files,\\n    14→// the old session is NOT condensed into the new session's commit.\\n    15→//\\n    16→// This is a regression test for the bug where sessions with carry-forward files\\n    17→// would be re-condensed into every subsequent commit indefinitely.\\n    18→//\\n    19→// This integration test complements the unit tests in phase_postcommit_test.go by\\n    20→// testing the full hook invocation path with multiple sessions interacting.\\n    21→//\\n    22→// Scenario:\\n    23→// 1. Session 1 creates file1.txt and file2.txt\\n    24→// 2. User commits only file1.txt (partial commit)\\n    25→// 3. Session 1 gets carry-forward: FilesTouched = [\\\"file2.txt\\\"]\\n    26→// 4. Session 1 ends\\n    27→// 5. Make some unrelated commits (simulating time passing)\\n    28→// 6. New session 2 creates and commits file6.txt\\n    29→// 7. Verify: Session 1 was NOT condensed into session 2's commit\\n    30→// 8. Finally commit file2.txt\\n    31→// 9. Verify: Session 1 IS condensed (carry-forward consumed)\\n    32→func TestCarryForward_NewSessionCommitDoesNotCondenseOldSession(t *testing.T) {\\n    33→\\tt.Parallel()\\n    34→\\tenv := NewTestEnv(t)\\n    35→\\tdefer env.Cleanup()\\n    36→\\n    37→\\t// ========================================\\n    38→\\t// Setup\\n    39→\\t// ========================================\\n    40→\\tenv.InitRepo()\\n    41→\\tenv.WriteFile(\\\"README.md\\\", \\\"# Test Repository\\\")\\n    42→\\tenv.GitAdd(\\\"README.md\\\")\\n    43→\\tenv.GitCommit(\\\"Initial commit\\\")\\n    44→\\tenv.GitCheckoutNewBranch(\\\"feature/multi-session-carry-forward\\\")\\n    45→\\tenv.InitEntire(strategy.StrategyNameManualCommit)\\n    46→\\n    47→\\t// ========================================\\n    48→\\t// Phase 1: Session 1 creates files, partial commit, ends with carry-forward\\n    49→\\t// ================