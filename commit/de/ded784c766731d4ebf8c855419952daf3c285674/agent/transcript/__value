ated by `entire enable --agent opencode`\\n     3→// Do not edit manually — changes will be overwritten on next install.\\n     4→// Requires Bun runtime (used by OpenCode's plugin system for loading ESM plugins).\\n     5→import type { Plugin } from \\\"@opencode-ai/plugin\\\"\\n     6→import { tmpdir } from \\\"node:os\\\"\\n     7→\\n     8→export const EntirePlugin: Plugin = async ({ client, directory, $ }) => {\\n     9→  const ENTIRE_CMD = \\\"__ENTIRE_CMD__\\\"\\n    10→  // Store transcripts in a temp directory — these are ephemeral handoff files\\n    11→  // between the plugin and the Go hook handler. Once checkpointed, the data\\n    12→  // lives on git refs and the file is disposable.\\n    13→  const sanitized = directory.replace(/[^a-zA-Z0-9]/g, \\\"-\\\")\\n    14→  const transcriptDir = `${tmpdir()}/entire-opencode/${sanitized}`\\n    15→  const seenUserMessages = new Set<string>()\\n    16→\\n    17→  // In-memory stores — used to write transcripts without relying on the SDK API,\\n    18→  // which may be unavailable during shutdown.\\n    19→  // messageStore: keyed by message ID, stores message metadata (role, time, tokens, etc.)\\n    20→  const messageStore = new Map<string, any>()\\n    21→  // partStore: keyed by message ID, stores accumulated parts from message.part.updated events\\n    22→  const partStore = new Map<string, any[]>()\\n    23→  let currentSessionID: string | null = null\\n    24→  // Full session info from session.created — needed for OpenCode export format on resume/rewind\\n    25→  let currentSessionInfo: any = null\\n    26→\\n    27→  // Ensure transcript directory exists\\n    28→  await $`mkdir -p ${transcriptDir}`.quiet().nothrow()\\n    29→\\n    30→  /**\\n    31→   * Pipe JSON payload to an entire hooks command.\\n    32→   * Errors are logged but never thrown — plugin failures must not crash OpenCode.\\n    33→   */\\n    34→  async function callHook(hookName: string, payload: Record<string, unknown>) {\\n    35→    try {\\n    36→      const json = JSON.stringify(payload)\\n    37→      await $`echo ${json} | ${ENTIRE_CMD} hooks opencode ${hookName}`.quiet().nothrow()\\n    38→    } catch {\\n    39→      // Silently ignore — plugin failures must not crash OpenCode\\n    40→    }\\n    41→  }\\n    42→\\n    43→  /** Extract text content from a list of parts. */\\n    44→  function textFromParts(parts: any[]): string {\\n    45→    return parts\\n    46→      .filter((p: any) => p.type === \\\"text\\\")\\n    47→      .map((p: any) => p.text ?? \\\"\\\")\\n    48→      .join(\\\"\\\\n\\\")\\n    49→  }\\n    50→\\n    51→  /** Format a message object from its accumulated parts. */\\n    52→  function formatMessageFromStore(msg: any) {\\n    53→    const parts = partStore.get(msg.id) ?? []\\n    54→    return {\\n    55→      id: msg.id,\\n    56→      role: msg.role,\\n    57→      content: textFromParts(parts),\\n    58→      time: msg.time,\\n    59→      ...(msg.role === \\\"assistant\\\" ? {\\n    60→        tokens: msg.tokens,\\n    61→        cost: msg.cost,\\n    62→        parts: parts.map((p: any) => ({\\n    63→          type: p.type,\\n    64→          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n    65→          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n    66→        })),\\n    67→      } : {}),\\n    68→    }\\n    69→  }\\n    70→\\n    71→  /** Format a message from an API response (which includes parts inline). */\\n    72→  function formatMessageFromAPI(info: any, parts: any[]) {\\n    73→    return {\\n    74→      id: info.id,\\n    75→      role: info.role,\\n    76→      content: textFromParts(parts),\\n    77→      time: info.time,\\n    78→      ...(info.role === \\\"assistant\\\" ? {\\n    79→        tokens: info.tokens,\\n    80→        cost: info.cost,\\n    81→        parts: parts.map((p: any) => ({\\n    82→          type: p.type,\\n    83→          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n    84→          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n    85→        })),\\n    86→      } : {}),\\n    87→    }\\n    88→  }\\n    89→\\n    90→  /**\\n    91→   * Write transcript as JSONL (one message per line) from in-memory stores.\\n    92→   * This does NOT call the SDK API, so it works even during shutdown.\\n    93→   */\\n    94→  async function writeTranscriptFromMemory(sessionID: string): Promise<string> {\\n    95→    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n    96→    try {\\n    97→      const messages = Array.from(messageStore.values())\\n    98→        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n    99→\\n   100→      const lines = messages.map(msg => JSON.stringify(formatMessageFromStore(msg)))\\n   101→      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n   102→    } catch {\\n   103→      // Silently ignore write failures\\n   104→    }\\n   105→    return transcriptPath\\n   106→  }\\n   107→\\n   108→  /**\\n   109→   * Try to fetch messages via the SDK API (returns messages with parts inline)\\n   110→   * and write transcript as JSONL. Falls back to in-memory stores if the API is unavailable.\\n   111→   */\\n   112→  async function writeTranscriptWithFallback(sessionID: string): Promise<string> {\\n   113→    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n   114→    try {\\n   115→      const response = await client.session.message.list({ path: { id: sessionID } })\\n   116→      // API returns Array<{ info: Message, parts: Array<Part> }>\\n   117→      const items = response.data ?? []\\n   118→\\n   119→      const lines = items.map((item: any) =>\\n   120→        JSON.stringify(formatMessageFromAPI(item.info, item.parts ?? []))\\n   121→      )\\n   122→      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n   123→      return transcriptPath\\n   124→    } catch {\\n   125→      // API unavailable (likely shutting down) — fall back to in-memory stores\\n   126→      return writeTranscriptFromMemory(sessionID)\\n   127→    }\\n   128→  }\\n   129→\\n   130→  /**\\n   131→   * Write session in OpenCode's native export format (JSON).\\n   132→   * This file is used by `opencode import` during resume/rewind to restore\\n   133→   * the session into OpenCode's SQLite database with the original session ID.\\n   134→   */\\n   135→  async function writeExportJSON(sessionID: string): Promise<string> {\\n   136→    const exportPath = `${transcriptDir}/${sessionID}.export.json`\\n   137→    try {\\n   138→      const messages = Array.from(messageStore.values())\\n   139→        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n   140→\\n   141→      const exportData = {\\n   142→        info: currentSessionInfo ?? { id: sessionID },\\n   143→        messages: messages.map(msg => ({\\n   144→          info: msg,\\n   145→          parts: (partStore.get(msg.id) ?? []),\\n   146→        })),\\n   147→      }\\n   148→      await Bun.write(exportPath, JSON.stringify(exportData))\\n   149→    } catch {\\n   150→      // Silently ignore — plugin failures must not crash OpenCode\\n   151→    }\\n   152→    return exportPath\\n   153→  }\\n   154→\\n   155→  return {\\n   156→    event: async ({ event }) => {\\n   157→      switch (event.type) {\\n   158→        case \\\"session.created\\\": {\\n   159→          const session = (event as any).properties?.info\\n   160→          if (!session?.id) break\\n   161→          currentSessionID = session.id\\n   162→          currentSessionInfo = session\\n   163→          await callHook(\\\"session-start\\\", {\\n   164→            session_id: session.id,\\n   165→            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n   166→          })\\n   167→          break\\n   168→        }\\n   169→\\n   170→        case \\\"message.updated\\\": {\\n   171→          const msg = (event as any).properties?.info\\n   172→          if (!msg) break\\n   173→          // Store message metadata (role, time, tokens, etc.)\\n   174→          // Content is NOT on the message — it arrives via message.part.updated events.\\n   175→          messageStore.set(msg.id, msg)\\n   176→          break\\n   177→        }\\n   178→\\n   179→        case \\\"message.part.updated\\\": {\\n   180→          const part = (event as any).properties?.part\\n   181→          if (!part?.messageID) break\\n   182→\\n   183→          // Accumulate parts per message\\n   184→          const existing = partStore.get(part.messageID) ?? []\\n   185→          // Replace existing part with same id, or append new one\\n   186→          const idx = existing.findIndex((p: any) => p.id === part.id)\\n   187→          if (idx >= 0) {\\n   188→            existing[idx] = part\\n   189→          } else {\\n   190→            existing.push(part)\\n   191→          }\\n   192→          partStore.set(part.messageID, existing)\\n   193→\\n   194→          // Fire turn-start on the first text part of a new user message\\n   195→          const msg = messageStore.get(part.messageID)\\n   196→          if (msg?.role === \\\"user\\\" && part.type === \\\"text\\\" && !seenUserMessages.has(msg.id)) {\\n   197→            seenUserMessages.add(msg.id)\\n   198→            const sessionID = msg.sessionID ?? currentSessionID\\n   199→            if (sessionID) {\\n   200→              await callHook(\\\"turn-start\\\", {\\n   201→                session_id: sessionID,\\n   202→                transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n   203→                prompt: part.text ?? \\\"\\\",\\n   204→              })\\n   205→            }\\n   206→          }\\n   207→          break\\n   208→        }\\n   209→\\n   210→        case \\\"session.idle\\\": {\\n   211→          const sessionID = (event as any).properties?.sessionID\\n   212→          if (!sessionID) break\\n   213→          const transcriptPath = await writeTranscriptWithFallback(sessionID)\\n   214→          await writeExportJSON(sessionID)\\n   215→          await callHook(\\\"turn-end\\\", {\\n   216→            session_id: sessionID,\\n   217→            transcript_path: transcriptPath,\\n   218→          })\\n   219→          break\\n   220→        }\\n   221→\\n   222→        case \\\"session.compacted\\\": {\\n   223→          const sessionID = (event as any).properties?.sessionID\\n   224→          if (!sessionID) break\\n   225→          await callHook(\\\"compaction\\\", {\\n   226→            session_id: sessionID,\\n   227→            transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n   228→          })\\n   229→          break\\n   230→        }\\n   231→\\n   232→        case \\\"session.deleted\\\": {\\n   233→          const session = (event as any).properties?.info\\n   234→          if (!session?.id) break\\n   235→          // Write final transcript + export JSON before signaling session end\\n   236→          if (messageStore.size > 0) {\\n   237→            await writeTranscriptFromMemory(session.id)\\n   238→            await writeExportJSON(session.id)\\n   239→          }\\n   240→          seenUserMessages.clear()\\n   241→          messageStore.clear()\\n   242→          partStore.clear()\\n   243→          currentSessionID = null\\n   244→          currentSessionInfo = null\\n   245→          await callHook(\\\"session-end\\\", {\\n   246→            session_id: session.id,\\n   247→            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n   248→          })\\n   249→          break\\n   250→        }\\n   251→      }\\n   252→    },\\n   253→  }\\n   254→}\\n   255→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze exis