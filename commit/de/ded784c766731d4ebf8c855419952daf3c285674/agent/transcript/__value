requires sorted entries)\\n  1034→\\tsortTreeEntries(treeEntries)\\n  1035→\\n  1036→\\t// Create tree object\\n  1037→\\ttree := &object.Tree{Entries: treeEntries}\\n  1038→\\n  1039→\\tobj := repo.Storer.NewEncodedObject()\\n  1040→\\tif err := tree.Encode(obj); err != nil {\\n  1041→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode tree: %w\\\", err)\\n  1042→\\t}\\n  1043→\\n  1044→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1045→\\tif err != nil {\\n  1046→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n  1047→\\t}\\n  1048→\\n  1049→\\treturn hash, nil\\n  1050→}\\n  1051→\\n  1052→// sortTreeEntries sorts tree entries in git's required order.\\n  1053→// Git sorts tree entries by name, with directories having a trailing /\\n  1054→func sortTreeEntries(entries []object.TreeEntry) {\\n  1055→\\tsort.Slice(entries, func(i, j int) bool {\\n  1056→\\t\\tnameI := entries[i].Name\\n  1057→\\t\\tnameJ := entries[j].Name\\n  1058→\\t\\tif entries[i].Mode == filemode.Dir {\\n  1059→\\t\\t\\tnameI += \\\"/\\\"\\n  1060→\\t\\t}\\n  1061→\\t\\tif entries[j].Mode == filemode.Dir {\\n  1062→\\t\\t\\tnameJ += \\\"/\\\"\\n  1063→\\t\\t}\\n  1064→\\t\\treturn nameI < nameJ\\n  1065→\\t})\\n  1066→}\\n  1067→\\n  1068→// collectChangedFiles collects all changed files (modified tracked + untracked non-ignored)\\n  1069→// using git CLI. This is much faster than filesystem walk and respects all gitignore sources\\n  1070→// including global gitignore (core.excludesfile).\\n  1071→//\\n  1072→// Uses git CLI instead of go-git because go-git's worktree.Status() does not respect\\n  1073→// global gitignore, which can cause globally ignored files to appear as untracked.\\n  1074→// See: https://github.com/entireio/cli/pull/129\\n  1075→//\\n  1076→// changedFilesResult contains both changed and deleted files from git status.\\n  1077→type changedFilesResult struct {\\n  1078→\\tChanged []string // Files to include (modified