  271→\\t}\\n   272→\\n   273→\\t// Create the commit\\n   274→\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n   275→\\tif err != nil {\\n   276→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   277→\\t}\\n   278→\\n   279→\\t// Update shadow branch reference\\n   280→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   281→\\tref := plumbing.NewHashReference(refName, commitHash)\\n   282→\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n   283→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\treturn commitHash, nil\\n   287→}\\n   288→\\n   289→// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n   290→// When IsIncremental is true, only adds the incremental checkpoint file.\\n   291→func (s *GitStore) addTaskMetadataToTree(baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n   292→\\t// Get base tree and flatten it\\n   293→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   294→\\tif err != nil {\\n   295→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tentries := make(map[string]object.TreeEntry)\\n   299→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   300→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\t// Compute metadata paths\\n   304→\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n   305→\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n   306→\\n   307→\\tif opts.IsIncremental {\\n   308→\\t\\t// Incremental checkpoint: only add the checkpoint file\\n   309→\\t\\t// Use proper JSON marshaling to handle nil/empty IncrementalData correctly\\n   310→\\t\\tvar incData []byte\\n   311→\\t\\tif opts.IncrementalData != nil {\\n   312→\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n   313→\\t\\t\\tif err != nil {\\n   314→\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n   315→\\t\\t\\t}\\n   316→\\t\\t}\\n   317→\\t\\tincrementalCheckpoint := struct {\\n   318→\\t\\t\\tType      string          `json:\\\"type\\\"`\\n   319→\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n   320→\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n   321→\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n   322→\\t\\t}{\\n   323→\\t\\t\\tType:      opts.IncrementalType,\\n   324→\\t\\t\\tToolUseID: opts.ToolUseID,\\n   325→\\t\\t\\tTimestamp: time.Now().UTC(),\\n   326→\\t\\t\\tData:      incData,\\n   327→\\t\\t}\\n   328→\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n   329→\\t\\tif err != nil {\\n   330→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n   331→\\t\\t}\\n   332→\\n   333→\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n   334→\\t\\tif err != nil {\\n   335→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n   336→\\t\\t}\\n   337→\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n   338→\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n   339→\\t\\tentries[cpPath] = object.TreeEntry{\\n   340→\\t\\t\\tName: cpPath,\\n   341→\\t\\t\\tMode: filemode.Regular,\\n   342→\\t\\t\\tHash: cpBlobHash,\\n   343→\\t\\t}\\n   344→\\t} else {\\n   345→\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n   346→\\n   347→\\t\\t// Add session transcript (with chunking support for large transcripts)\\n   348→\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n   349→\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n   350→\\t\\t\\t\\t// Detect agent type from content for proper chunking\\n   351→\\t\\t\\t\\tagentType := agent.DetectAgentTypeFromContent(transcriptContent)\\n   352→\\n   353→\\t\\t\\t\\t// Chunk if necessary\\n   354→\\t\\t\\t\\tchunks, chunkErr := agent.ChunkTranscript(transcriptContent, agentType)\\n   355→\\t\\t\\t\\tif chunkErr != nil {\\n   356→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to chunk transcript, checkpoint will be saved without transcript\\\",\\n   357→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", chunkErr.Error()),\\n   358→\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   359→\\t\\t\\t\\t\\t)\\n   360→\\t\\t\\t\\t} else {\\n   361→\\t\\t\\t\\t\\tfor i, chunk := range chunks {\\n   362→\\t\\t\\t\\t\\t\\tchunkPath := sessionMetadataDir + \\\"/\\\" + agent.ChunkFileName(paths.TranscriptFileName, i)\\n   363→\\t\\t\\t\\t\\t\\tblobHash, blobErr := CreateBlobFromContent(s.repo, chunk)\\n   364→\\t\\t\\t\\t\\t\\tif blobErr != nil {\\n   365→\\t\\t\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to create blob for transcript chunk\\\",\\n   366→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", blobErr.Error()),\\n   367→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", opts.SessionID),\\n   368→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"chunk_index\\\", i),\\n   369→\\t\\t\\t\\t\\t\\t\\t)\\n   370→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   371→\\t\\t\\t\\t\\t\\t}\\n   372→\\t\\t\\t\\t\\t\\tentries[chunkPath] = object.TreeEntry{\\n   373→\\t\\t\\t\\t\\t\\t\\tName: chunkPath,\\n   374→\\t\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   375→\\t\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   376→\\t\\t\\t\\t\\t\\t}\\n   377→\\t\\t\\t\\t\\t}\\n   378→\\t\\t\\t\\t}\\n   379→\\t\\t\\t}\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\t// Add subagent transcript if available\\n   383→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   384→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   385→\\t\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n   386→\\t\\t\\t\\tif jsonlErr != nil {\\n   387→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n   388→\\t\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n   389→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n   390→\\t\\t\\t\\t\\t)\\n   391→\\t\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\t\\tagentContent = redacted\\n   394→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   395→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   396→\\t\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n   397→\\t\\t\\t\\t\\t\\tName: agentPath,\\n   398→\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   399→\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   400→\\t\\t\\t\\t\\t}\\n   401→\\t\\t\\t\\t}\\n   402→\\t\\t\\t}\\n   403→\\t\\t}\\n   404→\\n   405→\\t\\t// Add checkpoint.json\\n   406→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   407→  \\\"session_id\\\": %q,\\n   408→  \\\"tool_use_id\\\": %q,\\n   409→  \\\"checkpoint_uuid\\\": %q,\\n   410→  \\\"agent_id\\\": %q\\n   411→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   412→\\n   413→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   414→\\t\\tif err != nil {\\n   415→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   416→\\t\\t}\\n   417→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   418→\\t\\tentries[checkpointPath] = object.TreeEntry{\\n   419→\\t\\t\\tName: checkpointPath,\\n   420→\\t\\t\\tMode: filemode.Regular,\\n   421→\\t\\t\\tHash: blobHash,\\n   422→\\t\\t}\\n   423→\\t}\\n   424→\\n   425→\\t// Build new tree from entries\\n   426→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   427→}\\n   428→\\n   429→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   430→// This returns individual commits (rewind points), not just branch info.\\n   431→// The sessionID filter, if provided, limits results to commits from that session.\\n   432→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   433→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   434→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   435→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   436→}\\n   437→\\n   438→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   439→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   440→// The sessionID filter, if provided, limits results to commits from that session.\\n   441→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   442→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   443→}\\n   444→\\n   445→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   446→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   447→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   448→\\t_ = ctx // Reserved for future use\\n   449→\\n   450→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   451→\\n   452→\\tref, err := s.repo.Reference(refName, true)\\n   453→\\tif err != nil {\\n   454→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n   455→\\t}\\n   456→\\n   457→\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n   458→\\tif err != nil {\\n   459→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   460→\\t}\\n   461→\\n   462→\\tvar results []TemporaryCheckpointInfo\\n   463→\\tcount := 0\\n   464→\\n   465→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   466→\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n   467→\\t\\t\\treturn errStop\\n   468→\\t\\t}\\n   469→\\t\\tcount++\\n   470→\\n   471→\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n   472→\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n   473→\\t\\tif !hasTrailer {\\n   474→\\t\\t\\treturn nil // Skip commits without session trailer\\n   475→\\t\\t}\\n   476→\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n   477→\\t\\t\\treturn nil // Skip commits from other sessions\\n   478→\\t\\t}\\n   479→\\n   480→\\t\\t// Get first line of message\\n   481→\\t\\tmessage := c.Message\\n   482→\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n   483→\\t\\t\\tmessage = message[:idx]\\n   484→\\t\\t}\\n   485→\\n   486→\\t\\tinfo := TemporaryCheckpointInfo{\\n   487→\\t\\t\\tCommitHash: c.Hash,\\n   488→\\t\\t\\tMessage:    message,\\n   489→\\t\\t\\tSessionID:  commitSessionID,\\n   490→\\t\\t\\tTimestamp:  c.Author.When,\\n   491→\\t\\t}\\n   492→\\n   493→\\t\\t// Check for task checkpoint first\\n   494→\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n   495→\\t\\tif foundTask {\\n   496→\\t\\t\\tinfo.IsTaskCheckpoint = true\\n   497→\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n   498→\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n   499→\\t\\t} else {\\n   500→\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n   501→\\t\\t\\tif found {\\n   502→\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n   503→\\t\\t\\t}\\n   504→\\t\\t}\\n   505→\\n   506→\\t\\tresults = append(results, info)\\n   507→\\n   508→\\t\\tif len(results) >= limit {\\n   509→\\t\\t\\treturn errStop\\n   510→\\t\\t}\\n   511→\\t\\treturn nil\\n   512→\\t})\\n   513→\\n   514→\\tif err != nil && !errors.Is(err, errStop) {\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   516→\\t}\\n   517→\\n   518→\\treturn results, nil\\n   519→}\\n   520→\\n   521→// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n   522→// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n   523→// The sessionID filter, if provided, limits results to commits from that session.\\n   524→func (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   525→\\t_ = ctx // Reserved for future use\\n   526→\\n   527→\\t// List all shadow branches\\n   528→\\tbranches, err := s.ListTemporary(ctx)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\tvar results []TemporaryCheckpointInfo\\n   534→\\n   535→\\t// Iterate through each shadow branch and collect checkpoints\\n   536→\\tfor _, branch := range branches {\\n   537→\\t\\t// Use the branch name directly to get checkpoints\\n   538→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   539→\\t\\tif branchErr != nil {\\n   540→\\t\\t\\tcontinue // Skip branches we can't read\\n   541→\\t\\t}\\n   542→\\t\\tresults = append(results, branchCheckpoints...)\\n   543→\\t\\tif len(results) >= limit {\\n   544→\\t\\t\\tresults = results[:limit]\\n   545→\\t\\t\\tbreak\\n   546→\\t\\t}\\n   547→\\t}\\n   548→\\n   549→\\treturn results, nil\\n   550→}\\n   551→\\n   552→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   553→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   554→func extractToolUseIDFromPath(metadataDir string) string {\\n   555→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   556→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   557→\\t\\treturn parts[len(parts)-1]\\n   558→\\t}\\n   559→\\treturn \\\"\\\"\\n   560→}\\n   561→\\n   562→// errStop is a sentinel error used to break out of git log iteration.\\n   563→var errStop = errors.New(\\\"stop iteration\\\")\\n   564→\\n   565→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   566→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   567→// rather than on the entire/checkpoints/v1 branch.\\n   568→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   569→// agentType is used for reassembling chunked transcripts in the correct format.\\n   570→// Handles both chunked and non-chunked transcripts.\\n   571→func (s *GitStore) GetTranscriptFromCommit(commitHash plumbing.Hash, metadataDir string, agentType agent.AgentType) ([]byte, error) {\\n   572→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   573→\\tif err != nil {\\n   574→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   575→\\t}\\n   576→\\n   577→\\ttree, err := commit.Tree()\\n   578→\\tif err != nil {\\n   579→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   580→\\t}\\n   581→\\n   582→\\t// Try to get the metadata subtree for chunk detection\\n   583→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   584→\\tif subTreeErr == nil {\\n   585→\\t\\t// Use the helper function that handles chunking\\n   586→\\t\\ttranscript, err := readTranscriptFromTree(subTree, agentType)\\n   587→\\t\\tif err == nil && transcript != nil {\\n   588→\\t\\t\\treturn transcript, nil\\n   589→\\t\\t}\\n   590→\\t}\\n   591→\\n   592→\\t// Fall back to direct file access (for backwards compatibility)\\n   593→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   594→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   595→\\t\\tcontent, contentErr := file.Contents()\\n   596→\\t\\tif contentErr == nil {\\n   597→\\t\\t\\treturn []byte(content), nil\\n   598→\\t\\t}\\n   599→\\t}\\n   600→\\n   601→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   602→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   603→\\t\\tcontent, contentErr := file.Contents()\\n   604→\\t\\tif contentErr == nil {\\n   605→\\t\\t\\treturn []byte(content), nil\\n   606→\\t\\t}\\n   607→\\t}\\n   608→\\n   609→\\treturn nil, ErrNoTranscript\\n   610→}\\n   611→\\n   612→// GetExportDataFromCommit reads the export data file from a commit tree's metadata directory.\\n   613→// Returns nil if not found (most agents don't produce export data).\\n   614→func (s *GitStore) GetExportDataFromCommit(commitHash plumbing.Hash, metadataDir string) []byte {\\n   615→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   616→\\tif err != nil {\\n   617→\\t\\treturn nil\\n   618→\\t}\\n   619→\\ttree, err := commit.Tree()\\n   620→\\tif err != nil {\\n   621→\\t\\treturn nil\\n   622→\\t}\\n   623→\\texportPath := metadataDir + \\\"/\\\" + paths.ExportDataFileName\\n   624→\\tfile, err := tree.File(exportPath)\\n   625→\\tif err != nil {\\n   626→\\t\\treturn nil\\n   627→\\t}\\n   628→\\tcontent, err := file.Contents()\\n   629→\\tif err != nil {\\n   630→\\t\\treturn nil\\n   631→\\t}\\n   632→\\treturn []byte(content)\\n   633→}\\n   634→\\n   635→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   636→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   637→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   638→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   639→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   640→\\t_, err := s.repo.Reference(refName, true)\\n   641→\\treturn err == nil\\n   642→}\\n   643→\\n   644→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   645→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   646→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   647→// persist deletions with packed refs or worktrees.\\n   648→func (s *GitStore) DeleteShadowBranch(baseCommit, worktreeID string) error {\\n   649→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   650→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName) //nolint:gosec // shadowBranchName is constructed from commit hash, not user input\\n   651→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   652→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   653→\\t}\\n   654→\\treturn nil\\n   655→}\\n   656→\\n   657→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   658→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   659→// or the internal git worktree name for linked worktrees.\\n   660→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   661→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   662→\\tcommitPart := baseCommit\\n   663→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   664→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   665→\\t}\\n   666→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   667→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   668→}\\n   669→\\n   670→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   671→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   672→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   673→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   674→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   675→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   676→\\t}\\n   677→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   678→\\n   679→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   680→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   681→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   682→\\t\\t// No dash, or dash at start/end - invalid format\\n   683→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   684→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   685→\\t}\\n   686→\\n   687→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   688→}\\n   689→\\n   690→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   691→// Returns (parentHash, baseTreeHash, error).\\n   692→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   693→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   694→\\tref, err := s.repo.Reference(refName, true)\\n   695→\\n   696→\\tif err == nil {\\n   697→\\t\\t// Branch exists\\n   698→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   699→\\t\\tif err != nil {\\n   700→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   701→\\t\\t}\\n   702→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   703→\\t}\\n   704→\\n   705→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   706→\\thead, err := s.repo.Head()\\n   707→\\tif err != nil {\\n   708→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   709→\\t}\\n   710→\\n   711→\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n   712→\\tif err != nil {\\n   713→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n   717→}\\n   718→\\n   719→// buildTreeWithChanges builds a git tree with the given changes.\\n   720→// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n   721→// for filesystem operations (needed when CLI is run from a subdirectory).\\n   722→func (s *GitStore) buildTreeWithChanges(\\n   723→\\tbaseTreeHash plumbing.Hash,\\n   724→\\tmodifiedFiles, deletedFiles []string,\\n   725→\\tmetadataDir, metadataDirAbs string,\\n   726→) (plumbing.Hash, error) {\\n   727→\\t// Get repo root for resolving file paths\\n   728→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   729→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   730→\\t// so we must resolve them against repo root, not CWD.\\n   731→\\trepoRoot, err := paths.RepoRoot()\\n   732→\\tif err != nil {\\n   733→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   734→\\t}\\n   735→\\n   736→\\t// Get the base tree\\n   737→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   738→\\tif err != nil {\\n   739→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\t// Flatten existing tree\\n   743→\\tentries := make(map[string]object.TreeEntry)\\n   744→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   745→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten base tree: %w\\\", err)\\n   746→\\t}\\n   747→\\n   748→\\t// Remove deleted files\\n   749→\\tfor _, file := range deletedFiles {\\n   750→\\t\\tdelete(entries, file)\\n   751→\\t}\\n   752→\\n   753→\\t// Add/update modified files\\n   754→\\tfor _, file := range modifiedFiles {\\n   755→\\t\\t// Resolve path relative to repo root for filesystem operations\\n   756→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   757→\\t\\tif !fileExists(absPath) {\\n   758→\\t\\t\\tdelete(entries, file)\\n   759→\\t\\t\\tcontinue\\n   760→\\t\\t}\\n   761→\\n   762→\\t\\tblobHash, mode, err := createBlobFromFile(s.repo, absPath)\\n   763→\\t\\tif err != nil {\\n   764→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   765→\\t\\t\\tcontinue\\n   766→\\t\\t}\\n   767→\\n   768→\\t\\tentries[file] = object.TreeEntry{\\n   769→\\t\\t\\tName: file,\\n   770→\\t\\t\\tMode: mode,\\n   771→\\t\\t\\tHash: blobHash,\\n   772→\\t\\t}\\n   773→\\t}\\n   774→\\n   775→\\t// Add metadata directory files\\n   776→\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n   777→\\t\\tif err := addDirectoryToEntriesWithAbsPath(s.repo, metadataDirAbs, metadataDir, entries); err != nil {\\n   778→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", err)\\n   779→\\t\\t}\\n   780→\\t}\\n   781→\\n   782→\\t// Build tree\\n   783→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   784→}\\n   785→\\n   786→// createCommit creates a commit object.\\n   787→func (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n   788→\\tnow := time.Now()\\n   789→\\tsig := object.Signature{\\n   790→\\t\\tName:  authorName,\\n   791→\\t\\tEmail: authorEmail,\\n   792→\\t\\tWhen:  now,\\n   793→\\t}\\n   794→\\n   795→\\tcommit := &object.Commit{\\n   796→\\t\\tTreeHash:  treeHash,\\n   797→\\t\\tAuthor:    sig,\\n   798→\\t\\tCommitter: sig,\\n   799→\\t\\tMessage:   message,\\n   800→\\t}\\n   801→\\n   802→\\t// Add parent if not a new branch\\n   803→\\tif parentHash != plumbing.ZeroHash {\\n   804→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n   805→\\t}\\n   806→\\n   807→\\tobj := s.repo.Storer.NewEncodedObject()\\n   808→\\tif err := commit.Encode(obj); err != nil {\\n   809→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   810→\\t}\\n   811→\\n   812→\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n   813→\\tif err != nil {\\n   814→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   815→\\t}\\n   816→\\n   817→\\treturn hash, nil\\n   818→}\\n   819→\\n   820→// Helper functions extracted from strategy/common.go\\n   821→// These are exported for use by strategy package (push_common.go, session_test.go)\\n   822→\\n   823→// FlattenTree recursively flattens a tree into a map of full paths to entries.\\n   824→func FlattenTree(repo *git.Repository, tree *object.Tree, prefix string, entries map[string]object.TreeEntry) error {\\n   825→\\tfor _, entry := range tree.Entries {\\n   826→\\t\\tfullPath := entry.Name\\n   827→\\t\\tif prefix != \\\"\\\" {\\n   828→\\t\\t\\tfullPath = prefix + \\\"/\\\" + entry.Name\\n   829→\\t\\t}\\n   830→\\n   831→\\t\\tif entry.Mode == filemode.Dir {\\n   832→\\t\\t\\t// Recurse into subtree\\n   833→\\t\\t\\tsubtree, err := repo.TreeObject(entry.Hash)\\n   834→\\t\\t\\tif err != nil {\\n   835→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get subtree %s: %w\\\", fullPath, err)\\n   836→\\t\\t\\t}\\n   837→\\t\\t\\tif err := FlattenTree(repo, subtree, fullPath, entries); err != nil {\\n   838→\\t\\t\\t\\treturn err\\n   839→\\t\\t\\t}\\n   840→\\t\\t} else {\\n   841→\\t\\t\\tentries[fullPath] = object.TreeEntry{\\n   842→\\t\\t\\t\\tName: fullPath,\\n   843→\\t\\t\\t\\tMode: entry.Mode,\\n   844→\\t\\t\\t\\tHash: entry.Hash,\\n   845→\\t\\t\\t}\\n   846→\\t\\t}\\n   847→\\t}\\n   848→\\treturn nil\\n   849→}\\n   850→\\n   851→// fileExists checks if a file exists at the given path.\\n   852→func fileExists(path string) bool {\\n   853→\\t_, err := os.Stat(path)\\n   854→\\treturn err == nil\\n   855→}\\n   856→\\n   857→// createBlobFromFile creates a blob object from a file in the working directory.\\n   858→func createBlobFromFile(repo *git.Repository, filePath string) (plumbing.Hash, filemode.FileMode, error) {\\n   859→\\tinfo, err := os.Stat(filePath)\\n   860→\\tif err != nil {\\n   861→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n   862→\\t}\\n   863→\\n   864→\\t// Determine file mode\\n   865→\\tmode := filemode.Regular\\n   866→\\tif info.Mode()&0o111 != 0 {\\n   867→\\t\\tmode = filemode.Executable\\n   868→\\t}\\n   869→\\tif info.Mode()&os.ModeSymlink != 0 {\\n   870→\\t\\tmode = filemode.Symlink\\n   871→\\t}\\n   872→\\n   873→\\t// Read file contents\\n   874→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the repository\\n   875→\\tif err != nil {\\n   876→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n   877→\\t}\\n   878→\\n   879→\\t// Create blob object\\n   880→\\tobj := repo.Storer.NewEncodedObject()\\n   881→\\tobj.SetType(plumbing.BlobObject)\\n   882→\\tobj.SetSize(int64(len(content)))\\n   883→\\n   884→\\twriter, err := obj.Writer()\\n   885→\\tif err != nil {\\n   886→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n   887→\\t}\\n   888→\\n   889→\\t_, err = writer.Write(content)\\n   890→\\tif err != nil {\\n   891→\\t\\t_ = writer.Close()\\n   892→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n   893→\\t}\\n   894→\\tif err := writer.Close(); err != nil {\\n   895→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n   896→\\t}\\n   897→\\n   898→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   899→\\tif err != nil {\\n   900→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n   901→\\t}\\n   902→\\n   903→\\treturn hash, mode, nil\\n   904→}\\n   905→\\n   906→// addDirectoryToEntriesWithAbsPath recursively adds all files in a directory to the entries map.\\n   907→func addDirectoryToEntriesWithAbsPath(repo *git.Repository, dirPathAbs, dirPathRel string, entries map[string]object.TreeEntry) error {\\n   908→\\terr := filepath.Walk(dirPathAbs, func(path string, info os.FileInfo, err error) error {\\n   909→\\t\\tif err != nil {\\n   910→\\t\\t\\treturn err\\n   911→\\t\\t}\\n   912→\\n   913→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n   914→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n   915→\\t\\t// then be captured in the checkpoint and stored in git history.\\n   916→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n   917→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n   918→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n   919→\\t\\t// directories and would recurse into them otherwise.\\n   920→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n   921→\\t\\tif lstatErr != nil {\\n   922→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n   923→\\t\\t}\\n   924→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n   925→\\t\\t\\tif info.IsDir() {\\n   926→\\t\\t\\t\\treturn filepath.SkipDir\\n   927→\\t\\t\\t}\\n   928→\\t\\t\\treturn nil\\n   929→\\t\\t}\\n   930→\\n   931→\\t\\tif info.IsDir() {\\n   932→\\t\\t\\treturn nil\\n   933→\\t\\t}\\n   934→\\n   935→\\t\\t// Calculate relative path within the directory, then join with dirPathRel for tree entry\\n   936→\\t\\trelWithinDir, err := filepath.Rel(dirPathAbs, path)\\n   937→\\t\\tif err != nil {\\n   938→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n   939→\\t\\t}\\n   940→\\n   941→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n   942→\\t\\tif strings.HasPrefix(relWithinDir, \\\"..\\\") {\\n   943→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relWithinDir)\\n   944→\\t\\t}\\n   945→\\n   946→\\t\\ttreePath := filepath.ToSlash(filepath.Join(dirPathRel, relWithinDir))\\n   947→\\n   948→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(repo, path, treePath)\\n   949→\\t\\tif err != nil {\\n   950→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n   951→\\t\\t}\\n   952→\\t\\tentries[treePath] = object.TreeEntry{\\n   953→\\t\\t\\tName: treePath,\\n   954→\\t\\t\\tMode: mode,\\n   955→\\t\\t\\tHash: blobHash,\\n   956→\\t\\t}\\n   957→\\t\\treturn nil\\n   958→\\t})\\n   959→\\tif err != nil {\\n   960→\\t\\treturn fmt.Errorf(\\\"failed to walk directory %s: %w\\\", dirPathAbs, err)\\n   961→\\t}\\n   962→\\treturn nil\\n   963→}\\n   964→\\n   965→// treeNode represents a node in our tree structure.\\n   966→type treeNode struct {\\n   967→\\tentries map[string]*treeNode // subdirectories\\n   968→\\tfiles   []object.TreeEntry   // files in this directory\\n   969→}\\n   970→\\n   971→// BuildTreeFromEntries builds a proper git tree structure from flattened file entries.\\n   972→// Exported for use by strategy package (push_common.go, session_test.go)\\n   973→func BuildTreeFromEntries(repo *git.Repository, entries map[string]object.TreeEntry) (plumbing.Hash, error) {\\n   974→\\t// Build a tree structure\\n   975→\\troot := &treeNode{\\n   976→\\t\\tentries: make(map[string]*treeNode),\\n   977→\\t\\tfiles:   []object.TreeEntry{},\\n   978→\\t}\\n   979→\\n   980→\\t// Insert all entries into the tree structure\\n   981→\\tfor fullPath, entry 