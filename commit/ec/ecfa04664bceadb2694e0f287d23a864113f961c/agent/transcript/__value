→\\tAgent            agents.Agent\\n    22→\\tDir              string\\n    23→\\tArtifactDir      string\\n    24→\\tHeadBefore       string\\n    25→\\tCheckpointBefore string\\n    26→\\tConsoleLog       *os.File\\n    27→\\tsession          agents.Session // interactive session, if started via StartSession\\n    28→\\tskipArtifacts    bool           // suppresses artifact capture on scenario restart\\n    29→}\\n    30→\\n    31→// SetupRepo creates a fresh git repository in a temporary directory, seeds it\\n    32→// with an initial commit, and runs `entire enable` for the given agent.\\n    33→// Artifact capture is registered as a cleanup function.\\n    34→//\\n    35→// When E2E_KEEP_REPOS is set, the temporary directory is not cleaned up\\n    36→// so it can be inspected after the test. A symlink in the artifact dir\\n    37→// points to the preserved repo.\\n    38→func SetupRepo(t *testing.T, agent agents.Agent) *RepoState {\\n    39→\\tt.Helper()\\n    40→\\n    41→\\tkeepRepos := os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\"\\n    42→\\n    43→\\t// Always use os.MkdirTemp instead of t.TempDir(). Go's t.TempDir()\\n    44→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    45→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    46→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    47→\\tif err != nil {\\n    48→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    49→\\t}\\n    50→\\tif keepRepos {\\n    51→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    52→\\t} else {\\n    53→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    54→\\t}\\n    55→\\n    56→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    57→\\t// what agent CLIs see when they resolve their own CWD.\\n    58→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    59→\\t\\tdir = resolved\\n    60→\\t}\\n    61→\\n    62→\\tGit(t, dir, \\\"init\\\")\\n    63→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    64→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    65→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    66→\\n    67→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    68→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    69→\\n    70→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    71→\\t// since there's no user to prompt. Write a config to allow it.\\n    72→\\tif agent.Name() == \\\"opencode\\\" {\\n    73→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    74→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    75→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    76→\\t\\t}\\n    77→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    78→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    79→\\t\\t}\\n    80→\\t}\\n    81→\\n    82→\\t// Create artifact dir eagerly so console.log is written to disk\\n    83→\\t// incrementally. Even if the test is killed by a global timeout,\\n    84→\\t// partial output survives.\\n    85→\\tartDir := artifactDir(t)\\n    86→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    87→\\tif err != nil {\\n    88→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    89→\\t}\\n    90→\\n    91→\\tstate := &RepoState{\\n    92→\\t\\tAgent:            agent,\\n    93→\\t\\tDir:              dir,\\n    94→\\t\\tArtifactDir:      artDir,\\n    95→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n    96→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n    97→\\t\\tConsoleLog:       consoleLog,\\n    98→\\t}\\n    99→\\n   100→\\tt.Cleanup(func() {\\n   101→\\t\\t_ = consoleLog.Close()\\n   102→\\t\\tif !state.skipArtifacts {\\n   103→\\t\\t\\tCaptureArtifacts(t, state)\\n   104→\\t\\t}\\n   105→\\t})\\n   106→\\n   107→\\treturn state\\n   108→}\\n   109→\\n   110→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   111→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   112→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   113→//\\n   114→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   115→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   116→// panic and restarts the entire scenario with a fresh repository, up to\\n   117→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   118→// failed attempt poisoning the retry.\\n   119→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   120→\\tt.Helper()\\n   121→\\tt.Parallel()\\n   122→\\tall := agents.All()\\n   123→\\tif len(all) == 0 {\\n   124→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   125→\\t}\\n   126→\\tfor _, agent := range all {\\n   127→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   128→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   129→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   130→\\t\\t\\tslotCtx := context.Background()\\n   131→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   132→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   133→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   134→\\t\\t\\t\\tdefer cancel()\\n   135→\\t\\t\\t}\\n   136→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   137→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   138→\\t\\t\\t}\\n   139→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   140→\\n   141→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   142→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   143→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   144→\\n   145→\\t\\t\\tvar prevState *RepoState\\n   146→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   147→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   148→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   149→\\n   150→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   151→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   152→\\t\\t\\t\\tif prevState != nil {\\n   153→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   154→\\t\\t\\t\\t}\\n   155→\\n   156→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   157→\\t\\t\\t\\tcancel()\\n   158→\\n   159→\\t\\t\\t\\tif !restarted {\\n   160→\\t\\t\\t\\t\\treturn\\n   161→\\t\\t\\t\\t}\\n   162→\\t\\t\\t\\tprevState = s\\n   163→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   164→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   165→\\t\\t\\t\\t}\\n   166→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   167→\\t\\t\\t}\\n   168→\\t\\t})\\n   169→\\t}\\n   170→}\\n   171→\\n   172→// runScenario runs the test function and recovers from errScenarioRestart\\n   173→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   174→// the scenario should be restarted with a fresh repository.\\n   175→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   176→\\tt.Helper()\\n   177→\\tdefer func() {\\n   178→\\t\\tif r := recover(); r != nil {\\n   179→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   180→\\t\\t\\t\\trestarted = true\\n   181→\\t\\t\\t\\treturn\\n   182→\\t\\t\\t}\\n   183→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   184→\\t\\t}\\n   185→\\t}()\\n   186→\\tfn(t, s, ctx)\\n   187→\\treturn false\\n   188→}\\n   189→\\n   190→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   191→\\n   192→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   193→// detected. ForEachAgent recovers from this panic and restarts the test\\n   194→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   195→// attempt.\\n   196→type errScenarioRestart struct {\\n   197→\\tmsg string\\n   198→}\\n   199→\\n   200→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   201→// and returns the result. If the agent reports a transient API error, it\\n   202→// panics with errScenarioRestart to trigger a full scenario restart in\\n   203→// ForEachAgent (see runScenario).\\n   204→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   205→\\tt.Helper()\\n   206→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   207→\\ts.logPromptResult(out)\\n   208→\\n   209→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   210→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   211→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   212→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   213→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   214→\\t}\\n   215→\\n   216→\\treturn out, err\\n   217→}\\n   218→\\n   219→func (s *RepoState) logPromptResult(out agents.Output) {\\n   220→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   221→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   222→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   223→}\\n   224→\\n   225→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   226→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   227→\\tt.Helper()\\n   228→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   229→\\tGit(t, s.Dir, args...)\\n   230→}\\n   231→\\n   232→// StartSession starts an interactive session and registers it for pane\\n   233→// capture in artifacts. Returns nil if the agent does not support interactive\\n   234→// mode. The session is closed automatically during test cleanup.\\n   235→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   236→\\tt.Helper()\\n   237→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   238→\\tif err != nil {\\n   239→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   240→\\t}\\n   241→\\tif session == nil {\\n   242→\\t\\treturn nil\\n   243→\\t}\\n   244→\\ts.session = session\\n   245→\\treturn session\\n   246→}\\n   247→\\n   248→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   249→// pane content to ConsoleLog after the wait completes (success or failure).\\n   250→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   251→\\tt.Helper()\\n   252→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   253→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   254→\\tif err != nil {\\n   255→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   256→\\t}\\n   257→}\\n   258→\\n   259→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   260→// Fails the test on error.\\n   261→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   262→\\tt.Helper()\\n   263→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   264→\\tif err := session.Send(input); err != nil {\\n   265→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   266→\\t}\\n   267→}\\n   268→\\n   269→// PatchSettings merges extra keys into .entire/settings.json.\\n   270→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   271→\\tt.Helper()\\n   272→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   273→\\tdata, err := os.ReadFile(path)\\n   274→\\tif err != nil {\\n   275→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   276→\\t}\\n   277→\\tvar settings map[string]any\\n   278→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   279→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   280→\\t}\\n   281→\\tfor k, v := range extra {\\n   282→\\t\\tsettings[k] = v\\n   283→\\t}\\n   284→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   285→\\tif err != nil {\\n   286→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   287→\\t}\\n   288→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   289→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   290→\\t}\\n   291→}\\n   292→\\n   293→// Git runs a git command in the given directory and fails the test if it\\n   294→// returns a non-zero exit code.\\n   295→func Git(t *testing.T, dir string, args ...string) {\\n   296→\\tt.Helper()\\n   297→\\n   298→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   299→\\tif dir != \\\"\\\" {\\n   300→\\t\\tcmd.Dir = dir\\n   301→\\t}\\n   302→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   303→\\n   304→\\tout, err := cmd.CombinedOutput()\\n   305→\\tif err != nil {\\n   306→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   307→\\t}\\n   308→}\\n   309→\\n   310→// GitOutput runs a git command in the given directory, returns its trimmed\\n   311→// stdout, and fails the test on error.\\n   312→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   313→\\tt.Helper()\\n   314→\\n   315→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   316→\\tif dir != \\\"\\\" {\\n   317→\\t\\tcmd.Dir = dir\\n   318→\\t}\\n   319→\\n   320→\\tout, err := cmd.Output()\\n   321→\\tif err != nil {\\n   322→\\t\\tvar stderr string\\n   323→\\t\\tee := &exec.ExitError{}\\n   324→\\t\\tif errors.As(err, &ee) {\\n   325→\\t\\t\\tstderr = string(ee.Stderr)\\n   326→\\t\\t}\\n   327→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   328→\\t}\\n   329→\\n   330→\\treturn strings.TrimSpace(string(out))\\n   331→}\\n   332→\\n   333→// NewCheckpointCommits returns the SHAs of commits added to the\\n   334→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   335→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   336→\\tt.Helper()\\n   337→\\n   338→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   339→\\tif log == \\\"\\\" {\\n   340→\\t\\treturn nil\\n   341→\\t}\\n   342→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   343→}\\n   344→\\n   345→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   346→// checkpoint branch. It parses the two-level directory structure\\n   347→// ({prefix}/{suffix}/metadata.json) and returns the concatenated IDs.\\n   348→func CheckpointIDs(t *testing.T, dir string) []string {\\n   349→\\tt.Helper()\\n   350→\\tout := gitOutputSafe(dir, \\\"ls-tree\\\", \\\"-r\\\", \\\"--name-only\\\", \\\"entire/checkpoints/v1\\\")\\n   351→\\tif out == \\\"\\\" {\\n   352→\\t\\treturn nil\\n   353→\\t}\\n   354→\\tseen := map[string]bool{}\\n   355→\\tvar ids []string\\n   356→\\tfor _, line := range strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\") {\\n   357→\\t\\t// Match {prefix}/{suffix}/metadata.json (top-level, not session-level)\\n   358→\\t\\tparts := strings.Split(line, \\\"/\\\")\\n   359→\\t\\tif len(parts) == 3 && parts[2] == \\\"metadata.json\\\" {\\n   360→\\t\\t\\tid := parts[0] + parts[1]\\n   361→\\t\\t\\tif !seen[id] {\\n   362→\\t\\t\\t\\tseen[id] = true\\n   363→\\t\\t\\t\\tids = append(ids, id)\\n   364→\\t\\t\\t}\\n   365→\\t\\t}\\n   366→\\t}\\n   367→\\treturn ids\\n   368→}\\n   369→\\n   370→// ReadCheckpointMetadata reads the checkpoint-level metadata.json from the\\n   371→// tip of the checkpoint branch for the given checkpoint ID.\\n   372→func ReadCheckpointMetadata(t *testing.T, dir string, checkpointID string) CheckpointMetadata {\\n   373→\\tt.Helper()\\n   374→\\n   375→\\tpath := CheckpointPath(checkpointID) + \\\"/metadata.json\\\"\\n   376→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   377→\\n   378→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   379→\\n   380→\\tvar meta CheckpointMetadata\\n   381→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   382→\\t\\tt.Fatalf(\\\"unmarshal checkpoint metadata from %s: %v\\\", blob, err)\\n   383→\\t}\\n   384→\\n   385→\\treturn meta\\n   386→}\\n   387→\\n   388→// ReadSessionMetadata reads a session's metadata.json from the tip of the\\n   389→// checkpoint branch for the given checkpoint ID and session index.\\n   390→func ReadSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int) SessionMetadata {\\n   391→\\tt.Helper()\\n   392→\\n   393→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   394→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   395→\\n   396→\\traw := GitOutput(t, dir, \\\"show\\\", blob)\\n   397→\\n   398→\\tvar meta SessionMetadata\\n   399→\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   400→\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   401→\\t}\\n   402→\\n   403→\\treturn meta\\n   404→}\\n   405→\\n   406→// WaitForSessionMetadata polls until session metadata exists on the checkpoint\\n   407→// branch for the given checkpoint ID and session index, then returns it.\\n   408→// This handles the race where the checkpoint branch advances before session\\n   409→// metadata is fully committed.\\n   410→func WaitForSessionMetadata(t *testing.T, dir string, checkpointID string, sessionIndex int, timeout time.Duration) SessionMetadata {\\n   411→\\tt.Helper()\\n   412→\\n   413→\\tpath := fmt.Sprintf(\\\"%s/%d/metadata.json\\\", CheckpointPath(checkpointID), sessionIndex)\\n   414→\\tblob := \\\"entire/checkpoints/v1:\\\" + path\\n   415→\\n   416→\\tdeadline := time.Now().Add(timeout)\\n   417→\\tfor time.Now().Before(deadline) {\\n   418→\\t\\traw := gitOutputSafe(dir, \\\"show\\\", blob)\\n   419→\\t\\tif raw != \\\"\\\" {\\n   420→\\t\\t\\tvar meta SessionMetadata\\n   421→\\t\\t\\tif err := json.Unmarshal([]byte(raw), &meta); err != nil {\\n   422→\\t\\t\\t\\tt.Fatalf(\\\"unmarshal session metadata from %s: %v\\\", blob, err)\\n   423→\\t\\t\\t}\\n   424→\\t\\t\\treturn meta\\n   425→\\t\\t}\\n   426→\\t\\ttime.Sleep(500 * time.Millisecond)\\n   427→\\t}\\n   428→\\tt.Fatalf(\\\"session metadata %s did not appear within %s\\\", blob, timeout)\\n   429→\\treturn SessionMetadata{}\\n   430→}\\n   431→\\n   432→// SetupBareRemote creates a bare git repo, adds it as \\\"origin\\\", and pushes\\n   433→// the initial commit. Returns the bare repo path.\\n   434→func SetupBareRemote(t *testing.T, s *RepoState) string {\\n   435→\\tt.Helper()\\n   436→\\n   437→\\tvar bareDir string\\n   438→\\tif os.Getenv(\\\"E2E_KEEP_REPOS\\\") != \\\"\\\" {\\n   439→\\t\\tvar err error\\n   440→\\t\\tbareDir, err = os.MkdirTemp(\\\"\\\", \\\"e2e-bare-*\\\")\\n   441→\\t\\tif err != nil {\\n   442→\\t\\t\\tt.Fatalf(\\\"create bare remote dir: %v\\\", err)\\n   443→\\t\\t}\\n   444→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: bare remote will be preserved at %s\\\", bareDir)\\n   445→\\t} else {\\n   446→\\t\\tbareDir = t.TempDir()\\n   447→\\t}\\n   448→\\n   449→\\tGit(t, bareDir, \\\"init\\\", \\\"--bare\\\")\\n   450→\\tGit(t, s.Dir, \\\"remote\\\", \\\"add\\\", \\\"origin\\\", bareDir)\\n   451→\\tGit(t, s.Dir, \\\"push\\\", \\\"-u\\\", \\\"origin\\\", \\\"HEAD\\\")\\n   452→\\treturn bareDir\\n   453→}\\n   454→\\n   455→// GitOutputErr runs a git command and returns (output, error) without\\n   456→// failing the test. For commands expected to fail.\\n   457→func GitOutputErr(dir string, args ...string) (string, error) {\\n   458→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   459→\\tif dir != \\\"\\\" {\\n   460→\\t\\tcmd.Dir = dir\\n   461→\\t}\\n   462→\\tout, err := cmd.CombinedOutput()\\n   463→\\treturn strings.TrimSpace(string(out)), err\\n   464→}\\n   465→\\n   466→// GetCheckpointTrailer extracts the Entire-Checkpoint trailer value from a\\n   467→// code commit. Returns the trimmed trailer value, or an empty string if the\\n   468→// trailer is not present.\\n   469→func GetCheckpointTrailer(t *testing.T, dir string, ref string) string {\\n   470→\\tt.Helper()\\n   471→\\n   472→\\treturn GitOutput(t, dir, \\\"log\\\", \\\"-1\\\", \\\"--format=%(trailers:key=Entire-Checkpoint,valueonly)\\\", ref)\\n   473→}\\n   474→\"}]},\"uuid\":\"df6c2387-cf17-49cc-b686-5b05ef6955d1\",\"timestamp\":\"2026-02-27T06:44:30.888Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand how the E2E test framework works, specifically:\\n\\n1. How does the opencode agent driver work? Look in `e2e/` for agent driver code related to opencode.\\n2. How does `ForEachAgent` and `RunPrompt` work? Look in `e2e/testutil/`.\\n3. Does opencode respect `XDG_DATA_HOME` or any env var to control its data directory?\\n4. How are tests currently parallelized? Do they share env vars?\\n\\nKey files to explore:\\n- `e2e/testutil/` - test utilities, RepoState, RunPrompt\\n- `e2e/` - agent drivers/adapters for opencode\\n- Any opencode-related co