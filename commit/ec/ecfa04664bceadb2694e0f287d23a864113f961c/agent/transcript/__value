  72→\\t\\to(cfg)\\n    73→\\t}\\n    74→\\n    75→\\t// Per-prompt timeout so a slow response gets killed early enough to\\n    76→\\t// retry within the test's overall budget.\\n    77→\\ttimeout := 60 * time.Second\\n    78→\\tif cfg.PromptTimeout > 0 {\\n    79→\\t\\ttimeout = cfg.PromptTimeout\\n    80→\\t}\\n    81→\\tpromptCtx, cancel := context.WithTimeout(ctx, timeout)\\n    82→\\tdefer cancel()\\n    83→\\n    84→\\targs := []string{\\\"-p\\\", prompt, \\\"--model\\\", cfg.Model, \\\"-y\\\"}\\n    85→\\tdisplayArgs := []string{\\\"-p\\\", fmt.Sprintf(\\\"%q\\\", prompt), \\\"--model\\\", cfg.Model, \\\"-y\\\"}\\n    86→\\tcmd := exec.CommandContext(promptCtx, g.Binary(), args...)\\n    87→\\tcmd.Dir = dir\\n    88→\\tcmd.Stdin = nil\\n    89→\\tcmd.Env = append(os.Environ(), \\\"ACCESSIBLE=1\\\", \\\"ENTIRE_TEST_TTY=0\\\")\\n    90→\\tcmd.SysProcAttr = &syscall.SysProcAttr{Setpgid: true}\\n    91→\\tcmd.Cancel = func() error {\\n    92→\\t\\treturn syscall.Kill(-cmd.Process.Pid, syscall.SIGKILL)\\n    93→\\t}\\n    94→\\tcmd.WaitDelay = 5 * time.Second\\n    95→\\n    96→\\tvar stdout, stderr strings.Builder\\n    97→\\tcmd.Stdout = &stdout\\n    98→\\tcmd.Stderr = &stderr\\n    99→\\n   100→\\terr := cmd.Run()\\n   101→\\texitCode := 0\\n   102→\\tif err != nil {\\n   103→\\t\\texitErr := &exec.ExitError{}\\n   104→\\t\\tif errors.As(err, &exitErr) {\\n   105→\\t\\t\\texitCode = exitErr.ExitCode()\\n   106→\\t\\t} else {\\n   107→\\t\\t\\texitCode = -1\\n   108→\\t\\t}\\n   109→\\t\\t// Wrap the prompt-level deadline so IsTransientError can detect it.\\n   110→\\t\\t// cmd.Run() returns \\\"signal: killed\\\", not the context error.\\n   111→\\t\\tif promptCtx.Err() == context.DeadlineExceeded {\\n   112→\\t\\t\\terr = fmt.Errorf(\\\"%w: %w\\\", err, context.DeadlineExceeded)\\n   113→\\t\\t}\\n   114→\\t}\\n   115→\\n   116→\\treturn Output{\\n   117→\\t\\tCommand:  g.Binary() + \\\" \\\" + strings.Join(displayArgs, \\\" \\\"),\\n   118→\\t\\tStdout:   s