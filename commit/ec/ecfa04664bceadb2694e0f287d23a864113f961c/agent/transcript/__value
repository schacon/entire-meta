TmuxSession) OnClose(fn func()) {\\n    20→\\ts.cleanups = append(s.cleanups, fn)\\n    21→}\\n    22→\\n    23→// NewTmuxSession creates a new tmux session running the given command in dir.\\n    24→// unsetEnv lists environment variable names to strip from the session.\\n    25→func NewTmuxSession(name string, dir string, unsetEnv []string, command string, args ...string) (*TmuxSession, error) {\\n    26→\\ts := &TmuxSession{name: name}\\n    27→\\n    28→\\ttmuxArgs := []string{\\\"new-session\\\", \\\"-d\\\", \\\"-s\\\", name, \\\"-c\\\", dir}\\n    29→\\t// Build a shell command string, prefixed with env -u for each var to strip.\\n    30→\\t// All arguments are shell-quoted to prevent injection or splitting.\\n    31→\\tvar parts []string\\n    32→\\tfor _, v := range unsetEnv {\\n    33→\\t\\tparts = append(parts, \\\"env\\\", \\\"-u\\\", shellQuote(v))\\n    34→\\t}\\n    35→\\tparts = append(parts, shellQuote(command))\\n    36→\\tfor _, a := range args {\\n    37→\\t\\tparts = append(parts, shellQuote(a))\\n    38→\\t}\\n    39→\\ttmuxArgs = append(tmuxArgs, strings.Join(parts, \\\" \\\"))\\n    40→\\n    41→\\tcmd := exec.Command(\\\"tmux\\\", tmuxArgs...)\\n    42→\\tif out, err := cmd.CombinedOutput(); err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"tmux new-session: %w\\\\n%s\\\", err, out)\\n    44→\\t}\\n    45→\\t// Keep the pane around after the command exits so we can capture error output.\\n    46→\\tsetCmd := exec.Command(\\\"tmux\\\", \\\"set-option\\\", \\\"-t\\\", name, \\\"remain-on-exit\\\", \\\"on\\\")\\n    47→\\t_ = setCmd.Run()\\n    48→\\treturn s, nil\\n    49→}\\n    50→\\n    51→func (s *TmuxSession) Send(input string) error {\\n    52→\\tpreSend := stableContent(s.Capture())\\n    53→\\t// Send text and Enter separately — Claude's TUI can swallow Enter\\n    54→\\t// if it arrives before the input handler finishes processing the text.\\n    55→\\tif err := s.SendKeys(input); err != nil {\\n    56→\\t\\treturn err\\n    57→\\t}\\n    58→\\ttime.Sleep(200 * time.Millisecond)\\n    59→\\tif err := s.SendKeys(\\\"Enter\\\"); err != nil {\\n    60→\\t\\treturn err\\n    61→\\t}\\n    62→\\n    63→\\t// Wait for the terminal to reflect the echoed input, then snapshot.\\n    64→\\t// This ensures WaitFor compares against post-echo content, preventing\\n    65→\\t// false matches on prompt characters (e.g. ❯) in the echoed input.\\n    66→\\tdeadline := time.Now().Add(5 * time.Second)\\n    67→\\tfor time.Now().Before(deadline) {\\n    68→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    69→\\t\\tcurrent := stableContent(s.Capture())\\n    70→\\t\\tif current != preSend {\\n    71→\\t\\t\\ts.stableAtSend = current\\n    72→\\t\\t\\treturn nil\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\ts.stableAtSend = stableContent(s.Capture())\\n    76→\\treturn nil\\n    77→}\\n    78→\\n    79→// SendKeys sends raw tmux key names without appending Enter.\\n    80→func (s *TmuxSession) SendKeys(keys ...string) error {\\n    81→\\targs := append([]string{\\\"send-keys\\\", \\\"-t\\\", s.name}, keys...)\\n    82→\\tcmd := exec.Command(\\\"tmux\\\", args...)\\n    83→\\tout, err := cmd.CombinedOutput()\\n    84→\\tif err != nil {\\n    85→\\t\\treturn fmt.Errorf(\\\"tmux send-keys: %w\\\\n%s\\\", err, out)\\n    86→\\t}\\n    87→\\treturn nil\\n    88→}\\n    89→\\n    90→const (\\n    91→\\tsettleTime   = 2 * time.Second\\n    92→\\tpollInterval = 500 * time.Millisecond\\n    93→)\\n    94→\\n    95→// stableContent returns the content with the last few lines stripped,\\n    96→// so that TUI status bar updates don't prevent the settle timer.\\n    97→func stableContent(content string) string {\\n    98→\\tlines := strings.Split(content, \\\"\\\\n\\\")\\n    99→\\tif len(lines) > 3 {\\n   100→\\t\\tlines = lines[:len(lines)-3]\\n   101→\\t}\\n   102→\\treturn strings.Join(lines, \\\"\\\\n\\\")\\n   103→}\\n   104→\\n   105→func (s *TmuxSession) WaitFor(pattern string, timeout time.Duration) (string, error) {\\n  