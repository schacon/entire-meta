if transcript[i].Type != transcriptTypeUser {\\n   134→\\t\\t\\tcontinue\\n   135→\\t\\t}\\n   136→\\t\\tvar msg userMessage\\n   137→\\t\\tif err := json.Unmarshal(transcript[i].Message, &msg); err != nil {\\n   138→\\t\\t\\tcontinue\\n   139→\\t\\t}\\n   140→\\n   141→\\t\\t// Handle string content\\n   142→\\t\\tif str, ok := msg.Content.(string); ok {\\n   143→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(str))\\n   144→\\t\\t\\tcontinue\\n   145→\\t\\t}\\n   146→\\n   147→\\t\\t// Handle array content (only if it contains text blocks)\\n   148→\\t\\tif arr, ok := msg.Content.([]interface{}); ok {\\n   149→\\t\\t\\tvar texts []string\\n   150→\\t\\t\\tfor _, item := range arr {\\n   151→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   152→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == contentTypeText {\\n   153→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   154→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   155→\\t\\t\\t\\t\\t\\t}\\n   156→\\t\\t\\t\\t\\t}\\n   157→\\t\\t\\t\\t}\\n   158→\\t\\t\\t}\\n   159→\\t\\t\\tif len(texts) > 0 {\\n   160→\\t\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\")))\\n   161→\\t\\t\\t}\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\treturn prompts\\n   165→}\\n   166→\\n   167→// extractLastUserPrompt extracts the last user message from the transcript.\\n   168→// Only considers messages with string content (not tool results).\\n   169→// IDE-injected context tags (like <ide_opened_file>) are stripped from the result.\\n   170→func extractLastUserPrompt(transcript []transcriptLine) string {\\n   171→\\tprompts := extractUserPrompts(transcript)\\n   172→\\tif len(prompts) == 0 {\\n   173→\\t\\treturn \\\"\\\"\\n   174→\\t}\\n   175→\\treturn prompts[len(prompts)-1]\\n   176→}\\n   177→\\n   178→// findLastUserUUID finds the UUID of the last user message (that has string content)\\n   179→func findLastUserUUID(transcript []transcri