ror {\\n   146→\\tif session == nil {\\n   147→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   148→\\t}\\n   149→\\n   150→\\tif session.AgentName != \\\"\\\" && session.AgentName != f.Name() {\\n   151→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, f.Name())\\n   152→\\t}\\n   153→\\n   154→\\tif session.SessionRef == \\\"\\\" {\\n   155→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   156→\\t}\\n   157→\\n   158→\\tif len(session.NativeData) == 0 {\\n   159→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   160→\\t}\\n   161→\\n   162→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   163→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   164→\\t}\\n   165→\\n   166→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   167→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   168→\\t}\\n   169→\\n   170→\\treturn nil\\n   171→}\\n   172→\\n   173→// FormatResumeCommand returns the command to resume a Factory AI Droid session.\\n   174→func (f *FactoryAIDroidAgent) FormatResumeCommand(sessionID string) string {\\n   175→\\treturn \\\"droid --session-id \\\" + sessionID\\n   176→}\\n   177→\"}]},\"uuid\":\"6c1aa7ee-d4ca-439e-bfd4-c05613e90aac\",\"timestamp\":\"2026-02-27T21:37:34.317Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Find the factoryai droid implementation and trace how the system message is being sent/displayed. The user is seeing raw JSON like `{\\\"systemMessage\\\":\\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"}` printed to the terminal when they type a prompt. I need to understand:\\n\\n1. Where the system message is constructed (search for \\\"Powered by Entire\\\" and \\\"systemMessage\\\")\\n2. How the factoryai droid communicates with the agent (s