op\\\"\\n   243→\\n   244→// waitForTranscriptFlush polls the transcript file for the stop hook sentinel.\\n   245→// Falls back silently after a timeout.\\n   246→func waitForTranscriptFlush(ctx context.Context, transcriptPath string, hookStartTime time.Time) {\\n   247→\\tconst (\\n   248→\\t\\tmaxWait      = 3 * time.Second\\n   249→\\t\\tpollInterval = 50 * time.Millisecond\\n   250→\\t\\ttailBytes    = 4096\\n   251→\\t\\tmaxSkew      = 2 * time.Second\\n   252→\\t)\\n   253→\\n   254→\\tlogCtx := logging.WithComponent(ctx, \\\"agent.claudecode\\\")\\n   255→\\tdeadline := time.Now().Add(maxWait)\\n   256→\\tfor time.Now().Before(deadline) {\\n   257→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   258→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   259→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   260→\\t\\t\\t)\\n   261→\\t\\t\\treturn\\n   262→\\t\\t}\\n   263→\\t\\ttime.Sleep(pollInterval)\\n   264→\\t}\\n   265→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   266→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   267→\\t)\\n   268→}\\n   269→\\n   270→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   271→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   272→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   273→\\tif err != nil {\\n   274→\\t\\treturn false\\n   275→\\t}\\n   276→\\tdefer f.Close()\\n   277→\\n   278→\\tinfo, err := f.Stat()\\n   279→\\tif err != nil {\\n   280→\\t\\treturn false\\n   281→\\t}\\n   282→\\toffset := info.Size() - tailBytes\\n   283→\\tif offset < 0 {\\n   284→\\t\\toffset = 0\\n   285→\\t}\\n   286→\\tbuf := make([]byte, info.Size()-offset)\\n   287→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   288→\\t\\treturn false\\n   289→\\t}\\n   