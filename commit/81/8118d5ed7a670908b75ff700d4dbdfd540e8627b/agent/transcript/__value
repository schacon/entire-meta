ok command already exists, return 0 (no changes needed)\\n   120→\\tif !force {\\n   121→\\t\\texistingCmd := getFirstEntireHookCommand(sessionStart)\\n   122→\\t\\texpectedCmd := cmdPrefix + \\\"session-start\\\"\\n   123→\\t\\tif existingCmd == expectedCmd {\\n   124→\\t\\t\\treturn 0, nil // Already installed with same mode\\n   125→\\t\\t}\\n   126→\\t}\\n   127→\\n   128→\\t// Remove existing Entire hooks first (for clean installs and mode switching)\\n   129→\\tsessionStart = removeEntireHooks(sessionStart)\\n   130→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   131→\\tbeforeAgent = removeEntireHooks(beforeAgent)\\n   132→\\tafterAgent = removeEntireHooks(afterAgent)\\n   133→\\tbeforeModel = removeEntireHooks(beforeModel)\\n   134→\\tafterModel = removeEntireHooks(afterModel)\\n   135→\\tbeforeToolSelection = removeEntireHooks(beforeToolSelection)\\n   136→\\tbeforeTool = removeEntireHooks(beforeTool)\\n   137→\\tafterTool = removeEntireHooks(afterTool)\\n   138→\\tpreCompress = removeEntireHooks(preCompress)\\n   139→\\tnotification = removeEntireHooks(notification)\\n   140→\\n   141→\\t// Install all hooks\\n   142→\\t// Session lifecycle hooks\\n   143→\\tsessionStart = addGeminiHook(sessionStart, \\\"\\\", \\\"entire-session-start\\\", cmdPrefix+\\\"session-start\\\")\\n   144→\\t// SessionEnd fires on both \\\"exit\\\" and \\\"logout\\\" - install hooks for both matchers\\n   145→\\tsessionEnd = addGeminiHook(sessionEnd, \\\"exit\\\", \\\"entire-session-end-exit\\\", cmdPrefix+\\\"session-end\\\")\\n   146→\\tsessionEnd = addGeminiHook(sessionEnd, \\\"logout\\\", \\\"entire-session-end-logout\\\", cmdPrefix+\\\"session-end\\\")\\n   147→\\n   148→\\t// Agent hooks (user prompt and response)\\n   149→\\tbeforeAgent = addGeminiHook(beforeAgent, \\\"\\\", \\\"entire-before-agent\\\", cmdPrefix+\\\"before-agent\\\")\\n   150→\\tafterAgent = addGeminiHook(afterAgent, \\\"\\\", \\\"entire-after-agent\\\", cmdPrefix+\\\"after-agent\\\")\\n   151→\\n   152→\\t// Model hooks (LLM request/response - fires on every LLM call)\\n   153→\\tbeforeModel = addGeminiHook(beforeModel, \\\"\\\", \\\"entire-before-model\\\", cmdPrefix+\\\"before-model\\\")\\n   154→\\tafterModel = addGeminiHook(afterModel, \\\"\\\", \\\"entire-after-model\\\", cmdPrefix+\\\"after-model\\\")\\n   155→\\n   156→\\t// Tool selection hook (before planner selects tools)\\n   157→\\tbeforeToolSelection = addGeminiHook(beforeToolSelection, \\\"\\\", \\\"entire-before-tool-selection\\\", cmdPrefix+\\\"before-tool-selection\\\")\\n   158→\\n   159→\\t// Tool hooks (before/after tool execution)\\n   160→\\tbeforeTool = addGeminiHook(beforeTool, \\\"*\\\", \\\"entire-before-tool\\\", cmdPrefix+\\\"before-tool\\\")\\n   161→\\tafterTool = addGeminiHook(afterTool, \\\"*\\\", \\\"entire-after-tool\\\", cmdPrefix+\\\"after-tool\\\")\\n   162→\\n   163→\\t// Compression hook (before chat history compression)\\n   164→\\tpreCompress = addGeminiHook(preCompress, \\\"\\\", \\\"entire-pre-compress\\\", cmdPrefix+\\\"pre-compress\\\")\\n   165→\\n   166→\\t// Notification hook (errors, warnings, info)\\n   167→\\tnotification = addGeminiHook(notification, \\\"\\\", \\\"entire-notification\\\", cmdPrefix+\\\"notification\\\")\\n   168→\\n   169→\\t// 12 hooks total:\\n   170→\\t// - session-start (1)\\n   171→\\t// - session-end exit + logout (2)\\n   172→\\t// - before-agent, after-agent (2)\\n   173→\\t// - before-model, after-model (2)\\n   174→\\t// - before-tool-selection (1)\\n   175→\\t// - before-tool, after-tool (2)\\n   176→\\t// - pre-compress (1)\\n   177→\\t// - notification (1)\\n   178→\\tcount := 12\\n   179→\\n   180→\\t// Marshal modified hook types back to rawHooks\\n   181→\\tmarshalGeminiHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   182→\\tmarshalGeminiHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   183→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeAgent\\\", beforeAgent)\\n   184→\\tmarshalGeminiHookType(rawHooks, \\\"AfterAgent\\\", afterAgent)\\n   185→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeModel\\\", beforeModel)\\n   186→\\tmarshalGeminiHookType(rawHooks, \\\"AfterModel\\\", afterModel)\\n   187→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeToolSelection\\\", beforeToolSelection)\\n   188→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeTool\\\", beforeTool)\\n   189→\\tmarshalGeminiHookType(rawHooks, \\\"AfterTool\\\", afterTool)\\n   190→\\tmarshalGeminiHookType(rawHooks, \\\"PreCompress\\\", preCompress)\\n   191→\\tmarshalGeminiHookType(rawHooks, \\\"Notification\\\", notification)\\n   192→\\n   193→\\t// Marshal hooksConfig back to raw settings\\n   194→\\thooksConfigJSON, err := json.Marshal(hooksConfig)\\n   195→\\tif err != nil {\\n   196→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooksConfig: %w\\\", err)\\n   197→\\t}\\n   198→\\trawSettings[\\\"hooksConfig\\\"] = hooksConfigJSON\\n   199→\\n   200→\\t// Marshal hooks back to raw settings (preserving unknown hook types)\\n   201→\\thooksJSON, err := json.Marshal(rawHooks)\\n   202→\\tif err != nil {\\n   203→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   204→\\t}\\n   205→\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   206→\\n   207→\\t// Write back to file\\n   208→\\tif err := os.MkdirAll(filepath.Dir(settingsPath), 0o750); err != nil {\\n   209→\\t\\treturn 0, fmt.Errorf(\\\"failed to create .gemini directory: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\toutput, err := json.MarshalIndent(rawSettings, \\\"\\\", \\\"  \\\")\\n   213→\\tif err != nil {\\n   214→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   215→\\t}\\n   216→\\n   217→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   218→\\t\\treturn 0, fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   219→\\t}\\n   220→\\n   221→\\treturn count, nil\\n   222→}\\n   223→\\n   224→// parseGeminiHookType parses a specific hook type from rawHooks into the target slice.\\n   225→// Silently ignores parse errors (leaves target unchanged).\\n   226→func parseGeminiHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]GeminiHookMatcher) {\\n   227→\\tif data, ok := rawHooks[hookType]; ok {\\n   228→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   229→\\t\\tjson.Unmarshal(data, target)\\n   230→\\t}\\n   231→}\\n   232→\\n   233→// marshalGeminiHookType marshals a hook type back to rawHooks.\\n   234→// If the slice is empty, removes the key from rawHooks.\\n   235→func marshalGeminiHookType(rawHooks map[string]json.RawMessage, hookType string, matchers []GeminiHookMatcher) {\\n   236→\\tif len(matchers) == 0 {\\n   237→\\t\\tdelete(rawHooks, hookType)\\n   238→\\t\\treturn\\n   239→\\t}\\n   240→\\tdata, err := json.Marshal(matchers)\\n   241→\\tif err != nil {\\n   242→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   243→\\t}\\n   244→\\trawHooks[hookType] = data\\n   245→}\\n   246→\\n   247→// UninstallHooks removes Entire hooks from Gemini CLI settings.\\n   248→func (g *GeminiCLIAgent) UninstallHooks(ctx context.Context) error {\\n   249→\\t// Use repo root to find .gemini directory when run from a subdirectory\\n   250→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   251→\\tif err != nil {\\n   252→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   253→\\t}\\n   254→\\tsettingsPath := filepath.Join(repoRoot, \\\".gemini\\\", GeminiSettingsFileName)\\n   255→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   256→\\tif err != nil {\\n   257→\\t\\treturn nil //nolint:nilerr // No settings file means nothing to uninstall\\n   258→\\t}\\n   259→\\n   260→\\tvar rawSettings map[string]json.RawMessage\\n   261→\\tif err := json.Unmarshal(data, &rawSettings); err != nil {\\n   262→\\t\\treturn fmt.Errorf(\\\"failed to parse settings.json: %w\\\", err)\\n   263→\\t}\\n   264→\\n   265→\\t// rawHooks preserves unknown hook types\\n   266→\\tvar rawHooks map[string]json.RawMessage\\n   267→\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n   268→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   269→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks: %w\\\", err)\\n   270→\\t\\t}\\n   271→\\t}\\n   272→\\tif rawHooks == nil {\\n   273→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   274→\\t}\\n   275→\\n   276→\\t// Parse only the hook types we need to modify\\n   277→\\tvar sessionStart, sessionEnd, beforeAgent, afterAgent []GeminiHookMatcher\\n   278→\\tvar beforeModel, afterModel, beforeToolSelection []GeminiHookMatcher\\n   279→\\tvar beforeTool, afterTool, preCompress, notification []GeminiHookMatcher\\n   280→\\tparseGeminiHookType(rawHooks, \\\"SessionStart\\\", &sessionStart)\\n   281→\\tparseGeminiHookType(rawHooks, \\\"SessionEnd\\\", &sessionEnd)\\n   282→\\tparseGeminiHookType(rawHooks, \\\"BeforeAgent\\\", &beforeAgent)\\n   283→\\tparseGeminiHookType(rawHooks, \\\"AfterAgent\\\", &afterAgent)\\n   284→\\tparseGeminiHookType(rawHooks, \\\"BeforeModel\\\", &beforeModel)\\n   285→\\tparseGeminiHookType(rawHooks, \\\"AfterModel\\\", &afterModel)\\n   286→\\tparseGeminiHookType(rawHooks, \\\"BeforeToolSelection\\\", &beforeToolSelection)\\n   287→\\tparseGeminiHookType(rawHooks, \\\"BeforeTool\\\", &beforeTool)\\n   288→\\tparseGeminiHookType(rawHooks, \\\"AfterTool\\\", &afterTool)\\n   289→\\tparseGeminiHookType(rawHooks, \\\"PreCompress\\\", &preCompress)\\n   290→\\tparseGeminiHookType(rawHooks, \\\"Notification\\\", &notification)\\n   291→\\n   292→\\t// Remove Entire hooks from all hook types\\n   293→\\tsessionStart = removeEntireHooks(sessionStart)\\n   294→\\tsessionEnd = removeEntireHooks(sessionEnd)\\n   295→\\tbeforeAgent = removeEntireHooks(beforeAgent)\\n   296→\\tafterAgent = removeEntireHooks(afterAgent)\\n   297→\\tbeforeModel = removeEntireHooks(beforeModel)\\n   298→\\tafterModel = removeEntireHooks(afterModel)\\n   299→\\tbeforeToolSelection = removeEntireHooks(beforeToolSelection)\\n   300→\\tbeforeTool = removeEntireHooks(beforeTool)\\n   301→\\tafterTool = removeEntireHooks(afterTool)\\n   302→\\tpreCompress = removeEntireHooks(preCompress)\\n   303→\\tnotification = removeEntireHooks(notification)\\n   304→\\n   305→\\t// Marshal modified hook types back to rawHooks\\n   306→\\tmarshalGeminiHookType(rawHooks, \\\"SessionStart\\\", sessionStart)\\n   307→\\tmarshalGeminiHookType(rawHooks, \\\"SessionEnd\\\", sessionEnd)\\n   308→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeAgent\\\", beforeAgent)\\n   309→\\tmarshalGeminiHookType(rawHooks, \\\"AfterAgent\\\", afterAgent)\\n   310→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeModel\\\", beforeModel)\\n   311→\\tmarshalGeminiHookType(rawHooks, \\\"AfterModel\\\", afterModel)\\n   312→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeToolSelection\\\", beforeToolSelection)\\n   313→\\tmarshalGeminiHookType(rawHooks, \\\"BeforeTool\\\", beforeTool)\\n   314→\\tmarshalGeminiHookType(rawHooks, \\\"AfterTool\\\", afterTool)\\n   315→\\tmarshalGeminiHookType(rawHooks, \\\"PreCompress\\\", preCompress)\\n   316→\\tmarshalGeminiHookType(rawHooks, \\\"Notification\\\", notification)\\n   317→\\n   318→\\t// Marshal hooks back (preserving unknown hook types)\\n   319→\\tif len(rawHooks) > 0 {\\n   320→\\t\\thooksJSON, err := json.Marshal(rawHooks)\\n   321→\\t\\tif err != nil {\\n   322→\\t\\t\\treturn fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   323→\\t\\t}\\n   324→\\t\\trawSettings[\\\"hooks\\\"] = hooksJSON\\n   325→\\t} else {\\n   326→\\t\\tdelete(rawSettings, \\\"hooks\\\")\\n   327→\\t}\\n   328→\\n   329→\\t// Write back\\n   330→\\toutput, err := json.MarshalIndent(rawSettings, \\\"\\\", \\\"  \\\")\\n   331→\\tif err != nil {\\n   332→\\t\\treturn fmt.Errorf(\\\"failed to marshal settings: %w\\\", err)\\n   333→\\t}\\n   334→\\n   335→\\tif err := os.WriteFile(settingsPath, output, 0o600); err != nil {\\n   336→\\t\\treturn fmt.Errorf(\\\"failed to write settings.json: %w\\\", err)\\n   337→\\t}\\n   338→\\treturn nil\\n   339→}\\n   340→\\n   341→// AreHooksInstalled checks if Entire hooks are installed.\\n   342→func (g *GeminiCLIAgent) AreHooksInstalled(ctx context.Context) bool {\\n   343→\\t// Use repo root to find .gemini directory when run from a subdirectory\\n   344→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   345→\\tif err != nil {\\n   346→\\t\\trepoRoot = \\\".\\\" // Fallback to CWD if not in a git repo\\n   347→\\t}\\n   348→\\tsettingsPath := filepath.Join(repoRoot, \\\".gemini\\\", GeminiSettingsFileName)\\n   349→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   350→\\tif err != nil {\\n   351→\\t\\treturn false\\n   352→\\t}\\n   353→\\n   354→\\tvar settings GeminiSettings\\n   355→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   356→\\t\\treturn false\\n   357→\\t}\\n   358→\\n   359→\\t// Check for at least one of our hooks using isEntireHook (works for both localDev and production)\\n   360→\\treturn hasEntireHook(settings.Hooks.SessionStart) ||\\n   361→\\t\\thasEntireHook(settings.Hooks.SessionEnd) ||\\n   362→\\t\\thasEntireHook(settings.Hooks.BeforeAgent) ||\\n   363→\\t\\thasEntireHook(settings.Hooks.AfterAgent) ||\\n   364→\\t\\thasEntireHook(settings.Hooks.BeforeModel) ||\\n   365→\\t\\thasEntireHook(settings.Hooks.AfterModel) ||\\n   366→\\t\\thasEntireHook(settings.Hooks.BeforeToolSelection) ||\\n   367→\\t\\thasEntireHook(settings.Hooks.BeforeTool) ||\\n   368→\\t\\thasEntireHook(settings.Hooks.AfterTool) ||\\n   369→\\t\\thasEntireHook(settings.Hooks.PreCompress) ||\\n   370→\\t\\thasEntireHook(settings.Hooks.Notification)\\n   371→}\\n   372→\\n   373→// Helper functions for hook management\\n   374→\\n   375→// addGeminiHook adds a hook entry to matchers.\\n   376→// Unlike Claude Code, Gemini hooks require a \\\"name\\\" field.\\n   377→func addGeminiHook(matchers []GeminiHookMatcher, matcherName, hookName, command string) []GeminiHookMatcher {\\n   378→\\tentry := GeminiHookEntry{\\n   379→\\t\\tName:    hookName,\\n   380→\\t\\tType:    \\\"command\\\",\\n   381→\\t\\tCommand: command,\\n   382→\\t}\\n   383→\\n   384→\\t// Find or create matcher\\n   385→\\tfor i, matcher := range matchers {\\n   386→\\t\\tif matcher.Matcher == matcherName {\\n   387→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   388→\\t\\t\\treturn matchers\\n   389→\\t\\t}\\n   390→\\t}\\n   391→\\n   392→\\t// Create new matcher\\n   393→\\tnewMatcher := GeminiHookMatcher{\\n   394→\\t\\tHooks: []GeminiHookEntry{entry},\\n   395→\\t}\\n   396→\\tif matcherName != \\\"\\\" {\\n   397→\\t\\tnewMatcher.Matcher = matcherName\\n   398→\\t}\\n   399→\\treturn append(matchers, newMatcher)\\n   400→}\\n   401→\\n   402→// isEntireHook checks if a command is an Entire hook\\n   403→func isEntireHook(command string) bool {\\n   404→\\tfor _, prefix := range entireHookPrefixes {\\n   405→\\t\\tif strings.HasPrefix(command, prefix) {\\n   406→\\t\\t\\treturn true\\n   407→\\t\\t}\\n   408→\\t}\\n   409→\\treturn false\\n   410→}\\n   411→\\n   412→// hasEntireHook checks if any hook in the matchers is an Entire hook\\n   413→func hasEntireHook(matchers []GeminiHookMatcher) bool {\\n   414→\\tfor _, matcher := range matchers {\\n   415→\\t\\tfor _, hook := range matcher.Hooks {\\n   416→\\t\\t\\tif isEntireHook(hook.Command) {\\n   417→\\t\\t\\t\\treturn true\\n   418→\\t\\t\\t}\\n   419→\\t\\t}\\n   420→\\t}\\n   421→\\treturn false\\n   422→}\\n   423→\\n   424→// getFirstEntireHookCommand returns the command of the first Entire hook found, or empty string\\n   425→func getFirstEntireHookCommand(matchers []GeminiHookMatcher) string {\\n   426→\\tfor _, matcher := range matchers {\\n   427→\\t\\tfor _, hook := range matcher.Hooks {\\n   428→\\t\\t\\tif isEntireHook(hook.Command) {\\n   429→\\t\\t\\t\\treturn hook.Command\\n   430→\\t\\t\\t}\\n   431→\\t\\t}\\n   432→\\t}\\n   433→\\treturn \\\"\\\"\\n   434→}\\n   435→\\n   436→// removeEntireHooks removes all Entire hooks from a list of matchers\\n   437→func removeEntireHooks(matchers []GeminiHookMatcher) []GeminiHookMatcher {\\n   438→\\tresult := make([]GeminiHookMatcher, 0, len(matchers))\\n   439→\\tfor _, matcher := range matchers {\\n   440→\\t\\tfilteredHooks := make([]GeminiHookEntry, 0, len(matcher.Hooks))\\n   441→\\t\\tfor _, hook := range matcher.Hooks {\\n   442→\\t\\t\\tif !isEntireHook(hook.Command) {\\n   443→\\t\\t\\t\\tfilteredHooks = append(filteredHooks, hook)\\n   444→\\t\\t\\t}\\n   445→\\t\\t}\\n   446→\\t\\t// Only keep the matcher if it has hooks remaining\\n   447→\\t\\tif len(filteredHooks) > 0 {\\n   448→\\t\\t\\tmatcher.Hooks = filteredHooks\\n   449→\\t\\t\\tresult = append(result, matcher)\\n   450→\\t\\t}\\n   451→\\t}\\n   452→\\treturn result\\n   453→}\\n   454→\"}]},\"uuid\":\"e9a54439-eda4-489d-ad09-a89c3dabbe50\",\"timestamp\":\"2026-02-27T22:10:02.602Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Search the codebase for any documentation or code that indicates which agents support reading/displaying stdout from hooks. Specifically look for:\\n\\n1. Any docs about hook response formats in docs/architecture/ or similar\\n2. Any agent guide or integration checklist that mentions hook responses\\n3. Comments in the Gemini CLI, OpenCode, and Cursor agent code about hook output/response support\\n4. The agent-integration-checklist.md or agent-guide.md files mentioned in CLAUDE.md\\n\\nFocus on understanding which agents support displaying messages from hook stdout vs which ignore it entirely.\",\"agentId\":\"a9e59ee791af10001\"},\"toolUseID\":\"agent_msg_01D4S9WcPvuqKyuax3AJer5K\",\"parentToolUseID\":\"toolu_01SsWq8BHSF4cb31oaen7RHp\",\"uuid\":\"30166849-f684-4010-affd-c09253152e35\",\"timestamp\":\"2026-02-27T22:10:02.892Z\"}\n{\"parentUuid\":\