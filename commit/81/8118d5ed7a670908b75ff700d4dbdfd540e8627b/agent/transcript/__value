patcher.\\n     2→// It routes normalized events from any agent to the appropriate framework actions.\\n     3→//\\n     4→// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5→// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6→// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"strings\\\"\\n    18→\\t\\\"time\\\"\\n    19→\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy(ctx)\\n    81→\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n    82→\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    83→\\t}\\n    84→\\n    85→\\t// Output informational message\\n    86→\\tif event.ResponseMessage != \\\"\\\" {\\n    87→\\t\\tmessage = event.ResponseMessage\\n    88→\\t}\\n    89→\\tif err := outputHookResponse(message); err != nil {\\n    90→\\t\\treturn err\\n    91→\\t}\\n    92→\\n    93→\\t// Fire EventSessionStart for the current session (if state exists).\\n    94→\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n    95→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n    96→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n    97→\\t} else if state != nil {\\n    98→\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n    99→\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n   100→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   101→\\t\\t}\\n   102→\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n   103→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n   104→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   105→\\t\\t}\\n   106→\\t}\\n   107→\\n   108→\\treturn nil\\n   109→}\\n   110→\\n   111→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   112→// ensures strategy setup, initializes session.\\n   113→func handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   114→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   115→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   116→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   117→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   118→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   119→\\t)\\n   120→\\n   121→\\tsessionID := event.SessionID\\n   122→\\tif sessionID == \\\"\\\" {\\n   123→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   124→\\t}\\n   125→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   127→\\t}\\n   128→\\n   129→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   130→\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n   131→\\t\\treturn err\\n   132→\\t}\\n   133→\\n   134→\\t// Ensure strategy setup and initialize session\\n   135→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   136→\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n   137→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   138→\\t}\\n   139→\\n   140→\\tstrat := GetStrategy(ctx)\\n   141→\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt); err != nil {\\n   142→\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n   143→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   144→\\t}\\n   145→\\n   146→\\treturn nil\\n   147→}\\n   148→\\n   149→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   150→// detects file changes, saves step + checkpoint, transitions phase.\\n   151→//\\n   152→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   153→func handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   154→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   155→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   156→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   157→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   158→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   159→\\t)\\n   160→\\n   161→\\tsessionID := event.SessionID\\n   162→\\tif sessionID == \\\"\\\" {\\n   163→\\t\\tsessionID = unknownSessionID\\n   164→\\t}\\n   165→\\n   166→\\ttranscriptRef := event.SessionRef\\n   167→\\tif transcriptRef == \\\"\\\" {\\n   168→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   169→\\t}\\n   170→\\tif !fileExists(transcriptRef) {\\n   171→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   172→\\t}\\n   173→\\n   174→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   175→\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n   176→\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n   177→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   178→\\t}\\n   179→\\n   180→\\t// Create session metadata directory\\n   181→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   182→\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n   183→\\tif err != nil {\\n   184→\\t\\tsessionDirAbs = sessionDir\\n   185→\\t}\\n   186→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   187→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   188→\\t}\\n   189→\\n   190→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   191→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   192→\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n   193→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n   194→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Copy transcript to session directory\\n   199→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   202→\\t}\\n   203→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   204→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   208→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   209→\\n   210→\\t// Load pre-prompt state (captured on TurnStart)\\n   211→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   212→\\tif err != nil {\\n   213→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   214→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   215→\\t}\\n   216→\\n   217→\\t// Determine transcript offset\\n   218→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   219→\\n   220→\\t// Compute subagents directory for agents that support subagent extraction.\\n   221→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   222→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   223→\\n   224→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   225→\\tvar allPrompts []string\\n   226→\\tvar summary string\\n   227→\\tvar modifiedFiles []string\\n   228→\\n   229→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   230→\\t\\t// Extract prompts\\n   231→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   232→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   233→\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n   234→\\t\\t} else {\\n   235→\\t\\t\\tallPrompts = prompts\\n   236→\\t\\t}\\n   237→\\n   238→\\t\\t// Extract summary\\n   239→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   240→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n   241→\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n   242→\\t\\t} else {\\n   243→\\t\\t\\tsummary = s\\n   244→\\t\\t}\\n   245→\\n   246→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   247→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   248→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n   249→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n   250→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   251→\\t\\t\\t} else {\\n   252→\\t\\t\\t\\tmodifiedFiles = files\\n   253→\\t\\t\\t}\\n   254→\\t\\t} else {\\n   255→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   256→\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   257→\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n   258→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   259→\\t\\t\\t} else {\\n   260→\\t\\t\\t\\tmodifiedFiles = files\\n   261→\\t\\t\\t}\\n   262→\\t\\t}\\n   263→\\t}\\n   264→\\n   265→\\t// Write prompts file\\n   266→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   267→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   268→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   270→\\t}\\n   271→\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n   272→\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n   273→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n   274→\\n   275→\\t// Write summary file\\n   276→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   277→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   278→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   279→\\t}\\n   280→\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n   281→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n   282→\\n   283→\\t// Generate commit message from last prompt\\n   284→\\tlastPrompt := \\\"\\\"\\n   285→\\tif len(allPrompts) > 0 {\\n   286→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   287→\\t}\\n   288→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   289→\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n   290→\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n   291→\\n   292→\\t// Get worktree root for path normalization\\n   293→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   294→\\tif err != nil {\\n   295→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   296→\\t}\\n   297→\\n   298→\\tvar preUntrackedFiles []string\\n   299→\\tif preState != nil {\\n   300→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n   301→\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n   302→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   303→\\t}\\n   304→\\n   305→\\t// Detect file changes via git status\\n   306→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   307→\\tif err != nil {\\n   308→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   309→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   310→\\t}\\n   311→\\n   312→\\t// Filter and normalize all paths\\n   313→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   314→\\tvar relNewFiles, relDeletedFiles []string\\n   315→\\tif changes != nil {\\n   316→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   317→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   318→\\n   319→\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n   320→\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n   321→\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n   322→\\t\\t// Git status catches any tracked file with working-tree changes.\\n   323→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   324→\\t}\\n   325→\\n   326→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   327→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   328→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   329→\\t// if it exists in HEAD with the same content as the working tree.\\n   330→\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n   331→\\n   332→\\t// Check if there are any changes\\n   333→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   334→\\tif totalChanges == 0 {\\n   335→\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n   336→\\t\\ttransitionSessionTurnEnd(ctx, sessionID)\\n   337→\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   338→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   339→\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   340→\\t\\t}\\n   341→\\t\\treturn nil\\n   342→\\t}\\n   343→\\n   344→\\t// Log file changes\\n   345→\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n   346→\\n   347→\\t// Create context file\\n   348→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   349→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   350→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   351→\\t}\\n   352→\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n   353→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n   354→\\n   355→\\t// Get git author\\n   356→\\tauthor, err := GetGitAuthor(ctx)\\n   357→\\tif err != nil {\\n   358→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   359→\\t}\\n   360→\\n   361→\\t// Get strategy and agent type\\n   362→\\tstrat := GetStrategy(ctx)\\n   363→\\tagentType := ag.Type()\\n   364→\\n   365→\\t// Get transcript position/identifier from pre-prompt state\\n   366→\\tvar transcriptIdentifierAtStart string\\n   367→\\tvar transcriptLinesAtStart int\\n   368→\\tif preState != nil {\\n   369→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   370→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   371→\\t}\\n   372→\\n   373→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   374→\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n   375→\\n   376→\\t// Build fully-populated step context and delegate to strategy\\n   377→\\tstepCtx := strategy.StepContext{\\n   378→\\t\\tSessionID:                sessionID,\\n   379→\\t\\tModifiedFiles:            relModifiedFiles,\\n   380→\\t\\tNewFiles:                 relNewFiles,\\n   381→\\t\\tDeletedFiles:             relDeletedFiles,\\n   382→\\t\\tMetadataDir:              sessionDir,\\n   383→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   384→\\t\\tCommitMessage:            commitMessage,\\n   385→\\t\\tTranscriptPath:           transcriptRef,\\n   386→\\t\\tAuthorName:               author.Name,\\n   387→\\t\\tAuthorEmail:              author.Email,\\n   388→\\t\\tAgentType:                agentType,\\n   389→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   390→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   391→\\t\\tTokenUsage:               tokenUsage,\\n   392→\\t}\\n   393→\\n   394→\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\t// Transition session phase and cleanup\\n   399→\\ttransitionSessionTurnEnd(ctx, sessionID)\\n   400→\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n   401→\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n   402→\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n   403→\\t}\\n   404→\\n   405→\\treturn nil\\n   406→}\\n   407→\\n   408→// handleLifecycleCompaction handles context compaction: saves current progress\\n   409→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   410→// Also resets the transcript offset since the transcript may be truncated.\\n   411→func handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   412→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   413→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   414→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   415→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   416→\\t)\\n   417→\\n   418→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   419→\\tsessionID := event.SessionID\\n   420→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   421→\\tif loadErr != nil {\\n   422→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n   423→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   424→\\t}\\n   425→\\tif sessionState != nil {\\n   426→\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   427→\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n   428→\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   429→\\t\\t}\\n   430→\\n   431→\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n   432→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n   433→\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n   434→\\t\\t}\\n   435→\\t}\\n   436→\\n   437→\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n   438→\\treturn nil\\n   439→}\\n   440→\\n   441→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   442→func handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   443→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   444→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   445→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   446→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   447→\\t)\\n   448→\\n   449→\\tif event.SessionID == \\\"\\\" {\\n   450→\\t\\treturn nil // No session to update\\n   451→\\t}\\n   452→\\n   453→\\t// Note: We intentionally don't clean up cached transcripts here.\\n   454→\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n   455→\\t// the transcript to extract file changes. Cleanup is handled by\\n   456→\\t// `entire clean` or when the session state is fully removed.\\n   457→\\n   458→\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n   459→\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n   460→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   461→\\t}\\n   462→\\treturn nil\\n   463→}\\n   464→\\n   465→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   466→func handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   467→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   468→\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n   469→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   470→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   471→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   472→\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n   473→\\t)\\n   474→\\n   475→\\t// Capture pre-task state\\n   476→\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n   477→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   478→\\t}\\n   479→\\n   480→\\treturn nil\\n   481→}\\n   482→\\n   483→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   484→func handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n   485→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n   486→\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n   487→\\t\\t// Extract subagent type and description from tool input\\n   488→\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n   489→\\t}\\n   490→\\n   491→\\t// Determine subagent transcript path\\n   492→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   493→\\tvar subagentTranscriptPath string\\n   494→\\tif event.SubagentID != \\\"\\\" {\\n   495→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   496→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   497→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   498→\\t\\t}\\n   499→\\t}\\n   500→\\n   501→\\t// Log context\\n   502→\\tsubagentEndAttrs := []any{\\n   503→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   504→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   505→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   506→\\t}\\n   507→\\tif event.SubagentID != \\\"\\\" {\\n   508→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"agent_id\\\", event.SubagentID))\\n   509→\\t}\\n   510→\\tif subagentTranscriptPath != \\\"\\\" {\\n   511→\\t\\tsubagentEndAttrs = append(subagentEndAttrs, slog.String(\\\"subagent_transcript\\\", subagentTranscriptPath))\\n   512→\\t}\\n   513→\\tlogging.Info(logCtx, \\\"subagent completed\\\", subagentEndAttrs...)\\n   514→\\n   515→\\t// Extract modified files from subagent transcript\\n   516→\\tvar modifiedFiles []string\\n   517→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   518→\\t\\ttranscriptToScan := event.SessionRef\\n   519→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   520→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   521→\\t\\t}\\n   522→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   523→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files from subagent\\\",\\n   524→\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n   525→\\t\\t} else {\\n   526→\\t\\t\\tmodifiedFiles = files\\n   527→\\t\\t}\\n   528→\\t}\\n   529→\\n   530→\\t// Load pre-task state and detect file changes\\n   531→\\tpreState, err := LoadPreTaskState(ctx, event.ToolUseID)\\n   532→\\tif err != nil {\\n   533→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-task state\\\",\\n   534→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   535→\\t}\\n   536→\\tvar preUntrackedFiles []string\\n   537→\\tif preState != nil {\\n   538→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   539→\\t}\\n   540→\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n   541→\\tif err != nil {\\n   542→\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n   543→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   544→\\t}\\n   545→\\n   546→\\t// Get worktree root and normalize paths\\n   547→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   548→\\tif err != nil {\\n   549→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   550→\\t}\\n   551→\\n   552→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   553→\\tvar relNewFiles, relDeletedFiles []string\\n   554→\\tif changes != nil {\\n   555→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   556→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   557→\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n   558→\\t}\\n   559→\\n   560→\\t// If no changes, skip\\n   561→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   562→\\t\\tlogging.Info(logCtx, \\\"no file changes detected, skipping task checkpoint\\\")\\n   563→\\t\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   564→\\t\\treturn nil\\n   565→\\t}\\n   566→\\n   567→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   568→\\tvar checkpointUUID string\\n   569→\\t// Use the existing CLI-level checkpoint UUID finder\\n   570→\\tmainLines, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   571→\\tif mainLines != nil {\\n   572→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   573→\\t}\\n   574→\\n   575→\\t// Get git author\\n   576→\\tauthor, err := GetGitAuthor(ctx)\\n   577→\\tif err != nil {\\n   578→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   579→\\t}\\n   580→\\n   581→\\t// Build task checkpoint context\\n   582→\\tstrat := GetStrategy(ctx)\\n   583→\\tagentType := ag.Type()\\n   584→\\n   585→\\ttaskStepCtx := strategy.TaskStepContext{\\n   586→\\t\\tSessionID:              event.SessionID,\\n   587→\\t\\tToolUseID:              event.ToolUseID,\\n   588→\\t\\tAgentID:                event.SubagentID,\\n   589→\\t\\tModifiedFiles:          relModifiedFiles,\\n   590→\\t\\tNewFiles:               relNewFiles,\\n   591→\\t\\tDeletedFiles:           relDeletedFiles,\\n   592→\\t\\tTranscriptPath:         event.SessionRef,\\n   593→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   594→\\t\\tCheckpointUUID:         checkpointUUID,\\n   595→\\t\\tAuthorName:             author.Name,\\n   596→\\t\\tAuthorEmail:            author.Email,\\n   597→\\t\\tSubagentType:           event.SubagentType,\\n   598→\\t\\tTaskDescription:        event.TaskDescription,\\n   599→\\t\\tAgentType:              agentType,\\n   600→\\t}\\n   601→\\n   602→\\tif err := strat.SaveTaskStep(ctx, taskStepCtx); err != nil {\\n   603→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   604→\\t}\\n   605→\\n   606→\\t_ = CleanupPreTaskState(ctx, event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   607→\\treturn nil\\n   608→}\\n   609→\\n   610→// --- Helper functions ---\\n   611→\\n   612→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   613→// Prefers pre-prompt state, falls back to session state.\\n   614→func resolveTranscriptOffset(ctx context.Context, preState *PrePromptState, sessionID string) int {\\n   615→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   616→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   617→\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state found, parsing transcript from offset\\\",\\n   618→\\t\\t\\tslog.Int(\\\"offset\\\", preState.TranscriptOffset))\\n   619→\\t\\treturn preState.TranscriptOffset\\n   620→\\t}\\n   621→\\n   622→\\t// Fall back to session state\\n   623→\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   624→\\tif loadErr != nil {\\n   625→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state\\\",\\n   626→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   627→\\t\\treturn 0\\n   628→\\t}\\n   629→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   630→\\t\\tlogging.Debug(logCtx, \\\"session state found, parsing transcript from offset\\\",\\n   631→\\t\\t\\tslog.Int(\\\"offset\\\", sessionState.CheckpointTranscriptStart))\\n   632→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   633→\\t}\\n   634→\\n   635→\\treturn 0\\n   636→}\\n   637→\\n   638→// createContextFile creates a context.md file for the session checkpoint.\\n   639→// This is a unified version that works for all agents.\\n   640→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   641→\\tvar sb strings.Builder\\n   642→\\n   643→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   644→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   645→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   646→\\n   647→\\tif len(prompts) > 0 {\\n   648→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   649→\\t\\tfor i, p := range prompts {\\n   650→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   651→\\t\\t}\\n   652→\\t}\\n   653→\\n   654→\\tif summary != \\\"\\\" {\\n   655→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   656→\\t\\tsb.WriteString(summary)\\n   657→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   658→\\t}\\n   659→\\n   660→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   661→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   662→\\t}\\n   663→\\treturn nil\\n   664→}\\n   665→\\n   666→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   667→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   668→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, error) {\\n   669→\\tlines, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   670→\\tif err != nil {\\n   671→\\t\\treturn nil, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   672→\\t}\\n   673→\\treturn lines, nil\\n   674→}\\n   675→\\n   676→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   677→func transitionSessionTurnEnd(ctx context.Context, sessionID string) {\\n   678→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   679→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   680→\\tif loadErr != nil {\\n   681→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   682→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   683→\\t\\treturn\\n   684→\\t}\\n   685→\\tif turnState == nil {\\n   686→\\t\\treturn\\n   687→\\t}\\n   688→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   689→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   690→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   691→\\t}\\n   692→\\n   693→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   694→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   695→\\tstrat := GetStrategy(ctx)\\n   696→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   697→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   698→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   699→\\t}\\n   700→\\n   701→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   702→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   703→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   704→\\t}\\n   705→}\\n   706→\\n   707→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   708→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   709→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   710→\\tif err != nil {\\n   711→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   712→\\t}\\n   713→\\tif state == nil {\\n   714→\\t\\treturn nil // No state file, nothing to update\\n   715→\\t}\\n   716→\\n   717→\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   718→\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"lifecycle\\\"), \\\"session stop transition failed\\\",\\n   719→\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n   720→\\t}\\n   721→\\n   722→\\tnow := time.Now()\\n   723→\\tstate.EndedAt = &now\\n   724→\\n   725→\\tif err := strategy.SaveSessionState(ctx, state); err != nil {\\n   726→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   727→\\t}\\n   728→\\treturn nil\\n   729→}\\n   730→\\n   731→// logFileChanges logs the files modified, created, and deleted during a session.\\n   732→func logFileChanges(ctx context.Context, modified, newFiles, deleted []string) {\\n   733→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   734→\\tlogging.Debug(logCtx, \\\"files changed during session\\\",\\n   735→\\t\\tslog.Int(\\\"modified\\\", len(modified)),\\n   736→\\t\\tslog.Int(\\\"new\\\", len(newFiles)),\\n   737→\\t\\tslog.Int(\\\"deleted\\\", len(deleted)))\\n   738→}\\n   739→\"}]},\"uuid\":\"fb105825-d729-4b6a-b4b3-5855b7a79142\",\"timestamp\":\"2026-02-27T21:38:30.661Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ctx, ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ctx, ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ctx, ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ctx, ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ctx, ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ctx, ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ctx, ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy(ctx)\\n\\tif count, err := strat.CountOtherActiveSessionsWithCheckpoints(ctx, event.SessionID); err == nil && count > 0 {\\n\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t}\\n\\n\\t// Output informational message\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif err := outputHookResponse(message); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(ctx, event.SessionID); loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state on start\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t} else if state != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"session start transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, state); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to update session state on start\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ctx, ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to ensure strategy setup\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\tstrat := GetStrategy(ctx)\\n\\tif err := strat.InitializeSession(ctx, sessionID, ag.Type(), event.SessionRef, event.Prompt); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to initialize session state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tlogging.Info(logCtx, \\\"skipping checkpoint - will activate after first commit\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(ctx, sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(ctx, transcriptRef); err != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to prepare transcript\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", promptErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract summary\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", sumErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptData, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files (with subagents)\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract modified files\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fileErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted prompts\\\",\\n\\t\\tslog.Int(\\\"count\\\", len(allPrompts)),\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.PromptFileName))\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"extracted summary\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName))\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt)\\n\\tlogging.Debug(logCtx, \\\"using commit message\\\",\\n\\t\\tslog.Int(\\\"message_length\\\", len(commitMessage)))\\n\\n\\t// Get worktree root for path normalization\\n\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"pre-prompt state\\\",\\n\\t\\t\\tslog.Int(\\\"pre_existing_untracked_files\\\", len(preState.UntrackedFiles)))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(ctx, preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to compute file changes\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\n\\t\\t// Merge git-status modified files as a fallback for transcript parsing.\\n\\t\\t// Transcript parsing is the primary source for modified files, but it can miss\\n\\t\\t// files if the agent uses an unrecognized tool or the transcript format changes.\\n\\t\\t// Git status catches any tracked file with working-tree changes.\\n\\t\\trelModifiedFiles = mergeUnique(relModifiedFiles, FilterAndNormalizePaths(changes.Modified, repoRoot))\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(ctx, relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tlogging.Info(logCtx, \\\"no files modified during session, skipping checkpoint\\\")\\n\\t\\ttransitionSessionTurnEnd(ctx, sessionID)\\n\\t\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(ctx, relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tlogging.Debug(logCtx, \\\"created context file\\\",\\n\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.ContextFileName))\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy(ctx)\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\ttokenUsage := agent.CalculateTokenUsage(ctx, ag, transcriptData, transcriptLinesAtStart, subagentsDir)\\n\\n\\t// Build fully-populated step context and delegate to strategy\\n\\tstepCtx := strategy.StepContext{\\n\\t\\tSessionID:                sessionID,\\n\\t\\tModifiedFiles:            relModifiedFiles,\\n\\t\\tNewFiles:                 relNewFiles,\\n\\t\\tDeletedFiles:             relDeletedFiles,\\n\\t\\tMetadataDir:              sessionDir,\\n\\t\\tMetadataDirAbs:           sessionDirAbs,\\n\\t\\tCommitMessage:            commitMessage,\\n\\t\\tTranscriptPath:           transcriptRef,\\n\\t\\tAuthorName:               author.Name,\\n\\t\\tAuthorEmail:              author.Email,\\n\\t\\tAgentType:                agentType,\\n\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n\\t\\tTokenUsage:               tokenUsage,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx, stepCtx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n\\t}\\n\\n\\t// Transition session phase and cleanup\\n\\ttransitionSessionTurnEnd(ctx, sessionID)\\n\\tif cleanupErr := CleanupPrePromptState(ctx, sessionID); cleanupErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to cleanup pre-prompt state\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", cleanupErr.Error()))\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleCompaction handles context compaction: saves current progress\\n// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n// Also resets the transcript offset since the transcript may be truncated.\\nfunc handleLifecycleCompaction(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"compaction\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n\\tsessionID := event.SessionID\\n\\tsessionState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n\\tif loadErr != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for compaction\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n\\t}\\n\\tif sessionState != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(ctx, sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"compaction transition failed\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", transErr.Error()))\\n\\t\\t}\\n\\n\\t\\tif saveErr := strategy.SaveSessionState(ctx, sessionState); saveErr != nil {\\n\\t\\t\\tlogging.Warn(logCtx, \\\"failed to save session state after compaction\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()))\\n\\t\\t}\\n\\t}\\n\\n\\tlogging.Info(logCtx, \\\"context compaction detected\\\")\\n\\treturn nil\\n}\\n\\n// handleLifecycleSessionEnd handles session end: marks the session as ended.\\nfunc handleLifecycleSessionEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn nil // No session to update\\n\\t}\\n\\n\\t// Note: We intentionally don't clean up cached transcripts here.\\n\\t// Post-session commits (carry-forward in ENDED phase) may still need\\n\\t// the transcript to extract file changes. Cleanup is handled by\\n\\t// `entire clean` or when the session state is fully removed.\\n\\n\\tif err := markSessionEnded(ctx, event.SessionID); err != nil {\\n\\t\\tlogging.Warn(logCtx, \\\"failed to mark session ended\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t}\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\nfunc handleLifecycleSubagentStart(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"subagent started\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t\\tslog.String(\\\"transcript\\\", event.SessionRef),\\n\\t)\\n\\n\\t// Capture pre-task state\\n\\tif err := CapturePreTaskState(ctx, event.ToolUseID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\nfunc handleLifecycleSubagentEnd(ctx context.Context, ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"lifecycle\\\"), ag.Name())\\n\\tif event.SubagentType == \\\"\\\" && event.TaskDescription == \\\"\\\" {\\n\\t\\t// Extract subagent type and description from tool input\\n\\t\\tevent.SubagentType, event.TaskDescription = ParseSubagentTypeAndDescription(event.ToolInput)\\n\\t}\\n\\n\\t// Determine subagent transcript path\\n\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n\\tvar subagentTranscriptPath string\\n\\tif event.SubagentID != \\\"\\\" {\\n\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n\\t\\tif !fileExists(subagentTranscriptPath) {\\n\\t\\t\\tsubagentTranscript