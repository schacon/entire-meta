s turn-end actions.\\n   681→func transitionSessionTurnEnd(ctx context.Context, sessionID string) {\\n   682→\\tlogCtx := logging.WithComponent(ctx, \\\"lifecycle\\\")\\n   683→\\tturnState, loadErr := strategy.LoadSessionState(ctx, sessionID)\\n   684→\\tif loadErr != nil {\\n   685→\\t\\tlogging.Warn(logCtx, \\\"failed to load session state for turn end\\\",\\n   686→\\t\\t\\tslog.String(\\\"error\\\", loadErr.Error()))\\n   687→\\t\\treturn\\n   688→\\t}\\n   689→\\tif turnState == nil {\\n   690→\\t\\treturn\\n   691→\\t}\\n   692→\\tif err := strategy.TransitionAndLog(ctx, turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   693→\\t\\tlogging.Warn(logCtx, \\\"turn-end transition failed\\\",\\n   694→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   695→\\t}\\n   696→\\n   697→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   698→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   699→\\tstrat := GetStrategy(ctx)\\n   700→\\tif err := strat.HandleTurnEnd(ctx, turnState); err != nil {\\n   701→\\t\\tlogging.Warn(logCtx, \\\"turn-end action dispatch failed\\\",\\n   702→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   703→\\t}\\n   704→\\n   705→\\tif updateErr := strategy.SaveSessionState(ctx, turnState); updateErr != nil {\\n   706→\\t\\tlogging.Warn(logCtx, \\\"failed to update session phase on turn end\\\",\\n   707→\\t\\t\\tslog.String(\\\"error\\\", updateErr.Error()))\\n   708→\\t}\\n   709→}\\n   710→\\n   711→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   712→func markSessionEnded(ctx context.Context, sessionID string) error {\\n   713→\\tstate, err := strategy.LoadSessionState(ctx, sessionID)\\n   714→\\tif err != nil {\\n   715→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   716→\\t}\\n   717→\\tif state == nil {\\n   718→\\t\\treturn nil // No state file, nothi