edFilesFromOffset(path string, startOffset int) ([]string, int, error) {\\n    89→\\tlines, currentPos, err := ParseDroidTranscript(path, startOffset)\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    92→\\t}\\n    93→\\tfiles := ExtractModifiedFiles(lines)\\n    94→\\treturn files, currentPos, nil\\n    95→}\\n    96→\\n    97→// ExtractPrompts extracts user prompts from the transcript starting at the given line offset.\\n    98→func (f *FactoryAIDroidAgent) ExtractPrompts(sessionRef string, fromOffset int) ([]string, error) {\\n    99→\\tlines, _, err := ParseDroidTranscript(sessionRef, fromOffset)\\n   100→\\tif err != nil {\\n   101→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   102→\\t}\\n   103→\\n   104→\\tvar prompts []string\\n   105→\\tfor i := range lines {\\n   106→\\t\\tif lines[i].Type != transcript.TypeUser {\\n   107→\\t\\t\\tcontinue\\n   108→\\t\\t}\\n   109→\\t\\tcontent := transcript.ExtractUserContent(lines[i].Message)\\n   110→\\t\\tif content != \\\"\\\" {\\n   111→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(content))\\n   112→\\t\\t}\\n   113→\\t}\\n   114→\\treturn prompts, nil\\n   115→}\\n   116→\\n   117→// ExtractSummary extracts the last assistant message as a session summary.\\n   118→func (f *FactoryAIDroidAgent) ExtractSummary(sessionRef string) (string, error) {\\n   119→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n   120→\\tif err != nil {\\n   121→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   122→\\t}\\n   123→\\tlines, _, err := ParseDroidTranscriptFromBytes(data, 0)\\n   124→\\tif err != nil {\\n   125→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   126→\\t}\\n   127→\\n   128→\\tfor i := len(lines) - 1; i >= 0; i-- {\\n   129→\\t\\tif lines[i].Type != transcript.TypeAssistant {\\n   130→\\