→\\t// This is needed because the CLI may be run from a subdirectory\\n    58→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    59→\\tif err != nil {\\n    60→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    61→\\t\\trepoRoot = \\\".\\\"\\n    62→\\t}\\n    63→\\n    64→\\t// Check for .claude directory\\n    65→\\tclaudeDir := filepath.Join(repoRoot, \\\".claude\\\")\\n    66→\\tif _, err := os.Stat(claudeDir); err == nil {\\n    67→\\t\\treturn true, nil\\n    68→\\t}\\n    69→\\t// Check for .claude/settings.json\\n    70→\\tsettingsFile := filepath.Join(repoRoot, \\\".claude\\\", \\\"settings.json\\\")\\n    71→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    72→\\t\\treturn true, nil\\n    73→\\t}\\n    74→\\treturn false, nil\\n    75→}\\n    76→\\n    77→// GetSessionID extracts the session ID from hook input.\\n    78→func (c *ClaudeCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    79→\\treturn input.SessionID\\n    80→}\\n    81→\\n    82→// ResolveSessionFile returns the path to a Claude session file.\\n    83→// Claude names files directly as <id>.jsonl.\\n    84→func (c *ClaudeCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    85→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    86→}\\n    87→\\n    88→// ProtectedDirs returns directories that Claude uses for config/state.\\n    89→func (c *ClaudeCodeAgent) ProtectedDirs() []string { return []string{\\\".claude\\\"} }\\n    90→\\n    91→// GetSessionDir returns the directory where Claude stores session transcripts.\\n    92→func (c *ClaudeCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    93→\\t// Check for test environment override\\n    94→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    95→\\t\\treturn override, nil\\n    96→\\t}\\n    97→\\n    98→\\thomeDir, err := os.UserHomeDir()\\n    99→\\tif err != nil {\\n   100→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   101→\\t}\\n   102→\\n   103→\\tprojectDir := SanitizePathForClaude(repoPath)\\n   104→\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   105→}\\n   106→\\n   107→// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   108→// The session data is stored in NativeData as raw JSONL bytes.\\n   109→// ModifiedFiles is computed by parsing the transcript.\\n   110→func (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\t// Read the raw JSONL file\\n   116→\\tdata, err := os.ReadFile(input.SessionRef)\\n   117→\\tif err != nil {\\n   118→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\t// Parse to extract computed fields\\n   122→\\tlines, err := transcript.ParseFromBytes(data)\\n   123→\\tif err != nil {\\n   124→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\treturn &agent.AgentSession{\\n   128→\\t\\tSessionID:     input.SessionID,\\n   129→\\t\\tAgentName:     c.Name(),\\n   130→\\t\\tSessionRef:    input.SessionRef,\\n   131→\\t\\tStartTime:     time.Now(),\\n   132→\\t\\tNativeData:    data,\\n   133→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   134→\\t}, nil\\n   135→}\\n   136→\\n   137→// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   138→// Uses the NativeData field which contains raw JSONL bytes.\\n   139→// The session must have been created by Claude Code (AgentName check).\\n   140→func (c *ClaudeCodeAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   141→\\tif session == nil {\\n   142→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   143→\\t}\\n   144→\\n   145→\\t// Verify this session belongs to Claude Code\\n   146→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   147→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   148→\\t}\\n   149→\\n   150→\\tif session.SessionRef == \\\"\\\" {\\n   151→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   152→\\t}\\n   153→\\n   154→\\tif len(session.NativeData) == 0 {\\n   155→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   156→\\t}\\n   157→\\n   158→\\t// Write the raw JSONL data\\n   159→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   160→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\treturn nil\\n   164→}\\n   165→\\n   166→// FormatResumeCommand returns the command to resume a Claude Code session.\\n   167→func (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   168→\\treturn \\\"claude -r \\\" + sessionID\\n   169→}\\n   170→\\n   171→// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   172→\\n   173→// GetLastUserPrompt extracts the last user prompt from the session.\\n   174→// Requires NativeData to be populated (call ReadSession first).\\n   175→func (c *ClaudeCodeAgent) GetLastUserPrompt(session *agent.AgentSession) string {\\n   176→\\tif session == nil || len(session.NativeData) == 0 {\\n   177→\\t\\treturn \\\"\\\"\\n   178→\\t}\\n   179→\\n   180→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   181→\\tif err != nil {\\n   182→\\t\\treturn \\\"\\\"\\n   183→\\t}\\n   184→\\n   185→\\treturn ExtractLastUserPrompt(lines)\\n   186→}\\n   187→\\n   188→// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   189→// This is used for rewind operations to restore transcript state.\\n   190→// Requires NativeData 