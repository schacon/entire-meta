re hooks (both old and new formats)\\n    39→var entireHookPrefixes = []string{\\n    40→\\t\\\"entire \\\",\\n    41→\\t\\\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    42→}\\n    43→\\n    44→// InstallHooks installs Claude Code hooks in .claude/settings.json.\\n    45→// If force is true, removes existing Entire hooks before installing.\\n    46→// Returns the number of hooks installed.\\n    47→func (c *ClaudeCodeAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    48→\\t// Use repo root instead of CWD to find .claude directory\\n    49→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    50→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    51→\\tif err != nil {\\n    52→\\t\\t// Fallback to CWD if not in a git repo (e.g., during tests)\\n    53→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when WorktreeRoot() fails (tests run outside git repos)\\n    54→\\t\\tif err != nil {\\n    55→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    56→\\t\\t}\\n    57→\\t}\\n    58→\\n    59→\\tsettingsPath := filepath.Join(repoRoot, \\\".claude\\\", ClaudeSettingsFileName)\\n    60→\\n    61→\\t// Read existing settings if they exist\\n    62→\\tvar rawSettings map[string]json.RawMessage\\n    63→\\n    64→\\t// rawHooks preserves unknown hook types (e.g., \\\"Notification\\\", \\\"SubagentStop\\\")\\n    65→\\tvar rawHooks map[string]json.RawMessage\\n    66→\\n    67→\\t// rawPermissions preserves unknown permission fields (e.g., \\\"ask\\\")\\n    68→\\tvar rawPermissions map[string]json.RawMessage\\n    69→\\n    70→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + settings file name\\n    71→\\tif readErr == nil {\\n    72→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    73→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settin