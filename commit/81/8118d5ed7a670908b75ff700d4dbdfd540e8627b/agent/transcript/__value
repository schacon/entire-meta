3→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    19→\\n    20→\\t\\\"github.com/spf13/cobra\\\"\\n    21→)\\n    22→\\n    23→// agentHookLogCleanup stores the cleanup function for agent hook logging.\\n    24→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    25→var agentHookLogCleanup func()\\n    26→\\n    27→// currentHookAgentName stores the agent name for the currently executing hook.\\n    28→// Set by newAgentHookVerbCmdWithLogging before calling the handler.\\n    29→// This allows handlers to know which agent invoked the hook without guessing.\\n    30→var currentHookAgentName types.AgentName\\n    31→\\n    32→// GetCurrentHookAgent returns the agent for the currently executing hook.\\n    33→// Returns the agent based on the hook command structure (e.g., \\\"entire hooks claude-code ...\\\")\\n    34→// rather than guessing from directory presence.\\n    35→// Falls back to GetAgent() if not in a hook context.\\n    36→func GetCurrentHookAgent() (agent.Agent, error) {\\n    37→\\tif currentHookAgentName == \\\"\\\" {\\n    38→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    39→\\t}\\n    40→\\n    41→\\tag, err := agent.Get(currentHookAgentName)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    44→\\t}\\n    45→\\treturn ag, nil\\n    46→}\\n    47→\\n    48→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookSupport.\\n    49→// It dynamically creates subcommands for each hook the agent supports.\\n    50→func newAgentHooksCmd(a