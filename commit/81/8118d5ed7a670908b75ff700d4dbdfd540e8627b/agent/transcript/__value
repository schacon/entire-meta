rn append(matchers, ClaudeHookMatcher{\\n   439→\\t\\t\\tMatcher: \\\"\\\",\\n   440→\\t\\t\\tHooks:   []ClaudeHookEntry{entry},\\n   441→\\t\\t})\\n   442→\\t}\\n   443→\\n   444→\\t// Find or create matcher with the given name\\n   445→\\tfor i, matcher := range matchers {\\n   446→\\t\\tif matcher.Matcher == matcherName {\\n   447→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   448→\\t\\t\\treturn matchers\\n   449→\\t\\t}\\n   450→\\t}\\n   451→\\n   452→\\treturn append(matchers, ClaudeHookMatcher{\\n   453→\\t\\tMatcher: matcherName,\\n   454→\\t\\tHooks:   []ClaudeHookEntry{entry},\\n   455→\\t})\\n   456→}\\n   457→\\n   458→// isEntireHook checks if a command is an Entire hook (old or new format)\\n   459→func isEntireHook(command string) bool {\\n   460→\\tfor _, prefix := range entireHookPrefixes {\\n   461→\\t\\tif strings.HasPrefix(command, prefix) {\\n   462→\\t\\t\\treturn true\\n   463→\\t\\t}\\n   464→\\t}\\n   465→\\treturn false\\n   466→}\\n   467→\\n   468→// removeEntireHooks removes all Entire hooks from a list of matchers (for simple hooks like Stop)\\n   469→func removeEntireHooks(matchers []ClaudeHookMatcher) []ClaudeHookMatcher {\\n   470→\\tresult := make([]ClaudeHookMatcher, 0, len(matchers))\\n   471→\\tfor _, matcher := range matchers {\\n   472→\\t\\tfilteredHooks := make([]ClaudeHookEntry, 0, len(matcher.Hooks))\\n   473→\\t\\tfor _, hook := range matcher.Hooks {\\n   474→\\t\\t\\tif !isEntireHook(hook.Command) {\\n   475→\\t\\t\\t\\tfilteredHooks = append(filteredHooks, hook)\\n   476→\\t\\t\\t}\\n   477→\\t\\t}\\n   478→\\t\\t// Only keep the matcher if it has hooks remaining\\n   479→\\t\\tif len(filteredHooks) > 0 {\\n   480→\\t\\t\\tmatcher.Hooks = filteredHooks\\n   481→\\t\\t\\tresult = append(result, matcher)\\n   482→\\t\\t}\\n   483→\\t}\\n   484→\\treturn result\\n   485→}\\n   486→\\n   487→// removeEntireHooksFromMatchers removes Entire hooks from tool-use matchers (PreToolUse, PostToolUse)\\n   488→//