rn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n    24→}\\n    25→\\n    26→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    27→func init() {\\n    28→\\tagent.Register(agent.AgentNameFactoryAIDroid, NewFactoryAIDroidAgent)\\n    29→}\\n    30→\\n    31→// FactoryAIDroidAgent implements the agent.Agent interface for Factory AI Droid.\\n    32→//\\n    33→//nolint:revive // FactoryAIDroidAgent is clearer than Agent in this context\\n    34→type FactoryAIDroidAgent struct{}\\n    35→\\n    36→// NewFactoryAIDroidAgent creates a new Factory AI Droid agent instance.\\n    37→func NewFactoryAIDroidAgent() agent.Agent {\\n    38→\\treturn &FactoryAIDroidAgent{}\\n    39→}\\n    40→\\n    41→// Name returns the agent registry key.\\n    42→func (f *FactoryAIDroidAgent) Name() types.AgentName { return agent.AgentNameFactoryAIDroid }\\n    43→\\n    44→// Type returns the agent type identifier.\\n    45→func (f *FactoryAIDroidAgent) Type() types.AgentType { return agent.AgentTypeFactoryAIDroid }\\n    46→\\n    47→// Description returns a human-readable description.\\n    48→func (f *FactoryAIDroidAgent) Description() string {\\n    49→\\treturn \\\"Factory AI Droid - agent-native development platform\\\"\\n    50→}\\n    51→\\n    52→// IsPreview returns true as Factory AI Droid integration is in preview.\\n    53→func (f *FactoryAIDroidAgent) IsPreview() bool { return true }\\n    54→\\n    55→// ProtectedDirs returns directories that Factory AI Droid uses for config/state.\\n    56→func (f *FactoryAIDroidAgent) ProtectedDirs() []string { return []string{\\\".factory\\\"} }\\n    57→\\n    58→// DetectPresence checks if Factory AI Droid is configured in the repository.\\n    59→func (f *FactoryAIDroidAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    60→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    61→\\tif err != nil {\\n    62→\\t\\trepoRoot = \\\".\\\"\\n    63→\\t}\\n    64→\\tif _, err := os.Stat(filepath.Join(repoRoot, \\\".factory\\\")); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\treturn false, nil\\n    68→}\\n    69→\\n    70→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    71→func (f *FactoryAIDroidAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    72→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    73→\\tif err != nil {\\n    74→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    75→\\t}\\n    76→\\treturn data, nil\\n    77→}\\n    78→\\n    79→// ChunkTranscript splits a JSONL transcript at line boundaries.\\n    80→func (f *FactoryAIDroidAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    81→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    82→\\tif err != nil {\\n    83→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    84→\\t}\\n    85→\\treturn chunks, nil\\n    86→}\\n    87→\\n    88→// ReassembleTranscript concatenates JSONL chunks with newlines.\\n    89→func (f *FactoryAIDroidAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    90→\\treturn agent.ReassembleJSONL(chunks), nil\\n    91→}\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (f *FactoryAIDroidAgent) GetSessionID(input *agent.HookInput) string { return input.SessionID }\\n    95→\\n    96→// GetSessionDir returns the directory where Factory AI Droid stores session transcripts.\\n    97→// Path: ~/.factory/sessions/<sanitized-repo-path>/\\n    98→func (f *FactoryAIDroidAgent) GetSessionDir(repoPath string) (string, error) {\\n    99→\\tif override := os.Getenv(\\\"ENTIRE_TEST_DROID_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   100→\\t\\treturn override, nil\\n   101→\\t}\\n   102→\\thomeDir, err := os.UserHomeDir()\\n   103→\\tif err != nil {\\n   104→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory