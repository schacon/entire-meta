oks claude-code stop\\\"\\n   230→\\n   231→// waitForTranscriptFlush polls the transcript file for the stop hook sentinel.\\n   232→// Falls back silently after a timeout.\\n   233→func waitForTranscriptFlush(ctx context.Context, transcriptPath string, hookStartTime time.Time) {\\n   234→\\tconst (\\n   235→\\t\\tmaxWait      = 3 * time.Second\\n   236→\\t\\tpollInterval = 50 * time.Millisecond\\n   237→\\t\\ttailBytes    = 4096\\n   238→\\t\\tmaxSkew      = 2 * time.Second\\n   239→\\t)\\n   240→\\n   241→\\tlogCtx := logging.WithComponent(ctx, \\\"agent.claudecode\\\")\\n   242→\\tdeadline := time.Now().Add(maxWait)\\n   243→\\tfor time.Now().Before(deadline) {\\n   244→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   245→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   246→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   247→\\t\\t\\t)\\n   248→\\t\\t\\treturn\\n   249→\\t\\t}\\n   250→\\t\\ttime.Sleep(pollInterval)\\n   251→\\t}\\n   252→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   253→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   254→\\t)\\n   255→}\\n   256→\\n   257→// checkStopSentinel reads the tail of the transcript file and looks for the sentinel.\\n   258→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   259→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   260→\\tif err != nil {\\n   261→\\t\\treturn false\\n   262→\\t}\\n   263→\\tdefer f.Close()\\n   264→\\n   265→\\tinfo, err := f.Stat()\\n   266→\\tif err != nil {\\n   267→\\t\\treturn false\\n   268→\\t}\\n   269→\\toffset := info.Size() - tailBytes\\n   270→\\tif offset < 0 {\\n   271→\\t\\toffset = 0\\n   272→\\t}\\n   273→\\tbuf := make([]byte, info.Size()-offset)\\n   274→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   275→\\t\\treturn false\\