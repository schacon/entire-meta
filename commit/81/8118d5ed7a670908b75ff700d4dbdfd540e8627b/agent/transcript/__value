allHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    46→\\t// Use repo root instead of CWD to find .gemini directory\\n    47→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    48→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    49→\\tif err != nil {\\n    50→\\t\\t// Fallback to CWD if not in a git repo (e.g., during tests)\\n    51→\\t\\trepoRoot, err = os.Getwd() //nolint:forbidigo // Intentional fallback when WorktreeRoot() fails (tests run outside git repos)\\n    52→\\t\\tif err != nil {\\n    53→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to get current directory: %w\\\", err)\\n    54→\\t\\t}\\n    55→\\t}\\n    56→\\n    57→\\tsettingsPath := filepath.Join(repoRoot, \\\".gemini\\\", GeminiSettingsFileName)\\n    58→\\n    59→\\t// Read existing settings if they exist\\n    60→\\tvar rawSettings map[string]json.RawMessage\\n    61→\\n    62→\\t// rawHooks preserves unknown hook types\\n    63→\\tvar rawHooks map[string]json.RawMessage\\n    64→\\n    65→\\tvar hooksConfig GeminiHooksConfig\\n    66→\\n    67→\\texistingData, readErr := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from cwd + fixed path\\n    68→\\tif readErr == nil {\\n    69→\\t\\tif err := json.Unmarshal(existingData, &rawSettings); err != nil {\\n    70→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing settings.json: %w\\\", err)\\n    71→\\t\\t}\\n    72→\\t\\tif hooksRaw, ok := rawSettings[\\\"hooks\\\"]; ok {\\n    73→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    74→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in settings.json: %w\\\", err)\\n    75→\\t\\t\\t}\\n    76→\\t\\t}\\n    77→\\t\\tif hooksConfigRaw, ok := rawSettings[\\\"hooksConfig\\\"]; ok {\\n    78→\\t\\t\\tif err := json.Unmarshal(hooksConfigRaw, &hooksConfig); err != nil {\\n    79→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooksConfig in settings.json: %w\\\", err)\\n    80→\\t\\t\\t}