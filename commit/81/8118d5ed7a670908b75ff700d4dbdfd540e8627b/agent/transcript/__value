kSupport\\n    18→var _ agent.HookSupport = (*FactoryAIDroidAgent)(nil)\\n    19→\\n    20→// Factory AI Droid hook names - these become subcommands under `entire hooks factoryai-droid`\\n    21→const (\\n    22→\\tHookNameSessionStart     = \\\"session-start\\\"\\n    23→\\tHookNameSessionEnd       = \\\"session-end\\\"\\n    24→\\tHookNameStop             = \\\"stop\\\"\\n    25→\\tHookNameUserPromptSubmit = \\\"user-prompt-submit\\\"\\n    26→\\tHookNamePreToolUse       = \\\"pre-tool-use\\\"\\n    27→\\tHookNamePostToolUse      = \\\"post-tool-use\\\"\\n    28→\\tHookNameSubagentStop     = \\\"subagent-stop\\\"\\n    29→\\tHookNamePreCompact       = \\\"pre-compact\\\"\\n    30→\\tHookNameNotification     = \\\"notification\\\"\\n    31→)\\n    32→\\n    33→// FactorySettingsFileName is the settings file used by Factory AI Droid.\\n    34→// This is Factory-specific and not shared with other agents.\\n    35→const FactorySettingsFileName = \\\"settings.json\\\"\\n    36→\\n    37→// metadataDenyRule blocks Factory Droid from reading Entire session metadata\\n    38→const metadataDenyRule = \\\"Read(./.entire/metadata/**)\\\"\\n    39→\\n    40→// entireHookPrefixes are command prefixes that identify Entire hooks (both old and new formats)\\n    41→var entireHookPrefixes = []string{\\n    42→\\t\\\"entire \\\",\\n    43→\\t\\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    44→}\\n    45→\\n    46→// InstallHooks installs Factory AI Droid hooks in .factory/settings.json.\\n    47→// If force is true, removes existing Entire hooks before installing.\\n    48→// Returns the number of hooks installed.\\n    49→func (f *FactoryAIDroidAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    50→\\t// Use repo root instead of CWD to find .factory directory\\n    51→\\t// This ensures hooks are installed correctly when run from a subdirectory\\n    52→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    53→\\tif err != nil {\\n  