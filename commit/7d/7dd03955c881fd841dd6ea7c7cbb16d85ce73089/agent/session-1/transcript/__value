gentNameKiro, NewKiroAgent)\\n    25→}\\n    26→\\n    27→// KiroAgent implements the Agent interface for Amazon's Kiro CLI.\\n    28→//\\n    29→//nolint:revive // KiroAgent is clearer than Agent in this context\\n    30→type KiroAgent struct{}\\n    31→\\n    32→// NewKiroAgent creates a new Kiro agent instance.\\n    33→func NewKiroAgent() agent.Agent {\\n    34→\\treturn &KiroAgent{}\\n    35→}\\n    36→\\n    37→// --- Identity ---\\n    38→\\n    39→func (k *KiroAgent) Name() types.AgentName   { return agent.AgentNameKiro }\\n    40→func (k *KiroAgent) Type() types.AgentType   { return agent.AgentTypeKiro }\\n    41→func (k *KiroAgent) Description() string     { return \\\"Kiro - Amazon AI coding CLI\\\" }\\n    42→func (k *KiroAgent) IsPreview() bool         { return true }\\n    43→func (k *KiroAgent) ProtectedDirs() []string { return []string{\\\".kiro\\\"} }\\n    44→\\n    45→// DetectPresence checks if Kiro is configured in the repository.\\n    46→func (k *KiroAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    47→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    48→\\tif err != nil {\\n    49→\\t\\tworktreeRoot = \\\".\\\"\\n    50→\\t}\\n    51→\\tif _, err := os.Stat(filepath.Join(worktreeRoot, \\\".kiro\\\")); err == nil {\\n    52→\\t\\treturn true, nil\\n    53→\\t}\\n    54→\\treturn false, nil\\n    55→}\\n    56→\\n    57→// --- Transcript Storage ---\\n    58→\\n    59→// ReadTranscript reads the cached transcript JSON for a session.\\n    60→func (k *KiroAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    61→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path from agent hook\\n    62→\\tif err != nil {\\n    63→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    64→\\t}\\n    65→\\treturn data, nil\\n    66→}\\n    67→\\n    68→// ChunkTranscript splits a JSON transcript into chunks.\\n    69→// Kiro transcripts are single JSON objects; we use the JSONL chunker since the\\n    70→// cached format is a JSON blob that fits in a single chunk in most cases.\\n    71→func (k *KiroAgent) ChunkTranscript(_ context.Context, content []byte, maxSize int) ([][]byte, error) {\\n    72→\\tif len(content) <= maxSize {\\n    73→\\t\\treturn [][]byte{content}, nil\\n    74→\\t}\\n    75→\\t// For large transcripts, split at line boundaries\\n    76→\\tchunks, err := agent.ChunkJSONL(content, maxSize)\\n    77→\\tif err != nil {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk transcript: %w\\\", err)\\n    79→\\t}\\n    80→\\treturn chunks, nil\\n    81→}\\n    82→\\n    83→// ReassembleTranscript combines transcript chunks back into a single blob.\\n    84→func (k *KiroAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n    85→\\tif len(chunks) == 1 {\\n    86→\\t\\treturn chunks[0], nil\\n    87→\\t}\\n    88→\\treturn agent.ReassembleJSONL(chunks), nil\\n    89→}\\n    90→\\n    91→// --- Session Management ---\\n    92→\\n    93→// GetSessionID extracts the session ID from hook input.\\n    94→func (k *KiroAgent) GetSessionID(input *agent.HookInput) string {\\n    95→\\treturn input.SessionID\\n    96→}\\n    97→\\n    98→// GetSessionDir returns the directory where Kiro stores session data.\\n    99→// For Kiro, sessions are in SQLite, but we cache transcripts to .entire/tmp/.\\n   100→func (k *KiroAgent) GetSessionDir(repoPath string) (string, error) {\\n   101→\\treturn filepath.Join(repoPath, \\\".entire\\\", \\\"tmp\\\"), nil\\n   102→}\\n   103→\\n   104→// ResolveSessionFile returns the path to the cached transcript file.\\n   105→func (k *KiroAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   106→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   107→}\\n   108→\\n   109→// ReadSession reads session data from the cached transcript.\\n   110→func (k *KiroAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\tdata, err := os.ReadFile(input.SessionRef)\\n   116→\\tif err != nil {\\n   117→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\treturn &agent.AgentSession{\\n   121→\\t\\tSessionID:  input.SessionID,\\n   122→\\t\\tAgentName:  k.Name(),\\n   123→\\t\\tSessionRef: input.SessionRef,\\n   124→\\t\\tStartTime:  time.Now(),\\n   125→\\t\\tNativeData: data,\\n   126→\\t}, nil\\n   127→}\\n   128→\\n   129→// WriteSession writes session data for resumption.\\n   130→func (k *KiroAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   131→\\tif session == nil {\\n   132→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   133→\\t}\\n   134→\\tif session.AgentName != \\\"\\\" && session.AgentName != k.Name() {\\n   135→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, k.Name())\\n   136→\\t}\\n   137→\\tif session.SessionRef == \\\"\\\" {\\n   138→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   139→\\t}\\n   140→\\tif len(session.NativeData) == 0 {\\n   141→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   142→\\t}\\n   143→\\n   144→\\tif err := os.MkdirAll(filepath.Dir(session.SessionRef), 0o750); err != nil {\\n   145→\\t\\treturn fmt.Errorf(\\\"failed to create session dir: %w\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   149→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   150→\\t}\\n   151→\\treturn nil\\n   152→}\\n   153→\\n   154→// FormatResumeCommand returns the command to resume a Kiro session.\\n   155→func (k *KiroAgent) FormatResumeCommand(_ string) string {\\n   156→\\treturn \\\"kiro-cli chat --resume\\\"\\n   157→}\\n   158→\\n   159→// GetHookConfigPath returns the path to the hook config file relative to repo root.\\n   160→func (k *KiroAgent) GetHookConfigPath() string {\\n   161→\\treturn filepath.Join(\\\".kiro\\\", hooksDir, HooksFileName)\\n   162→}\\n   163→\\n   164→// --- TranscriptAnalyzer interface implementation ---\\n   165→\\n   166→// GetTranscriptPosition returns the number of history entries in a Kiro transcript.\\n   167→// Kiro uses JSON format with paired user+assistant history entries, so position\\n   168→// is the entry count. Returns 0 if the file doesn't exist, is empty, or is a\\n   169→// placeholder \\\"{}\\\".\\n   170→func (k *KiroAgent) GetTranscriptPosition(path string) (int, error) {\\n   171→\\tif path == \\\"\\\" {\\n   172→\\t\\treturn 0, nil\\n   173→\\t}\\n   174→\\n   175→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   176→\\tif err != nil {\\n   177→\\t\\tif os.IsNotExist(err) {\\n   178→\\t\\t\\treturn 0, nil\\n   179→\\t\\t}\\n   180→\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   181→\\t}\\n   182→\\n   183→\\tif len(data) == 0 {\\n   184→\\t\\treturn 0, nil\\n   185→\\t}\\n   186→\\n   187→\\tt, err := parseTranscript(data)\\n   188→\\tif err != nil {\\n   189→\\t\\treturn 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\treturn len(t.History), nil\\n   193→}\\n   194→\\n   195→// ExtractModifiedFilesFromOffset extracts files modified since a given history index.\\n   196→// For Kiro (JSON format), offset is the starting history entry index.\\n   197→func (k *KiroAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   198→\\tif path == \\\"\\\" {\\n   199→\\t\\treturn nil, 0, nil\\n   200→\\t}\\n   201→\\n   202→\\tdata, readErr := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   203→\\tif readErr != nil {\\n   204→\\t\\tif os.IsNotExist