it.Author.When,\\n   172→\\t}, nil\\n   173→}\\n   174→\\n   175→// ListTemporary lists all shadow branches with their checkpoint info.\\n   176→func (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n   177→\\t_ = ctx // Reserved for future use\\n   178→\\n   179→\\titer, err := s.repo.Branches()\\n   180→\\tif err != nil {\\n   181→\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n   182→\\t}\\n   183→\\n   184→\\tvar results []TemporaryInfo\\n   185→\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n   186→\\t\\tbranchName := ref.Name().Short()\\n   187→\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   188→\\t\\t\\treturn nil\\n   189→\\t\\t}\\n   190→\\n   191→\\t\\t// Skip the sessions branch\\n   192→\\t\\tif branchName == paths.MetadataBranchName {\\n   193→\\t\\t\\treturn nil\\n   194→\\t\\t}\\n   195→\\n   196→\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n   197→\\t\\tif commitErr != nil {\\n   198→\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n   199→\\t\\t\\treturn nil\\n   200→\\t\\t}\\n   201→\\n   202→\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n   203→\\n   204→\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n   205→\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n   206→\\n   207→\\t\\tresults = append(results, TemporaryInfo{\\n   208→\\t\\t\\tBranchName:   branchName,\\n   209→\\t\\t\\tBaseCommit:   baseCommit,\\n   210→\\t\\t\\tLatestCommit: ref.Hash(),\\n   211→\\t\\t\\tSessionID:    sessionID,\\n   212→\\t\\t\\tTimestamp:    commit.Author.When,\\n   213→\\t\\t})\\n   214→\\n   215→\\t\\treturn nil\\n   216→\\t})\\n   217→\\n   218→\\tif err != nil {\\n   219→\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n   220→\\t}\\n   221→\\n   222→\\treturn results, nil\\n   223→}\\n   224→\\n   225→// WriteTemporaryTask writes a