\\n   369→\\t\\t\\t\\t\\t\\t\\t)\\n   370→\\t\\t\\t\\t\\t\\t\\tcontinue\\n   371→\\t\\t\\t\\t\\t\\t}\\n   372→\\t\\t\\t\\t\\t\\tentries[chunkPath] = object.TreeEntry{\\n   373→\\t\\t\\t\\t\\t\\t\\tName: chunkPath,\\n   374→\\t\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   375→\\t\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   376→\\t\\t\\t\\t\\t\\t}\\n   377→\\t\\t\\t\\t\\t}\\n   378→\\t\\t\\t\\t}\\n   379→\\t\\t\\t}\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\t// Add subagent transcript if available\\n   383→\\t\\tif opts.SubagentTranscriptPath != \\\"\\\" && opts.AgentID != \\\"\\\" {\\n   384→\\t\\t\\tif agentContent, readErr := os.ReadFile(opts.SubagentTranscriptPath); readErr == nil {\\n   385→\\t\\t\\t\\tredacted, jsonlErr := redact.JSONLBytes(agentContent)\\n   386→\\t\\t\\t\\tif jsonlErr != nil {\\n   387→\\t\\t\\t\\t\\tlogging.Warn(context.Background(), \\\"subagent transcript is not valid JSONL, falling back to plain redaction\\\",\\n   388→\\t\\t\\t\\t\\t\\tslog.String(\\\"path\\\", opts.SubagentTranscriptPath),\\n   389→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", jsonlErr.Error()),\\n   390→\\t\\t\\t\\t\\t)\\n   391→\\t\\t\\t\\t\\tredacted = redact.Bytes(agentContent)\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\t\\tagentContent = redacted\\n   394→\\t\\t\\t\\tif blobHash, blobErr := CreateBlobFromContent(s.repo, agentContent); blobErr == nil {\\n   395→\\t\\t\\t\\t\\tagentPath := taskMetadataDir + \\\"/agent-\\\" + opts.AgentID + \\\".jsonl\\\"\\n   396→\\t\\t\\t\\t\\tentries[agentPath] = object.TreeEntry{\\n   397→\\t\\t\\t\\t\\t\\tName: agentPath,\\n   398→\\t\\t\\t\\t\\t\\tMode: filemode.Regular,\\n   399→\\t\\t\\t\\t\\t\\tHash: blobHash,\\n   400→\\t\\t\\t\\t\\t}\\n   401→\\t\\t\\t\\t}\\n   402→\\t\\t\\t}\\n   403→\\t\\t}\\n   404→\\n   405→\\t\\t// Add checkpoint.json\\n   406→\\t\\tcheckpointJSON := fmt.Sprintf(`{\\n   407→  \\\"session_id\\\": %q,\\n   408→  \\\"tool_use_id\\\": %q,\\n   409→  \\\"checkpoint_uuid\\\": %q,\\n   410→  \\\"agent_id\\\": %q\\n   411→}`, opts.SessionID, opts.ToolUseID, opts.CheckpointUUID, opts.AgentID)\\n   412→\\n   413→\\t\\tblobHash, err := CreateBlobFromContent(s.repo, []byte(checkpointJSON))\\n   414→\\t\\tif err != nil {\\n   415→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create checkpoint blob: %w\\\", err)\\n   416→\\t\\t}\\n   417→\\t\\tcheckpointPath := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   418→\\t\\tentries[checkpointPath] = object.TreeEntry{\\n   419→\\t\\t\\tName: checkpointPath,\\n   420→\\t\\t\\tMode: filemode.Regular,\\n   421→\\t\\t\\tHash: blobHash,\\n   422→\\t\\t}\\n   423→\\t}\\n   424→\\n   425→\\t// Build new tree from entries\\n   426→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   427→}\\n   428→\\n   429→// ListTemporaryCheckpoints lists all checkpoint commits on a shadow branch.\\n   430→// This returns individual commits (rewind points), not just branch info.\\n   431→// The sessionID filter, if provided, limits results to commits from that session.\\n   432→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   433→func (s *GitStore) ListTemporaryCheckpoints(ctx context.Context, baseCommit, worktreeID, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   434→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   435→\\treturn s.listCheckpointsForBranch(ctx, shadowBranchName, sessionID, limit)\\n   436→}\\n   437→\\n   438→// ListCheckpointsForBranch lists checkpoint commits for a shadow branch by name.\\n   439→// Use this when you already have the full branch name (e.g., from ListTemporary).\\n   440→// The sessionID filter, if provided, limits results to commits from that session.\\n   441→func (s *GitStore) ListCheckpointsForBranch(ctx context.Context, branchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   442→\\treturn s.listCheckpointsForBranch(ctx, branchName, sessionID, limit)\\n   443→}\\n   444→\\n   445→// listCheckpointsForBranch lists checkpoint commits for a specific shadow branch name.\\n   446→// This is an internal helper used by ListTemporaryCheckpoints, ListCheckpointsForBranch, and ListAllTemporaryCheckpoints.\\n   447→func (s *GitStore) listCheckpointsForBranch(ctx context.Context, shadowBranchName, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   448→\\t_ = ctx // Reserved for future use\\n   449→\\n   450→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   451→\\n   452→\\tref, err := s.repo.Reference(refName, true)\\n   453→\\tif err != nil {\\n   454→\\t\\treturn nil, nil //nolint:nilerr // No shadow branch is expected case\\n   455→\\t}\\n   456→\\n   457→\\titer, err := s.repo.Log(&git.LogOptions{From: ref.Hash()})\\n   458→\\tif err != nil {\\n   459→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit log: %w\\\", err)\\n   460→\\t}\\n   461→\\n   462→\\tvar results []TemporaryCheckpointInfo\\n   463→\\tcount := 0\\n   464→\\n   465→\\terr = iter.ForEach(func(c *object.Commit) error {\\n   466→\\t\\tif count >= limit*5 { // Scan more to allow for session filtering\\n   467→\\t\\t\\treturn errStop\\n   468→\\t\\t}\\n   469→\\t\\tcount++\\n   470→\\n   471→\\t\\t// Verify commit belongs to target session via Entire-Session trailer\\n   472→\\t\\tcommitSessionID, hasTrailer := trailers.ParseSession(c.Message)\\n   473→\\t\\tif !hasTrailer {\\n   474→\\t\\t\\treturn nil // Skip commits without session trailer\\n   475→\\t\\t}\\n   476→\\t\\tif sessionID != \\\"\\\" && commitSessionID != sessionID {\\n   477→\\t\\t\\treturn nil // Skip commits from other sessions\\n   478→\\t\\t}\\n   479→\\n   480→\\t\\t// Get first line of message\\n   481→\\t\\tmessage := c.Message\\n   482→\\t\\tif idx := strings.Index(message, \\\"\\\\n\\\"); idx > 0 {\\n   483→\\t\\t\\tmessage = message[:idx]\\n   484→\\t\\t}\\n   485→\\n   486→\\t\\tinfo := TemporaryCheckpointInfo{\\n   487→\\t\\t\\tCommitHash: c.Hash,\\n   488→\\t\\t\\tMessage:    message,\\n   489→\\t\\t\\tSessionID:  commitSessionID,\\n   490→\\t\\t\\tTimestamp:  c.Author.When,\\n   491→\\t\\t}\\n   492→\\n   493→\\t\\t// Check for task checkpoint first\\n   494→\\t\\ttaskMetadataDir, foundTask := trailers.ParseTaskMetadata(c.Message)\\n   495→\\t\\tif foundTask {\\n   496→\\t\\t\\tinfo.IsTaskCheckpoint = true\\n   497→\\t\\t\\tinfo.MetadataDir = taskMetadataDir\\n   498→\\t\\t\\tinfo.ToolUseID = extractToolUseIDFromPath(taskMetadataDir)\\n   499→\\t\\t} else {\\n   500→\\t\\t\\tmetadataDir, found := trailers.ParseMetadata(c.Message)\\n   501→\\t\\t\\tif found {\\n   502→\\t\\t\\t\\tinfo.MetadataDir = metadataDir\\n   503→\\t\\t\\t}\\n   504→\\t\\t}\\n   505→\\n   506→\\t\\tresults = append(results, info)\\n   507→\\n   508→\\t\\tif len(results) >= limit {\\n   509→\\t\\t\\treturn errStop\\n   510→\\t\\t}\\n   511→\\t\\treturn nil\\n   512→\\t})\\n   513→\\n   514→\\tif err != nil && !errors.Is(err, errStop) {\\n   515→\\t\\treturn nil, fmt.Errorf(\\\"error iterating commits: %w\\\", err)\\n   516→\\t}\\n   517→\\n   518→\\treturn results, nil\\n   519→}\\n   520→\\n   521→// ListAllTemporaryCheckpoints lists checkpoint commits from ALL shadow branches.\\n   522→// This is used for checkpoint lookup when the base commit is unknown (e.g., HEAD advanced since session start).\\n   523→// The sessionID filter, if provided, limits results to commits from that session.\\n   524→func (s *GitStore) ListAllTemporaryCheckpoints(ctx context.Context, sessionID string, limit int) ([]TemporaryCheckpointInfo, error) {\\n   525→\\t_ = ctx // Reserved for future use\\n   526→\\n   527→\\t// List all shadow branches\\n   528→\\tbranches, err := s.ListTemporary(ctx)\\n   529→\\tif err != nil {\\n   530→\\t\\treturn nil, fmt.Errorf(\\\"failed to list shadow branches: %w\\\", err)\\n   531→\\t}\\n   532→\\n   533→\\tvar results []TemporaryCheckpointInfo\\n   534→\\n   535→\\t// Iterate through each shadow branch and collect checkpoints\\n   536→\\tfor _, branch := range branches {\\n   537→\\t\\t// Use the branch name directly to get checkpoints\\n   538→\\t\\tbranchCheckpoints, branchErr := s.listCheckpointsForBranch(ctx, branch.BranchName, sessionID, limit)\\n   539→\\t\\tif branchErr != nil {\\n   540→\\t\\t\\tcontinue // Skip branches we can't read\\n   541→\\t\\t}\\n   542→\\t\\tresults = append(results, branchCheckpoints...)\\n   543→\\t\\tif len(results) >= limit {\\n   544→\\t\\t\\tresults = results[:limit]\\n   545→\\t\\t\\tbreak\\n   546→\\t\\t}\\n   547→\\t}\\n   548→\\n   549→\\treturn results, nil\\n   550→}\\n   551→\\n   552→// extractToolUseIDFromPath extracts the ToolUseID from a task metadata directory path.\\n   553→// Task metadata dirs have format: .entire/metadata/<session>/tasks/<toolUseID>\\n   554→func extractToolUseIDFromPath(metadataDir string) string {\\n   555→\\tparts := strings.Split(metadataDir, \\\"/\\\")\\n   556→\\tif len(parts) >= 2 && parts[len(parts)-2] == \\\"tasks\\\" {\\n   557→\\t\\treturn parts[len(parts)-1]\\n   558→\\t}\\n   559→\\treturn \\\"\\\"\\n   560→}\\n   561→\\n   562→// errStop is a sentinel error used to break out of git log iteration.\\n   563→var errStop = errors.New(\\\"stop iteration\\\")\\n   564→\\n   565→// GetTranscriptFromCommit retrieves the transcript from a specific commit's tree.\\n   566→// This is used for shadow branch checkpoints where the transcript is stored in the commit tree\\n   567→// rather than on the entire/checkpoints/v1 branch.\\n   568→// commitHash is the commit to read from, metadataDir is the path within the tree.\\n   569→// agentType is used for reassembling chunked transcripts in the correct format.\\n   570→// Handles both chunked and non-chunked transcripts.\\n   571→func (s *GitStore) GetTranscriptFromCommit(commitHash plumbing.Hash, metadataDir string, agentType agent.AgentType) ([]byte, error) {\\n   572→\\tcommit, err := s.repo.CommitObject(commitHash)\\n   573→\\tif err != nil {\\n   574→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit: %w\\\", err)\\n   575→\\t}\\n   576→\\n   577→\\ttree, err := commit.Tree()\\n   578→\\tif err != nil {\\n   579→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   580→\\t}\\n   581→\\n   582→\\t// Try to get the metadata subtree for chunk detection\\n   583→\\tsubTree, subTreeErr := tree.Tree(metadataDir)\\n   584→\\tif subTreeErr == nil {\\n   585→\\t\\t// Use the helper function that handles chunking\\n   586→\\t\\ttranscript, err := readTranscriptFromTree(subTree, agentType)\\n   587→\\t\\tif err == nil && transcript != nil {\\n   588→\\t\\t\\treturn transcript, nil\\n   589→\\t\\t}\\n   590→\\t}\\n   591→\\n   592→\\t// Fall back to direct file access (for backwards compatibility)\\n   593→\\ttranscriptPath := metadataDir + \\\"/\\\" + paths.TranscriptFileName\\n   594→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   595→\\t\\tcontent, contentErr := file.Contents()\\n   596→\\t\\tif contentErr == nil {\\n   597→\\t\\t\\treturn []byte(content), nil\\n   598→\\t\\t}\\n   599→\\t}\\n   600→\\n   601→\\ttranscriptPath = metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy\\n   602→\\tif file, fileErr := tree.File(transcriptPath); fileErr == nil {\\n   603→\\t\\tcontent, contentErr := file.Contents()\\n   604→\\t\\tif contentErr == nil {\\n   605→\\t\\t\\treturn []byte(content), nil\\n   606→\\t\\t}\\n   607→\\t}\\n   608→\\n   609→\\treturn nil, ErrNoTranscript\\n   610→}\\n   611→\\n   612→// ShadowBranchExists checks if a shadow branch exists for the given base commit and worktree.\\n   613→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   614→func (s *GitStore) ShadowBranchExists(baseCommit, worktreeID string) bool {\\n   615→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   616→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   617→\\t_, err := s.repo.Reference(refName, true)\\n   618→\\treturn err == nil\\n   619→}\\n   620→\\n   621→// DeleteShadowBranch deletes the shadow branch for the given base commit and worktree.\\n   622→// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\n   623→// Uses git CLI instead of go-git's RemoveReference because go-git v5 doesn't properly\\n   624→// persist deletions with packed refs or worktrees.\\n   625→func (s *GitStore) DeleteShadowBranch(baseCommit, worktreeID string) error {\\n   626→\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n   627→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"branch\\\", \\\"-D\\\", \\\"--\\\", shadowBranchName) //nolint:gosec // shadowBranchName is constructed from commit hash, not user input\\n   628→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   629→\\t\\treturn fmt.Errorf(\\\"failed to delete shadow branch %s: %s: %w\\\", shadowBranchName, strings.TrimSpace(string(output)), err)\\n   630→\\t}\\n   631→\\treturn nil\\n   632→}\\n   633→\\n   634→// ShadowBranchNameForCommit returns the shadow branch name for a base commit hash\\n   635→// and worktree identifier. The worktree ID should be empty for the main worktree\\n   636→// or the internal git worktree name for linked worktrees.\\n   637→// Format: entire/<commit[:7]>-<hash(worktreeID)[:6]>\\n   638→func ShadowBranchNameForCommit(baseCommit, worktreeID string) string {\\n   639→\\tcommitPart := baseCommit\\n   640→\\tif len(baseCommit) >= ShadowBranchHashLength {\\n   641→\\t\\tcommitPart = baseCommit[:ShadowBranchHashLength]\\n   642→\\t}\\n   643→\\tworktreeHash := HashWorktreeID(worktreeID)\\n   644→\\treturn ShadowBranchPrefix + commitPart + \\\"-\\\" + worktreeHash\\n   645→}\\n   646→\\n   647→// ParseShadowBranchName extracts the commit prefix and worktree hash from a shadow branch name.\\n   648→// Input format: \\\"entire/<commit[:7]>-<worktreeHash[:6]>\\\"\\n   649→// Returns (commitPrefix, worktreeHash, ok). Returns (\\\"\\\", \\\"\\\", false) if not a valid shadow branch.\\n   650→func ParseShadowBranchName(branchName string) (commitPrefix, worktreeHash string, ok bool) {\\n   651→\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n   652→\\t\\treturn \\\"\\\", \\\"\\\", false\\n   653→\\t}\\n   654→\\tsuffix := strings.TrimPrefix(branchName, ShadowBranchPrefix)\\n   655→\\n   656→\\t// Find the last dash - everything before is commit prefix, after is worktree hash\\n   657→\\tlastDash := strings.LastIndex(suffix, \\\"-\\\")\\n   658→\\tif lastDash == -1 || lastDash == 0 || lastDash == len(suffix)-1 {\\n   659→\\t\\t// No dash, or dash at start/end - invalid format\\n   660→\\t\\t// Could be old format \\\"entire/<commit[:7]>\\\" without worktree hash\\n   661→\\t\\treturn suffix, \\\"\\\", true // Return as commit prefix with empty worktree hash\\n   662→\\t}\\n   663→\\n   664→\\treturn suffix[:lastDash], suffix[lastDash+1:], true\\n   665→}\\n   666→\\n   667→// getOrCreateShadowBranch gets or creates the shadow branch for checkpoints.\\n   668→// Returns (parentHash, baseTreeHash, error).\\n   669→func (s *GitStore) getOrCreateShadowBranch(branchName string) (plumbing.Hash, plumbing.Hash, error) {\\n   670→\\trefName := plumbing.NewBranchReferenceName(branchName)\\n   671→\\tref, err := s.repo.Reference(refName, true)\\n   672→\\n   673→\\tif err == nil {\\n   674→\\t\\t// Branch exists\\n   675→\\t\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n   676→\\t\\tif err != nil {\\n   677→\\t\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   678→\\t\\t}\\n   679→\\t\\treturn ref.Hash(), commit.TreeHash, nil\\n   680→\\t}\\n   681→\\n   682→\\t// Branch doesn't exist, use current HEAD's tree as base\\n   683→\\thead, err := s.repo.Head()\\n   684→\\tif err != nil {\\n   685→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   686→\\t}\\n   687→\\n   688→\\theadCommit, err := s.repo.CommitObject(head.Hash())\\n   689→\\tif err != nil {\\n   690→\\t\\treturn plumbing.ZeroHash, plumbing.ZeroHash, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   691→\\t}\\n   692→\\n   693→\\treturn plumbing.ZeroHash, headCommit.TreeHash, nil\\n   694→}\\n   695→\\n   696→// buildTreeWithChanges builds a git tree with the given changes.\\n   697→// metadataDir is the relative path for git tree entries, metadataDirAbs is the absolute path\\n   698→// for filesystem operations (needed when CLI is run from a subdirectory).\\n   699→func (s *GitStore) buildTreeWithChanges(\\n   700→\\tbaseTreeHash plumbing.Hash,\\n   701→\\tmodifiedFiles, deletedFiles []string,\\n   702→\\tmetadataDir, metadataDirAbs string,\\n   703→) (plumbing.Hash, error) {\\n   704→\\t// Get worktree root for resolving file paths\\n   705→\\t// This is critical because fileExists() and createBlobFromFile() use os.Stat()\\n   706→\\t// which resolves relative to CWD. The modifiedFiles are repo-relative paths,\\n   707→\\t// so we must resolve them against repo root, not CWD.\\n   708→\\trepoRoot, err := paths.WorktreeRoot()\\n   709→\\tif err != nil {\\n   710→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   711→\\t}\\n   712→\\n   713→\\t// Get the base tree\\n   714→\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n   715→\\tif err != nil {\\n   716→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n   717→\\t}\\n   718→\\n   719→\\t// Flatten existing tree\\n   720→\\tentries := make(map[string]object.TreeEntry)\\n   721→\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n   722→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten base tree: %w\\\", err)\\n   723→\\t}\\n   724→\\n   725→\\t// Remove deleted files\\n   726→\\tfor _, file := range deletedFiles {\\n   727→\\t\\tdelete(entries, file)\\n   728→\\t}\\n   729→\\n   730→\\t// Add/update modified files\\n   731→\\tfor _, file := range modifiedFiles {\\n   732→\\t\\t// Resolve path relative to repo root for filesystem operations\\n   733→\\t\\tabsPath := filepath.Join(repoRoot, file)\\n   734→\\t\\tif !fileExists(absPath) {\\n   735→\\t\\t\\tdelete(entries, file)\\n   736→\\t\\t\\tcontinue\\n   737→\\t\\t}\\n   738→\\n   739→\\t\\tblobHash, mode, err := createBlobFromFile(s.repo, absPath)\\n   740→\\t\\tif err != nil {\\n   741→\\t\\t\\t// Skip files that can't be staged (may have been deleted since detection)\\n   742→\\t\\t\\tcontinue\\n   743→\\t\\t}\\n   744→\\n   745→\\t\\tentries[file] = object.TreeEntry{\\n   746→\\t\\t\\tName: file,\\n   747→\\t\\t\\tMode: mode,\\n   748→\\t\\t\\tHash: blobHash,\\n   749→\\t\\t}\\n   750→\\t}\\n   751→\\n   752→\\t// Add metadata directory files\\n   753→\\tif metadataDir != \\\"\\\" && metadataDirAbs != \\\"\\\" {\\n   754→\\t\\tif err := addDirectoryToEntriesWithAbsPath(s.repo, metadataDirAbs, metadataDir, entries); err != nil {\\n   755→\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add metadata directory: %w\\\", err)\\n   756→\\t\\t}\\n   757→\\t}\\n   758→\\n   759→\\t// Build tree\\n   760→\\treturn BuildTreeFromEntries(s.repo, entries)\\n   761→}\\n   762→\\n   763→// createCommit creates a commit object.\\n   764→func (s *GitStore) createCommit(treeHash, parentHash plumbing.Hash, message, authorName, authorEmail string) (plumbing.Hash, error) {\\n   765→\\tnow := time.Now()\\n   766→\\tsig := object.Signature{\\n   767→\\t\\tName:  authorName,\\n   768→\\t\\tEmail: authorEmail,\\n   769→\\t\\tWhen:  now,\\n   770→\\t}\\n   771→\\n   772→\\tcommit := &object.Commit{\\n   773→\\t\\tTreeHash:  treeHash,\\n   774→\\t\\tAuthor:    sig,\\n   775→\\t\\tCommitter: sig,\\n   776→\\t\\tMessage:   message,\\n   777→\\t}\\n   778→\\n   779→\\t// Add parent if not a new branch\\n   780→\\tif parentHash != plumbing.ZeroHash {\\n   781→\\t\\tcommit.ParentHashes = []plumbing.Hash{parentHash}\\n   782→\\t}\\n   783→\\n   784→\\tobj := s.repo.Storer.NewEncodedObject()\\n   785→\\tif err := commit.Encode(obj); err != nil {\\n   786→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode commit: %w\\\", err)\\n   787→\\t}\\n   788→\\n   789→\\thash, err := s.repo.Storer.SetEncodedObject(obj)\\n   790→\\tif err != nil {\\n   791→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store commit: %w\\\", err)\\n   792→\\t}\\n   793→\\n   794→\\treturn hash, nil\\n   795→}\\n   796→\\n   797→// Helper functions extracted from strategy/common.go\\n   798→// These are exported for use by strategy package (push_common.go, session_test.go)\\n   799→\\n   800→// FlattenTree recursively flattens a tree into a map of full paths to entries.\\n   801→func FlattenTree(repo *git.Repository, tree *object.Tree, prefix string, entries map[string]object.TreeEntry) error {\\n   802→\\tfor _, entry := range tree.Entries {\\n   803→\\t\\tfullPath := entry.Name\\n   804→\\t\\tif prefix != \\\"\\\" {\\n   805→\\t\\t\\tfullPath = prefix + \\\"/\\\" + entry.Name\\n   806→\\t\\t}\\n   807→\\n   808→\\t\\tif entry.Mode == filemode.Dir {\\n   809→\\t\\t\\t// Recurse into subtree\\n   810→\\t\\t\\tsubtree, err := repo.TreeObject(entry.Hash)\\n   811→\\t\\t\\tif err != nil {\\n   812→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get subtree %s: %w\\\", fullPath, err)\\n   813→\\t\\t\\t}\\n   814→\\t\\t\\tif err := FlattenTree(repo, subtree, fullPath, entries); err != nil {\\n   815→\\t\\t\\t\\treturn err\\n   816→\\t\\t\\t}\\n   817→\\t\\t} else {\\n   818→\\t\\t\\tentries[fullPath] = object.TreeEntry{\\n   819→\\t\\t\\t\\tName: fullPath,\\n   820→\\t\\t\\t\\tMode: entry.Mode,\\n   821→\\t\\t\\t\\tHash: entry.Hash,\\n   822→\\t\\t\\t}\\n   823→\\t\\t}\\n   824→\\t}\\n   825→\\treturn nil\\n   826→}\\n   827→\\n   828→// fileExists checks if a file exists at the given path.\\n   829→func fileExists(path string) bool {\\n   830→\\t_, err := os.Stat(path)\\n   831→\\treturn err == nil\\n   832→}\\n   833→\\n   834→// createBlobFromFile creates a blob object from a file in the working directory.\\n   835→func createBlobFromFile(repo *git.Repository, filePath string) (plumbing.Hash, filemode.FileMode, error) {\\n   836→\\tinfo, err := os.Stat(filePath)\\n   837→\\tif err != nil {\\n   838→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to stat file: %w\\\", err)\\n   839→\\t}\\n   840→\\n   841→\\t// Determine file mode\\n   842→\\tmode := filemode.Regular\\n   843→\\tif info.Mode()&0o111 != 0 {\\n   844→\\t\\tmode = filemode.Executable\\n   845→\\t}\\n   846→\\tif info.Mode()&os.ModeSymlink != 0 {\\n   847→\\t\\tmode = filemode.Symlink\\n   848→\\t}\\n   849→\\n   850→\\t// Read file contents\\n   851→\\tcontent, err := os.ReadFile(filePath) //nolint:gosec // filePath comes from walking the repository\\n   852→\\tif err != nil {\\n   853→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to read file: %w\\\", err)\\n   854→\\t}\\n   855→\\n   856→\\t// Create blob object\\n   857→\\tobj := repo.Storer.NewEncodedObject()\\n   858→\\tobj.SetType(plumbing.BlobObject)\\n   859→\\tobj.SetSize(int64(len(content)))\\n   860→\\n   861→\\twriter, err := obj.Writer()\\n   862→\\tif err != nil {\\n   863→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to get object writer: %w\\\", err)\\n   864→\\t}\\n   865→\\n   866→\\t_, err = writer.Write(content)\\n   867→\\tif err != nil {\\n   868→\\t\\t_ = writer.Close()\\n   869→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to write blob content: %w\\\", err)\\n   870→\\t}\\n   871→\\tif err := writer.Close(); err != nil {\\n   872→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to close blob writer: %w\\\", err)\\n   873→\\t}\\n   874→\\n   875→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n   876→\\tif err != nil {\\n   877→\\t\\treturn plumbing.ZeroHash, 0, fmt.Errorf(\\\"failed to store blob object: %w\\\", err)\\n   878→\\t}\\n   879→\\n   880→\\treturn hash, mode, nil\\n   881→}\\n   882→\\n   883→// addDirectoryToEntriesWithAbsPath recursively adds all files in a directory to the entries map.\\n   884→func addDirectoryToEntriesWithAbsPath(repo *git.Repository, dirPathAbs, dirPathRel string, entries map[string]object.TreeEntry) error {\\n   885→\\terr := filepath.Walk(dirPathAbs, func(path string, info os.FileInfo, err error) error {\\n   886→\\t\\tif err != nil {\\n   887→\\t\\t\\treturn err\\n   888→\\t\\t}\\n   889→\\n   890→\\t\\t// Skip symlinks to prevent reading files outside the metadata directory.\\n   891→\\t\\t// A symlink could point to sensitive files (e.g., /etc/passwd) which would\\n   892→\\t\\t// then be captured in the checkpoint and stored in git history.\\n   893→\\t\\t// NOTE: filepath.Walk uses os.Stat (follows symlinks), so info.Mode() never\\n   894→\\t\\t// reports ModeSymlink. We use os.Lstat to check the entry itself.\\n   895→\\t\\t// This check MUST come before IsDir() because Walk follows symlinked\\n   896→\\t\\t// directories and would recurse into them otherwise.\\n   897→\\t\\tlinfo, lstatErr := os.Lstat(path)\\n   898→\\t\\tif lstatErr != nil {\\n   899→\\t\\t\\treturn fmt.Errorf(\\\"failed to lstat %s: %w\\\", path, lstatErr)\\n   900→\\t\\t}\\n   901→\\t\\tif linfo.Mode()&os.ModeSymlink != 0 {\\n   902→\\t\\t\\tif info.IsDir() {\\n   903→\\t\\t\\t\\treturn filepath.SkipDir\\n   904→\\t\\t\\t}\\n   905→\\t\\t\\treturn nil\\n   906→\\t\\t}\\n   907→\\n   908→\\t\\tif info.IsDir() {\\n   909→\\t\\t\\treturn nil\\n   910→\\t\\t}\\n   911→\\n   912→\\t\\t// Calculate relative path within the directory, then join with dirPathRel for tree entry\\n   913→\\t\\trelWithinDir, err := filepath.Rel(dirPathAbs, path)\\n   914→\\t\\tif err != nil {\\n   915→\\t\\t\\treturn fmt.Errorf(\\\"failed to get relative path for %s: %w\\\", path, err)\\n   916→\\t\\t}\\n   917→\\n   918→\\t\\t// Prevent path traversal via symlinks pointing outside the metadata dir\\n   919→\\t\\tif strings.HasPrefix(relWithinDir, \\\"..\\\") {\\n   920→\\t\\t\\treturn fmt.Errorf(\\\"path traversal detected: %s\\\", relWithinDir)\\n   921→\\t\\t}\\n   922→\\n   923→\\t\\ttreePath := filepath.ToSlash(filepath.Join(dirPathRel, relWithinDir))\\n   924→\\n   925→\\t\\tblobHash, mode, err := createRedactedBlobFromFile(repo, path, treePath)\\n   926→\\t\\tif err != nil {\\n   927→\\t\\t\\treturn fmt.Errorf(\\\"failed to create blob for %s: %w\\\", path, err)\\n   928→\\t\\t}\\n   929→\\t\\tentries[treePath] = object.TreeEntry{\\n   930→\\t\\t\\tName: treePath,\\n   931→\\t\\t\\tMode: mode,\\n   932→\\t\\t\\tHash: blobHash,\\n   933→\\t\\t}\\n   934→\\t\\treturn nil\\n   935→\\t})\\n   936→\\tif err != nil {\\n   937→\\t\\treturn fmt.Errorf(\\\"failed to walk directory %s: %w\\\", dirPathAbs, err)\\n   938→\\t}\\n   939→\\treturn nil\\n   940→}\\n   941→\\n   942→// treeNode represents a node in our tree structure.\\n   943→type treeNode struct {\\n   944→\\tentries map[string]*treeNode // subdirectories\\n   945→\\tfiles   []object.TreeEntry   // files in this directory\\n   946→}\\n   947→\\n   948→// BuildTreeFromEntries builds a proper git tree structure from flattened file entries.\\n   949→// Exported for use by strategy package (push_common.go, session_test.go)\\n   950→func BuildTreeFromEntries(repo *git.Repository, entries map[string]object.TreeEntry) (plumbing.Hash, error) {\\n   951→\\t// Build a tree structure\\n   952→\\troot := &treeNode{\\n   953→\\t\\tentries: make(map[string]*treeNode),\\n   954→\\t\\tfiles:   []object.TreeEntry{},\\n   955→\\t}\\n   956→\\n   957→\\t// Insert all entries into the tree structure\\n   958→\\tfor fullPath, entry := range entries {\\n   959→\\t\\tparts := strings.Split(fullPath, \\\"/\\\")\\n   960→\\t\\tinsertIntoTree(root, parts, entry)\\n   961→\\t}\\n   962→\\n   963→\\t// Recursively build tree objects from bottom up\\n   964→\\treturn buildTreeObject(repo, root)\\n   965→}\\n   966→\\n   967→// insertIntoTree inserts a file entry into the tree structure.\\n   968→func insertIntoTree(node *treeNode, pathParts []string, entry object.TreeEntry) {\\n   969→\\tif len(pathParts) == 1 {\\n   970→\\t\\t// This is a file in the current directory\\n   971→\\t\\tnode.files = append(node.files, object.TreeEntry{\\n   972→\\t\\t\\tName: pathParts[0],\\n   973→\\t\\t\\tMode: entry.Mode,\\n   974→\\t\\t\\tHash: entry.Hash,\\n   975→\\t\\t})\\n   976→\\t\\treturn\\n   977→\\t}\\n   978→\\n   979→\\t// This is in a subdirectory\\n   980→\\tdirName := pathParts[0]\\n   981→\\tif node.entries[dirName] == nil {\\n   982→\\t\\tnode.entries[dirName] = &treeNode{\\n   983→\\t\\t\\tentries: make(map[string]*treeNode),\\n   984→\\t\\t\\tfiles:   []object.TreeEntry{},\\n   985→\\t\\t}\\n   986→\\t}\\n   987→\\tinsertIntoTree(node.entries[dirName], pathParts[1:], entry)\\n   988→}\\n   989→\\n   990→// buildTreeObject recursively builds tree objects from a treeNode.\\n   991→func buildTreeObject(repo *git.Repository, node *treeNode) (plumbing.Hash, error) {\\n   992→\\tvar treeEntries []object.TreeEntry\\n   993→\\n   994→\\t// Add files\\n   995→\\ttreeEntries = append(treeEntries, node.files...)\\n   996→\\n   997→\\t// Recursively build subtrees\\n   998→\\tfor name, subnode := range node.entries {\\n   999→\\t\\tsubHash, err := buildTreeObject(repo, subnode)\\n  1000→\\t\\tif err != nil {\\n  1001→\\t\\t\\treturn plumbing.ZeroHash, err\\n  1002→\\t\\t}\\n  1003→\\t\\ttreeEntries = append(treeEntries, object.TreeEntry{\\n  1004→\\t\\t\\tName: name,\\n  1005→\\t\\t\\tMode: filemode.Dir,\\n  1006→\\t\\t\\tHash: subHash,\\n  1007→\\t\\t})\\n  1008→\\t}\\n  1009→\\n  1010→\\t// Sort entries (git requires sorted entries)\\n  1011→\\tsortTreeEntries(treeEntries)\\n  1012→\\n  1013→\\t// Create tree object\\n  1014→\\ttree := &object.Tree{Entries: treeEntries}\\n  1015→\\n  1016→\\tobj := repo.Storer.NewEncodedObject()\\n  1017→\\tif err := tree.Encode(obj); err != nil {\\n  1018→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to encode tree: %w\\\", err)\\n  1019→\\t}\\n  1020→\\n  1021→\\thash, err := repo.Storer.SetEncodedObject(obj)\\n  1022→\\tif err != nil {\\n  1023→\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to store tree: %w\\\", err)\\n  1024→\\t}\\n  1025→\\n  1026→\\treturn hash, nil\\n  1027→}\\n  1028→\\n  1029→// sortTreeEntries sorts tree entries in git's required order.\\n  1030→// Git sorts tree entries by name, with directories having a trailing /\\n  1031→func sortTreeEntries(entries []object.TreeEntry) {\\n  1032→\\tsort.Slice(entries, func(i, j int) bool {\\n  1033→\\t\\tnameI := entries[i].Name\\n  1034→\\t\\tnameJ := entries[j].Name\\n  1035→\\t\\tif entries[i].Mode == filemode.Dir {\\n  1036→\\t\\t\\tnameI += \\\"/\\\"\\n  1037→\\t\\t}\\n  1038→\\t\\tif entries[j].Mode == filemode.Dir {\\n  1039→\\t\\t\\tnameJ += \\\"/\\\"\\n  1040→\\t\\t}\\n  1041→\\t\\treturn nameI < nameJ\\n  1042→\\t})\\n  1043→}\\n  1044→\\n  1045→// collectChangedFiles collects all changed files (modified tracked + untracked non-ignored)\\n  1046→// using git CLI. This is much faster than filesystem walk and respects all gitignore sources\\n  1047→// including global gitignore (core.excludesfile).\\n  1048→//\\n  1049→// Uses git CLI instead of go-git because go-git's worktree.Status() does not respect\\n  1050→// global gitignore, which can cause globally ignored files to appear as untracked.\\n  1051→// See: https://github.com/entireio/cli/pull/129\\n  1052→//\\n  1053→// changedFilesResult contains both changed and deleted files from git status.\\n  1054→type changedFilesResult struct {\\n  1055→\\tChanged []string // Files to include (modified, added, untracked, renamed, etc.)\\n  1056→\\tDeleted []string // Files that were deleted (need to be excluded from checkpoint tree)\\n  1057→}\\n  1058→\\n  1059→// collectChangedFiles returns all changed files from git status for the first checkpoint.\\n  1060→//\\n  1061→// For the first checkpoint, we need to capture:\\n  1062→// - Modified tracked files (user's uncommitted changes)\\n  1063→// - Untracked non-ignored files (new files not yet added to git)\\n  1064→// - Renamed/copied files (both source removal and destination)\\n  1065→// - Deleted files (to exclude from checkpoint tree)\\n  1066→//\\n  1067→// The base tree from HEAD already contains all unchanged tracked files.\\n  1068→//\\n  1069→// Uses `git status --porcelain -z` for reliable parsing of filenames with special characters.\\n  1070→func collectChangedFiles(ctx context.Context, repo *git.Repository) (changedFilesResult, error) {\\n  1071→\\t// Get worktree root directory for running git command\\n  1072→\\twt, err := repo.Worktree()\\n  1073→\\tif err != nil {\\n  1074→\\t\\treturn changedFilesResult{}, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n  1075→\\t}\\n  1076→\\trepoRoot := wt.Filesystem.Root()\\n  1077→\\n  1078→\\t// Use -z for NUL-separated output (handles quoted filenames with spaces/special chars)\\n  1079→\\t// Use -uall to list individual untracked files instead of collapsed directories.\\n  1080→\\t// Note: CLAUDE.md warns against -uall for user-facing display, but we need the full list\\n  1081→\\t// for checkpointing.\\n  1082→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"status\\\", \\\"--porcelain\\\", \\\"-z\\\", \\\"-uall\\\")\\n  1083→\\tcmd.Dir = repoRoot\\n  1084→\\toutput, err := cmd.Output()\\n  1085→\\tif err != nil {\\n  1086→\\t\\treturn changedFilesResult{}, fmt.Errorf(\\\"failed to get git status in %s: %w\\\", repoRoot, err)\\n  1087→\\t}\\n  1088→\\n  1089→\\tchangedSeen := make(map[string]struct{})\\n  1090→\\tdeletedSeen := make(map[string]struct{})\\n  1091→\\n  1092→\\t// Parse NUL-separated output\\n  1093→\\t// Format: XY filename\\\\0 (for most entries)\\n  1094→\\t// For renames/copies: XY newname\\\\0oldname\\\\0\\n  1095→\\tentries := strings.Split(string(output), \\\"\\\\x00\\\")\\n  1096→\\n  1097→\\tfor i := 0; i < len(entries); i++ {\\n  1098→\\t\\tentry := entries[i]\\n  1099→\\t\\tif len(entry) < 3 {\\n  1100→\\t\\t\\tcontinue\\n  1101→\\t\\t}\\n  1102→\\n  1103→\\t\\t// git status --porcelain format: XY filename\\n  1104→\\t\\t// X = staging status, Y = worktree status\\n  1105→\\t\\tstaging := entry[0]\\n  1106→\\t\\twtStatus := entry[1]\\n  1107→\\t\\tfilename := entry[3:] // No TrimSpace needed with -z format\\n  1108→\\n  1109→\\t\\t// Handle R/C (rename/copy) first - they have a second entry we must skip\\n  1110→\\t\\t// even if the new filename is an infrastructure path\\n  1111→\\t\\tif staging == 'R' || staging == 'C' {\\n  1112→\\t\\t\\t// Renamed or copied: current entry is new name, next entry is old name\\n  1113→\\t\\t\\tif !paths.IsInfrastructurePath(filename) {\\n  1114→\\t\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1115→\\t\\t\\t}\\n  1116→\\t\\t\\t// The old name follows as the next NUL-separated entry - must always skip it\\n  1117→\\t\\t\\tif i+1 < len(entries) && entries[i+1] != \\\"\\\" {\\n  1118→\\t\\t\\t\\toldName := entries[i+1]\\n  1119→\\t\\t\\t\\tif staging == 'R' && !paths.IsInfrastructurePath(oldName) {\\n  1120→\\t\\t\\t\\t\\t// For renames, old file is effectively deleted\\n  1121→\\t\\t\\t\\t\\tdeletedSeen[oldName] = struct{}{}\\n  1122→\\t\\t\\t\\t}\\n  1123→\\t\\t\\t\\ti++ // Skip the old name entry\\n  1124→\\t\\t\\t}\\n  1125→\\t\\t\\tcontinue\\n  1126→\\t\\t}\\n  1127→\\n  1128→\\t\\t// Skip .entire directory for non-R/C entries\\n  1129→\\t\\tif paths.IsInfrastructurePath(filename) {\\n  1130→\\t\\t\\tcontinue\\n  1131→\\t\\t}\\n  1132→\\n  1133→\\t\\t// Handle different status codes\\n  1134→\\t\\tswitch {\\n  1135→\\t\\tcase staging == 'D' || wtStatus == 'D':\\n  1136→\\t\\t\\t// Deleted file - track separately\\n  1137→\\t\\t\\tdeletedSeen[filename] = struct{}{}\\n  1138→\\n  1139→\\t\\tcase wtStatus == 'M' || wtStatus == 'A':\\n  1140→\\t\\t\\t// Modified or added in worktree\\n  1141→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1142→\\n  1143→\\t\\tcase staging == '?' && wtStatus == '?':\\n  1144→\\t\\t\\t// Untracked file\\n  1145→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1146→\\n  1147→\\t\\tcase staging == 'A' || staging == 'M':\\n  1148→\\t\\t\\t// Staged add or modify\\n  1149→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1150→\\n  1151→\\t\\tcase staging == 'T' || wtStatus == 'T':\\n  1152→\\t\\t\\t// Type change (e.g., file to symlink)\\n  1153→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1154→\\n  1155→\\t\\tcase staging == 'U' || wtStatus == 'U':\\n  1156→\\t\\t\\t// Unmerged (conflict) - include current file state\\n  1157→\\t\\t\\tchangedSeen[filename] = struct{}{}\\n  1158→\\t\\t}\\n  1159→\\t}\\n  1160→\\n  1161→\\tchanged := make([]string, 0, len(changedSeen))\\n  1162→\\tfor file := range changedSeen {\\n  1163→\\t\\tchanged = append(changed, file)\\n  1164→\\t}\\n  1165→\\n  1166→\\tdeleted := make([]string, 0, len(deletedSeen))\\n  1167→\\tfor file := range deletedSeen {\\n  1168→\\t\\tdeleted = append(deleted, file)\\n  1169→\\t}\\n  1170→\\n  1171→\\treturn changedFilesResult{Changed: changed, Deleted: deleted}, nil\\n  1172→}\\n  1173→\"}]},\"uuid\":\"a944895d-1942-4daf-b820-26b4895a8b56\",\"timestamp\":\"2026-03-02T10:37:04.289Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/4/cmd/entire/cli/checkpoint/temporary.go\",\"content\":\"package checkpoint\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"crypto/sha256\\\"\\n\\t\\\"encoding/hex\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"sort\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n\\t\\\"github.com/entireio/cli/redact\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/filemode\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\nconst (\\n\\t// ShadowBranchPrefix is the prefix for shadow branches.\\n\\tShadowBranchPrefix = \\\"entire/\\\"\\n\\n\\t// ShadowBranchHashLength is the number of hex characters used in shadow branch names.\\n\\t// Shadow branches are named \\\"entire/<hash>\\\" using the first 7 characters of the commit hash.\\n\\tShadowBranchHashLength = 7\\n\\n\\t// WorktreeIDHashLength is the number of hex characters used for worktree ID hash.\\n\\tWorktreeIDHashLength = 6\\n)\\n\\n// HashWorktreeID returns a short hash of the worktree identifier.\\n// Used to create unique shadow branch names per worktree.\\nfunc HashWorktreeID(worktreeID string) string {\\n\\th := sha256.Sum256([]byte(worktreeID))\\n\\treturn hex.EncodeToString(h[:])[:WorktreeIDHashLength]\\n}\\n\\n// WriteTemporary writes a temporary checkpoint to a shadow branch.\\n// Shadow branches are named entire/<base-commit-short-hash>.\\n// Returns the result containing commit hash and whether it was skipped.\\n// If the new tree hash matches the last checkpoint's tree hash, the checkpoint\\n// is skipped to avoid duplicate commits (deduplication).\\nfunc (s *GitStore) WriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error) {\\n\\t// Validate base commit - required for shadow branch naming\\n\\tif opts.BaseCommit == \\\"\\\" {\\n\\t\\treturn WriteTemporaryResult{}, errors.New(\\\"BaseCommit is required for temporary checkpoint\\\")\\n\\t}\\n\\n\\t// Validate session ID to prevent path traversal\\n\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"invalid temporary checkpoint options: %w\\\", err)\\n\\t}\\n\\n\\t// Get shadow branch name\\n\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n\\n\\t// Get or create shadow branch\\n\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n\\t}\\n\\n\\t// Get the last checkpoint's tree hash for deduplication\\n\\tvar lastTreeHash plumbing.Hash\\n\\tif parentHash != plumbing.ZeroHash {\\n\\t\\tif lastCommit, err := s.repo.CommitObject(parentHash); err == nil {\\n\\t\\t\\tlastTreeHash = lastCommit.TreeHash\\n\\t\\t}\\n\\t}\\n\\n\\t// Collect all files to include\\n\\tvar allFiles []string\\n\\tvar allDeletedFiles []string\\n\\tif opts.IsFirstCheckpoint {\\n\\t\\t// For the first checkpoint, capture all changed files (modified tracked + untracked)\\n\\t\\t// using `git status --porcelain -z` which respects both repo and global .gitignore.\\n\\t\\t// This is much faster than filesystem walk. The base tree from HEAD already contains\\n\\t\\t// all unchanged tracked files. We also capture user's pre-existing deletions.\\n\\t\\tresult, err := collectChangedFiles(ctx, s.repo)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to collect changed files: %w\\\", err)\\n\\t\\t}\\n\\t\\tallFiles = result.Changed\\n\\t\\t// Merge user's pre-existing deletions with agent's deletions\\n\\t\\tallDeletedFiles = result.Deleted\\n\\t\\tallDeletedFiles = append(allDeletedFiles, opts.DeletedFiles...)\\n\\t} else {\\n\\t\\t// For subsequent checkpoints, only include modified/new files\\n\\t\\tallFiles = make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n\\t\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n\\t\\tallFiles = append(allFiles, opts.NewFiles...)\\n\\t\\tallDeletedFiles = opts.DeletedFiles\\n\\t}\\n\\n\\t// Build tree with changes\\n\\ttreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, allDeletedFiles, opts.MetadataDir, opts.MetadataDirAbs)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n\\t}\\n\\n\\t// Deduplication: skip if tree hash matches the last checkpoint\\n\\tif lastTreeHash != plumbing.ZeroHash && treeHash == lastTreeHash {\\n\\t\\treturn WriteTemporaryResult{\\n\\t\\t\\tCommitHash: parentHash,\\n\\t\\t\\tSkipped:    true,\\n\\t\\t}, nil\\n\\t}\\n\\n\\t// Create checkpoint commit with trailers\\n\\tcommitMsg := trailers.FormatShadowCommit(opts.CommitMessage, opts.MetadataDir, opts.SessionID)\\n\\n\\tcommitHash, err := s.createCommit(treeHash, parentHash, commitMsg, opts.AuthorName, opts.AuthorEmail)\\n\\tif err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n\\t}\\n\\n\\t// Update branch reference\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n\\t\\treturn WriteTemporaryResult{}, fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn WriteTemporaryResult{\\n\\t\\tCommitHash: commitHash,\\n\\t\\tSkipped:    false,\\n\\t}, nil\\n}\\n\\n// ReadTemporary reads the latest checkpoint from a shadow branch.\\n// Returns nil if the shadow branch doesn't exist.\\n// worktreeID should be empty for main worktree or the internal git worktree name for linked worktrees.\\nfunc (s *GitStore) ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\tshadowBranchName := ShadowBranchNameForCommit(baseCommit, worktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\n\\tref, err := s.repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, nil //nolint:nilnil,nilerr // Branch not found is an expected case\\n\\t}\\n\\n\\tcommit, err := s.repo.CommitObject(ref.Hash())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\t// Extract session ID and metadata dir from commit trailers\\n\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n\\tmetadataDir, _ := trailers.ParseMetadata(commit.Message)\\n\\n\\treturn &ReadTemporaryResult{\\n\\t\\tCommitHash:  ref.Hash(),\\n\\t\\tTreeHash:    commit.TreeHash,\\n\\t\\tSessionID:   sessionID,\\n\\t\\tMetadataDir: metadataDir,\\n\\t\\tTimestamp:   commit.Author.When,\\n\\t}, nil\\n}\\n\\n// ListTemporary lists all shadow branches with their checkpoint info.\\nfunc (s *GitStore) ListTemporary(ctx context.Context) ([]TemporaryInfo, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\titer, err := s.repo.Branches()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list branches: %w\\\", err)\\n\\t}\\n\\n\\tvar results []TemporaryInfo\\n\\terr = iter.ForEach(func(ref *plumbing.Reference) error {\\n\\t\\tbranchName := ref.Name().Short()\\n\\t\\tif !strings.HasPrefix(branchName, ShadowBranchPrefix) {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\t// Skip the sessions branch\\n\\t\\tif branchName == paths.MetadataBranchName {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tcommit, commitErr := s.repo.CommitObject(ref.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\t//nolint:nilerr // Skip branches we can't read (non-fatal)\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\n\\t\\tsessionID, _ := trailers.ParseSession(commit.Message)\\n\\n\\t\\t// Extract base commit from branch name (handles new \\\"entire/<commit>-<worktreeHash>\\\" format)\\n\\t\\tbaseCommit, _, _ := ParseShadowBranchName(branchName)\\n\\n\\t\\tresults = append(results, TemporaryInfo{\\n\\t\\t\\tBranchName:   branchName,\\n\\t\\t\\tBaseCommit:   baseCommit,\\n\\t\\t\\tLatestCommit: ref.Hash(),\\n\\t\\t\\tSessionID:    sessionID,\\n\\t\\t\\tTimestamp:    commit.Author.When,\\n\\t\\t})\\n\\n\\t\\treturn nil\\n\\t})\\n\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to iterate branches: %w\\\", err)\\n\\t}\\n\\n\\treturn results, nil\\n}\\n\\n// WriteTemporaryTask writes a task checkpoint to a shadow branch.\\n// Task checkpoints include both code changes and task-specific metadata.\\n// Returns the commit hash of the created checkpoint.\\nfunc (s *GitStore) WriteTemporaryTask(ctx context.Context, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n\\t_ = ctx // Reserved for future use\\n\\n\\t// Validate base commit - required for shadow branch naming\\n\\tif opts.BaseCommit == \\\"\\\" {\\n\\t\\treturn plumbing.ZeroHash, errors.New(\\\"BaseCommit is required for task checkpoint\\\")\\n\\t}\\n\\n\\t// Validate identifiers to prevent path traversal and malformed data\\n\\tif err := validation.ValidateSessionID(opts.SessionID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateToolUseID(opts.ToolUseID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\tif err := validation.ValidateAgentID(opts.AgentID); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"invalid task checkpoint options: %w\\\", err)\\n\\t}\\n\\n\\t// Get shadow branch name\\n\\tshadowBranchName := ShadowBranchNameForCommit(opts.BaseCommit, opts.WorktreeID)\\n\\n\\t// Get or create shadow branch\\n\\tparentHash, baseTreeHash, err := s.getOrCreateShadowBranch(shadowBranchName)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get shadow branch: %w\\\", err)\\n\\t}\\n\\n\\t// Collect all files to include in the commit\\n\\tallFiles := make([]string, 0, len(opts.ModifiedFiles)+len(opts.NewFiles))\\n\\tallFiles = append(allFiles, opts.ModifiedFiles...)\\n\\tallFiles = append(allFiles, opts.NewFiles...)\\n\\n\\t// Build new tree with code changes (no metadata dir yet)\\n\\tnewTreeHash, err := s.buildTreeWithChanges(baseTreeHash, allFiles, opts.DeletedFiles, \\\"\\\", \\\"\\\")\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n\\t}\\n\\n\\t// Add task metadata to tree\\n\\tnewTreeHash, err = s.addTaskMetadataToTree(newTreeHash, opts)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to add task metadata: %w\\\", err)\\n\\t}\\n\\n\\t// Create the commit\\n\\tcommitHash, err := s.createCommit(newTreeHash, parentHash, opts.CommitMessage, opts.AuthorName, opts.AuthorEmail)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n\\t}\\n\\n\\t// Update shadow branch reference\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref := plumbing.NewHashReference(refName, commitHash)\\n\\tif err := s.repo.Storer.SetReference(ref); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to update shadow branch reference: %w\\\", err)\\n\\t}\\n\\n\\treturn commitHash, nil\\n}\\n\\n// addTaskMetadataToTree adds task checkpoint metadata to a git tree.\\n// When IsIncremental is true, only adds the incremental checkpoint file.\\nfunc (s *GitStore) addTaskMetadataToTree(baseTreeHash plumbing.Hash, opts WriteTemporaryTaskOptions) (plumbing.Hash, error) {\\n\\t// Get base tree and flatten it\\n\\tbaseTree, err := s.repo.TreeObject(baseTreeHash)\\n\\tif err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to get base tree: %w\\\", err)\\n\\t}\\n\\n\\tentries := make(map[string]object.TreeEntry)\\n\\tif err := FlattenTree(s.repo, baseTree, \\\"\\\", entries); err != nil {\\n\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n\\t}\\n\\n\\t// Compute metadata paths\\n\\tsessionMetadataDir := paths.EntireMetadataDir + \\\"/\\\" + opts.SessionID\\n\\ttaskMetadataDir := sessionMetadataDir + \\\"/tasks/\\\" + opts.ToolUseID\\n\\n\\tif opts.IsIncremental {\\n\\t\\t// Incremental checkpoint: only add the checkpoint file\\n\\t\\t// Use proper JSON marshaling to handle nil/empty IncrementalData correctly\\n\\t\\tvar incData []byte\\n\\t\\tif opts.IncrementalData != nil {\\n\\t\\t\\tincData, err = redact.JSONLBytes(opts.IncrementalData)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to redact incremental checkpoint: %w\\\", err)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\tincrementalCheckpoint := struct {\\n\\t\\t\\tType      string          `json:\\\"type\\\"`\\n\\t\\t\\tToolUseID string          `json:\\\"tool_use_id\\\"`\\n\\t\\t\\tTimestamp time.Time       `json:\\\"timestamp\\\"`\\n\\t\\t\\tData      json.RawMessage `json:\\\"data\\\"`\\n\\t\\t}{\\n\\t\\t\\tType:      opts.IncrementalType,\\n\\t\\t\\tToolUseID: opts.ToolUseID,\\n\\t\\t\\tTimestamp: time.Now().UTC(),\\n\\t\\t\\tData:      incData,\\n\\t\\t}\\n\\t\\tcpData, err := jsonutil.MarshalIndentWithNewline(incrementalCheckpoint, \\\"\\\", \\\"  \\\")\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to marshal incremental checkpoint: %w\\\", err)\\n\\t\\t}\\n\\n\\t\\tcpBlobHash, err := CreateBlobFromContent(s.repo, cpData)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn plumbing.ZeroHash, fmt.Errorf(\\\"failed to create incremental checkpoint blob: %w\\\", err)\\n\\t\\t}\\n\\t\\tcpFilename := fmt.Sprintf(\\\"%03d-%s.json\\\", opts.IncrementalSequence, opts.ToolUseID)\\n\\t\\tcpPath := taskMetadataDir + \\\"/checkpoints/\\\" + cpFilename\\n\\t\\tentries[cpPath] = object.TreeEntry{\\n\\t\\t\\tName: cpPath,\\n\\t\\t\\tMode: filemode.Regular,\\n\\t\\t\\tHash: cpBlobHash,\\n\\t\\t}\\n\\t} else {\\n\\t\\t// Final checkpoint: add transcripts and checkpoint.json\\n\\n\\t\\t// Add session transcript (with chunking support for large transcripts)\\n\\t\\tif opts.TranscriptPath != \\\"\\\" {\\n\\t\\t\\tif transcriptContent, readErr := os.ReadFile(opts.TranscriptPath); readErr == nil {\\n\\t\\t\\t\\t// Detect agent type from content