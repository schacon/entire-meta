\\t\\t// Handle string content\\n   104→\\t\\tif str, ok := msg.Content.(string); ok {\\n   105→\\t\\t\\treturn str\\n   106→\\t\\t}\\n   107→\\n   108→\\t\\t// Handle array content (text blocks)\\n   109→\\t\\tif arr, ok := msg.Content.([]interface{}); ok {\\n   110→\\t\\t\\tvar texts []string\\n   111→\\t\\t\\tfor _, item := range arr {\\n   112→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   113→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   114→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   115→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   116→\\t\\t\\t\\t\\t\\t}\\n   117→\\t\\t\\t\\t\\t}\\n   118→\\t\\t\\t\\t}\\n   119→\\t\\t\\t}\\n   120→\\t\\t\\tif len(texts) > 0 {\\n   121→\\t\\t\\t\\treturn strings.Join(texts, \\\"\\\\n\\\\n\\\")\\n   122→\\t\\t\\t}\\n   123→\\t\\t}\\n   124→\\t}\\n   125→\\treturn \\\"\\\"\\n   126→}\\n   127→\\n   128→// TruncateAtUUID returns transcript lines up to and including the line with given UUID\\n   129→func TruncateAtUUID(lines []TranscriptLine, uuid string) []TranscriptLine {\\n   130→\\tif uuid == \\\"\\\" {\\n   131→\\t\\treturn lines\\n   132→\\t}\\n   133→\\n   134→\\tfor i, line := range lines {\\n   135→\\t\\tif line.UUID == uuid {\\n   136→\\t\\t\\treturn lines[:i+1]\\n   137→\\t\\t}\\n   138→\\t}\\n   139→\\n   140→\\t// UUID not found, return full transcript\\n   141→\\treturn lines\\n   142→}\\n   143→\\n   144→// toolResultBlock represents a tool_result in a user message\\n   145→type toolResultBlock struct {\\n   146→\\tType      string `json:\\\"type\\\"`\\n   147→\\tToolUseID string `json:\\\"tool_use_id\\\"`\\n   148→}\\n   149→\\n   150→// userMessageWithToolResults represents a user message that may contain tool results\"}]},\"uuid\":\"9bd633fd-8999-4d75-85b1-1b49ff85a69c\",\"timestamp\":\"2026-03-02T23:46:05.615Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adc16565cae9c0b13\"},\"toolUseID\":\"agent_msg_01H7gniE