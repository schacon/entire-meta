  338→\\t\\t\\treturn true\\n   339→\\t\\t}\\n   340→\\t}\\n   341→\\treturn false\\n   342→}\\n   343→\\n   344→// filesWithRemainingAgentChanges returns files from filesTouched that still have\\n   345→// uncommitted agent changes. This is used for carry-forward after partial commits.\\n   346→//\\n   347→// A file has remaining agent changes if:\\n   348→//   - It wasn't committed at all (not in committedFiles), OR\\n   349→//   - It was committed but the committed content doesn't match the shadow branch\\n   350→//     (user committed partial changes, e.g., via git add -p)\\n   351→//\\n   352→// Falls back to file-level subtraction if shadow branch is unavailable.\\n   353→func filesWithRemainingAgentChanges(\\n   354→\\trepo *git.Repository,\\n   355→\\tshadowBranchName string,\\n   356→\\theadCommit *object.Commit,\\n   357→\\tfilesTouched []string,\\n   358→\\tcommittedFiles map[string]struct{},\\n   359→) []string {\\n   360→\\tlogCtx := logging.WithComponent(context.Background(), \\\"checkpoint\\\")\\n   361→\\n   362→\\t// Get HEAD commit tree (the committed content)\\n   363→\\tcommitTree, err := headCommit.Tree()\\n   364→\\tif err != nil {\\n   365→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: failed to get commit tree, falling back to file subtraction\\\",\\n   366→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   367→\\t\\t)\\n   368→\\t\\treturn subtractFilesByName(filesTouched, committedFiles)\\n   369→\\t}\\n   370→\\n   371→\\t// Get shadow branch tree (the session's full content)\\n   372→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   373→\\tshadowRef, err := repo.Reference(refName, true)\\n   374→\\tif err != nil {\\n   375→\\t\\tlogging.Debug(logCtx, \\\"filesWithRemainingAgentChanges: shadow branch not found, falling back to file subtraction\\\",\\n   376→\\t\\t\\tslog.String(\\\"branch\\\", shadowBranchName),\\n   377→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   378→\\t\\t)\\n   379→\\t\