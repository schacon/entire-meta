e/cli/logging\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\n    27→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    29→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    30→)\\n    31→\\n    32→// listCheckpoints returns all checkpoints from the metadata branch.\\n    33→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    34→func (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n    35→\\tstore, err := s.getCheckpointStore()\\n    36→\\tif err != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    38→\\t}\\n    39→\\n    40→\\tcommitted, err := store.ListCommitted(context.Background())\\n    41→\\tif err != nil {\\n    42→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    43→\\t}\\n    44→\\n    45→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    46→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    47→\\tfor _, c := range committed {\\n    48→\\t\\tresult = append(result, CheckpointInfo{\\n    49→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    50→\\t\\t\\tSessionID:        c.SessionID,\\n    51→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    52→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    53→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    54→\\t\\t\\tAgent:            c.Agent,\\n    55→\\t\\t\\tIsTask:           c.IsTask,\\n    56→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    57→\\t\\t\\tSessionCount:     c.SessionCount,\\n    58→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    59→\\t\\t})\\n    60→\\t}\\n    61→\\n    62→\\treturn result, nil\\n    63→}\\n    64→\\n    65→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    66→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    67→\\tall, err := s.listCheckpoints()\\n    68→\\tif err != nil {\\n    69→\\t\\treturn nil, err\\n    70→\\t}\\n    71→\\n    72→\\tvar result []CheckpointInfo\\n    73→\\tfor _, cp := range all {\\n    74→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    75→\\t\\t\\tresult = append(result, cp)\\n    76→\\t\\t}\\n    77→\\t}\\n    78→\\n    79→\\tif len(result) == 0 {\\n    80→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    81→\\t}\\n    82→\\n    83→\\treturn result, nil\\n    84→}\\n    85→\\n    86→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    87→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    88→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    89→\\tstore, err := s.getCheckpointStore()\\n    90→\\tif err != nil {\\n    91→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    92→\\t}\\n    93→\\n    94→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    95→\\tif err != nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    97→\\t}\\n    98→\\tif content == nil {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\tif len(content.Transcript) == 0 {\\n   102→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   103→\\t}\\n   104→\\n   105→\\treturn content.Transcript, nil\\n   106→}\\n   107→\\n   108→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   109→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   110→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   111→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   112→//\\n   113→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   114→// In this case, data is extracted from the live transcript instead.\\n   115→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}) (*CondenseResult, error) {\\n   116→\\t// Get shadow branch (may not exist for mid-session commits)\\n   117→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   118→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\thasShadowBranch := err == nil\\n   121→\\n   122→\\tvar sessionData *ExtractedSessionData\\n   123→\\tif hasShadowBranch {\\n   124→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   125→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   126→\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   127→\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n   128→\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n   129→\\t\\t// last turn had no code changes).\\n   130→\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   131→\\t\\tsessionData, err = s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n   132→\\t\\tif err != nil {\\n   133→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   134→\\t\\t}\\n   135→\\t} else {\\n   136→\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n   137→\\t\\t// Extract data directly from live transcript.\\n   138→\\t\\tif state.TranscriptPath == \\\"\\\" {\\n   139→\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n   140→\\t\\t}\\n   141→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   142→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   143→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   144→\\t\\tif state.Phase.IsActive() {\\n   145→\\t\\t\\tprepareTranscriptIfNeeded(state.AgentType, state.TranscriptPath)\\n   146→\\t\\t}\\n   147→\\t\\tsessionData, err = s.extractSessionDataFromLiveTranscript(state)\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", err)\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\n   153→\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n   154→\\t// committed in this specific commit. This ensures each checkpoint represents\\n   155→\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n   156→\\tif len(committedFiles) > 0 {\\n   157→\\t\\t// Track if we had files before filtering to distinguish between:\\n   158→\\t\\t// - Session had files but none were committed (don't fallback)\\n   159→\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n   160→\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n   161→\\n   162→\\t\\tif hadFilesBeforeFiltering {\\n   163→\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n   164→\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n   165→\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n   166→\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n   167→\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n   168→\\t\\t\\t\\t}\\n   169→\\t\\t\\t}\\n   170→\\t\\t\\tsessionData.FilesTouched = filtered\\n   171→\\t\\t}\\n   172→\\n   173→\\t\\t// Only use committedFiles as fallback for genuine mid-session commits where\\n   174→\\t\\t// no files were tracked yet (extraction returned empty). Do NOT fallback when\\n   175→\\t\\t// the session had files that simply didn't overlap with the commit - that\\n   176→\\t\\t// indicates an unrelated session that shouldn't have its files_touched\\n   177→\\t\\t// overwritten with unrelated committed files.\\n   178→\\t\\tif len(sessionData.FilesTouched) == 0 && !hadFilesBeforeFiltering {\\n   179→\\t\\t\\tsessionData.FilesTouched = make([]string, 0, len(committedFiles))\\n   180→\\t\\t\\tfor f := range committedFiles {\\n   181→\\t\\t\\t\\tsessionData.FilesTouched = append(sessionData.FilesTouched, f)\\n   182→\\t\\t\\t}\\n   183→\\t\\t}\\n   184→\\t}\\n   185→\\n   186→\\t// Get checkpoint store\\n   187→\\tstore, err := s.getCheckpointStore()\\n   188→\\tif err != nil {\\n   189→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\t// Get author info\\n   193→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   194→\\t// Calculate attribution. When no shadow branch exists (agent committed mid-turn\\n   195→\\t// before SaveStep), pass nil ref — the function uses HEAD as the shadow tree\\n   196→\\t// since the agent's commit IS HEAD (no user edits between agent work and commit).\\n   197→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   198→\\t// Get current branch name\\n   199→\\tbranchName := GetCurrentBranchName(repo)\\n   200→\\n   201→\\t// Generate summary if enabled\\n   202→\\tvar summary *cpkg.Summary\\n   203→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   204→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   205→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   206→\\n   207→\\t\\t// Scope transcript to this checkpoint's portion.\\n   208→\\t\\t// For Claude Code (JSONL), CheckpointTranscriptStart is a line offset.\\n   209→\\t\\t// For Gemini/OpenCode (JSON), CheckpointTranscriptStart is a message index.\\n   210→\\t\\tvar scopedTranscript []byte\\n   211→\\t\\tswitch state.AgentType {\\n   212→\\t\\tcase agent.AgentTypeGemini:\\n   213→\\t\\t\\tscoped, sliceErr := geminicli.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   214→\\t\\t\\tif sliceErr != nil {\\n   215→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope Gemini transcript for summary\\\",\\n   216→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   217→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   218→\\t\\t\\t}\\n   219→\\t\\t\\tscopedTranscript = scoped\\n   220→\\t\\tcase agent.AgentTypeOpenCode:\\n   221→\\t\\t\\tscoped, sliceErr := opencode.SliceFromMessage(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   222→\\t\\t\\tif sliceErr != nil {\\n   223→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"failed to scope OpenCode transcript for summary\\\",\\n   224→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   225→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", sliceErr.Error()))\\n   226→\\t\\t\\t}\\n   227→\\t\\t\\tscopedTranscript = scoped\\n   228→\\t\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeCursor, agent.AgentTypeUnknown:\\n   229→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   230→\\t\\t}\\n   231→\\t\\tif len(scopedTranscript) > 0 {\\n   232→\\t\\t\\tvar err error\\n   233→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, state.AgentType, nil)\\n   234→\\t\\t\\tif err != nil {\\n   235→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   236→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   237→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   238→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   239→\\t\\t\\t} else {\\n   240→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   241→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   242→\\t\\t\\t}\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\n   246→\\t// Write checkpoint metadata using the checkpoint store\\n   247→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   248→\\t\\tCheckpointID:                checkpointID,\\n   249→\\t\\tSessionID:                   state.SessionID,\\n   250→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   251→\\t\\tBranch:                      branchName,\\n   252→\\t\\tTranscript:                  sessionData.Transcript,\\n   253→\\t\\tPrompts:                     sessionData.Prompts,\\n   254→\\t\\tContext:                     sessionData.Context,\\n   255→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   256→\\t\\tCheckpointsCount:            state.StepCount,\\n   257→\\t\\tEphemeralBranch:             shadowBranchName,\\n   258→\\t\\tAuthorName:                  authorName,\\n   259→\\t\\tAuthorEmail:                 authorEmail,\\n   260→\\t\\tAgent:                       state.AgentType,\\n   261→\\t\\tTurnID:                      state.TurnID,\\n   262→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   263→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   264→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   265→\\t\\tInitialAttribution:          attribution,\\n   266→\\t\\tSummary:                     summary,\\n   267→\\t}); err != nil {\\n   268→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\treturn &CondenseResult{\\n   272→\\t\\tCheckpointID:         checkpointID,\\n   273→\\t\\tSessionID:            state.SessionID,\\n   274→\\t\\tCheckpointsCount:     state.StepCount,\\n   275→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   276→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   277→\\t}, nil\\n   278→}\\n   279→\\n   280→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   281→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   282→\\t// This uses user edits captured at each prompt start (before agent works),\\n   283→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   284→\\t//\\n   285→\\t// When shadowRef is nil (agent committed mid-turn before SaveStep),\\n   286→\\t// HEAD is used as the shadow tree. This is correct because the agent's\\n   287→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   288→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   289→\\n   290→\\theadRef, headErr := repo.Head()\\n   291→\\tif headErr != nil {\\n   292→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   293→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   294→\\t\\treturn nil\\n   295→\\t}\\n   296→\\n   297→\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   298→\\tif commitErr != nil {\\n   299→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   300→\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   301→\\t\\treturn nil\\n   302→\\t}\\n   303→\\n   304→\\theadTree, treeErr := headCommit.Tree()\\n   305→\\tif treeErr != nil {\\n   306→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   307→\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   308→\\t\\treturn nil\\n   309→\\t}\\n   310→\\n   311→\\t// Get shadow tree: from shadow branch if available, otherwise HEAD (agent committed directly).\\n   312→\\tvar shadowTree *object.Tree\\n   313→\\tif shadowRef != nil {\\n   314→\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   315→\\t\\tif shadowErr != nil {\\n   316→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   317→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   318→\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   319→\\t\\t\\treturn nil\\n   320→\\t\\t}\\n   321→\\t\\tvar shadowTreeErr error\\n   322→\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   323→\\t\\tif shadowTreeErr != nil {\\n   324→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   325→\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   326→\\t\\t\\treturn nil\\n   327→\\t\\t}\\n   328→\\t} else {\\n   329→\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   330→\\t\\t// because the agent's work is the commit itself.\\n   331→\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   332→\\t\\tshadowTree = headTree\\n   333→\\t}\\n   334→\\n   335→\\t// Get base tree (state before session started)\\n   336→\\tvar baseTree *object.Tree\\n   337→\\tattrBase := state.AttributionBaseCommit\\n   338→\\tif attrBase == \\\"\\\" {\\n   339→\\t\\tattrBase = state.BaseCommit // backward compat\\n   340→\\t}\\n   341→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   342→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   343→\\t\\t\\tbaseTree = tree\\n   344→\\t\\t} else {\\n   345→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   346→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   347→\\t\\t}\\n   348→\\t} else {\\n   349→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   350→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   351→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   352→\\t}\\n   353→\\n   354→\\t// Log accumulated prompt attributions for debugging\\n   355→\\tvar totalUserAdded, totalUserRemoved int\\n   356→\\tfor i, pa := range state.PromptAttributions {\\n   357→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   358→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   359→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   360→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   361→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   362→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   363→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   364→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   365→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   366→\\t}\\n   367→\\n   368→\\tattribution := CalculateAttributionWithAccumulated(\\n   369→\\t\\tbaseTree,\\n   370→\\t\\tshadowTree,\\n   371→\\t\\theadTree,\\n   372→\\t\\tsessionData.FilesTouched,\\n   373→\\t\\tstate.PromptAttributions,\\n   374→\\t)\\n   375→\\n   376→\\tif attribution != nil {\\n   377→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   378→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   379→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   380→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   381→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   382→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   383→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   384→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   385→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   386→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   387→\\t}\\n   388→\\n   389→\\treturn attribution\\n   390→}\\n   391→\\n   392→// extractSessionData extracts session data from the shadow branch.\\n   393→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   394→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   395→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   396→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   397→// continued growing — the shadow branch copy would be stale.\\n   398→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   399→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   400→\\tcommit, err := repo.CommitObject(shadowRef)\\n   401→\\tif err != nil {\\n   402→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   403→\\t}\\n   404→\\n   405→\\ttree, err := commit.Tree()\\n   406→\\tif err != nil {\\n   407→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   408→\\t}\\n   409→\\n   410→\\tdata := &ExtractedSessionData{}\\n   411→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   412→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   413→\\n   414→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   415→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   416→\\t// (SaveStep is only called when there are file modifications).\\n   417→\\tvar fullTranscript string\\n   418→\\tif liveTranscriptPath != \\\"\\\" {\\n   419→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   420→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   421→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   422→\\t\\tif isActive {\\n   423→\\t\\t\\tprepareTranscriptIfNeeded(agentType, liveTranscriptPath)\\n   424→\\t\\t}\\n   425→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   426→\\t\\t\\tfullTranscript = string(liveData)\\n   427→\\t\\t}\\n   428→\\t}\\n   429→\\tif fullTranscript == \\\"\\\" {\\n   430→\\t\\t// Fall back to shadow branch copy\\n   431→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   432→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   433→\\t\\t\\t\\tfullTranscript = content\\n   434→\\t\\t\\t}\\n   435→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   436→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   437→\\t\\t\\t\\tfullTranscript = content\\n   438→\\t\\t\\t}\\n   439→\\t\\t}\\n   440→\\t}\\n   441→\\n   442→\\t// Process transcript based on agent type\\n   443→\\tif fullTranscript != \\\"\\\" {\\n   444→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   445→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   446→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   447→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   448→\\t}\\n   449→\\n   450→\\t// Use tracked files from session state (not all files in tree)\\n   451→\\tdata.FilesTouched = filesTouched\\n   452→\\n   453→\\t// Calculate token usage from the extracted transcript portion\\n   454→\\tif len(data.Transcript) > 0 {\\n   455→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   456→\\t}\\n   457→\\n   458→\\treturn data, nil\\n   459→}\\n   460→\\n   461→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   462→// This is used for mid-session commits where no shadow branch exists yet.\\n   463→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(state *SessionState) (*ExtractedSessionData, error) {\\n   464→\\tdata := &ExtractedSessionData{}\\n   465→\\n   466→\\t// Read the live transcript\\n   467→\\tif state.TranscriptPath == \\\"\\\" {\\n   468→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   469→\\t}\\n   470→\\n   471→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   472→\\tif err != nil {\\n   473→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   474→\\t}\\n   475→\\n   476→\\tif len(liveData) == 0 {\\n   477→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   478→\\t}\\n   479→\\n   480→\\tfullTranscript := string(liveData)\\n   481→\\tdata.Transcript = liveData\\n   482→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   483→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   484→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   485→\\n   486→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   487→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   488→\\tif len(state.FilesTouched) > 0 {\\n   489→\\t\\tdata.FilesTouched = state.FilesTouched\\n   490→\\t} else {\\n   491→\\t\\t// Use the shared helper which includes subagent transcripts\\n   492→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(state, state.CheckpointTranscriptStart)\\n   493→\\t}\\n   494→\\n   495→\\t// Calculate token usage from the extracted transcript portion\\n   496→\\tif len(data.Transcript) > 0 {\\n   497→\\t\\tdata.TokenUsage = calculateTokenUsage(state.AgentType, data.Transcript, state.CheckpointTranscriptStart)\\n   498→\\t}\\n   499→\\n   500→\\treturn data, nil\\n   501→}\\n   502→\\n   503→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   504→// For Claude Code and JSONL-based agents, this counts lines.\\n   505→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   506→// Returns 0 if the content is empty or malformed.\\n   507→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   508→\\tif content == \\\"\\\" {\\n   509→\\t\\treturn 0\\n   510→\\t}\\n   511→\\n   512→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   513→\\tif agentType == agent.AgentTypeOpenCode {\\n   514→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   515→\\t\\tif err == nil && session != nil {\\n   516→\\t\\t\\treturn len(session.Messages)\\n   517→\\t\\t}\\n   518→\\t\\treturn 0\\n   519→\\t}\\n   520→\\n   521→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   522→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   523→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   524→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   525→\\t\\t\\treturn len(transcript.Messages)\\n   526→\\t\\t}\\n   527→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   528→\\t\\tif agentType == agent.AgentTypeGemini {\\n   529→\\t\\t\\treturn 0\\n   530→\\t\\t}\\n   531→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   532→\\t}\\n   533→\\n   534→\\t// Claude Code and other JSONL-based agents\\n   535→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   536→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   537→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   538→\\t\\tallLines = allLines[:len(allLines)-1]\\n   539→\\t}\\n   540→\\treturn len(allLines)\\n   541→}\\n   542→\\n   543→// extractUserPrompts extracts all user prompts from transcript content.\\n   544→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   545→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   546→\\tif content == \\\"\\\" {\\n   547→\\t\\treturn nil\\n   548→\\t}\\n   549→\\n   550→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   551→\\tif agentType == agent.AgentTypeOpenCode {\\n   552→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   553→\\t\\tif err == nil && len(prompts) > 0 {\\n   554→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   555→\\t\\t\\tfor _, prompt := range prompts {\\n   556→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   557→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   558→\\t\\t\\t\\t}\\n   559→\\t\\t\\t}\\n   560→\\t\\t\\treturn cleaned\\n   561→\\t\\t}\\n   562→\\t\\treturn nil\\n   563→\\t}\\n   564→\\n   565→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   566→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   567→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   568→\\t\\tif err == nil && len(prompts) > 0 {\\n   569→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   570→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   571→\\t\\t\\tfor _, prompt := range prompts {\\n   572→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   573→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   574→\\t\\t\\t\\t}\\n   575→\\t\\t\\t}\\n   576→\\t\\t\\treturn cleaned\\n   577→\\t\\t}\\n   578→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   579→\\t\\tif agentType == agent.AgentTypeGemini {\\n   580→\\t\\t\\treturn nil\\n   581→\\t\\t}\\n   582→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   583→\\t}\\n   584→\\n   585→\\t// Claude Code and other JSONL-based agents\\n   586→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   587→}\\n   588→\\n   589→// calculateTokenUsage calculates token usage from raw transcript data.\\n   590→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   591→// where the current checkpoint began, allowing calculation for only the portion\\n   592→// of the transcript since the last checkpoint.\\n   593→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   594→\\t// No token usage information from Cursor yet\\n   595→\\tif agentType == agent.AgentTypeCursor {\\n   596→\\t\\treturn nil\\n   597→\\t}\\n   598→\\n   599→\\tif len(data) == 0 {\\n   600→\\t\\treturn &agent.TokenUsage{}\\n   601→\\t}\\n   602→\\n   603→\\t// OpenCode uses JSONL with token info on assistant messages (different schema from Claude Code)\\n   604→\\tif agentType == agent.AgentTypeOpenCode {\\n   605→\\t\\treturn opencode.CalculateTokenUsageFromBytes(data, startOffset)\\n   606→\\t}\\n   607→\\n   608→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   609→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   610→\\t\\t// Attempt to parse as Gemini JSON\\n   611→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   612→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   613→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   614→\\t\\t}\\n   615→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   616→\\t\\tif agentType == agent.AgentTypeGemini {\\n   617→\\t\\t\\treturn &agent.TokenUsage{}\\n   618→\\t\\t}\\n   619→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   620→\\t}\\n   621→\\n   622→\\t// Claude Code and other JSONL-based agents\\n   623→\\tlines, err := transcript.ParseFromBytes(data)\\n   624→\\tif err != nil || len(lines) == 0 {\\n   625→\\t\\treturn &agent.TokenUsage{}\\n   626→\\t}\\n   627→\\t// Slice transcript lines to only include checkpoint portion\\n   628→\\tif startOffset > 0 && startOffset < len(lines) {\\n   629→\\t\\tlines = lines[startOffset:]\\n   630→\\t}\\n   631→\\treturn claudecode.CalculateTokenUsage(lines)\\n   632→}\\n   633→\\n   634→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   635→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   636→func extractUserPromptsFromLines(lines []string) []string {\\n   637→\\tvar prompts []string\\n   638→\\tfor _, line := range lines {\\n   639→\\t\\tline = strings.TrimSpace(line)\\n   640→\\t\\tif line == \\\"\\\" {\\n   641→\\t\\t\\tcontinue\\n   642→\\t\\t}\\n   643→\\n   644→\\t\\tvar entry map[string]interface{}\\n   645→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   646→\\t\\t\\tcontinue\\n   647→\\t\\t}\\n   648→\\n   649→\\t\\t// Check for user message:\\n   650→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   651→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   652→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   653→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   654→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   655→\\t\\tif !isUser {\\n   656→\\t\\t\\tcontinue\\n   657→\\t\\t}\\n   658→\\n   659→\\t\\t// Extract message content\\n   660→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   661→\\t\\tif !ok {\\n   662→\\t\\t\\tcontinue\\n   663→\\t\\t}\\n   664→\\n   665→\\t\\t// Handle string content\\n   666→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   667→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   668→\\t\\t\\tif cleaned != \\\"\\\" {\\n   669→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   670→\\t\\t\\t}\\n   671→\\t\\t\\tcontinue\\n   672→\\t\\t}\\n   673→\\n   674→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   675→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   676→\\t\\t\\tvar texts []string\\n   677→\\t\\t\\tfor _, item := range arr {\\n   678→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   679→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   680→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   681→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   682→\\t\\t\\t\\t\\t\\t}\\n   683→\\t\\t\\t\\t\\t}\\n   684→\\t\\t\\t\\t}\\n   685→\\t\\t\\t}\\n   686→\\t\\t\\tif len(texts) > 0 {\\n   687→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   688→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   689→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   690→\\t\\t\\t\\t}\\n   691→\\t\\t\\t}\\n   692→\\t\\t}\\n   693→\\t}\\n   694→\\treturn prompts\\n   695→}\\n   696→\\n   697→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   698→func generateContextFromPrompts(prompts []string) []byte {\\n   699→\\tif len(prompts) == 0 {\\n   700→\\t\\treturn nil\\n   701→\\t}\\n   702→\\n   703→\\tvar buf strings.Builder\\n   704→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   705→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   706→\\n   707→\\tfor i, prompt := range prompts {\\n   708→\\t\\t// Truncate very long prompts for readability.\\n   709→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   710→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, 500, \\\"...\\\")\\n   711→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   712→\\t\\tbuf.WriteString(displayPrompt)\\n   713→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   714→\\t}\\n   715→\\n   716→\\treturn []byte(buf.String())\\n   717→}\\n   718→\\n   719→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   720→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   721→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   722→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   723→\\n   724→\\t// Load session state\\n   725→\\tstate, err := s.loadSessionState(sessionID)\\n   726→\\tif err != nil {\\n   727→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   728→\\t}\\n   729→\\tif state == nil {\\n   730→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   731→\\t}\\n   732→\\n   733→\\t// Open repository\\n   734→\\trepo, err := OpenRepository()\\n   735→\\tif err != nil {\\n   736→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   737→\\t}\\n   738→\\n   739→\\t// Generate a checkpoint ID\\n   740→\\tcheckpointID, err := id.Generate()\\n   741→\\tif err != nil {\\n   742→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   743→\\t}\\n   744→\\n   745→\\t// Check if shadow branch exists (required for condensation)\\n   746→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   747→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   748→\\t_, refErr := repo.Reference(refName, true)\\n   749→\\thasShadowBranch := refErr == nil\\n   750→\\n   751→\\tif !hasShadowBranch {\\n   752→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   753→\\t\\t// Just clean up the state file.\\n   754→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   755→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   756→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   757→\\t\\t)\\n   758→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   759→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   760→\\t\\t}\\n   761→\\t\\treturn nil\\n   762→\\t}\\n   763→\\n   764→\\t// Condense the session\\n   765→\\tresult, err := s.CondenseSession(repo, checkpointID, state, nil)\\n   766→\\tif err != nil {\\n   767→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   768→\\t}\\n   769→\\n   770→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   771→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   772→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   773→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   774→\\t)\\n   775→\\n   776→\\t// Update session state: reset step count and transition to idle\\n   777→\\tstate.StepCount = 0\\n   778→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   779→\\tstate.Phase = session.PhaseIdle\\n   780→\\tstate.LastCheckpointID = checkpointID\\n   781→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   782→\\tstate.PromptAttributions = nil\\n   783→\\tstate.PendingPromptAttribution = nil\\n   784→\\n   785→\\tif err := s.saveSessionState(state); err != nil {\\n   786→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   787→\\t}\\n   788→\\n   789→\\t// Clean up shadow branch if no other sessions need it\\n   790→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   791→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   792→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   793→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   794→\\t\\t)\\n   795→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   796→\\t}\\n   797→\\n   798→\\treturn nil\\n   799→}\\n   800→\\n   801→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   802→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   803→\\t// List all session states to check if any other session uses this shadow branch\\n   804→\\tallStates, err := s.listAllSessionStates()\\n   805→\\tif err != nil {\\n   806→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   807→\\t}\\n   808→\\n   809→\\tfor _, state := range allStates {\\n   810→\\t\\tif state.SessionID == excludeSessionID {\\n   811→\\t\\t\\tcontinue\\n   812→\\t\\t}\\n   813→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   814→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   815→\\t\\t\\t// Another session still needs this shadow branch\\n   816→\\t\\t\\treturn nil\\n   817→\\t\\t}\\n   818→\\t}\\n   819→\\n   820→\\t// No other sessions need it, delete the shadow branch via CLI\\n   821→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   822→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   823→\\t\\t// Branch already gone is not an error\\n   824→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   825→\\t\\t\\treturn nil\\n   826→\\t\\t}\\n   827→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   828→\\t}\\n   829→\\treturn nil\\n   830→}\\n   831→\"}]},\"uuid\":\"9309460d-2b67-4b9d-b634-1b291b00996b\",\"