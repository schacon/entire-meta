 []string\\n    33→}\\n    34→\\n    35→// ExtractAllPromptResponses extracts all user prompt and assistant response pairs from a transcript.\\n    36→// Returns pairs in chronological order (oldest first).\\n    37→// Each pair contains the user's prompt, assistant's text response, and files modified.\\n    38→func ExtractAllPromptResponses(transcript []transcriptLine) []PromptResponsePair {\\n    39→\\tvar pairs []PromptResponsePair\\n    40→\\n    41→\\t// Find all user prompts (messages with string content, not tool results)\\n    42→\\tvar userIndices []int\\n    43→\\tfor i, line := range transcript {\\n    44→\\t\\tif line.Type == transcriptTypeUser {\\n    45→\\t\\t\\tvar msg userMessage\\n    46→\\t\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n    47→\\t\\t\\t\\tcontinue\\n    48→\\t\\t\\t}\\n    49→\\t\\t\\t// Only count messages with string content (real user prompts)\\n    50→\\t\\t\\tif _, ok := msg.Content.(string); ok {\\n    51→\\t\\t\\t\\tuserIndices = append(userIndices, i)\\n    52→\\t\\t\\t} else if arr, ok := msg.Content.([]interface{}); ok {\\n    53→\\t\\t\\t\\t// Check if array has text blocks (also a real user prompt)\\n    54→\\t\\t\\t\\tfor _, item := range arr {\\n    55→\\t\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n    56→\\t\\t\\t\\t\\t\\tif m[\\\"type\\\"] == contentTypeText {\\n    57→\\t\\t\\t\\t\\t\\t\\tuserIndices = append(userIndices, i)\\n    58→\\t\\t\\t\\t\\t\\t\\tbreak\\n    59→\\t\\t\\t\\t\\t\\t}\\n    60→\\t\\t\\t\\t\\t}\\n    61→\\t\\t\\t\\t}\\n    62→\\t\\t\\t}\\n    63→\\t\\t}\\n    64→\\t}\\n    65→\\n    66→\\t// For each user prompt, extract the prompt text, following assistant response, and files\\n    67→\\tfor idx, userIdx := range userIndices {\\n    68→\\t\\t// Determine the range for this prompt's conversation\\n    69→\\t\\tendIdx := len(transcript)\\n    70→\\t\\tif idx < len(userIndices)-1 {\\n    71→\\t\\t\\tendIdx = userIndices[idx+1]\\n    72→\\t\\t}\\n    73→\\n    74→\\t\\t// Extract prompt text\\n    75→\\t\\tprompt := extractUserPromptAt(transcript, userIdx)\\n    76→\\t\\tif prompt == \\\"\\\" {\\n    77→\\t\\t\\tcontinue\\n    78→\\t\\t}\\n    79→\\n    80→\\t\\t// Extract assistant responses and files from this range\\n    81→\\t\\tslice := transcript[userIdx:endIdx]\\n    82→\\t\\tresponses := extractAssistantResponses(slice)\\n    83→\\t\\tfiles := extractModifiedFiles(slice)\\n    84→\\n    85→\\t\\tpairs = append(pairs, PromptResponsePair{\\n    86→\\t\\t\\tPrompt:    prompt,\\n    87→\\t\\t\\tResponses: responses,\\n    88→\\t\\t\\tFiles:     files,\\n    89→\\t\\t})\\n    90→\\t}\\n    91→\\n    92→\\treturn pairs\\n    93→}\\n    94→\\n    95→// extractUserPromptAt extracts the user prompt at the given index.\\n    96→// IDE-injected context tags (like <ide_opened_file>) are stripped from the result.\\n    97→func extractUserPromptAt(lines []transcriptLine, idx int) string {\\n    98→\\tif idx >= len(lines) || lines[idx].Type != transcriptTypeUser {\\n    99→\\t\\treturn \\\"\\\"\\n   100→\\t}\\n   101→\\n   102→\\treturn transcript.ExtractUserContent(lines[idx].Message)\\n   103→}\\n   104→\\n   105→// extractAssistantResponses collects all assistant text blocks from the given transcript slice.\\n   106→// A single prompt can trigger multiple assistant responses interspersed with tool calls.\\n   107→func extractAssistantResponses(transcript []transcriptLine) []string {\\n   108→\\tvar texts []string\\n   109→\\tfor _, line := range transcript {\\n   110→\\t\\tif line.Type == transcriptTypeAssistant {\\n   111→\\t\\t\\tvar msg assistantMessage\\n   112→\\t\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   113→\\t\\t\\t\\tcontinue\\n   114→\\t\\t\\t}\\n   115→\\n   116→\\t\\t\\tfor _, block := range msg.Content {\\n   117→\\t\\t\\t\\tif block.Type == contentTypeText && block.Text != \\\"\\\" {\\n   118→\\t\\t\\t\\t\\ttexts = append(texts, block.Text)\\n   119→\\t\\t\\t\\t}\\n   120→\\t\\t\\t}\\n   121→\\t\\t}\\n   122→\\t}\\n   123→\\treturn texts\\n   124→}\\n   125→\\n   126→// extractUserPrompts extracts all user messages from the transcript in order.\\n   127→// Only considers messages with string content (not tool results).\\n   128→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   129→func extractUserPrompts(transcript []transcriptLine) []string {\\n   130→\\tvar prompts []string\\n   131→\\tfor i := range transcript {\\n   132→\\t\\tif transcript[i].Type != transcriptTypeUser {\\n   133→\\t\\t\\tcontinue\\n   134→\\t\\t}\\n   135→\\t\\tvar msg userMessage\\n   136→\\t\\tif err := json.Unmarshal(transcript[i].Message, &msg); err != nil {\\n   137→\\t\\t\\tcontinue\\n   138→\\t\\t}\\n   139→\\n   140→\\t\\t// Handle string content\\n   141→\\t\\tif str, ok := msg.Content.(string); ok {\\n   142→\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(str))\\n   143→\\t\\t\\tcontinue\\n   144→\\t\\t}\\n   145→\\n   146→\\t\\t// Handle array content (only if it contains text blocks)\\n   147→\\t\\tif arr, ok := msg.Content.([]interface{}); ok {\\n   148→\\t\\t\\tvar texts []string\\n   149→\\t\\t\\tfor _, item := range arr {\\n   150→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   151→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == contentTypeText {\\n   152→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   153→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   154→\\t\\t\\t\\t\\t\\t}\\n   155→\\t\\t\\t\\t\\t}\\n   156→\\t\\t\\t\\t}\\n   157→\\t\\t\\t}\\n   158→\\t\\t\\tif len(texts) > 0 {\\n   159→\\t\\t\\t\\tprompts = append(prompts, textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\")))\\n   160→\\t\\t\\t}\\n   161→\\t\\t}\\n   162→\\t}\\n   163→\\treturn prompts\\n   164→}\\n   165→\\n   166→// extractLastUserPrompt extracts the last user message from the transcript.\\n   167→// Only considers messages with string content (not tool results).\\n   168→// IDE-inj