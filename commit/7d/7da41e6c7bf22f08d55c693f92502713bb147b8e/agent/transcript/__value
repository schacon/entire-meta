.Type != MessageTypeGemini {\\n   118→\\t\\t\\tcontinue\\n   119→\\t\\t}\\n   120→\\n   121→\\t\\t// Process tool calls in this message\\n   122→\\t\\tfor _, toolCall := range msg.ToolCalls {\\n   123→\\t\\t\\t// Check if it's a file modification tool\\n   124→\\t\\t\\tisModifyTool := false\\n   125→\\t\\t\\tfor _, name := range FileModificationTools {\\n   126→\\t\\t\\t\\tif toolCall.Name == name {\\n   127→\\t\\t\\t\\t\\tisModifyTool = true\\n   128→\\t\\t\\t\\t\\tbreak\\n   129→\\t\\t\\t\\t}\\n   130→\\t\\t\\t}\\n   131→\\n   132→\\t\\t\\tif !isModifyTool {\\n   133→\\t\\t\\t\\tcontinue\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\t// Extract file path from args map\\n   137→\\t\\t\\tvar file string\\n   138→\\t\\t\\tif fp, ok := toolCall.Args[\\\"file_path\\\"].(string); ok && fp != \\\"\\\" {\\n   139→\\t\\t\\t\\tfile = fp\\n   140→\\t\\t\\t} else if p, ok := toolCall.Args[\\\"path\\\"].(string); ok && p != \\\"\\\" {\\n   141→\\t\\t\\t\\tfile = p\\n   142→\\t\\t\\t} else if fn, ok := toolCall.Args[\\\"filename\\\"].(string); ok && fn != \\\"\\\" {\\n   143→\\t\\t\\t\\tfile = fn\\n   144→\\t\\t\\t}\\n   145→\\n   146→\\t\\t\\tif file != \\\"\\\" && !fileSet[file] {\\n   147→\\t\\t\\t\\tfileSet[file] = true\\n   148→\\t\\t\\t\\tfiles = append(files, file)\\n   149→\\t\\t\\t}\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\n   153→\\treturn files\\n   154→}\\n   155→\\n   156→// ExtractLastUserPrompt extracts the last user message from transcript data\\n   157→func ExtractLastUserPrompt(data []byte) (string, error) {\\n   158→\\ttranscript, err := ParseTranscript(data)\\n   159→\\tif err != nil {\\n   160→\\t\\treturn \\\"\\\", err\\n   161→\\t}\\n   162→\\n   163→\\treturn ExtractLastUserPromptFromTranscript(transcript), nil\\n   164→}\\n   165→\\n   166→// ExtractLastUserPromptFromTranscript extracts the last user prompt from a parsed transcript\\n   167→func ExtractLastUserPromptFromTranscript(transcript *GeminiTranscript) string {\\n   168→\\tfor i := len(transcr