→// Package geminicli implements the Agent interface for Gemini CLI.\\n     2→package geminicli\\n     3→\\n     4→import (\\n     5→\\t\\\"context\\\"\\n     6→\\t\\\"crypto/sha256\\\"\\n     7→\\t\\\"encoding/hex\\\"\\n     8→\\t\\\"encoding/json\\\"\\n     9→\\t\\\"errors\\\"\\n    10→\\t\\\"fmt\\\"\\n    11→\\t\\\"log/slog\\\"\\n    12→\\t\\\"os\\\"\\n    13→\\t\\\"path/filepath\\\"\\n    14→\\t\\\"time\\\"\\n    15→\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    19→)\\n    20→\\n    21→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    22→func init() {\\n    23→\\tagent.Register(agent.AgentNameGemini, NewGeminiCLIAgent)\\n    24→}\\n    25→\\n    26→// GeminiCLIAgent implements the Agent interface for Gemini CLI.\\n    27→//\\n    28→//nolint:revive // GeminiCLIAgent is clearer than Agent in this context\\n    29→type GeminiCLIAgent struct{}\\n    30→\\n    31→func NewGeminiCLIAgent() agent.Agent {\\n    32→\\treturn &GeminiCLIAgent{}\\n    33→}\\n    34→\\n    35→// Name returns the agent registry key.\\n    36→func (g *GeminiCLIAgent) Name() agent.AgentName {\\n    37→\\treturn agent.AgentNameGemini\\n    38→}\\n    39→\\n    40→// Type returns the agent type identifier.\\n    41→func (g *GeminiCLIAgent) Type() agent.AgentType {\\n    42→\\treturn agent.AgentTypeGemini\\n    43→}\\n    44→\\n    45→// Description returns a human-readable description.\\n    46→func (g *GeminiCLIAgent) Description() string {\\n    47→\\treturn \\\"Gemini CLI - Google's AI coding assistant\\\"\\n    48→}\\n    49→\\n    50→func (g *GeminiCLIAgent) IsPreview() bool { return true }\\n    51→\\n    52→// DetectPresence checks if Gemini CLI is configured in the repository.\\n    53→func (g *GeminiCLIAgent) DetectPresence() (bool, error) {\\n    54→\\t// Get worktree root to check for .gemini directory\\n    55→\\t// This is needed because the CLI may be run from a subdirectory\\n    56→\\trepoRoot, err := paths.WorktreeRoot()\\n    57→\\tif err != nil {\\n    58→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    59→\\t\\trepoRoot = \\\".\\\"\\n    60→\\t}\\n    61→\\n    62→\\t// Check for .gemini directory\\n    63→\\tgeminiDir := filepath.Join(repoRoot, \\\".gemini\\\")\\n    64→\\tif _, err := os.Stat(geminiDir); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\t// Check for .gemini/settings.json\\n    68→\\tsettingsFile := filepath.Join(repoRoot, \\\".gemini\\\", \\\"settings.json\\\")\\n    69→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    70→\\t\\treturn true, nil\\n    71→\\t}\\n    72→\\treturn false, nil\\n    73→}\\n    74→\\n    75→// GetSessionID extracts the session ID from hook input.\\n    76→func (g *GeminiCLIAgent) GetSessionID(input *agent.HookInput) string {\\n    77→\\treturn input.SessionID\\n    78→}\\n    79→\\n    80→// ProtectedDirs returns directories that Gemini uses for config/state.\\n    81→func (g *GeminiCLIAgent) ProtectedDirs() []string { return []string{\\\".gemini\\\"} }\\n    82→\\n    83→// ResolveSessionFile returns the path to a Gemini session file.\\n    84→// Gemini names files as session-<date>-<shortid>.json where shortid is the first 8 chars\\n    85→// of the session UUID. This searches for an existing file matching the pattern, falling\\n    86→// back to constructing a filename matching Gemini's convention if no match is found.\\n    87→func (g *GeminiCLIAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    88→\\t// Try to find existing file matching Gemini's naming convention:\\n    89→\\t// session-*-<first8chars>.json\\n    90→\\tshortID := agentSessionID\\n    91→\\tif len(shortID) > 8 {\\n    92→\\t\\tshortID = shortID[:8]\\n    93→\\t}\\n    94→\\n    95→\\tpattern := filepath.Join(sessionDir, \\\"session-*-\\\"+shortID+\\\".json\\\")\\n    96→\\tmatches, err := filepath.Glob(pattern)\\n    97→\\tif err == nil && len(matches) > 0 {\\n    98→\\t\\t// Return the most recent match (last alphabetically, since date is in the name)\\n    99→\\t\\treturn matches[len(matches)-1]\\n   100→\\t}\\n   101→\\n   102→\\t// Fallback: construct filename matching Gemini's convention: session-<timestamp>-<id[:8]>.json\\n   103→\\ttimestamp := time.Now().UTC().Format(\\\"2006-01-02T15-04\\\")\\n   104→\\treturn filepath.Join(sessionDir, \\\"session-\\\"+timestamp+\\\"-\\\"+shortID+\\\".json\\\")\\n   105→}\\n   106→\\n   107→// GetSessionDir returns the directory where Gemini stores session transcripts.\\n   108→// Gemini stores sessions in ~/.gemini/tmp/<project-hash>/chats/\\n   109→func (g *GeminiCLIAgent) GetSessionDir(repoPath string) (string, error) {\\n   110→\\t// Check for test environment override\\n   111→\\tif override := os.Getenv(\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   112→\\t\\treturn override, nil\\n   113→\\t}\\n   114→\\n   115→\\thomeDir, err := os.UserHomeDir()\\n   116→\\tif err != nil {\\n   117→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   118→\\t}\\n   119→\\n   120→\\t// Gemini uses a SHA256 hash of the project path for the directory name\\n   121→\\tprojectDir := GetProjectHash(repoPath)\\n   122→\\treturn filepath.Join(homeDir, \\\".gemini\\\", \\\"tmp\\\", projectDir, \\\"chats\\\"), nil\\n   123→}\\n   124→\\n   125→// ReadSession reads a session from Gemini's storage (JSON transcript file).\\n   126→// The session data is stored in NativeData as raw JSON bytes.\\n   127→func (g *GeminiCLIAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   128→\\tif input.SessionRef == \\\"\\\" {\\n   129→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   130→\\t}\\n   131→\\n   132→\\t// Read the raw JSON file\\n   133→\\tdata, err := os.ReadFile(input.SessionRef)\\n   134→\\tif err != nil {\\n   135→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   136→\\t}\\n   137→\\n   138→\\t// Parse to extract computed fields\\n   139→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   140→\\tif err != nil {\\n   141→\\t\\t// Non-fatal: we can still return the session without modified files\\n   142→\\t\\tmodifiedFiles = nil\\n   143→\\t}\\n   144→\\n   145→\\treturn &agent.AgentSession{\\n   146→\\t\\tSessionID:     input.SessionID,\\n   147→\\t\\tAgentName:     g.Name(),\\n   148→\\t\\tSessionRef:    input.SessionRef,\\n   149→\\t\\tStartTime:     time.Now(),\\n   150→\\t\\tNativeData:    data,\\n   151→\\t\\tModifiedFiles: modifiedFiles,\\n   152→\\t}, nil\\n   153→}\\n   154→\\n   155→// WriteSession writes a session to Gemini's storage (JSON transcript file).\\n   156→// Uses the NativeData field which contains raw JSON bytes.\\n   157→func (g *GeminiCLIAgent) WriteSession(session *agent.AgentSession) error {\\n   158→\\tif session == nil {\\n   159→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   160→\\t}\\n   161→\\n   162→\\t// Verify this session belongs to Gemini CLI\\n   163→\\tif session.AgentName != \\\"\\\" && session.AgentName != g.Name() {\\n   164→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, g.Name())\\n   165→\\t}\\n   166→\\n   167→\\tif session.SessionRef == \\\"\\\" {\\n   168→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   169→\\t}\\n   170→\\n   171→\\tif len(session.NativeData) == 0 {\\n   172→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   173→\\t}\\n   174→\\n   175→\\t// Write the raw JSON data\\n   176→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   177→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   178→\\t}\\n   179→\\n   180→\\treturn nil\\n   181→}\\n   182→\\n   183→// FormatResumeCommand returns the command to resume a Gemini CLI session.\\n   184→func (g *GeminiCLIAgent) FormatResumeCommand(sessionID string) string {\\n   185→\\treturn \\\"gemini --resume \\\" + sessionID\\n   186→}\\n   187→\\n   188→// GetProjectHash generates a unique hash for a project based on its root path.\\n   189→// This matches Gemini CLI's getProjectHash() which uses SHA256 of the project root.\\n   190→func GetProjectHash(projectRoot string) string {\\n   191→\\thash := sha256.Sum256([]byte(projectRoot))\\n   192→\\treturn hex.EncodeToString(hash[:])\\n   193→}\\n   194→\\n   195→// TranscriptAnalyzer interface implementation\\n   196→\\n   197→// GetTranscriptPosition returns the current message count of a Gemini transcript.\\n   198→// Gemini uses JSON format with a messages array, so position is the message count.\\n   199→// Returns 0 if the file doesn't exist or is empty.\\n   200→func (g *GeminiCLIAgent) GetTranscriptPosition(path string) (int, error) {\\n   201→\\tif path == \\\"\\\" {\\n   202→\\t\\treturn 0, nil\\n   203→\\t}\\n   204→\\n   205→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   206→\\tif err != nil {\\n   207→\\t\\tif os.IsNotExist(err) {\\n   208→\\t\\t\\treturn 0, nil\\n   209→\\t\\t}\\n   210→\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\tif len(data) == 0 {\\n   214→\\t\\treturn 0, nil\\n   215→\\t}\\n   216→\\n   217→\\ttranscript, err := ParseTranscript(data)\\n   218→\\tif err != nil {\\n   219→\\t\\treturn 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   220→\\t}\\n   221→\\n   222→\\treturn len(transcript.Messages), nil\\n   223→}\\n   224→\\n   225→// ExtractModifiedFilesFromOffset extracts files modified since a given message index.\\n   226→// For Gemini (JSON format), offset is the starting message index.\\n   227→// Returns:\\n   228→//   - files: list of file paths modified by Gemini (from Write/Edit tools)\\n   229→//   - currentPosition: total number of messages in the transcript\\n   230→//   - error: any error encountered during reading\\n   231→func (g *GeminiCLIAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   232→\\tif path == \\\"\\\" {\\n   233→\\t\\treturn nil, 0, nil\\n   234→\\t}\\n   235→\\n   236→\\tdata, readErr := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   237→\\tif readErr != nil {\\n   238→\\t\\tif os.IsNotExist(readErr) {\\n   239→\\t\\t\\treturn nil, 0, nil\\n   240→\\t\\t}\\n   241→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   242→\\t}\\n   243→\\n   244→\\tif len(data) == 0 {\\n   245→\\t\\treturn nil, 0, nil\\n   246→\\t}\\n   247→\\n   248→\\ttranscript, parseErr := ParseTranscript(data)\\n   249→\\tif parseErr != nil {\\n   250→\\t\\treturn nil, 0, parseErr\\n   251→\\t}\\n   252→\\n   253→\\ttotalMessages := len(transcript.Messages)\\n   254→\\n   255→\\t// Extract files from messages starting at startOffset\\n   256→\\tfileSet := make(map[string]bool)\\n   257→\\tfor i := startOffset; i < len(transcript.Messages); i++ {\\n   258→\\t\\tmsg := transcript.Messages[i]\\n   259→\\t\\t// Only process gemini messages (assistant messages)\\n   260→\\t\\tif msg.Type != MessageTypeGemini {\\n   261→\\t\\t\\tcontinue\\n   262→\\t\\t}\\n   263→\\n   264→\\t\\t// Process tool calls in this message\\n   265→\\t\\tfor _, toolCall := range msg.ToolCalls {\\n   266→\\t\\t\\t// Check if it's a file modification tool\\n   267→\\t\\t\\tisModifyTool := false\\n   268→\\t\\t\\tfor _, name := range FileModificationTools {\\n   269→\\t\\t\\t\\tif toolCall.Name == name {\\n   270→\\t\\t\\t\\t\\tisModifyTool = true\\n   271→\\t\\t\\t\\t\\tbreak\\n   272→\\t\\t\\t\\t}\\n   273→\\t\\t\\t}\\n   274→\\n   275→\\t\\t\\tif !isModifyTool {\\n   276→\\t\\t\\t\\tcontinue\\n   277→\\t\\t\\t}\\n   278→\\n   279→\\t\\t\\t// Extract file path from args map\\n   280→\\t\\t\\tvar file string\\n   281→\\t\\t\\tif fp, ok := toolCall.Args[\\\"file_path\\\"].(string); ok && fp != \\\"\\\" {\\n   282→\\t\\t\\t\\tfile = fp\\n   283→\\t\\t\\t} else if p, ok := toolCall.Args[\\\"path\\\"].(string); ok && p != \\\"\\\" {\\n   284→\\t\\t\\t\\tfile = p\\n   285→\\t\\t\\t} else if fn, ok := toolCall.Args[\\\"filename\\\"].(string); ok && fn != \\\"\\\" {\\n   286→\\t\\t\\t\\tfile = fn\\n   287→\\t\\t\\t}\\n   288→\\n   289→\\t\\t\\tif file != \\\"\\\" && !fileSet[file] {\\n   290→\\t\\t\\t\\tfileSet[file] = true\\n   291→\\t\\t\\t\\tfiles = append(files, file)\\n   292→\\t\\t\\t}\\n   293→\\t\\t}\\n   294→\\t}\\n   295→\\n   296→\\treturn files, totalMessages, nil\\n   297→}\\n   298→\\n   299→// ChunkTranscript splits a Gemini JSON transcript by distributing messages across chunks.\\n   300→// Gemini uses JSON format with a {\\\"messages\\\": [...]} structure, so chunking splits\\n   301→// the messages array while preserving the JSON structure in each chunk.\\n   302→func (g *GeminiCLIAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n   303→\\tvar transcript GeminiTranscript\\n   304→\\tif err := json.Unmarshal(content, &transcript); err != nil {\\n   305→\\t\\t// Fall back to JSONL chunking if not valid Gemini JSON\\n   306→\\t\\tchunks, chunkErr := agent.ChunkJSONL(content, maxSize)\\n   307→\\t\\tif chunkErr != nil {\\n   308→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk as JSONL: %w\\\", chunkErr)\\n   309→\\t\\t}\\n   310→\\t\\treturn chunks, nil\\n   311→\\t}\\n   312→\\n   313→\\tif len(transcript.Messages) == 0 {\\n   314→\\t\\treturn [][]byte{content}, nil\\n   315→\\t}\\n   316→\\n   317→\\tvar chunks [][]byte\\n   318→\\tvar currentMessages []GeminiMessage\\n   319→\\tcurrentSize := len(`{\\\"messages\\\":[]}`) // Base JSON structure size\\n   320→\\n   321→\\tfor i, msg := range transcript.Messages {\\n   322→\\t\\t// Marshal message to get its size\\n   323→\\t\\tmsgBytes, err := json.Marshal(msg)\\n   324→\\t\\tif err != nil {\\n   325→\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to marshal Gemini message during chunking\\\",\\n   326→\\t\\t\\t\\tslog.Int(\\\"message_index\\\", i),\\n   327→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   328→\\t\\t\\t)\\n   329→\\t\\t\\tcontinue\\n   330→\\t\\t}\\n   331→\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n   332→\\n   333→\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n   334→\\t\\t\\t// Save current chunk\\n   335→\\t\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   336→\\t\\t\\tif err != nil {\\n   337→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   338→\\t\\t\\t}\\n   339→\\t\\t\\tchunks = append(chunks, chunkData)\\n   340→\\n   341→\\t\\t\\t// Start new chunk\\n   342→\\t\\t\\tcurrentMessages = nil\\n   343→\\t\\t\\tcurrentSize = len(`{\\\"messages\\\":[]}`)\\n   344→\\t\\t}\\n   345→\\n   346→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   347→\\t\\tcurrentSize += msgSize\\n   348→\\t}\\n   349→\\n   350→\\t// Add the last chunk\\n   351→\\tif len(currentMessages) > 0 {\\n   352→\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   353→\\t\\tif err != nil {\\n   354→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n   355→\\t\\t}\\n   356→\\t\\tchunks = append(chunks, chunkData)\\n   357→\\t}\\n   358→\\n   359→\\t// Ensure we created at least one chunk (could be empty if all messages failed to marshal)\\n   360→\\tif len(chunks) == 0 {\\n   361→\\t\\treturn nil, errors.New(\\\"failed to create any chunks: all messages failed to marshal\\\")\\n   362→\\t}\\n   363→\\n   364→\\treturn chunks, nil\\n   365→}\\n   366→\\n   367→// ReassembleTranscript merges Gemini JSON chunks by combining their message arrays.\\n   368→func (g *GeminiCLIAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   369→\\tvar allMessages []GeminiMessage\\n   370→\\n   371→\\tfor _, chunk := range chunks {\\n   372→\\t\\tvar transcript GeminiTranscript\\n   373→\\t\\tif err := json.Unmarshal(chunk, &transcript); err != nil {\\n   374→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk: %w\\\", err)\\n   375→\\t\\t}\\n   376→\\t\\tallMessages = append(allMessages, transcript.Messages...)\\n   377→\\t}\\n   378→\\n   379→\\tresult, err := json.Marshal(GeminiTranscript{Messages: allMessages})\\n   380→\\tif err != nil {\\n   381→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal reassembled transcript: %w\\\", err)\\n   382→\\t}\\n   383→\\treturn result, nil\\n   384→}\\n   385→\"}]},\"uuid\":\"5b03692d-7efb-477d-b2b1-b7b9f7167d0c\",\"timestamp\":\"2026-03-02T23:46:02.916Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"adc16565cae9c0b13\"},\"toolUseID\":\"agent_msg_01H7gniE85Q1srm7bth1YLUi\",\"parentToolUseID\":\"toolu_01PrScdZ2T9pT5fN4C6X5vNg\",\"uuid\":\"c361b8e2-fc7d-4d23-a217-7d863e55bf65\",\"timestamp\":\"2026-03-02T23:46:03.095Z\"}\n{\"parentUuid\":\"c361b8e2-fc7d-4d23-a217-7d863e55bf65\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/4\",\"sessionId\":\"19f14d88-0a6d-4b8e-a97e-06173d423309\",\"version\":\"2.1.63\",\"gitBranch\":\"alex/more-e2e-fixes\",\"slug\":\"curried-riding-mitten\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-02T23:46:03.134Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01Mve5d7RHPL1zRg5nTuRMsb\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01VmYtisQFDwYBEeaUZMSbtN\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/alex/workspace/cli/.worktrees/4/cmd/entire/cli/agent/geminicli/lifecycle.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":7,\"cache_creation_input