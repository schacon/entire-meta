aitForFileExists polls until at least one file matches the glob pattern\\n    39→// relative to dir, or fails the test after timeout. Handles the race where an\\n    40→// interactive agent's prompt pattern appears before file writes land on disk.\\n    41→func WaitForFileExists(t *testing.T, dir string, glob string, timeout time.Duration) {\\n    42→\\tt.Helper()\\n    43→\\tpattern := filepath.Join(dir, glob)\\n    44→\\tdeadline := time.Now().Add(timeout)\\n    45→\\tfor {\\n    46→\\t\\tmatches, err := filepath.Glob(pattern)\\n    47→\\t\\trequire.NoError(t, err)\\n    48→\\t\\tif len(matches) > 0 {\\n    49→\\t\\t\\treturn\\n    50→\\t\\t}\\n    51→\\t\\tif time.Now().After(deadline) {\\n    52→\\t\\t\\tt.Fatalf(\\\"expected files matching %s in %s within %s\\\", glob, dir, timeout)\\n    53→\\t\\t}\\n    54→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    55→\\t}\\n    56→}\\n    57→\\n    58→// AssertNewCommits polls until at least `atLeast` new commits exist since setup,\\n    59→// or fails after 10 seconds. Polling handles the race where an interactive\\n    60→// agent's prompt pattern appears before its git commit lands on disk.\\n    61→func AssertNewCommits(t *testing.T, s *RepoState, atLeast int) {\\n    62→\\tt.Helper()\\n    63→\\tdeadline := time.Now().Add(10 * time.Second)\\n    64→\\tfor {\\n    65→\\t\\tout := GitOutput(t, s.Dir, \\\"log\\\", \\\"--oneline\\\", s.HeadBefore+\\\"..HEAD\\\")\\n    66→\\t\\tvar lines []string\\n    67→\\t\\tif out != \\\"\\\" {\\n    68→\\t\\t\\tlines = strings.Split(strings.TrimSpace(out), \\\"\\\\n\\\")\\n    69→\\t\\t}\\n    70→\\t\\tif len(lines) >= atLeast {\\n    71→\\t\\t\\treturn\\n    72→\\t\\t}\\n    73→\\t\\tif time.Now().After(deadline) {\\n    74→\\t\\t\\tt.Fatalf(\\\"expected at least %d new commit(s), got %d after 10s\\\", atLeast, len(lines))\\n    75→\\t\\t}\\n    76→\\t\\ttime.Sleep(500 * time.Millisecond)\\n    77→\\t}\\n    78→}\\n    79→\\n    80→// WaitForCheckpoint polls until the checkpoint branch advances from its\\n    81→// initial state, or fails the test after timeout. Use this before any\\n    82→// assertions that depend on the checkpoint branch (post-commit hook is async).\\n    83→func WaitForCheckpoint(t *testing.T, s *RepoState, timeout time.Duration) {\\n    84→\\tt.Helper()\\n    85→\\tdeadline := time.Now().Add(timeout)\\n    86→\\tfor time.Now().Before(deadline) {\\n    87→\\t\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    88→\\t\\tif after != s.CheckpointBefore {\\n    89→\\t\\t\\treturn\\n    90→\\t\\t}\\n    91→\\t\\ttime.Sleep(200 * time.Millisecond)\\n    92→\\t}\\n    93→\\tt.Fatalf(\\\"checkpoint branch did not advance within %s\\\", timeout)\\n    94→}\\n    95→\\n    96→// AssertNoShadowBranches asserts that no shadow branches (entire/*) remain,\\n    97→// excluding entire/checkpoints/*. Shadow branches should be cleaned up after\\n    98→// commits condense session data to the metadata branch.\\n    99→func AssertNoShadowBranches(t *testing.T, dir string) {\\n   100→\\tt.Helper()\\n   101→\\tbranches := GitOutput(t, dir, \\\"for-each-ref\\\", \\\"--format=%(refname:short)\\\", \\\"refs/heads/entire/\\\")\\n   102→\\tvar shadow []string\\n   103→\\tfor _, b := range strings.Split(branches, \\\"\\\\n\\\") {\\n   104→\\t\\tb = strings.TrimSpace(b)\\n   105→\\t\\tif b == \\\"\\\" || strings.HasPrefix(b, \\\"entire/checkpoints\\\") {\\n   106→\\t\\t\\tcontinue\\n   107→\\t\\t}\\n   108→\\t\\tshadow = append(shadow, b)\\n   109→\\t}\\n   110→\\tassert.Empty(t, shadow,\\n   111→\\t\\t\\\"shadow branches should be cleaned up after commit, found: %v\\\", shadow)\\n   112→}\\n   113→\\n   114→// AssertCheckpointAdvanced asserts the checkpoint branch moved forward.\\n   115→func AssertCheckpointAdvanced(t *testing.T, s *RepoState) {\\n   116→\\tt.Helper()\\n   117→\\tafter := GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n   118→\\tassert.NotEqual(t, s.CheckpointBefore, after