essages\\\"`\\n    24→}\\n    25→\\n    26→// GeminiMessage represents a single message in the transcript\\n    27→type GeminiMessage struct {\\n    28→\\tID        string           `json:\\\"id,omitempty\\\"` // UUID for the message\\n    29→\\tType      string           `json:\\\"type\\\"`         // MessageTypeUser or MessageTypeGemini\\n    30→\\tContent   string           `json:\\\"content,omitempty\\\"`\\n    31→\\tToolCalls []GeminiToolCall `json:\\\"toolCalls,omitempty\\\"`\\n    32→}\\n    33→\\n    34→// UnmarshalJSON handles both string and array content formats in Gemini transcripts.\\n    35→// User messages use: \\\"content\\\": [{\\\"text\\\": \\\"...\\\"}] (array of objects)\\n    36→// Gemini messages use: \\\"content\\\": \\\"response text\\\" (string)\\n    37→func (m *GeminiMessage) UnmarshalJSON(data []byte) error {\\n    38→\\t// Use an alias to avoid infinite recursion\\n    39→\\ttype Alias GeminiMessage\\n    40→\\taux := &struct {\\n    41→\\t\\t*Alias\\n    42→\\n    43→\\t\\tContent json.RawMessage `json:\\\"content,omitempty\\\"`\\n    44→\\t}{\\n    45→\\t\\tAlias: (*Alias)(m),\\n    46→\\t}\\n    47→\\n    48→\\tif err := json.Unmarshal(data, aux); err != nil {\\n    49→\\t\\treturn fmt.Errorf(\\\"failed to unmarshal message: %w\\\", err)\\n    50→\\t}\\n    51→\\n    52→\\tif len(aux.Content) == 0 || string(aux.Content) == \\\"null\\\" {\\n    53→\\t\\tm.Content = \\\"\\\"\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\t// Try string first (most common for gemini messages)\\n    58→\\tvar strContent string\\n    59→\\tif err := json.Unmarshal(aux.Content, &strContent); err == nil {\\n    60→\\t\\tm.Content = strContent\\n    61→\\t\\treturn nil\\n    62→\\t}\\n    63→\\n    64→\\t// Try array of objects with \\\"text\\\" fields (user messages)\\n    65→\\tvar parts []struct {\\n    66→\\t\\tText string `json:\\\"text\\\"`\\n    67→\\t}\\n    68→\\tif err := json.Unmarshal(aux.Content, &parts); err == nil {\\n    69→\\t\\