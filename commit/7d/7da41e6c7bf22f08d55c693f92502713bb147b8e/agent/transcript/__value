", err)\\n   267→\\t}\\n   268→\\n   269→\\tsessionDir, err := agent.GetSessionDir(repoRoot)\\n   270→\\tif err != nil {\\n   271→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get agent session directory: %w\\\", err)\\n   272→\\t}\\n   273→\\treturn agent.ResolveSessionFile(sessionDir, sessionID), nil\\n   274→}\\n   275→\\n   276→// AgentTranscriptPath returns the path to a subagent's transcript file.\\n   277→// Subagent transcripts are stored as agent-{agentId}.jsonl in the same directory\\n   278→// as the main transcript.\\n   279→func AgentTranscriptPath(transcriptDir, agentID string) string {\\n   280→\\treturn filepath.Join(transcriptDir, fmt.Sprintf(\\\"agent-%s.jsonl\\\", agentID))\\n   281→}\\n   282→\\n   283→// toolResultBlock represents a tool_result in a user message\\n   284→type toolResultBlock struct {\\n   285→\\tType      string `json:\\\"type\\\"`\\n   286→\\tToolUseID string `json:\\\"tool_use_id\\\"`\\n   287→}\\n   288→\\n   289→// userMessageWithToolResults represents a user message that may contain tool results\\n   290→type userMessageWithToolResults struct {\\n   291→\\tContent []toolResultBlock `json:\\\"content\\\"`\\n   292→}\\n   293→\\n   294→// FindCheckpointUUID finds the UUID of the message containing the tool_result\\n   295→// for the given tool_use_id. This is used to find the checkpoint point for\\n   296→// transcript truncation when rewinding to a task.\\n   297→// Returns the UUID and true if found, empty string and false otherwise.\\n   298→func FindCheckpointUUID(transcript []transcriptLine, toolUseID string) (string, bool) {\\n   299→\\tfor _, line := range transcript {\\n   300→\\t\\tif line.Type != transcriptTypeUser {\\n   301→\\t\\t\\tcontinue\\n   302→\\t\\t}\\n   303→\\n   304→\\t\\tvar msg userMessageWithToolResults\\n   305→\\t\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   306→\\t\\t\\tcontinue\\n   307→\\t\\t}\\n   308→\\n   309→\\t\\tfor _, block := range msg.Content {\\n   310→\\t\\t\\tif block.Type == \\\"tool_result\\\" && block.ToolUseID == toolUseID {\\n   311→\\t\\t\\t\\treturn line.UUID, true\\n   312→\\t\\t\\t}\\n   313→\\t\\t}\\n   314→\\t}\\n   315→\\treturn \\\"\\\", false\\n   316→}\\n   317→\\n   318→// TruncateTranscriptAtUUID returns transcript lines up to and including the\\n   319→// line with the given UUID. If the UUID is not found or is empty, returns\\n   320→// the entire transcript.\\n   321→//\\n   322→//nolint:revive // Exported for testing purposes\\n   323→func TruncateTranscriptAtUUID(transcript []transcriptLine, uuid string) []transcriptLine {\\n   324→\\tif uuid == \\\"\\\" {\\n   325→\\t\\treturn transcript\\n   326→\\t}\\n   327→\\n   328→\\tfor i, line := range transcript {\\n   329→\\t\\tif line.UUID == uuid {\\n   330→\\t\\t\\treturn transcript[:i+1]\\n   331→\\t\\t}\\n   332→\\t}\\n   333→\\n   334→\\t// UUID not found, return full transcript\\n   335→\\treturn transcript\\n   336→}\\n   337→\\n   338→// writeTranscript writes transcript lines to a file in JSONL format.\\n   339→func writeTranscript(path string, transcript []transcriptLine) error {\\n   340→\\tfile, err := os.Create(path) //nolint:gosec // Writing to controlled git metadata path\\n   341→\\tif err != nil {\\n   342→\\t\\treturn fmt.Errorf(\\\"failed to create file: %w\\\", err)\\n   343→\\t}\\n   344→\\tdefer func() { _ = file.Close() }()\\n   345→\\n   346→\\tfor _, line := range transcript {\\n   347→\\t\\tdata, err := json.Marshal(line)\\n   348→\\t\\tif err != nil {\\n   349→\\t\\t\\treturn fmt.Errorf(\\\"failed to marshal line: %w\\\", err)\\n   350→\\t\\t}\\n   351→\\t\\tif _, err := file.Write(data); err != nil {\\n   352→\\t\\t\\treturn fmt.Errorf(\\\"failed to write line: %w\\\", err)\\n   353→\\t\\t}\\n   354→\\t\\tif _, err := file.WriteString(\\\"\\\\n\\\"); err != nil {\\n   355→\\t\\t\\treturn fmt.Errorf(\\\"failed to write newline: %w\\\", err)\\n   356→\\t\\t}\\n   357→\\t}\\n   358→\\n   359→\\treturn nil\\n   360→}\\n   361→\\n   362→// TranscriptPosition contains the position information for a transcript file.\\n   363→type TranscriptPosition struct {\\n   364→\\tLastUUID  string // Last non-empty UUID (from user/assistant messages)\\n   365→\\tLineCount int    // Total number of lines\\n   366→}\\n   367→\\n   368→// GetTranscriptPosition reads a transcript file and returns the last UUID and line count.\\n   369→// Returns empty position if file doesn't exist or is empty.\\n   370→// Only considers UUIDs from actual messages (user/assistant), not summary rows which use leafUuid.\\n   371→func GetTranscriptPosition(path string) (TranscriptPosition, error) {\\n   372→\\tif path == \\\"\\\" {\\n   373→\\t\\treturn TranscriptPosition{}, nil\\n   374→\\t}\\n   375→\\n   376→\\tfile, err := os.Open(path) //nolint:gosec // Reading from controlled transcript path\\n   377→\\tif err != nil {\\n   378→\\t\\tif os.IsNotExist(err) {\\n   379→\\t\\t\\treturn TranscriptPosition{}, nil\\n   380→\\t\\t}\\n   381→\\t\\treturn TranscriptPosition{}, fmt.Errorf(\\\"failed to open transcript: %w\\\", err)\\n   382→\\t}\\n   383→\\tdefer func() { _ = file.Close() }()\\n   384→\\n   385→\\tvar pos TranscriptPosition\\n   386→\\treader := bufio.NewReader(file)\\n   387→\\n   388→\\tfor {\\n   389→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n   390→\\t\\tif err != nil && err != io.EOF {\\n   391→\\t\\t\\treturn TranscriptPosition{}, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   392→\\t\\t}\\n   393→\\n   394→\\t\\tif len(lineBytes) == 0 {\\n   395→\\t\\t\\tif err == io.EOF {\\n   396→\\t\\t\\t\\tbreak\\n   397→\\t\\t\\t}\\n   398→\\t\\t\\tcontinue\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\tpos.LineCount++\\n   402→\\n   403→\\t\\t// Parse line to extract UUID (only from user/assistant messages, not summaries)\\n   404→\\t\\tvar line transcriptLine\\n   405→\\t\\tif err := json.Unmarshal(lineBytes, &line); err == nil {\\n   406→\\t\\t\\tif line.UUID != \\\"\\\" {\\n   407→\\t\\t\\t\\tpos.LastUU