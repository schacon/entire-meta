15→)\\n    16→\\n    17→// TestAgentContinuesAfterCommit: agent commits, then makes more changes in a\\n    18→// second prompt. User commits those. Both commits should have distinct checkpoint IDs.\\n    19→func TestAgentContinuesAfterCommit(t *testing.T) {\\n    20→\\ttestutil.ForEachAgent(t, 3*time.Minute, func(t *testing.T, s *testutil.RepoState, ctx context.Context) {\\n    21→\\t\\t// First prompt — agent creates and commits.\\n    22→\\t\\t_, err := s.RunPrompt(t, ctx,\\n    23→\\t\\t\\t\\\"create a markdown file at docs/red.md with a paragraph about the colour red, then commit it. Do not ask for confirmation, just make the change.\\\")\\n    24→\\t\\tif err != nil {\\n    25→\\t\\t\\tt.Fatalf(\\\"agent prompt 1 failed: %v\\\", err)\\n    26→\\t\\t}\\n    27→\\n    28→\\t\\ttestutil.WaitForCheckpoint(t, s, 15*time.Second)\\n    29→\\t\\tcpID1 := testutil.AssertHasCheckpointTrailer(t, s.Dir, \\\"HEAD\\\")\\n    30→\\t\\tcpBranchAfterFirst := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    31→\\n    32→\\t\\t// Second prompt — agent creates another file, user commits.\\n    33→\\t\\t_, err = s.RunPrompt(t, ctx,\\n    34→\\t\\t\\t\\\"create a markdown file at docs/blue.md with a paragraph about the colour blue. Do not commit it, only create the file. Do not ask for confirmation, just make the change.\\\")\\n    35→\\t\\tif err != nil {\\n    36→\\t\\t\\tt.Fatalf(\\\"agent prompt 2 failed: %v\\\", err)\\n    37→\\t\\t}\\n    38→\\n    39→\\t\\ts.Git(t, \\\"add\\\", \\\"docs/\\\")\\n    40→\\t\\ts.Git(t, \\\"commit\\\", \\\"-m\\\", \\\"Add blue.md\\\")\\n    41→\\n    42→\\t\\t// Wait for checkpoint branch to advance past the first checkpoint.\\n    43→\\t\\tdeadline := time.Now().Add(15 * time.Second)\\n    44→\\t\\tfor time.Now().Before(deadline) {\\n    45→\\t\\t\\tafter := testutil.GitOutput(t, s.Dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\")\\n    46→\\t\\t\\tif after != cpBranchAfterFirst {\\n    47→\\t\\t\\t\\tbr