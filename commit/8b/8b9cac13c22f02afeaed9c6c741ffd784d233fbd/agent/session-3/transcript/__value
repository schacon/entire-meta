\"\\n     5→\\t\\\"errors\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"log/slog\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"path/filepath\\\"\\n    10→\\t\\\"sort\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    19→\\n    20→\\t\\\"github.com/charmbracelet/huh\\\"\\n    21→\\t\\\"github.com/go-git/go-git/v6\\\"\\n    22→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    23→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    24→\\t\\\"github.com/spf13/cobra\\\"\\n    25→)\\n    26→\\n    27→func newResumeCmd() *cobra.Command {\\n    28→\\tvar force bool\\n    29→\\n    30→\\tcmd := &cobra.Command{\\n    31→\\t\\tUse:   \\\"resume <branch>\\\",\\n    32→\\t\\tShort: \\\"Switch to a branch and resume its session\\\",\\n    33→\\t\\tLong: `Switch to a local branch and resume the agent session from its last commit.\\n    34→\\n    35→This command:\\n    36→1. Checks out the specified branch\\n    37→2. Finds the session ID from commits unique to this branch (not on main)\\n    38→3. Restores the session log if it doesn't exist locally\\n    39→4. Shows the command to resume the session\\n    40→\\n    41→If the branch doesn't exist locally but exists on origin, you'll be prompted\\n    42→to fetch it.\\n    43→\\n    44→If newer commits without checkpoints exist on the branch (e.g., after merging main\\n    45→or cherry-picking from elsewhere), this operation will reset your Git status to the\\n    46→most recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n    47→\\t\\tArgs: cobra.ExactArgs(1),\\n    48→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    49→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n    50→\\t\\t\\t\\treturn nil\\n    51→\\t\\t\\t}\\n    52→\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n    53→\\t\\t},\\n    54→\\t}\\n    55→\\n    56→\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n    57→\\n    58→\\treturn cmd\\n    59→}\\n    60→\\n    61→func runResume(ctx context.Context, branchName string, force bool) error {\\n    62→\\t// Check if we're already on this branch\\n    63→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    64→\\tif err == nil && currentBranch == branchName {\\n    65→\\t\\t// Already on the branch, skip checkout\\n    66→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    67→\\t}\\n    68→\\n    69→\\t// Check if branch exists locally\\n    70→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tif !exists {\\n    76→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoints(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif len(result.checkpointIDs) == 0 {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\tcheckpointID := result.checkpointIDs[0]\\n   157→\\n   158→\\t// Multiple checkpoints (squash merge): resolve latest by CreatedAt timestamp.\\n   159→\\t// resolveLatestCheckpoint also returns the metadata tree so we can reuse it\\n   160→\\t// for the ReadCheckpointMetadata call below without a redundant lookup.\\n   161→\\tvar metadataTree *object.Tree\\n   162→\\tif len(result.checkpointIDs) > 1 {\\n   163→\\t\\tlatest, tree, err := resolveLatestCheckpoint(ctx, repo, result.checkpointIDs)\\n   164→\\t\\tif err != nil {\\n   165→\\t\\t\\t// No metadata available — nothing to resume from\\n   166→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s but metadata is not available\\\\n\\\",\\n   167→\\t\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7])\\n   168→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, result.checkpointIDs[0])\\n   169→\\t\\t}\\n   170→\\t\\tskipped := len(result.checkpointIDs) - 1\\n   171→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints for commit %s, resuming from the latest (%d older checkpoints skipped)\\\\n\\\",\\n   172→\\t\\t\\tlen(result.checkpointIDs), result.commitHash[:7], skipped)\\n   173→\\t\\tcheckpointID = latest\\n   174→\\t\\tmetadataTree = tree\\n   175→\\t}\\n   176→\\n   177→\\t// Get metadata branch tree for lookups (reuse from resolveLatestCheckpoint if available)\\n   178→\\tif metadataTree == nil {\\n   179→\\t\\tvar err error\\n   180→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   181→\\t\\tif err != nil {\\n   182→\\t\\t\\t// No local metadata branch, check if remote has it\\n   183→\\t\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   184→\\t\\t}\\n   185→\\t}\\n   186→\\n   187→\\t// Look up metadata from sharded path\\n   188→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   189→\\tif err != nil {\\n   190→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   191→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   192→\\t}\\n   193→\\n   194→\\treturn resumeSession(ctx, metadata, force)\\n   195→}\\n   196→\\n   197→// resolveLatestCheckpoint reads metadata for each checkpoint ID and returns\\n   198→// the one with the latest CreatedAt, along with the metadata tree for reuse.\\n   199→// It tries the local metadata branch first, then fetches from remote, then\\n   200→// falls back to the remote tree directly.\\n   201→func resolveLatestCheckpoint(ctx context.Context, repo *git.Repository, checkpointIDs []id.CheckpointID) (id.CheckpointID, *object.Tree, error) {\\n   202→\\tmetadataTree, err := getMetadataTree(ctx, repo)\\n   203→\\tif err != nil {\\n   204→\\t\\treturn id.EmptyCheckpointID, nil, err\\n   205→\\t}\\n   206→\\tinfoMap := make(map[id.CheckpointID]strategy.CheckpointInfo, len(checkpointIDs))\\n   207→\\tfor _, cpID := range checkpointIDs {\\n   208→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, cpID.Path())\\n   209→\\t\\tif err != nil {\\n   210→\\t\\t\\tcontinue\\n   211→\\t\\t}\\n   212→\\t\\tinfoMap[cpID] = *metadata\\n   213→\\t}\\n   214→\\tlatest, found := strategy.ResolveLatestCheckpointFromMap(checkpointIDs, infoMap)\\n   215→\\tif !found {\\n   216→\\t\\treturn id.EmptyCheckpointID, nil, errors.New(\\\"no checkpoint metadata found\\\")\\n   217→\\t}\\n   218→\\treturn latest.CheckpointID, metadataTree, nil\\n   219→}\\n   220→\\n   221→// getMetadataTree returns the metadata branch tree, trying local first,\\n   222→// then treeless fetch, then full fetch, then remote tree directly.\\n   223→func getMetadataTree(ctx context.Context, repo *git.Repository) (*object.Tree, error) {\\n   224→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   225→\\tif err == nil {\\n   226→\\t\\treturn metadataTree, nil\\n   227→\\t}\\n   228→\\n   229→\\t// Try treeless fetch first (only downloads commit + tree objects, no blobs)\\n   230→\\tif fetchErr := FetchMetadataTreeOnly(ctx); fetchErr == nil {\\n   231→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   232→\\t\\tif err == nil {\\n   233→\\t\\t\\treturn metadataTree, nil\\n   234→\\t\\t}\\n   235→\\t}\\n   236→\\n   237→\\t// Fallback: full fetch from remote\\n   238→\\tif fetchErr := FetchMetadataBranch(ctx); fetchErr == nil {\\n   239→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   240→\\t\\tif err == nil {\\n   241→\\t\\t\\treturn metadataTree, nil\\n   242→\\t\\t}\\n   243→\\t}\\n   244→\\n   245→\\t// Try remote tree directly\\n   246→\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   247→\\tif remoteErr != nil {\\n   248→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch not available: %w\\\", remoteErr)\\n   249→\\t}\\n   250→\\treturn remoteTree, nil\\n   251→}\\n   252→\\n   253→// ensureTranscriptBlobs checks which transcript blobs for a checkpoint are\\n   254→// present in the local object store (via go-git) and fetches any missing\\n   255→// ones from the remote (via git CLI).\\n   256→// This enables the treeless-fetch optimization: tree objects are fetched first,\\n   257→// then only the specific full.jsonl blobs needed for resume are downloaded.\\n   258→func ensureTranscriptBlobs(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   259→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   260→\\tif err != nil {\\n   261→\\t\\t// If we can't get the tree, blobs can't be checked — caller will handle the error\\n   262→\\t\\treturn nil //nolint:nilerr // Tree unavailable means no sparse fetch possible\\n   263→\\t}\\n   264→\\n   265→\\trefs, err := checkpoint.CollectTranscriptBlobHashes(metadataTree, checkpointID)\\n   266→\\tif err != nil {\\n   267→\\t\\t// Tree navigation failed — not fatal, ReadSessionContent will fail with a clear error\\n   268→\\t\\treturn nil //nolint:nilerr // Best-effort blob prefetch\\n   269→\\t}\\n   270→\\n   271→\\tresolver := checkpoint.NewBlobResolver(repo.Storer)\\n   272→\\tvar missing []plumbing.Hash\\n   273→\\tfor _, ref := range refs {\\n   274→\\t\\tif !resolver.HasBlob(ref.Hash) {\\n   275→\\t\\t\\tmissing = append(missing, ref.Hash)\\n   276→\\t\\t}\\n   277→\\t}\\n   278→\\tif len(missing) == 0 {\\n   279→\\t\\treturn nil\\n   280→\\t}\\n   281→\\n   282→\\treturn FetchBlobsByHash(ctx, missing)\\n   283→}\\n   284→\\n   285→// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\n   286→type branchCheckpointsResult struct {\\n   287→\\tcheckpointIDs     []id.CheckpointID\\n   288→\\tcommitHash        string\\n   289→\\tcommitMessage     string\\n   290→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   291→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   292→}\\n   293→\\n   294→// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n   295→// among commits that are unique to this branch (not reachable from the default branch).\\n   296→// This handles the case where main has been merged into the feature branch.\\n   297→func findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n   298→\\tresult := &branchCheckpointsResult{}\\n   299→\\n   300→\\t// Get HEAD commit\\n   301→\\thead, err := repo.Head()\\n   302→\\tif err != nil {\\n   303→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   307→\\tif err != nil {\\n   308→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   312→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   313→\\t\\tresult.checkpointIDs = cpIDs\\n   314→\\t\\tresult.commitHash = head.Hash().String()\\n   315→\\t\\tresult.commitMessage = headCommit.Message\\n   316→\\t\\tresult.newerCommitsExist = false\\n   317→\\t\\treturn result, nil\\n   318→\\t}\\n   319→\\n   320→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   321→\\t// Get the default branch name\\n   322→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   323→\\tif defaultBranch == \\\"\\\" {\\n   324→\\t\\t// Fallback: try common names\\n   325→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   326→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   327→\\t\\t\\t\\tdefaultBranch = name\\n   328→\\t\\t\\t\\tbreak\\n   329→\\t\\t\\t}\\n   330→\\t\\t}\\n   331→\\t}\\n   332→\\n   333→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   334→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   335→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   336→\\t}\\n   337→\\n   338→\\t// Get the default branch reference\\n   339→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   340→\\tif err != nil {\\n   341→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   342→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   343→\\t}\\n   344→\\n   345→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   346→\\tif err != nil {\\n   347→\\t\\t// Can't get default commit, fall back to walking all commits\\n   348→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   349→\\t}\\n   350→\\n   351→\\t// Find merge base\\n   352→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   353→\\tif err != nil || len(mergeBase) == 0 {\\n   354→\\t\\t// No common ancestor, fall back to walking all commits\\n   355→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   356→\\t}\\n   357→\\n   358→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   359→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   360→}\\n   361→\\n   362→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   363→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   364→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   365→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   366→// (actual branch work) to avoid false warnings after merging main.\\n   367→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n   368→\\tresult := &branchCheckpointsResult{}\\n   369→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   370→\\tconst maxCommits = 100 // Limit search depth\\n   371→\\ttotalChecked := 0\\n   372→\\n   373→\\tcurrent := start\\n   374→\\tfor current != nil && totalChecked < maxCommits {\\n   375→\\t\\t// Stop if we've reached the boundary\\n   376→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   377→\\t\\t\\tbreak\\n   378→\\t\\t}\\n   379→\\n   380→\\t\\t// Check for checkpoint trailer\\n   381→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   382→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   383→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   384→\\t\\t\\tresult.commitMessage = current.Message\\n   385→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   386→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   387→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   388→\\t\\t\\treturn result\\n   389→\\t\\t}\\n   390→\\n   391→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   392→\\t\\tif current.NumParents() <= 1 {\\n   393→\\t\\t\\tbranchWorkCommits++\\n   394→\\t\\t}\\n   395→\\n   396→\\t\\ttotalChecked++\\n   397→\\n   398→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   399→\\t\\tif current.NumParents() == 0 {\\n   400→\\t\\t\\tbreak\\n   401→\\t\\t}\\n   402→\\t\\tparent, err := current.Parent(0)\\n   403→\\t\\tif err != nil {\\n   404→\\t\\t\\t// Can't get parent, treat as end of history\\n   405→\\t\\t\\tbreak\\n   406→\\t\\t}\\n   407→\\t\\tcurrent = parent\\n   408→\\t}\\n   409→\\n   410→\\t// No checkpoint found\\n   411→\\treturn result\\n   412→}\\n   413→\\n   414→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   415→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   416→\\tvar confirmed bool\\n   417→\\n   418→\\tform := NewAccessibleForm(\\n   419→\\t\\thuh.NewGroup(\\n   420→\\t\\t\\thuh.NewConfirm().\\n   421→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   422→\\t\\t\\t\\tValue(&confirmed),\\n   423→\\t\\t),\\n   424→\\t)\\n   425→\\n   426→\\tif err := form.Run(); err != nil {\\n   427→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   428→\\t\\t\\treturn false, nil\\n   429→\\t\\t}\\n   430→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   431→\\t}\\n   432→\\n   433→\\treturn confirmed, nil\\n   434→}\\n   435→\\n   436→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   437→// and automatically fetches it if available.\\n   438→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   439→\\t// Try to get remote metadata branch tree\\n   440→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   441→\\tif err != nil {\\n   442→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   443→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   444→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   445→\\t}\\n   446→\\n   447→\\t// Check if the checkpoint exists on the remote\\n   448→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   449→\\tif err != nil {\\n   450→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   451→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   452→\\t}\\n   453→\\n   454→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   455→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   456→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   457→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   458→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   459→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   460→\\t}\\n   461→\\n   462→\\t// Now resume the session with the fetched metadata\\n   463→\\treturn resumeSession(ctx, metadata, false)\\n   464→}\\n   465→\\n   466→// resumeSession restores and displays the resume command for a specific session.\\n   467→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   468→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   469→// The caller must provide the already-resolved checkpoint metadata to avoid redundant lookups\\n   470→// and to support both local and remote metadata trees.\\n   471→func resumeSession(ctx context.Context, metadata *strategy.CheckpointInfo, force bool) error {\\n   472→\\tcheckpointID := metadata.CheckpointID\\n   473→\\tsessionID := metadata.SessionID\\n   474→\\n   475→\\t// Resolve agent from checkpoint metadata (same as rewind)\\n   476→\\tag, err := strategy.ResolveAgentForRewind(metadata.Agent)\\n   477→\\tif err != nil {\\n   478→\\t\\treturn fmt.Errorf(\\\"failed to resolve agent: %w\\\", err)\\n   479→\\t}\\n   480→\\n   481→\\t// Initialize logging context with agent\\n   482→\\tlogCtx := logging.WithAgent(logging.WithComponent(ctx, \\\"resume\\\"), ag.Name())\\n   483→\\n   484→\\tlogging.Debug(logCtx, \\\"resume session started\\\",\\n   485→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   486→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   487→\\t)\\n   488→\\n   489→\\t// Get worktree root for session directory lookup\\n   490→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   491→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\tsessionDir, err := ag.GetSessionDir(repoRoot)\\n   496→\\tif err != nil 