→\\n    46→// ensureBlobs walks the entire tree recursively and batch-fetches all\\n    47→// missing blobs in a single call. Only tree objects are read during the\\n    48→// walk; blobs are identified by hash from tree entries.\\n    49→func (t *FetchingTree) ensureBlobs() {\\n    50→\\tif t.fetch == nil {\\n    51→\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.ensureBlobs: no fetch func, skipping\\\")\\n    52→\\t\\treturn\\n    53→\\t}\\n    54→\\tt.once.Do(func() {\\n    55→\\t\\tvar total int\\n    56→\\t\\tvar missing []plumbing.Hash\\n    57→\\t\\tvar fileNames []string\\n    58→\\t\\twalkErr := t.inner.Files().ForEach(func(f *object.File) error {\\n    59→\\t\\t\\ttotal++\\n    60→\\t\\t\\thas := t.resolver.HasBlob(f.Hash)\\n    61→\\t\\t\\tif !has {\\n    62→\\t\\t\\t\\tmissing = append(missing, f.Hash)\\n    63→\\t\\t\\t}\\n    64→\\t\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.ensureBlobs: file entry\\\",\\n    65→\\t\\t\\t\\tslog.String(\\\"name\\\", f.Name),\\n    66→\\t\\t\\t\\tslog.String(\\\"hash\\\", f.Hash.String()[:12]),\\n    67→\\t\\t\\t\\tslog.Bool(\\\"local\\\", has),\\n    68→\\t\\t\\t)\\n    69→\\t\\t\\tfileNames = append(fileNames, f.Name)\\n    70→\\t\\t\\treturn nil\\n    71→\\t\\t})\\n    72→\\t\\tif walkErr != nil {\\n    73→\\t\\t\\tlogging.Warn(t.ctx, \\\"FetchingTree.ensureBlobs: tree walk failed\\\",\\n    74→\\t\\t\\t\\tslog.String(\\\"tree_hash\\\", t.inner.Hash.String()),\\n    75→\\t\\t\\t\\tslog.String(\\\"error\\\", walkErr.Error()),\\n    76→\\t\\t\\t)\\n    77→\\t\\t}\\n    78→\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.ensureBlobs: walk complete\\\",\\n    79→\\t\\t\\tslog.String(\\\"tree_hash\\\", t.inner.Hash.String()),\\n    80→\\t\\t\\tslog.Int(\\\"total_files\\\", total),\\n    81→\\t\\t\\tslog.Int(\\\"missing_blobs\\\", len(missing)),\\n    82→\\t\\t\\tslog.Any(\\\"files\\\", fileNames),\\n    83→\\t\\t)\\n    84→\\t\\tif len(missing) > 0 {\\n    85→\\t\\t\\tvar hashStrs []string\\n    86→\\t\\t\\tfor _, h := range missing {\\n    87→\\t\\t\\t\\thashStrs = append(hashStrs, h.String()[:12])\\n    88→\\t\\t\\t}\\n    89→\\t\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.ensureBlobs: fetching missing blobs\\\",\\n    90→\\t\\t\\t\\tslog.Any(\\\"hashes\\\", hashStrs),\\n    91→\\t\\t\\t)\\n    92→\\t\\t\\tif fetchErr := t.fetch(t.ctx, missing); fetchErr != nil {\\n    93→\\t\\t\\t\\tlogging.Warn(t.ctx, \\\"FetchingTree.ensureBlobs: blob fetch failed\\\",\\n    94→\\t\\t\\t\\t\\tslog.Int(\\\"missing_count\\\", len(missing)),\\n    95→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", fetchErr.Error()),\\n    96→\\t\\t\\t\\t)\\n    97→\\t\\t\\t} else {\\n    98→\\t\\t\\t\\t// Verify blobs are now available\\n    99→\\t\\t\\t\\tvar stillMissing int\\n   100→\\t\\t\\t\\tfor _, h := range missing {\\n   101→\\t\\t\\t\\t\\tif !t.resolver.HasBlob(h) {\\n   102→\\t\\t\\t\\t\\t\\tstillMissing++\\n   103→\\t\\t\\t\\t\\t\\tlogging.Warn(t.ctx, \\\"FetchingTree.ensureBlobs: blob still missing after fetch\\\",\\n   104→\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"hash\\\", h.String()[:12]),\\n   105→\\t\\t\\t\\t\\t\\t)\\n   106→\\t\\t\\t\\t\\t}\\n   107→\\t\\t\\t\\t}\\n   108→\\t\\t\\t\\tif stillMissing > 0 {\\n   109→\\t\\t\\t\\t\\tlogging.Warn(t.ctx, \\\"FetchingTree.ensureBlobs: some blobs still missing after fetch\\\",\\n   110→\\t\\t\\t\\t\\t\\tslog.Int(\\\"still_missing\\\", stillMissing),\\n   111→\\t\\t\\t\\t\\t\\tslog.Int(\\\"fetched\\\", len(missing)-stillMissing),\\n   112→\\t\\t\\t\\t\\t)\\n   113→\\t\\t\\t\\t} else {\\n   114→\\t\\t\\t\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.ensureBlobs: all blobs fetched successfully\\\",\\n   115→\\t\\t\\t\\t\\t\\tslog.Int(\\\"count\\\", len(missing)),\\n   116→\\t\\t\\t\\t\\t)\\n   117→\\t\\t\\t\\t}\\n   118→\\t\\t\\t}\\n   119→\\t\\t}\\n   120→\\t})\\n   121→}\\n   122→\\n   123→// File returns the file at the given path. On the first call, all missing\\n   124→// blobs in this tree (and subtrees) are batch-fetched from the remote.\\n   125→func (t *FetchingTree) File(path string) (*object.File, error) {\\n   126→\\tt.ensureBlobs()\\n   127→\\tfile, err := t.inner.File(path)\\n   128→\\tif err != nil {\\n   129→\\t\\tlogging.Debug(t.ctx, \\\"FetchingTree.File: lookup failed\\\",\\n   130→\\t\\t\\tslog.String(\\\"path\\\", path),\\n   131→\\t\\t\\tslog.String(\\\"tree_hash\\\", t.inner.Hash.String()),\\n   132→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   133→\\t\\t)\\n   134→\\t}\\n   135→\\treturn file, err //nolint:wrapcheck // pass-through wrapper\\n   136→}\\n   137→\\n   138→// Tree returns the subtree at the given path, wrapped with the same fetching\\n   139→// behavior. The child shares the parent's prefetch state — if the parent\\n   140→// already fetched blobs (which includes subtree blobs), the child won't\\n   141→// re-fetch.\\n   142→func (t *FetchingTree) Tree(path string) (*FetchingTree, error) {\\n   143→\\tsubtree, err := t.inner.Tree(path)\\n   144→\\tif err != nil {\\n   145→\\t\\treturn nil, fmt.Errorf(\\\"tree %s: %w\\\", path, err)\\n   146→\\t}\\n   147→\\treturn &FetchingTree{\\n   148→\\t\\tinner:    subtree,\\n   149→\\t\\tctx:      t.ctx,\\n   150→\\t\\tresolver: t.resolver,\\n   151→\\t\\tfetch:    t.fetch,\\n   152→\\t\\tonce:     t.once, // share — parent fetch covers subtree blobs\\n   153→\\t}, nil\\n   154→}\\n   155→\\n   156→// RawEntries returns the direct tree entries (no blob reads needed).\\n   157→func (t *FetchingTree) RawEntries() []object.TreeEntry {\\n   158→\\treturn t.inner.Entries\\n   159→}\\n   160→\\n   161→// Unwrap returns the underlying *object.Tree.\\n   162→func (t *FetchingTree) Unwrap() *object.Tree {\\n   163→\\treturn t.inner\\n   164→}\\n   165→\\n   166→// Files returns a recursive file iterator from the underlying tree.\\n   167→// This only walks tree objects and does not read blobs.\\n   168→func (t *FetchingTree) Files() *object.FileIter {\\n   169→\\treturn t.inner.Files()\\n   170→}\\n   171→\\n   172→// FileReader provides read access to files within