.t[pathCurrent] = tree\\n   162→\\t}\\n   163→\\n   164→\\treturn tree.entry(pathParts[0])\\n   165→}\\n   166→\\n   167→func (t *Tree) dir(baseName string) (*Tree, error) {\\n   168→\\tentry, err := t.entry(baseName)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn nil, ErrDirectoryNotFound\\n   171→\\t}\\n   172→\\n   173→\\tobj, err := t.s.EncodedObject(plumbing.TreeObject, entry.Hash)\\n   174→\\tif err != nil {\\n   175→\\t\\treturn nil, err\\n   176→\\t}\\n   177→\\n   178→\\ttree := &Tree{s: t.s}\\n   179→\\terr = tree.Decode(obj)\\n   180→\\n   181→\\treturn tree, err\\n   182→}\\n   183→\\n   184→func (t *Tree) entry(baseName string) (*TreeEntry, error) {\\n   185→\\tif t.m == nil {\\n   186→\\t\\tt.buildMap()\\n   187→\\t}\\n   188→\\n   189→\\tentry, ok := t.m[baseName]\\n   190→\\tif !ok {\\n   191→\\t\\treturn nil, ErrEntryNotFound\\n   192→\\t}\\n   193→\\n   194→\\treturn entry, nil\\n   195→}\\n   196→\\n   197→// Files returns a FileIter allowing to iterate over the Tree\\n   198→func (t *Tree) Files() *FileIter {\\n   199→\\treturn NewFileIter(t.s, t)\\n   200→}\\n   201→\\n   202→// ID returns the object ID of the tree. The returned value will always match\\n   203→// the current value of Tree.Hash.\\n   204→//\\n   205→// ID is present to fulfill the Object interface.\\n   206→func (t *Tree) ID() plumbing.Hash {\\n   207→\\treturn t.Hash\\n   208→}\\n   209→\\n   210→// Type returns the type of object. It always returns plumbing.TreeObject.\\n   211→func (t *Tree) Type() plumbing.ObjectType {\\n   212→\\treturn plumbing.TreeObject\\n   213→}\\n   214→\\n   215→// Decode transform an plumbing.EncodedObject into a Tree struct\\n   216→func (t *Tree) Decode(o plumbing.EncodedObject) (err error) {\\n   217→\\tif o.Type() != plumbing.TreeObject {\\n   218→\\t\\treturn ErrUnsupportedObject\\n   219→\\t}\\n   220→\\n   221→\\tt.Hash = o.Hash()\\n   222→\\tif o.Size() == 0 {\\n   223→\\t\\treturn nil\\n   224→\\t}\\n   225→\\n   226→\\tt.Entries = nil\\n   227→\\tt.m = nil\\n   228→\\n   229→\\treader, err := o.Reader()\\n   230→\\tif err != nil {\\n   231→\\t\\treturn err\\n   232→\\t}\\n   233→\\tdefer ioutil.CheckClose(reader, &err)\\n   234→\\n   235→\\tr := sync.GetBufioReader(reader)\\n   236→\\tdefer sync.PutBufioReader(r)\\n   237→\\n   238→\\tfor {\\n   239→\\t\\tstr, err := r.ReadString(' ')\\n   240→\\t\\tif err != nil {\\n   241→\\t\\t\\tif err == io.EOF {\\n   242→\\t\\t\\t\\tbreak\\n   243→\\t\\t\\t}\\n   244→\\n   245→\\t\\t\\treturn err\\n   246→\\t\\t}\\n   247→\\t\\tstr = str[:len(str)-1] // strip last byte (' ')\\n   248→\\n   249→\\t\\tmode, err := filemode.New(str)\\n   250→\\t\\tif err != nil {\\n   251→\\t\\t\\treturn err\\n   252→\\t\\t}\\n   253→\\n   254→\\t\\tname, err := r.ReadString(0)\\n   255→\\t\\tif err != nil && err != io.EOF {\\n   256→\\t\\t\\treturn err\\n   257→\\t\\t}\\n   258→\\n   259→\\t\\tvar hash plumbing.Hash\\n   260→\\t\\thash.ResetBySize(t.Hash.Size())\\n   261→\\t\\tif _, err = hash.ReadFrom(r); err != nil {\\n   262→\\t\\t\\treturn err\\n   263→\\t\\t}\\n   264→\\n   265→\\t\\tbaseName := name[:len(name)-1]\\n   266→\\t\\tt.Entries = append(t.Entries, TreeEntry{\\n   267→\\t\\t\\tHash: hash,\\n   268→\\t\\t\\tMode: mode,\\n   269→\\t\\t\\tName: baseName,\\n   270→\\t\\t})\\n   271→\\t}\\n   272→\\n   273→\\treturn nil\\n   274→}\\n   275→\\n   276→// TreeEntrySorter is a helper type for sorting TreeEntry slices.\\n   277→type TreeEntrySorter []TreeEntry\\n   278→\\n   279→func (s TreeEntrySorter) Len() int {\\n   280→\\treturn len(s)\\n   281→}\\n   282→\\n   283→func (s TreeEntrySorter) Less(i, j int) bool {\\n   284→\\tname1 := s[i].Name\\n   285→\\tname2 := s[j].Name\\n   286→\\tif s[i].Mode == filemode.Dir {\\n   287→\\t\\tname1 += \\\"/\\\"\\n   288→\\t}\\n   289→\\tif s[j].Mode == filemode.Dir {\\n   290→\\t\\tname2 += \\\"/\\\"\\n   291→\\t}\\n   292→\\treturn name1 < name2\\n   293→}\\n   294→\\n   295→func (s TreeEntrySorter) Swap(i, j int) {\\n   296→\\ts[i], s[j] = s[j], s[i]\\n   297→}\\n   298→\\n   299→// Encode transforms a Tree into a plumbing.EncodedObject.\\n   300→// The tree entries must be sorted by name.\\n   301→func (t *Tree) Encode(o plumbing.EncodedObject) (err error) {\\n   302→\\to.SetType(plumbing.TreeObject)\\n   303→\\tw, err := o.Writer()\\n   304→\\tif err != nil {\\n   305→\\t\\treturn err\\n   306→\\t}\\n   307→\\n   308→\\tdefer ioutil.CheckClose(w, &err)\\n   309→\\n   310→\\tif !sort.IsSorted(TreeEntrySorter(t.Entries)) {\\n   311→\\t\\treturn ErrEntriesNotSorted\\n   312→\\t}\\n   313→\\n   314→\\tfor _, entry := range t.Entries {\\n   315→\\t\\tif strings.IndexByte(entry.Name, 0) != -1 {\\n   316→\\t\\t\\treturn fmt.Errorf(\\\"malformed filename %q\\\", entry.Name)\\n   317→\\t\\t}\\n   318→\\t\\tif _, err = fmt.Fprintf(w, \\\"%o %s\\\", entry.Mode, entry.Name); err != nil {\\n   319→\\t\\t\\treturn err\\n   320→\\t\\t}\\n   321→\\n   322→\\t\\tif _, err = w.Write([]byte{0x00}); err != nil {\\n   323→\\t\\t\\treturn err\\n   324→\\t\\t}\\n   325→\\n   326→\\t\\tif _, err = entry.Hash.WriteTo(w); err != nil {\\n   327→\\t\\t\\treturn err\\n   328→\\t\\t}\\n   329→\\t}\\n   330→\\n   331→\\treturn err\\n   332→}\\n   333→\\n   334→func (t *Tree) buildMap() {\\n   335→\\tt.m = make(map[string]*TreeEntry)\\n   336→\\tfor i := 0; i < len(t.Entries); i++ {\\n   337→\\t\\tt.m[t.Entries[i].Name] = &t.Entries[i]\\n   338→\\t}\\n   339→}\\n   340→\\n   341→// Diff returns a list of changes between this tree and the provided one\\n   342→func (t *Tree) Diff(to *Tree) (Changes, error) {\\n   343→\\treturn t.DiffContext(context.Background(), to)\\n   344→}\\n   345→\\n   346→// DiffContext returns a list of changes between this tree and the provided one\\n   347→// Error will be returned if context expires. Provided context must be non nil.\\n   348→//\\n   349→// NOTE: Since version 5.1.0 the renames are correctly handled, the settings\\n   350→// used are the recommended options DefaultDiffTreeOptions.\\n   351→func (t *Tree) DiffContext(ctx context.Context, to *Tree) (Changes, error) {\\n   352→\\treturn DiffTreeWithOptions(ctx, t, to, DefaultDiffTreeOptions)\\n   353→}\\n   354→\\n   355→// Patch returns a slice of Patch objects with all the changes between trees\\n   356→// in chunks. This representation can be used to create several diff outputs.\\n   357→func (t *Tree) Patch(to *Tree) (*Patch, error) {\\n   358→\\treturn t.PatchContext(context.Background(), to)\\n   359→}\\n   360→\\n   361→// PatchContext returns a slice of Patch objects with all the changes between\\n   362→// trees in chunks. This representation can be used to create several diff\\n   363→// outputs. If context expires, an error will be returned. Provided context must\\n   364→// be non-nil.\\n   365→//\\n   366→// NOTE: Since version 5.1.0 the renames are correctly handled, the settings\\n   367→// used are the recommended options DefaultDiffTreeOptions.\\n   368→func (t *Tree) PatchContext(ctx context.Context, to *Tree) (*Patch, error) {\\n   369→\\tchanges, err := t.DiffContext(ctx, to)\\n   370→\\tif err != nil {\\n   371→\\t\\treturn nil, err\\n   372→\\t}\\n   373→\\n   374→\\treturn changes.PatchContext(ctx)\\n   375→}\\n   376→\\n   377→// treeEntryIter facilitates iterating through the TreeEntry objects in a Tree.\\n   378→type treeEntryIter struct {\\n   379→\\tt   *Tree\\n   380→\\tpos int\\n   381→}\\n   382→\\n   383→func (iter *treeEntryIter) Next() (TreeEntry, error) {\\n   384→\\tif iter.pos >= len(iter.t.Entries) {\\n   385→\\t\\treturn TreeEntry{}, io.EOF\\n   386→\\t}\\n   387→\\titer.pos++\\n   388→\\treturn iter.t.Entries[iter.pos-1], nil\\n   389→}\\n   390→\\n   391→// TreeWalker provides a means of walking through all of the entries in a Tree.\\n   392→type TreeWalker struct {\\n   393→\\tstack     []*treeEntryIter\\n   394→\\tbase      string\\n   395→\\trecursive bool\\n   396→\\tseen      map[plumbing.Hash]bool\\n   397→\\n   398→\\ts storer.EncodedObjectStorer\\n   399→\\tt *Tree\\n   400→}\\n   401→\\n   402→// NewTreeWalker returns a new TreeWalker for the given tree.\\n   403→//\\n   404→// It is the caller's responsibility to call Close() when finished with the\\n   405→// tree walker.\\n   406→func NewTreeWalker(t *Tree, recursive bool, seen map[plumbing.Hash]bool) *TreeWalker {\\n   407→\\tstack := make([]*treeEntryIter, 0, startingStackSize)\\n   408→\\tstack = append(stack, &treeEntryIter{t, 0})\\n   409→\\n   410→\\treturn &TreeWalker{\\n   411→\\t\\tstack:     stack,\\n   412→\\t\\trecursive: recursive,\\n   413→\\t\\tseen:      seen,\\n   414→\\n   415→\\t\\ts: t.s,\\n   416→\\t\\tt: t,\\n   417→\\t}\\n   418→}\\n   419→\\n   420→// Next returns the next object from the tree. Objects are returned in order\\n   421→// and subtrees are included. After the last object has been returned further\\n   422→// calls to Next() will return io.EOF.\\n   423→//\\n   424→// In the current implementation any objects which cannot be found in the\\n   425→// underlying repository will be skipped automatically. It is possible that this\\n   426→// may change in future versions.\\n   427→func (w *TreeWalker) Next() (name string, entry TreeEntry, err error) {\\n   428→\\tvar obj *Tree\\n   429→\\tfor {\\n   430→\\t\\tcurrent := len(w.stack) - 1\\n   431→\\t\\tif current < 0 {\\n   432→\\t\\t\\t// Nothing left on the stack so we're finished\\n   433→\\t\\t\\terr = io.EOF\\n   434→\\t\\t\\treturn name, entry, err\\n   435→\\t\\t}\\n   436→\\n   437→\\t\\tif current > maxTreeDepth {\\n   438→\\t\\t\\t// We're probably following bad data or some self-referencing tree\\n   439→\\t\\t\\terr = ErrMaxTreeDepth\\n   440→\\t\\t\\treturn name, entry, err\\n   441→\\t\\t}\\n   442→\\n   443→\\t\\tentry, err = w.stack[current].Next()\\n   444→\\t\\tif err == io.EOF {\\n   445→\\t\\t\\t// Finished with the current tree, move back up to the parent\\n   446→\\t\\t\\tw.stack = w.stack[:current]\\n   447→\\t\\t\\tw.base, _ = path.Split(w.base)\\n   448→\\t\\t\\tw.base = strings.TrimSuffix(w.base, \\\"/\\\")\\n   449→\\t\\t\\tcontinue\\n   450→\\t\\t}\\n   451→\\n   452→\\t\\tif err != nil {\\n   453→\\t\\t\\treturn name, entry, err\\n   454→\\t\\t}\\n   455→\\n   456→\\t\\tif w.seen[entry.Hash] {\\n   457→\\t\\t\\tcontinue\\n   458→\\t\\t}\\n   459→\\n   460→\\t\\tif entry.Mode == filemode.Dir {\\n   461→\\t\\t\\tobj, err = GetTree(w.s, entry.Hash)\\n   462→\\t\\t}\\n   463→\\n   464→\\t\\tname = simpleJoin(w.base, entry.Name)\\n   465→\\n   466→\\t\\tif err != nil {\\n   467→\\t\\t\\terr = io.EOF\\n   468→\\t\\t\\treturn name, entry, err\\n   469→\\t\\t}\\n   470→\\n   471→\\t\\tbreak\\n   472→\\t}\\n   473→\\n   474→\\tif !w.recursive {\\n   475→\\t\\treturn name, entry, err\\n   476→\\t}\\n   477→\\n   478→\\tif obj != nil {\\n   479→\\t\\tw.stack = append(w.stack, &treeEntryIter{obj, 0})\\n   480→\\t\\tw.base = simpleJoin(w.base, entry.Name)\\n   481→\\t}\\n   482→\\n   483→\\treturn name, entry, err\\n   484→}\\n   485→\\n   486→// Tree returns the tree that the tree walker most recently operated on.\\n   487→func (w *TreeWalker) Tree() *Tree {\\n   488→\\tcurrent := len(w.stack) - 1\\n   489→\\tif w.stack[current].pos == 0 {\\n   490→\\t\\tcurrent--\\n   491→\\t}\\n   492→\\n   493→\\tif current < 0 {\\n   494→\\t\\treturn nil\\n   495→\\t}\\n   496→\\n   497→\\treturn w.stack[current].t\\n   498→}\\n   499→\\n   500→// Close releases any resources used by the TreeWalker.\\n   501→func (w *TreeWalker) Close() {\\n   502→\\tw.stack = nil\\n   503→}\\n   504→\\n   505→// TreeIter provides an iterator for a set of trees.\\n   506→type TreeIter struct {\\n   507→\\tstorer.EncodedObjectIter\\n   508→\\ts storer.EncodedObjectStorer\\n   509→}\\n   510→\\n   511→// NewTreeIter takes a storer.EncodedObjectStorer and a\\n   512→// storer.EncodedObjectIter and returns a *TreeIter that iterates over all\\n   513→// tree contained in the storer.EncodedObjectIter.\\n   514→//\\n   515→// Any non-tree object re