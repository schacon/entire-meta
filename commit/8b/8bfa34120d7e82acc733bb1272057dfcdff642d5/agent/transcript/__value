\tif err != nil {\\n    40→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    41→\\t}\\n    42→\\n    43→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    44→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    45→\\tfor _, c := range committed {\\n    46→\\t\\tresult = append(result, CheckpointInfo{\\n    47→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    48→\\t\\t\\tSessionID:        c.SessionID,\\n    49→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    50→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    51→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    52→\\t\\t\\tAgent:            c.Agent,\\n    53→\\t\\t\\tIsTask:           c.IsTask,\\n    54→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    55→\\t\\t\\tSessionCount:     c.SessionCount,\\n    56→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    57→\\t\\t})\\n    58→\\t}\\n    59→\\n    60→\\treturn result, nil\\n    61→}\\n    62→\\n    63→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    64→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    65→\\tall, err := s.listCheckpoints()\\n    66→\\tif err != nil {\\n    67→\\t\\treturn nil, err\\n    68→\\t}\\n    69→\\n    70→\\tvar result []CheckpointInfo\\n    71→\\tfor _, cp := range all {\\n    72→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    73→\\t\\t\\tresult = append(result, cp)\\n    74→\\t\\t}\\n    75→\\t}\\n    76→\\n    77→\\tif len(result) == 0 {\\n    78→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    79→\\t}\\n    80→\\n    81→\\treturn result, nil\\n    82→}\\n    83→\\n    84→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    85→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    86→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    87→\\tstore, err := s.getCheckpointStore()\\n    88→\\tif err != nil {\\n    89→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    90→\\t}\\n    91→\\n    92→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    93→\\tif err != nil {\\n    94→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    95→\\t}\\n    96→\\tif content == nil {\\n    97→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    98→\\t}\\n    99→\\tif len(content.Transcript) == 0 {\\n   100→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   101→\\t}\\n   102→\\n   103→\\treturn content.Transcript, nil\\n   104→}\\n   105→\\n   106→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   107→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   108→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   109→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   110→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState) (*CondenseResult, error) {\\n   111→\\t// Get shadow branch\\n   112→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   113→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   114→\\tref, err := repo.Reference(refName, true)\\n   115→\\tif err != nil {\\n   116→\\t\\treturn nil, fmt.Errorf(\\\"shadow branch not found: %w\\\", err)\\n   117→\\t}\\n   118→\\n   119→\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   120→\\t// Use tracked files from session state instead of collecting all files from tree.\\n   121→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   122→\\t// Pass live transcript path so condensation reads the current file rather than a\\n   123→\\t// potentially stale shadow branch copy (SaveChanges may have been skipped if the\\n   124→\\t// last turn had no code changes).\\n   125→\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   126→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   129→\\t}\\n   130→\\n   131→\\t// Get checkpoint store\\n   132→\\tstore, err := s.getCheckpointStore()\\n   133→\\tif err != nil {\\n   134→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   135→\\t}\\n   136→\\n   137→\\t// Get author info\\n   138→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   139→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   140→\\t// Get current branch name\\n   141→\\tbranchName := GetCurrentBranchName(repo)\\n   142→\\n   143→\\t// Generate summary if enabled\\n   144→\\tvar summary *cpkg.Summary\\n   145→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   146→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   147→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   148→\\n   149→\\t\\t// Scope transcript to this checkpoint's portion\\n   150→\\t\\tscopedTranscript := transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   151→\\t\\tif len(scopedTranscript) > 0 {\\n   152→\\t\\t\\tvar err error\\n   153→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, nil)\\n   154→\\t\\t\\tif err != nil {\\n   155→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   156→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   157→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   158→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   159→\\t\\t\\t} else {\\n   160→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   161→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   162→\\t\\t\\t}\\n   163→\\t\\t}\\n   164→\\t}\\n   165→\\n   166→\\t// Write checkpoint metadata using the checkpoint store\\n   167→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   168→\\t\\tCheckpointID:                checkpointID,\\n   169→\\t\\tSessionID:                   state.SessionID,\\n   170→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   171→\\t\\tBranch:                      branchName,\\n   172→\\t\\tTranscript:                  sessionData.Transcript,\\n   173→\\t\\tPrompts:                     sessionData.Prompts,\\n   174→\\t\\tContext:                     sessionData.Context,\\n   175→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   176→\\t\\tCheckpointsCount:            state.StepCount,\\n   177→\\t\\tEphemeralBranch:             shadowBranchName,\\n   178→\\t\\tAuthorName:                  authorName,\\n   179→\\t\\tAuthorEmail:                 authorEmail,\\n   180→\\t\\tAgent:                       state.AgentType,\\n   181→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   182→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   183→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   184→\\t\\tInitialAttribution:          attribution,\\n   185→\\t\\tSummary:                     summary,\\n   186→\\t}); err != nil {\\n   187→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   188→\\t}\\n   189→\\n   190→\\treturn &CondenseResult{\\n   191→\\t\\tCheckpointID:         checkpointID,\\n   192→\\t\\tSessionID:            state.SessionID,\\n   193→\\t\\tCheckpointsCount:     state.StepCount,\\n   194→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   195→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   196→\\t}, nil\\n   197→}\\n   198→\\n   199→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   200→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   201→\\t// This uses user edits captured at each prompt start (before agent works),\\n   202→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   203→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   204→\\tvar attribution *cpkg.InitialAttribution\\n   205→\\theadRef, headErr := repo.Head()\\n   206→\\tif headErr != nil {\\n   207→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   208→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   209→\\t} else {\\n   210→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   211→\\t\\tif commitErr != nil {\\n   212→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   213→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   214→\\t\\t} else {\\n   215→\\t\\t\\theadTree, treeErr := headCommit.Tree()\\n   216→\\t\\t\\tif treeErr != nil {\\n   217→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   218→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   219→\\t\\t\\t} else {\\n   220→\\t\\t\\t\\t// Get shadow branch tree (checkpoint tree - what the agent wrote)\\n   221→\\t\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   222→\\t\\t\\t\\tif shadowErr != nil {\\n   223→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   224→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   225→\\t\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   226→\\t\\t\\t\\t} else {\\n   227→\\t\\t\\t\\t\\tshadowTree, shadowTreeErr := shadowCommit.Tree()\\n   228→\\t\\t\\t\\t\\tif shadowTreeErr != nil {\\n   229→\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   230→\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   231→\\t\\t\\t\\t\\t} else {\\n   232→\\t\\t\\t\\t\\t\\t// Get base tree (state before session started)\\n   233→\\t\\t\\t\\t\\t\\tvar baseTree *object.Tree\\n   234→\\t\\t\\t\\t\\t\\tattrBase := state.AttributionBaseCommit\\n   235→\\t\\t\\t\\t\\t\\tif attrBase == \\\"\\\" {\\n   236→\\t\\t\\t\\t\\t\\t\\tattrBase = state.BaseCommit // backward compat\\n   237→\\t\\t\\t\\t\\t\\t}\\n   238→\\t\\t\\t\\t\\t\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   239→\\t\\t\\t\\t\\t\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   240→\\t\\t\\t\\t\\t\\t\\t\\tbaseTree = tree\\n   241→\\t\\t\\t\\t\\t\\t\\t} else {\\n   242→\\t\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   243→\\t\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   244→\\t\\t\\t\\t\\t\\t\\t}\\n   245→\\t\\t\\t\\t\\t\\t} else {\\n   246→\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   247→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   248→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   249→\\t\\t\\t\\t\\t\\t}\\n   250→\\n   251→\\t\\t\\t\\t\\t\\t// Log accumulated prompt attributions for debugging\\n   252→\\t\\t\\t\\t\\t\\tvar totalUserAdded, totalUserRemoved int\\n   253→\\t\\t\\t\\t\\t\\tfor i, pa := range state.PromptAttributions {\\n   254→\\t\\t\\t\\t\\t\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   255→\\t\\t\\t\\t\\t\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   256→\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   257→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   258→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   259→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   260→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   261→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   262→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   263→\\t\\t\\t\\t\\t\\t}\\n   264→\\n   265→\\t\\t\\t\\t\\t\\tattribution = CalculateAttributionWithAccumulated(\\n   266→\\t\\t\\t\\t\\t\\t\\tbaseTree,\\n   267→\\t\\t\\t\\t\\t\\t\\tshadowTree,\\n   268→\\t\\t\\t\\t\\t\\t\\theadTree,\\n   269→\\t\\t\\t\\t\\t\\t\\tsessionData.FilesTouched,\\n   270→\\t\\t\\t\\t\\t\\t\\tstate.PromptAttributions,\\n   271→\\t\\t\\t\\t\\t\\t)\\n   272→\\n   273→\\t\\t\\t\\t\\t\\tif attribution != nil {\\n   274→\\t\\t\\t\\t\\t\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   275→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   276→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   277→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   278→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   279→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   280→\\t\\t\\t\\t\\t\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   281→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   282→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   283→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   284→\\t\\t\\t\\t\\t\\t}\\n   285→\\t\\t\\t\\t\\t}\\n   286→\\t\\t\\t\\t}\\n   287→\\t\\t\\t}\\n   288→\\t\\t}\\n   289→\\t}\\n   290→\\treturn attribution\\n   291→}\\n   292→\\n   293→// extractSessionData extracts session data from the shadow branch.\\n   294→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   295→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   296→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   297→// This handles the case where SaveChanges was skipped (no code changes) but the transcript\\n   298→// continued growing — the shadow branch copy would be stale.\\n   299→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   300→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   301→\\tcommit, err := repo.CommitObject(shadowRef)\\n   302→\\tif err != nil {\\n   303→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\ttree, err := commit.Tree()\\n   307→\\tif err != nil {\\n   308→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\tdata := &ExtractedSessionData{}\\n   312→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   313→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   314→\\n   315→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   316→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   317→\\t// (SaveChanges is only called when there are file modifications).\\n   318→\\tvar fullTranscript string\\n   319→\\tif liveTranscriptPath != \\\"\\\" {\\n   320→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   321→\\t\\t\\tfullTranscript = string(liveData)\\n   322→\\t\\t}\\n   323→\\t}\\n   324→\\tif fullTranscript == \\\"\\\" {\\n   325→\\t\\t// Fall back to shadow branch copy\\n   326→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   327→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   328→\\t\\t\\t\\tfullTranscript = content\\n   329→\\t\\t\\t}\\n   330→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   331→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   332→\\t\\t\\t\\tfullTranscript = content\\n   333→\\t\\t\\t}\\n   334→\\t\\t}\\n   335→\\t}\\n   336→\\n   337→\\t// Check if this is a Gemini CLI transcript (JSON format, not JSONL)\\n   338→\\tisGeminiFormat := agentType == agent.AgentTypeGemini || isGeminiJSONTranscript(fullTranscript)\\n   339→\\n   340→\\t// Process transcript based on agent type\\n   341→\\tif fullTranscript != \\\"\\\" {\\n   342→\\n   343→\\t\\tif isGeminiFormat {\\n   344→\\t\\t\\t// Gemini uses JSON format with a \\\"messages\\\" array\\n   345→\\t\\t\\tdata.Transcript = []byte(fullTranscript)\\n   346→<<<<<<< HEAD\\n   347→\\t\\t\\t// Count messages in Gemini JSON for consistent position tracking\\n   348→\\t\\t\\t// This must match GetTranscriptPosition() which returns message count\\n   349→\\t\\t\\tif geminiTranscript, err := geminicli.ParseTranscript([]byte(fullTranscript)); err == nil {\\n   350→\\t\\t\\t\\tdata.FullTranscriptLines = len(geminiTranscript.Messages)\\n   351→\\t\\t\\t} else {\\n   352→\\t\\t\\t\\tdata.FullTranscriptLines = 1 // Fallback if parsing fails\\n   353→\\t\\t\\t}\\n   354→=======\\n   355→\\t\\t\\t// Count messages for proper indexing (used for CheckpointTranscriptStart)\\n   356→\\t\\t\\tdata.FullTranscriptLines = countGeminiMessages(fullTranscript)\\n   357→>>>>>>> 2dd8eff6 (addressed PR feedback)\\n   358→\\t\\t\\tdata.Prompts = extractUserPromptsFromGeminiJSON(fullTranscript)\\n   359→\\t\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   360→\\t\\t} else {\\n   361→\\t\\t\\t// Claude Code and others use JSONL format (one JSON object per line)\\n   362→\\t\\t\\tallLines := strings.Split(fullTranscript, \\\"\\\\n\\\")\\n   363→\\n   364→\\t\\t\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   365→\\t\\t\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   366→\\t\\t\\t\\tallLines = allLines[:len(allLines)-1]\\n   367→\\t\\t\\t}\\n   368→\\n   369→\\t\\t\\tdata.FullTranscriptLines = len(allLines)\\n   370→\\n   371→\\t\\t\\t// Always store the full transcript for complete session history\\n   372→\\t\\t\\tdata.Transcript = []byte(strings.Join(allLines, \\\"\\\\n\\\"))\\n   373→\\n   374→\\t\\t\\t// Extract prompts from the full transcript\\n   375→\\t\\t\\tdata.Prompts = extractUserPromptsFromLines(allLines)\\n   376→\\n   377→\\t\\t\\t// Generate context from prompts\\n   378→\\t\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   379→\\t\\t}\\n   380→\\t}\\n   381→\\n   382→\\t// Use tracked files from session state (not all files in tree)\\n   383→\\tdata.FilesTouched = filesTouched\\n   384→\\n   385→\\t// Calculate token usage from the extracted transcript portion\\n   386→\\tif len(data.Transcript) > 0 {\\n   387→\\t\\t// Use agent-specific parser for token calculation\\n   388→\\t\\tif isGeminiFormat {\\n   389→\\t\\t\\t// Gemini JSON format - use Gemini token parser with message index\\n   390→\\t\\t\\tdata.TokenUsage = geminicli.CalculateTokenUsage(data.Transcript, checkpointTranscriptStart)\\n   391→\\t\\t} else {\\n   392→\\t\\t\\t// Claude JSONL format - use Claude token parser\\n   393→\\t\\t\\ttranscriptLines, err := claudecode.ParseTranscript(data.Transcript)\\n   394→\\t\\t\\tif err == nil && len(transcriptLines) > 0 {\\n   395→\\t\\t\\t\\tdata.TokenUsage = claudecode.CalculateTokenUsage(transcriptLines)\\n   396→\\t\\t\\t}\\n   397→\\t\\t}\\n   398→\\t}\\n   399→\\n   400→\\treturn data, nil\\n   401→}\\n   402→\\n   403→// isGeminiJSONTranscript detects if the transcript is in Gemini's JSON format.\\n   404→// Gemini transcripts are JSON objects containing a \\\"messages\\\" array.\\n   405→// Returns true if the content has a valid \\\"messages\\\" field, even if empty.\\n   406→func isGeminiJSONTranscript(content string) bool {\\n   407→\\tcontent = strings.TrimSpace(content)\\n   408→\\t// Quick check: Gemini JSON starts with {\\n   409→\\tif !strings.HasPrefix(content, \\\"{\\\") {\\n   410→\\t\\treturn false\\n   411→\\t}\\n   412→\\t// Try to parse as Gemini format - check for messages field existence\\n   413→\\tvar transcript struct {\\n   414→\\t\\tMessages []json.RawMessage `json:\\\"messages\\\"`\\n   415→\\t}\\n   416→\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n   417→\\t\\treturn false\\n   418→\\t}\\n   419→\\treturn transcript.Messages != nil\\n   420→}\\n   421→\\n   422→// countGeminiMessages counts the number of messages in a Gemini JSON transcript.\\n   423→// Returns 0 if the content is not valid Gemini JSON.\\n   424→func countGeminiMessages(content string) int {\\n   425→\\tvar transcript struct {\\n   426→\\t\\tMessages []json.RawMessage `json:\\\"messages\\\"`\\n   427→\\t}\\n   428→\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n   429→\\t\\treturn 0\\n   430→\\t}\\n   431→\\treturn len(transcript.Messages)\\n   432→}\\n   433→\\n   434→// extractUserPromptsFromGeminiJSON extracts user prompts from Gemini's JSON transcript format.\\n   435→// Gemini transcripts are structured as: {\\\"messages\\\": [{\\\"type\\\": \\\"user\\\", \\\"content\\\": \\\"...\\\"}, ...]}\\n   436→func extractUserPromptsFromGeminiJSON(content string) []string {\\n   437→\\tvar transcript struct {\\n   438→\\t\\tMessages []struct {\\n   439→\\t\\t\\tType    string `json:\\\"type\\\"`\\n   440→\\t\\t\\tContent string `json:\\\"content\\\"`\\n   441→\\t\\t} `json:\\\"messages\\\"`\\n   442→\\t}\\n   443→\\n   444→\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n   445→\\t\\treturn nil\\n   446→\\t}\\n   447→\\n   448→\\tvar prompts []string\\n   449→\\tfor _, msg := range transcript.Messages {\\n   450→\\t\\tif msg.Type == \\\"user\\\" && msg.Content != \\\"\\\" {\\n   451→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   452→\\t\\t\\tcleaned := textutil.StripIDEContextTags(msg.Content)\\n   453→\\t\\t\\tif cleaned != \\\"\\\" {\\n   454→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   455→\\t\\t\\t}\\n   456→\\t\\t}\\n   457→\\t}\\n   458→\\n   459→\\treturn prompts\\n   460→}\\n   461→\\n   462→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   463→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   464→func extractUserPromptsFromLines(lines []string) []string {\\n   465→\\tvar prompts []string\\n   466→\\tfor _, line := range lines {\\n   467→\\t\\tline = strings.TrimSpace(line)\\n   468→\\t\\tif line == \\\"\\\" {\\n   469→\\t\\t\\tcontinue\\n   470→\\t\\t}\\n   471→\\n   472→\\t\\tvar entry map[string]interface{}\\n   473→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   474→\\t\\t\\tcontinue\\n   475→\\t\\t}\\n   476→\\n   477→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   478→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   479→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   480→\\t\\t\\tcontinue\\n   481→\\t\\t}\\n   482→\\n   483→\\t\\t// Extract message content\\n   484→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   485→\\t\\tif !ok {\\n   486→\\t\\t\\tcontinue\\n   487→\\t\\t}\\n   488→\\n   489→\\t\\t// Handle string content\\n   490→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   491→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   492→\\t\\t\\tif cleaned != \\\"\\\" {\\n   493→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   494→\\t\\t\\t}\\n   495→\\t\\t\\tcontinue\\n   496→\\t\\t}\\n   497→\\n   498→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   499→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   500→\\t\\t\\tvar texts []string\\n   501→\\t\\t\\tfor _, item := range arr {\\n   502→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   503→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   504→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   505→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   506→\\t\\t\\t\\t\\t\\t}\\n   507→\\t\\t\\t\\t\\t}\\n   508→\\t\\t\\t\\t}\\n   509→\\t\\t\\t}\\n   510→\\t\\t\\tif len(texts) > 0 {\\n   511→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   512→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   513→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   514→\\t\\t\\t\\t}\\n   515→\\t\\t\\t}\\n   516→\\t\\t}\\n   517→\\t}\\n   518→\\treturn prompts\\n   519→}\\n   520→\\n   521→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   522→func generateContextFromPrompts(prompts []string) []byte {\\n   523→\\tif len(prompts) == 0 {\\n   524→\\t\\treturn nil\\n   525→\\t}\\n   526→\\n   527→\\tvar buf strings.Builder\\n   528→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   529→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   530→\\n   531→\\tfor i, prompt := range prompts {\\n   532→\\t\\t// Truncate very long prompts for readability\\n   533→\\t\\tdisplayPrompt := prompt\\n   534→\\t\\tif len(displayPrompt) > 500 {\\n   535→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   536→\\t\\t}\\n   537→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   538→\\t\\tbuf.WriteString(displayPrompt)\\n   539→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   540→\\t}\\n   541→\\n   542→\\treturn []byte(buf.String())\\n   543→}\\n   544→\\n   545→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   546→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   547→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   548→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   549→\\n   550→\\t// Load session state\\n   551→\\tstate, err := s.loadSessionState(sessionID)\\n   552→\\tif err != nil {\\n   553→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   554→\\t}\\n   555→\\tif state == nil {\\n   556→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   557→\\t}\\n   558→\\n   559→\\t// Open repository\\n   560→\\trepo, err := OpenRepository()\\n   561→\\tif err != nil {\\n   562→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   563→\\t}\\n   564→\\n   565→\\t// Generate a checkpoint ID\\n   566→\\tcheckpointID, err := id.Generate()\\n   567→\\tif err != nil {\\n   568→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   569→\\t}\\n   570→\\n   571→\\t// Check if shadow branch exists (required for condensation)\\n   572→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   573→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   574→\\t_, refErr := repo.Reference(refName, true)\\n   575→\\thasShadowBranch := refErr == nil\\n   576→\\n   577→\\tif !hasShadowBranch {\\n   578→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   579→\\t\\t// Just clean up the state file.\\n   580→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   581→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   582→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   583→\\t\\t)\\n   584→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   585→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   586→\\t\\t}\\n   587→\\t\\treturn nil\\n   588→\\t}\\n   589→\\n   590→\\t// Condense the session\\n   591→\\tresult, err := s.CondenseSession(repo, checkpointID, state)\\n   592→\\tif err != nil {\\n   593→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   594→\\t}\\n   595→\\n   596→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   597→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   598→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   599→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   600→\\t)\\n   601→\\n   602→\\t// Update session state: reset step count and transition to idle\\n   603→\\tstate.StepCount = 0\\n   604→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   605→\\tstate.Phase = session.PhaseIdle\\n   606→\\tstate.LastCheckpointID = checkpointID\\n   607→\\tstate.PendingCheckpointID = \\\"\\\" // Clear after condensation (amend handler uses LastCheckpointID)\\n   608→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   609→\\tstate.PromptAttributions = nil\\n   610→\\tstate.PendingPromptAttribution = nil\\n   611→\\n   612→\\tif err := s.saveSessionState(state); err != nil {\\n   613→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   614→\\t}\\n   615→\\n   616→\\t// Clean up shadow branch if no other sessions need it\\n   617→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   618→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   619→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   620→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   621→\\t\\t)\\n   622→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   623→\\t}\\n   624→\\n   625→\\treturn nil\\n   626→}\\n   627→\\n   628→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   629→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(_ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   630→\\t// List all session states to check if any other session uses this shadow branch\\n   631→\\tallStates, err := s.listAllSessionStates()\\n   632→\\tif err != nil {\\n   633→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   634→\\t}\\n   635→\\n   636→\\tfor _, state := range allStates {\\n   637→\\t\\tif state.SessionID == excludeSessionID {\\n   638→\\t\\t\\tcontinue\\n   639→\\t\\t}\\n   640→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   641→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   642→\\t\\t\\t// Another session still needs this shadow branch\\n   643→\\t\\t\\treturn nil\\n   644→\\t\\t}\\n   645→\\t}\\n   646→\\n   647→\\t// No other sessions need it, delete the shadow branch via CLI\\n   648→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   649→\\tif err := DeleteBranchCLI(shadowBranchName); err != nil {\\n   650→\\t\\t// Branch already gone is not an error\\n   651→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   652→\\t\\t\\treturn nil\\n   653→\\t\\t}\\n   654→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   655→\\t}\\n   656→\\treturn nil\\n   657→}\\n   658→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"285eb8e1-c37e-45cf-9fc7-7541fd1f6a03\",\"timestamp\":\"2026-02-10T04:46:00.255Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the sessions branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState) (*CondenseResult, error) {\\n\\t// Get shadow branch\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"shadow branch not found: %w\\\", err)\\n\\t}\\n\\n\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t// potentially stale shadow branch copy (SaveChanges may have been skipped if the\\n\\t// last turn had no code changes).\\n\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion\\n\\t\\tscopedTranscript := transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\tvar attribution *cpkg.InitialAttribution\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t} else {\\n\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\theadTree, treeErr := headCommit.Tree()\\n\\t\\t\\tif treeErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\t// Get shadow branch tree (checkpoint tree - what the agent wrote)\\n\\t\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\t\\t\\tif shadowErr != nil {\\n\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tshadowTree, shadowTreeErr := shadowCommit.Tree()\\n\\t\\t\\t\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t// Get base tree (state before session started)\\n\\t\\t\\t\\t\\t\\tvar baseTree *object.Tree\\n\\t\\t\\t\\t\\t\\tattrBase := state.AttributionBaseCommit\\n\\t\\t\\t\\t\\t\\tif attrBase == \\\"\\\" {\\n\\t\\t\\t\\t\\t\\t\\tattrBase = state.BaseCommit // backward compat\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n\\t\\t\\t\\t\\t\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\tbaseTree = tree\\n\\t\\t\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n\\t\\t\\t\\t\\t\\t}\\n\\n\\t\\t\\t\\t\\t\\t// Log accumulated prompt attributions for debugging\\n\\t\\t\\t\\t\\t\\tvar totalUserAdded, totalUserRemoved int\\n\\t\\t\\t\\t\\t\\tfor i, pa := range state.PromptAttributions {\\n\\t\\t\\t\\t\\t\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\t\\t\\t\\t\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t\\t\\t\\t\\t\\t}\\n\\n\\t\\t\\t\\t\\t\\tattribution = CalculateAttributionWithAccumulated(\\n\\t\\t\\t\\t\\t\\t\\tbaseTree,\\n\\t\\t\\t\\t\\t\\t\\tshadowTree,\\n\\t\\t\\t\\t\\t\\t\\theadTree,\\n\\t\\t\\t\\t\\t\\t\\tsessionData.FilesTouched,\\n\\t\\t\\t\\t\\t\\t\\tstate.PromptAttributions,\\n\\t\\t\\t\\t\\t\\t)\\n\\n\\t\\t\\t\\t\\t\\tif attribution != nil {\\n\\t\\t\\t\\t\\t\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveChanges was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveChanges is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Check if this is a Gemini CLI transcript (JSON format, not JSONL)\\n\\tisGeminiFormat := agentType == agent.AgentTypeGemini || isGeminiJSONTranscript(fullTranscript)\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\n\\t\\tif isGeminiFormat {\\n\\t\\t\\t// Gemini uses JSON format with a \\\"messages\\\" array\\n\\t\\t\\tdata.Transcript = []byte(fullTranscript)\\n<<<<<<< HEAD\\n\\t\\t\\t// Count messages in Gemini JSON for consistent position tracking\\n\\t\\t\\t// This must match GetTranscriptPosition() which returns message count\\n\\t\\t\\tif geminiTranscript, err := geminicli.ParseTranscript([]byte(fullTranscript)); err == nil {\\n\\t\\t\\t\\tdata.FullTranscriptLines = len(geminiTranscript.Messages)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tdata.FullTranscriptLines = 1 // Fallback if parsing fails\\n\\t\\t\\t}\\n=======\\n\\t\\t\\t// Count messages for proper indexing (used for CheckpointTranscriptStart)\\n\\t\\t\\tdata.FullTranscriptLines = countGeminiMessages(fullTranscript)\\n>>>>>>> 2dd8eff6 (addressed PR feedback)\\n\\t\\t\\tdata.Prompts = extractUserPromptsFromGeminiJSON(fullTranscript)\\n\\t\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t\\t} else {\\n\\t\\t\\t// Claude Code and others use JSONL format (one JSON object per line)\\n\\t\\t\\tallLines := strings.Split(fullTranscript, \\\"\\\\n\\\")\\n\\n\\t\\t\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\t\\t\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\t\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t\\t\\t}\\n\\n\\t\\t\\tdata.FullTranscriptLines = len(allLines)\\n\\n\\t\\t\\t// Always store the full transcript for complete session history\\n\\t\\t\\tdata.Transcript = []byte(strings.Join(allLines, \\\"\\\\n\\\"))\\n\\n\\t\\t\\t// Extract prompts from the full transcript\\n\\t\\t\\tdata.Prompts = extractUserPromptsFromLines(allLines)\\n\\n\\t\\t\\t// Generate context from prompts\\n\\t\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t\\t}\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\t// Use agent-specific parser for token calculation\\n\\t\\tif isGeminiFormat {\\n\\t\\t\\t// Gemini JSON format - use Gemini token parser with message index\\n\\t\\t\\tdata.TokenUsage = geminicli.CalculateTokenUsage(data.Transcript, checkpointTranscriptStart)\\n\\t\\t} else {\\n\\t\\t\\t// Claude JSONL format - use Claude token parser\\n\\t\\t\\ttranscriptLines, err := claudecode.ParseTranscript(data.Transcript)\\n\\t\\t\\tif err == nil && len(transcriptLines) > 0 {\\n\\t\\t\\t\\tdata.TokenUsage = claudecode.CalculateTokenUsage(transcriptLines)\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// isGeminiJSONTranscript detects if the transcript is in Gemini's JSON format.\\n// Gemini transcripts are JSON objects containing a \\\"messages\\\" array.\\n// Returns true if the content has a valid \\\"messages\\\" field, even if empty.\\nfunc isGeminiJSONTranscript(content string) bool {\\n\\tcontent = strings.TrimSpace(content)\\n\\t// Quick check: Gemini JSON starts with {\\n\\tif !strings.HasPrefix(content, \\\"{\\\") {\\n\\t\\treturn false\\n\\t}\\n\\t// Try to parse as Gemini format - check for messages field existence\\n\\tvar transcript struct {\\n\\t\\tMessages []json.RawMessage `json:\\\"messages\\\"`\\n\\t}\\n\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n\\t\\treturn false\\n\\t}\\n\\treturn transcript.Messages != nil\\n}\\n\\n// countGeminiMessages counts the number of messages in a Gemini JSON transcript.\\n// Returns 0 if the content is not valid Gemini JSON.\\nfunc countGeminiMessages(content string) int {\\n\\tvar transcript struct {\\n\\t\\tMessages []json.RawMessage `json:\\\"messages\\\"`\\n\\t}\\n\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n\\t\\treturn 0\\n\\t}\\n\\treturn len(transcript.Messages)\\n}\\n\\n// extractUserPromptsFromGeminiJSON extracts user prompts from Gemini's JSON transcript format.\\n// Gemini transcripts are structured as: {\\\"messages\\\": [{\\\"type\\\": \\\"user\\\", \\\"content\\\": \\\"...\\\"}, ...]}\\nfunc extractUserPromptsFromGeminiJSON(content string) []string {\\n\\tvar transcript struct {\\n\\t\\tMessages []struct {\\n\\t\\t\\tType    string `json:\\\"type\\\"`\\n\\t\\t\\tContent string `json:\\\"content\\\"`\\n\\t\\t} `json:\\\"messages\\\"`\\n\\t}\\n\\n\\tif err := json.Unmarshal([]byte(content), &transcript); err != nil {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar prompts []string\\n\\tfor _, msg := range transcript.Messages {\\n\\t\\tif msg.Type == \\\"user\\\" && msg.Content != \\\"\\\" {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(msg.Content)\\n\\t\\t\\tif cleaned != \\\"\\