\\"fmt\\\"\\n     7→\\t\\\"log/slog\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    14→\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    23→\\n    24→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    25→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    26→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    27→)\\n    28→\\n    29→// listCheckpoints returns all checkpoints from the metadata branch.\\n    30→// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\n    31→func (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n    32→\\tstore, err := s.getCheckpointStore()\\n    33→\\tif err != nil {\\n    34→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    35→\\t}\\n    36→\\n    37→\\tcommitted, err := store.ListCommitted(context.Background())\\n    38→\\tif err != nil {\\n    39→\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n    40→\\t}\\n    41→\\n    42→\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n    43→\\tresult := make([]CheckpointInfo, 0, len(committed))\\n    44→\\tfor _, c := range committed {\\n    45→\\t\\tresult = append(result, CheckpointInfo{\\n    46→\\t\\t\\tCheckpointID:     c.CheckpointID,\\n    47→\\t\\t\\tSessionID:        c.SessionID,\\n    48→\\t\\t\\tCreatedAt:        c.CreatedAt,\\n    49→\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n    50→\\t\\t\\tFilesTouched:     c.FilesTouched,\\n    51→\\t\\t\\tAgent:            c.Agent,\\n    52→\\t\\t\\tIsTask:           c.IsTask,\\n    53→\\t\\t\\tToolUseID:        c.ToolUseID,\\n    54→\\t\\t\\tSessionCount:     c.SessionCount,\\n    55→\\t\\t\\tSessionIDs:       c.SessionIDs,\\n    56→\\t\\t})\\n    57→\\t}\\n    58→\\n    59→\\treturn result, nil\\n    60→}\\n    61→\\n    62→// getCheckpointsForSession returns all checkpoints for a session ID.\\n    63→func (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n    64→\\tall, err := s.listCheckpoints()\\n    65→\\tif err != nil {\\n    66→\\t\\treturn nil, err\\n    67→\\t}\\n    68→\\n    69→\\tvar result []CheckpointInfo\\n    70→\\tfor _, cp := range all {\\n    71→\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n    72→\\t\\t\\tresult = append(result, cp)\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\n    76→\\tif len(result) == 0 {\\n    77→\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n    78→\\t}\\n    79→\\n    80→\\treturn result, nil\\n    81→}\\n    82→\\n    83→// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n    84→// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\n    85→func (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n    86→\\tstore, err := s.getCheckpointStore()\\n    87→\\tif err != nil {\\n    88→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    89→\\t}\\n    90→\\n    91→\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n    92→\\tif err != nil {\\n    93→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n    94→\\t}\\n    95→\\tif content == nil {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n    97→\\t}\\n    98→\\tif len(content.Transcript) == 0 {\\n    99→\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n   100→\\t}\\n   101→\\n   102→\\treturn content.Transcript, nil\\n   103→}\\n   104→\\n   105→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   106→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   107→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   108→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   109→func (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState) (*CondenseResult, error) {\\n   110→\\t// Get shadow branch\\n   111→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   112→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   113→\\tref, err := repo.Reference(refName, true)\\n   114→\\tif err != nil {\\n   115→\\t\\treturn nil, fmt.Errorf(\\\"shadow branch not found: %w\\\", err)\\n   116→\\t}\\n   117→\\n   118→\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   119→\\t// Use tracked files from session state instead of collecting all files from tree.\\n   120→\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n   121→\\t// Pass live transcript path so condensation reads the current file rather than a\\n   122→\\t// potentially stale shadow branch copy (SaveChanges may have been skipped if the\\n   123→\\t// last turn had no code changes).\\n   124→\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n   125→\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n   126→\\tif err != nil {\\n   127→\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\t// Get checkpoint store\\n   131→\\tstore, err := s.getCheckpointStore()\\n   132→\\tif err != nil {\\n   133→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   134→\\t}\\n   135→\\n   136→\\t// Get author info\\n   137→\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n   138→\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n   139→\\t// Get current branch name\\n   140→\\tbranchName := GetCurrentBranchName(repo)\\n   141→\\n   142→\\t// Generate summary if enabled\\n   143→\\tvar summary *cpkg.Summary\\n   144→\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n   145→\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   146→\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n   147→\\n   148→\\t\\t// Scope transcript to this checkpoint's portion.\\n   149→\\t\\t// SliceFromLine only works for JSONL (Claude Code) transcripts where\\n   150→\\t\\t// CheckpointTranscriptStart is a line offset. For Gemini JSON transcripts,\\n   151→\\t\\t// CheckpointTranscriptStart is a message index and the transcript is a single\\n   152→\\t\\t// JSON blob, so line-based slicing would produce malformed content.\\n   153→\\t\\t// The summarizer (ParseFromBytes) only supports JSONL, so skip scoping for Gemini.\\n   154→\\t\\tvar scopedTranscript []byte\\n   155→\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n   156→\\t\\t\\tscopedTranscript = sessionData.Transcript\\n   157→\\t\\t} else {\\n   158→\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n   159→\\t\\t}\\n   160→\\t\\tif len(scopedTranscript) > 0 {\\n   161→\\t\\t\\tvar err error\\n   162→\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, nil)\\n   163→\\t\\t\\tif err != nil {\\n   164→\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n   165→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   166→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   167→\\t\\t\\t\\t// Continue without summary - non-blocking\\n   168→\\t\\t\\t} else {\\n   169→\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n   170→\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n   171→\\t\\t\\t}\\n   172→\\t\\t}\\n   173→\\t}\\n   174→\\n   175→\\t// Write checkpoint metadata using the checkpoint store\\n   176→\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n   177→\\t\\tCheckpointID:                checkpointID,\\n   178→\\t\\tSessionID:                   state.SessionID,\\n   179→\\t\\tStrategy:                    StrategyNameManualCommit,\\n   180→\\t\\tBranch:                      branchName,\\n   181→\\t\\tTranscript:                  sessionData.Transcript,\\n   182→\\t\\tPrompts:                     sessionData.Prompts,\\n   183→\\t\\tContext:                     sessionData.Context,\\n   184→\\t\\tFilesTouched:                sessionData.FilesTouched,\\n   185→\\t\\tCheckpointsCount:            state.StepCount,\\n   186→\\t\\tEphemeralBranch:             shadowBranchName,\\n   187→\\t\\tAuthorName:                  authorName,\\n   188→\\t\\tAuthorEmail:                 authorEmail,\\n   189→\\t\\tAgent:                       state.AgentType,\\n   190→\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n   191→\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n   192→\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n   193→\\t\\tInitialAttribution:          attribution,\\n   194→\\t\\tSummary:                     summary,\\n   195→\\t}); err != nil {\\n   196→\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n   197→\\t}\\n   198→\\n   199→\\treturn &CondenseResult{\\n   200→\\t\\tCheckpointID:         checkpointID,\\n   201→\\t\\tSessionID:            state.SessionID,\\n   202→\\t\\tCheckpointsCount:     state.StepCount,\\n   203→\\t\\tFilesTouched:         sessionData.FilesTouched,\\n   204→\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n   205→\\t}, nil\\n   206→}\\n   207→\\n   208→func calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n   209→\\t// Calculate initial attribution using accumulated prompt attribution data.\\n   210→\\t// This uses user edits captured at each prompt start (before agent works),\\n   211→\\t// plus any user edits after the final checkpoint (shadow → head).\\n   212→\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n   213→\\tvar attribution *cpkg.InitialAttribution\\n   214→\\theadRef, headErr := repo.Head()\\n   215→\\tif headErr != nil {\\n   216→\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   217→\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   218→\\t} else {\\n   219→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   220→\\t\\tif commitErr != nil {\\n   221→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   222→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   223→\\t\\t} else {\\n   224→\\t\\t\\theadTree, treeErr := headCommit.Tree()\\n   225→\\t\\t\\tif treeErr != nil {\\n   226→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   227→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   228→\\t\\t\\t} else {\\n   229→\\t\\t\\t\\t// Get shadow branch tree (checkpoint tree - what the agent wrote)\\n   230→\\t\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   231→\\t\\t\\t\\tif shadowErr != nil {\\n   232→\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   233→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   234→\\t\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   235→\\t\\t\\t\\t} else {\\n   236→\\t\\t\\t\\t\\tshadowTree, shadowTreeErr := shadowCommit.Tree()\\n   237→\\t\\t\\t\\t\\tif shadowTreeErr != nil {\\n   238→\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   239→\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   240→\\t\\t\\t\\t\\t} else {\\n   241→\\t\\t\\t\\t\\t\\t// Get base tree (state before session started)\\n   242→\\t\\t\\t\\t\\t\\tvar baseTree *object.Tree\\n   243→\\t\\t\\t\\t\\t\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); baseErr == nil {\\n   244→\\t\\t\\t\\t\\t\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   245→\\t\\t\\t\\t\\t\\t\\t\\tbaseTree = tree\\n   246→\\t\\t\\t\\t\\t\\t\\t} else {\\n   247→\\t\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   248→\\t\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   249→\\t\\t\\t\\t\\t\\t\\t}\\n   250→\\t\\t\\t\\t\\t\\t} else {\\n   251→\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   252→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   253→\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit))\\n   254→\\t\\t\\t\\t\\t\\t}\\n   255→\\n   256→\\t\\t\\t\\t\\t\\t// Log accumulated prompt attributions for debugging\\n   257→\\t\\t\\t\\t\\t\\tvar totalUserAdded, totalUserRemoved int\\n   258→\\t\\t\\t\\t\\t\\tfor i, pa := range state.PromptAttributions {\\n   259→\\t\\t\\t\\t\\t\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   260→\\t\\t\\t\\t\\t\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   261→\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   262→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   263→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   264→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   265→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   266→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   267→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   268→\\t\\t\\t\\t\\t\\t}\\n   269→\\n   270→\\t\\t\\t\\t\\t\\tattribution = CalculateAttributionWithAccumulated(\\n   271→\\t\\t\\t\\t\\t\\t\\tbaseTree,\\n   272→\\t\\t\\t\\t\\t\\t\\tshadowTree,\\n   273→\\t\\t\\t\\t\\t\\t\\theadTree,\\n   274→\\t\\t\\t\\t\\t\\t\\tsessionData.FilesTouched,\\n   275→\\t\\t\\t\\t\\t\\t\\tstate.PromptAttributions,\\n   276→\\t\\t\\t\\t\\t\\t)\\n   277→\\n   278→\\t\\t\\t\\t\\t\\tif attribution != nil {\\n   279→\\t\\t\\t\\t\\t\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   280→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   281→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   282→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   283→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   284→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   285→\\t\\t\\t\\t\\t\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   286→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   287→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   288→\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   289→\\t\\t\\t\\t\\t\\t}\\n   290→\\t\\t\\t\\t\\t}\\n   291→\\t\\t\\t\\t}\\n   292→\\t\\t\\t}\\n   293→\\t\\t}\\n   294→\\t}\\n   295→\\treturn attribution\\n   296→}\\n   297→\\n   298→// extractSessionData extracts session data from the shadow branch.\\n   299→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   300→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   301→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   302→// This handles the case where SaveChanges was skipped (no code changes) but the transcript\\n   303→// continued growing — the shadow branch copy would be stale.\\n   304→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   305→func (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n   306→\\tcommit, err := repo.CommitObject(shadowRef)\\n   307→\\tif err != nil {\\n   308→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   309→\\t}\\n   310→\\n   311→\\ttree, err := commit.Tree()\\n   312→\\tif err != nil {\\n   313→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   314→\\t}\\n   315→\\n   316→\\tdata := &ExtractedSessionData{}\\n   317→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   318→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   319→\\n   320→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   321→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   322→\\t// (SaveChanges is only called when there are file modifications).\\n   323→\\tvar fullTranscript string\\n   324→\\tif liveTranscriptPath != \\\"\\\" {\\n   325→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   326→\\t\\t\\tfullTranscript = string(liveData)\\n   327→\\t\\t}\\n   328→\\t}\\n   329→\\tif fullTranscript == \\\"\\\" {\\n   330→\\t\\t// Fall back to shadow branch copy\\n   331→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   332→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   333→\\t\\t\\t\\tfullTranscript = content\\n   334→\\t\\t\\t}\\n   335→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   336→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   337→\\t\\t\\t\\tfullTranscript = content\\n   338→\\t\\t\\t}\\n   339→\\t\\t}\\n   340→\\t}\\n   341→\\n   342→\\t// Process transcript based on agent type\\n   343→\\tif fullTranscript != \\\"\\\" {\\n   344→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   345→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   346→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   347→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   348→\\t}\\n   349→\\n   350→\\t// Use tracked files from session state (not all files in tree)\\n   351→\\tdata.FilesTouched = filesTouched\\n   352→\\n   353→\\t// Calculate token usage from the extracted transcript portion\\n   354→\\tif len(data.Transcript) > 0 {\\n   355→\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n   356→\\t}\\n   357→\\n   358→\\treturn data, nil\\n   359→}\\n   360→\\n   361→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   362→// For Claude Code and JSONL-based agents, this counts lines.\\n   363→// For Gemini CLI and JSON-based agents, this counts messages.\\n   364→// Returns 0 if the content is empty or malformed.\\n   365→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   366→\\tif content == \\\"\\\" {\\n   367→\\t\\treturn 0\\n   368→\\t}\\n   369→\\n   370→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   371→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   372→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   373→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   374→\\t\\t\\treturn len(transcript.Messages)\\n   375→\\t\\t}\\n   376→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   377→\\t\\tif agentType == agent.AgentTypeGemini {\\n   378→\\t\\t\\treturn 0\\n   379→\\t\\t}\\n   380→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   381→\\t}\\n   382→\\n   383→\\t// Claude Code and other JSONL-based agents\\n   384→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   385→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   386→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   387→\\t\\tallLines = allLines[:len(allLines)-1]\\n   388→\\t}\\n   389→\\treturn len(allLines)\\n   390→}\\n   391→\\n   392→// extractUserPrompts extracts all user prompts from transcript content.\\n   393→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   394→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   395→\\tif content == \\\"\\\" {\\n   396→\\t\\treturn nil\\n   397→\\t}\\n   398→\\n   399→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   400→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   401→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   402→\\t\\tif err == nil && len(prompts) > 0 {\\n   403→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   404→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   405→\\t\\t\\tfor _, prompt := range prompts {\\n   406→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   407→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   408→\\t\\t\\t\\t}\\n   409→\\t\\t\\t}\\n   410→\\t\\t\\treturn cleaned\\n   411→\\t\\t}\\n   412→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   413→\\t\\tif agentType == agent.AgentTypeGemini {\\n   414→\\t\\t\\treturn nil\\n   415→\\t\\t}\\n   416→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   417→\\t}\\n   418→\\n   419→\\t// Claude Code and other JSONL-based agents\\n   420→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   421→}\\n   422→\\n   423→// calculateTokenUsage calculates token usage from raw transcript data.\\n   424→// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n   425→// where the current checkpoint began, allowing calculation for only the portion\\n   426→// of the transcript since the last checkpoint.\\n   427→func calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n   428→\\tif len(data) == 0 {\\n   429→\\t\\treturn &agent.TokenUsage{}\\n   430→\\t}\\n   431→\\n   432→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   433→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   434→\\t\\t// Attempt to parse as Gemini JSON\\n   435→\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n   436→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   437→\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n   438→\\t\\t}\\n   439→\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n   440→\\t\\tif agentType == agent.AgentTypeGemini {\\n   441→\\t\\t\\treturn &agent.TokenUsage{}\\n   442→\\t\\t}\\n   443→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   444→\\t}\\n   445→\\n   446→\\t// Claude Code and other JSONL-based agents\\n   447→\\tlines, err := claudecode.ParseTranscript(data)\\n   448→\\tif err != nil || len(lines) == 0 {\\n   449→\\t\\treturn &agent.TokenUsage{}\\n   450→\\t}\\n   451→\\t// Slice transcript lines to only include checkpoint portion\\n   452→\\tif startOffset > 0 && startOffset < len(lines) {\\n   453→\\t\\tlines = lines[startOffset:]\\n   454→\\t}\\n   455→\\treturn claudecode.CalculateTokenUsage(lines)\\n   456→}\\n   457→\\n   458→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   459→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   460→func extractUserPromptsFromLines(lines []string) []string {\\n   461→\\tvar prompts []string\\n   462→\\tfor _, line := range lines {\\n   463→\\t\\tline = strings.TrimSpace(line)\\n   464→\\t\\tif line == \\\"\\\" {\\n   465→\\t\\t\\tcontinue\\n   466→\\t\\t}\\n   467→\\n   468→\\t\\tvar entry map[string]interface{}\\n   469→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   470→\\t\\t\\tcontinue\\n   471→\\t\\t}\\n   472→\\n   473→\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n   474→\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n   475→\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n   476→\\t\\t\\tcontinue\\n   477→\\t\\t}\\n   478→\\n   479→\\t\\t// Extract message content\\n   480→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   481→\\t\\tif !ok {\\n   482→\\t\\t\\tcontinue\\n   483→\\t\\t}\\n   484→\\n   485→\\t\\t// Handle string content\\n   486→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   487→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   488→\\t\\t\\tif cleaned != \\\"\\\" {\\n   489→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   490→\\t\\t\\t}\\n   491→\\t\\t\\tcontinue\\n   492→\\t\\t}\\n   493→\\n   494→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   495→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   496→\\t\\t\\tvar texts []string\\n   497→\\t\\t\\tfor _, item := range arr {\\n   498→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   499→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   500→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   501→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   502→\\t\\t\\t\\t\\t\\t}\\n   503→\\t\\t\\t\\t\\t}\\n   504→\\t\\t\\t\\t}\\n   505→\\t\\t\\t}\\n   506→\\t\\t\\tif len(texts) > 0 {\\n   507→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   508→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   509→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   510→\\t\\t\\t\\t}\\n   511→\\t\\t\\t}\\n   512→\\t\\t}\\n   513→\\t}\\n   514→\\treturn prompts\\n   515→}\\n   516→\\n   517→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   518→func generateContextFromPrompts(prompts []string) []byte {\\n   519→\\tif len(prompts) == 0 {\\n   520→\\t\\treturn nil\\n   521→\\t}\\n   522→\\n   523→\\tvar buf strings.Builder\\n   524→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   525→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   526→\\n   527→\\tfor i, prompt := range prompts {\\n   528→\\t\\t// Truncate very long prompts for readability\\n   529→\\t\\tdisplayPrompt := prompt\\n   530→\\t\\tif len(displayPrompt) > 500 {\\n   531→\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n   532→\\t\\t}\\n   533→\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n   534→\\t\\tbuf.WriteString(displayPrompt)\\n   535→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   536→\\t}\\n   537→\\n   538→\\treturn []byte(buf.String())\\n   539→}\\n   540→\\n   541→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   542→// This is used by \\\"entire sessions fix\\\" to salvage stuck sessions.\\n   543→func (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n   544→\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n   545→\\n   546→\\t// Load session state\\n   547→\\tstate, err := s.loadSessionState(sessionID)\\n   548→\\tif err != nil {\\n   549→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   550→\\t}\\n   551→\\tif state == nil {\\n   552→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   553→\\t}\\n   554→\\n   555→\\t// Open repository\\n   556→\\trepo, err := OpenRepository()\\n   557→\\tif err != nil {\\n   558→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   559→\\t}\\n   560→\\n   561→\\t// Generate a checkpoint ID\\n   562→\\tcheckpointID, err := id.Generate()\\n   563→\\tif err != nil {\\n   564→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   565→\\t}\\n   566→\\n   567→\\t// Check if shadow branch exists (required for condensation)\\n   568→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   569→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   570→\\t_, refErr := repo.Reference(refName, true)\\n   571→\\thasShadowBranch := refErr == nil\\n   572→\\n   573→\\tif !hasShadowBranch {\\n   574→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   575→\\t\\t// Just clean up the state file.\\n   576→\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n   577→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   578→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   579→\\t\\t)\\n   580→\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n   581→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   582→\\t\\t}\\n   583→\\t\\treturn nil\\n   584→\\t}\\n   585→\\n   586→\\t// Condense the session\\n   587→\\tresult, err := s.CondenseSession(repo, checkpointID, state)\\n   588→\\tif err != nil {\\n   589→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   590→\\t}\\n   591→\\n   592→\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n   593→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   594→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   595→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   596→\\t)\\n   597→\\n   598→\\t// Update session state: reset step count and transition to idle\\n   599→\\tstate.StepCount = 0\\n   600→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   601→\\tstate.Phase = session.PhaseIdle\\n   602→\\tstate.LastCheckpointID = checkpointID\\n   603→\\tstate.PendingCheckpointID = \\\"\\\" // Clear after condensation (amend handler uses LastCheckpointID)\\n   604→\\tstate.PromptAttributions = nil\\n   605→\\tstate.PendingPromptAttribution = nil\\n   606→\\n   607→\\tif err := s.saveSessionState(state); err != nil {\\n   608→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   609→\\t}\\n   610→\\n   611→\\t// Clean up shadow branch if no other sessions need it\\n   612→\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n   613→\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n   614→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   615→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   616→\\t\\t)\\n   617→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   618→\\t}\\n   619→\\n   620→\\treturn nil\\n   621→}\\n   622→\\n   623→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   624→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(repo *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   625→\\t// List all session states to check if any other session uses this shadow branch\\n   626→\\tallStates, err := s.listAllSessionStates()\\n   627→\\tif err != nil {\\n   628→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   629→\\t}\\n   630→\\n   631→\\tfor _, state := range allStates {\\n   632→\\t\\tif state.SessionID == excludeSessionID {\\n   633→\\t\\t\\tcontinue\\n   634→\\t\\t}\\n   635→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   636→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   637→\\t\\t\\t// Another session still needs this shadow branch\\n   638→\\t\\t\\treturn nil\\n   639→\\t\\t}\\n   640→\\t}\\n   641→\\n   642→\\t// No other sessions need it, delete the shadow branch\\n   643→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   644→\\tref, refErr := repo.Reference(refName, true)\\n   645→\\tif refErr != nil {\\n   646→\\t\\t// Branch already gone, nothing to clean up\\n   647→\\t\\treturn nil //nolint:nilerr // intentional: missing branch is not an error\\n   648→\\t}\\n   649→\\tif err := repo.Storer.RemoveReference(ref.Name()); err != nil {\\n   650→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch reference: %w\\\", err)\\n   651→\\t}\\n   652→\\treturn nil\\n   653→}\\n   654→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"8f151834-eea0-4270-a9fd-508e78df56bb\",\"timestamp\":\"2026-02-10T04:25:20.190Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/alex/workspace/cli/.worktrees/3/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints() ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(context.Background())\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints()\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(context.Background(), checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\nfunc (s *ManualCommitStrategy) CondenseSession(repo *git.Repository, checkpointID id.CheckpointID, state *SessionState) (*CondenseResult, error) {\\n\\t// Get shadow branch\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, err := repo.Reference(refName, true)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"shadow branch not found: %w\\\", err)\\n\\t}\\n\\n\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t// potentially stale shadow branch copy (SaveChanges may have been skipped if the\\n\\t// last turn had no code changes).\\n\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\tsessionData, err := s.extractSessionData(repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", err)\\n\\t}\\n\\n\\t// Get checkpoint store\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\t// Get author info\\n\\tauthorName, authorEmail := GetGitAuthorFromRepo(repo)\\n\\tattribution := calculateSessionAttributions(repo, ref, sessionData, state)\\n\\t// Get current branch name\\n\\tbranchName := GetCurrentBranchName(repo)\\n\\n\\t// Generate summary if enabled\\n\\tvar summary *cpkg.Summary\\n\\tif settings.IsSummarizeEnabled() && len(sessionData.Transcript) > 0 {\\n\\t\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\t\\tsummarizeCtx := logging.WithComponent(logCtx, \\\"summarize\\\")\\n\\n\\t\\t// Scope transcript to this checkpoint's portion.\\n\\t\\t// SliceFromLine only works for JSONL (Claude Code) transcripts where\\n\\t\\t// CheckpointTranscriptStart is a line offset. For Gemini JSON transcripts,\\n\\t\\t// CheckpointTranscriptStart is a message index and the transcript is a single\\n\\t\\t// JSON blob, so line-based slicing would produce malformed content.\\n\\t\\t// The summarizer (ParseFromBytes) only supports JSONL, so skip scoping for Gemini.\\n\\t\\tvar scopedTranscript []byte\\n\\t\\tif state.AgentType == agent.AgentTypeGemini {\\n\\t\\t\\tscopedTranscript = sessionData.Transcript\\n\\t\\t} else {\\n\\t\\t\\tscopedTranscript = transcript.SliceFromLine(sessionData.Transcript, state.CheckpointTranscriptStart)\\n\\t\\t}\\n\\t\\tif len(scopedTranscript) > 0 {\\n\\t\\t\\tvar err error\\n\\t\\t\\tsummary, err = summarize.GenerateFromTranscript(summarizeCtx, scopedTranscript, sessionData.FilesTouched, nil)\\n\\t\\t\\tif err != nil {\\n\\t\\t\\t\\tlogging.Warn(summarizeCtx, \\\"summary generation failed\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n\\t\\t\\t\\t// Continue without summary - non-blocking\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tlogging.Info(summarizeCtx, \\\"summary generated\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID))\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write checkpoint metadata using the checkpoint store\\n\\tif err := store.WriteCommitted(context.Background(), cpkg.WriteCommittedOptions{\\n\\t\\tCheckpointID:                checkpointID,\\n\\t\\tSessionID:                   state.SessionID,\\n\\t\\tStrategy:                    StrategyNameManualCommit,\\n\\t\\tBranch:                      branchName,\\n\\t\\tTranscript:                  sessionData.Transcript,\\n\\t\\tPrompts:                     sessionData.Prompts,\\n\\t\\tContext:                     sessionData.Context,\\n\\t\\tFilesTouched:                sessionData.FilesTouched,\\n\\t\\tCheckpointsCount:            state.StepCount,\\n\\t\\tEphemeralBranch:             shadowBranchName,\\n\\t\\tAuthorName:                  authorName,\\n\\t\\tAuthorEmail:                 authorEmail,\\n\\t\\tAgent:                       state.AgentType,\\n\\t\\tTranscriptIdentifierAtStart: state.TranscriptIdentifierAtStart,\\n\\t\\tCheckpointTranscriptStart:   state.CheckpointTranscriptStart,\\n\\t\\tTokenUsage:                  sessionData.TokenUsage,\\n\\t\\tInitialAttribution:          attribution,\\n\\t\\tSummary:                     summary,\\n\\t}); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to write checkpoint metadata: %w\\\", err)\\n\\t}\\n\\n\\treturn &CondenseResult{\\n\\t\\tCheckpointID:         checkpointID,\\n\\t\\tSessionID:            state.SessionID,\\n\\t\\tCheckpointsCount:     state.StepCount,\\n\\t\\tFilesTouched:         sessionData.FilesTouched,\\n\\t\\tTotalTranscriptLines: sessionData.FullTranscriptLines,\\n\\t}, nil\\n}\\n\\nfunc calculateSessionAttributions(repo *git.Repository, shadowRef *plumbing.Reference, sessionData *ExtractedSessionData, state *SessionState) *cpkg.InitialAttribution {\\n\\t// Calculate initial attribution using accumulated prompt attribution data.\\n\\t// This uses user edits captured at each prompt start (before agent works),\\n\\t// plus any user edits after the final checkpoint (shadow → head).\\n\\tlogCtx := logging.WithComponent(context.Background(), \\\"attribution\\\")\\n\\tvar attribution *cpkg.InitialAttribution\\n\\theadRef, headErr := repo.Head()\\n\\tif headErr != nil {\\n\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n\\t} else {\\n\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n\\t\\tif commitErr != nil {\\n\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n\\t\\t} else {\\n\\t\\t\\theadTree, treeErr := headCommit.Tree()\\n\\t\\t\\tif treeErr != nil {\\n\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n\\t\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n\\t\\t\\t} else {\\n\\t\\t\\t\\t// Get shadow branch tree (checkpoint tree - what the agent wrote)\\n\\t\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n\\t\\t\\t\\tif shadowErr != nil {\\n\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n\\t\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\tshadowTree, shadowTreeErr := shadowCommit.Tree()\\n\\t\\t\\t\\t\\tif shadowTreeErr != nil {\\n\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t// Get base tree (state before session started)\\n\\t\\t\\t\\t\\t\\tvar baseTree *object.Tree\\n\\t\\t\\t\\t\\t\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(state.BaseCommit)); baseErr == nil {\\n\\t\\t\\t\\t\\t\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n\\t\\t\\t\\t\\t\\t\\t\\tbaseTree = tree\\n\\t\\t\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n\\t\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t\\t} else {\\n\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.String(\\\"base_commit\\\", state.BaseCommit))\\n\\t\\t\\t\\t\\t\\t}\\n\\n\\t\\t\\t\\t\\t\\t// Log accumulated prompt attributions for debugging\\n\\t\\t\\t\\t\\t\\tvar totalUserAdded, totalUserRemoved int\\n\\t\\t\\t\\t\\t\\tfor i, pa := range state.PromptAttributions {\\n\\t\\t\\t\\t\\t\\t\\ttotalUserAdded += pa.UserLinesAdded\\n\\t\\t\\t\\t\\t\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n\\t\\t\\t\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"index\\\", i))\\n\\t\\t\\t\\t\\t\\t}\\n\\n\\t\\t\\t\\t\\t\\tattribution = CalculateAttributionWithAccumulated(\\n\\t\\t\\t\\t\\t\\t\\tbaseTree,\\n\\t\\t\\t\\t\\t\\t\\tshadowTree,\\n\\t\\t\\t\\t\\t\\t\\theadTree,\\n\\t\\t\\t\\t\\t\\t\\tsessionData.FilesTouched,\\n\\t\\t\\t\\t\\t\\t\\tstate.PromptAttributions,\\n\\t\\t\\t\\t\\t\\t)\\n\\n\\t\\t\\t\\t\\t\\tif attribution != nil {\\n\\t\\t\\t\\t\\t\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n\\t\\t\\t\\t\\t\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn attribution\\n}\\n\\n// extractSessionData extracts session data from the shadow branch.\\n// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n// This handles the case where SaveChanges was skipped (no code changes) but the transcript\\n// continued growing — the shadow branch copy would be stale.\\n// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\nfunc (s *ManualCommitStrategy) extractSessionData(repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int) (*ExtractedSessionData, error) {\\n\\tcommit, err := repo.CommitObject(shadowRef)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n\\t}\\n\\n\\ttree, err := commit.Tree()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n\\t}\\n\\n\\tdata := &ExtractedSessionData{}\\n\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\n\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n\\t// (SaveChanges is only called when there are file modifications).\\n\\tvar fullTranscript string\\n\\tif liveTranscriptPath != \\\"\\\" {\\n\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n\\t\\t\\tfullTranscript = string(liveData)\\n\\t\\t}\\n\\t}\\n\\tif fullTranscript == \\\"\\\" {\\n\\t\\t// Fall back to shadow branch copy\\n\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n\\t\\t\\t\\tfullTranscript = content\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Process transcript based on agent type\\n\\tif fullTranscript != \\\"\\\" {\\n\\t\\tdata.Transcript = []byte(fullTranscript)\\n\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n\\t}\\n\\n\\t// Use tracked files from session state (not all files in tree)\\n\\tdata.FilesTouched = filesTouched\\n\\n\\t// Calculate token usage from the extracted transcript portion\\n\\tif len(data.Transcript) > 0 {\\n\\t\\tdata.TokenUsage = calculateTokenUsage(agentType, data.Transcript, checkpointTranscriptStart)\\n\\t}\\n\\n\\treturn data, nil\\n}\\n\\n// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n// For Claude Code and JSONL-based agents, this counts lines.\\n// For Gemini CLI and JSON-based agents, this counts messages.\\n// Returns 0 if the content is empty or malformed.\\nfunc countTranscriptItems(agentType agent.AgentType, content string) int {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn 0\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn len(transcript.Messages)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn 0\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n\\t\\tallLines = allLines[:len(allLines)-1]\\n\\t}\\n\\treturn len(allLines)\\n}\\n\\n// extractUserPrompts extracts all user prompts from transcript content.\\n// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\nfunc extractUserPrompts(agentType agent.AgentType, content string) []string {\\n\\tif content == \\\"\\\" {\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n\\t\\tif err == nil && len(prompts) > 0 {\\n\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n\\t\\t\\tfor _, prompt := range prompts {\\n\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\treturn cleaned\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n}\\n\\n// calculateTokenUsage calculates token usage from raw transcript data.\\n// startOffset is the line number (Claude Code) or message index (Gemini CLI)\\n// where the current checkpoint began, allowing calculation for only the portion\\n// of the transcript since the last checkpoint.\\nfunc calculateTokenUsage(agentType agent.AgentType, data []byte, startOffset int) *agent.TokenUsage {\\n\\tif len(data) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\n\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n\\t\\t// Attempt to parse as Gemini JSON\\n\\t\\ttranscript, err := geminicli.ParseTranscript(data)\\n\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n\\t\\t\\treturn geminicli.CalculateTokenUsage(data, startOffset)\\n\\t\\t}\\n\\t\\t// If agentType is explicitly Gemini but parsing failed, return empty usage\\n\\t\\tif agentType == agent.AgentTypeGemini {\\n\\t\\t\\treturn &agent.TokenUsage{}\\n\\t\\t}\\n\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n\\t}\\n\\n\\t// Claude Code and other JSONL-based agents\\n\\tlines, err := claudecode.ParseTranscript(data)\\n\\tif err != nil || len(lines) == 0 {\\n\\t\\treturn &agent.TokenUsage{}\\n\\t}\\n\\t// Slice transcript lines to only include checkpoint portion\\n\\tif startOffset > 0 && startOffset < len(lines) {\\n\\t\\tlines = lines[startOffset:]\\n\\t}\\n\\treturn claudecode.CalculateTokenUsage(lines)\\n}\\n\\n// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\nfunc extractUserPromptsFromLines(lines []string) []string {\\n\\tvar prompts []string\\n\\tfor _, line := range lines {\\n\\t\\tline = strings.TrimSpace(line)\\n\\t\\tif line == \\\"\\\" {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\tvar entry map[string]interface{}\\n\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Check for user message (supports both \\\"human\\\" and \\\"user\\\" types)\\n\\t\\tmsgType, ok := entry[\\\"type\\\"].(string)\\n\\t\\tif !ok || (msgType != \\\"human\\\" && msgType != \\\"user\\\") {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Extract message content\\n\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n\\t\\tif !ok {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle string content\\n\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t}\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\n\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n\\t\\t\\tvar texts []string\\n\\t\\t\\tfor _, item := range arr {\\n\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n\\t\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t\\t}\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tif len(texts) > 0 {\\n\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\treturn prompts\\n}\\n\\n// generateContextFromPrompts generates context.md content from a list of prompts.\\nfunc generateContextFromPrompts(prompts []string) []byte {\\n\\tif len(prompts) == 0 {\\n\\t\\treturn nil\\n\\t}\\n\\n\\tvar buf strings.Builder\\n\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n\\n\\tfor i, prompt := range prompts {\\n\\t\\t// Truncate very long prompts for readability\\n\\t\\tdisplayPrompt := prompt\\n\\t\\tif len(displayPrompt) > 500 {\\n\\t\\t\\tdisplayPrompt = displayPrompt[:500] + \\\"...\\\"\\n\\t\\t}\\n\\t\\tbuf.WriteString(fmt.Sprintf(\\\"### Prompt %d\\\\n\\\\n\\\", i+1))\\n\\t\\tbuf.WriteString(displayPrompt)\\n\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n\\t}\\n\\n\\treturn []byte(buf.String())\\n}\\n\\n// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n// This is used by \\\"entire sessions fix\\\" to salvage stuck sessions.\\nfunc (s *ManualCommitStrategy) CondenseSessionByID(sessionID string) error {\\n\\tctx := logging.WithComponent(context.Background(), \\\"condense-by-id\\\")\\n\\n\\t// Load session state\\n\\tstate, err := s.loadSessionState(sessionID)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n\\t}\\n\\tif state == nil {\\n\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n\\t}\\n\\n\\t// Open repository\\n\\trepo, err := OpenRepository()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Generate a checkpoint ID\\n\\tcheckpointID, err := id.Generate()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n\\t}\\n\\n\\t// Check if shadow branch exists (required for condensation)\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t_, refErr := repo.Reference(refName, true)\\n\\thasShadowBranch := refErr == nil\\n\\n\\tif !hasShadowBranch {\\n\\t\\t// No shadow branch means no checkpoint data to condense.\\n\\t\\t// Just clean up the state file.\\n\\t\\tlogging.Info(ctx, \\\"no shadow branch for session, clearing state only\\\",\\n\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t)\\n\\t\\tif err := s.clearSessionState(sessionID); err != nil {\\n\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Condense the session\\n\\tresult, err := s.CondenseSession(repo, checkpointID, state)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n\\t}\\n\\n\\tlogging.Info(ctx, \\\"session condensed by ID\\\",\\n\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n\\t)\\n\\n\\t// Update session state: reset step count and transition to idle\\n\\tstate.StepCount = 0\\n\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n\\tstate.Phase = session.PhaseIdle\\n\\tstate.LastCheckpointID = checkpointID\\n\\tstate.PendingCheckpointID = \\\"\\\" // Clear after condensation (amend handler uses LastCheckpointID)\\n\\tstate.PromptAttributions = nil\\n\\tstate.PendingPromptAttribution = nil\\n\\n\\tif err := s.saveSessionState(state); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n\\t}\\n\\n\\t// Clean up shadow branch if no other sessions need it\\n\\tif err := s.cleanupShadowBranchIfUnused(repo, shadowBranchName, sessionID); err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"failed to clean up shadow branch\\\",\\n\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\nfunc (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(repo *git.Repository, shadowBranchName, excludeSessionID string) error {\\n\\t// List all session states to check if any other session uses this shadow branch\\n\\tallStates, err := s.listAllSessionStates()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n\\t}\\n\\n\\tfor _, state := range allStates {\\n\\t\\tif state.SessionID == excludeSessionID {\\n\\t\\t\\tcontinue\\n\\t\\t}\\n\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n\\t\\t\\t// Another session still needs this shadow branch\\n\\t\\t\\treturn nil\\n\\t\\t}\\n\\t}\\n\\n\\t// No other sessions need it, delete the shadow branch\\n\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\tref, refErr := repo.Reference(refName, true)\\n\\tif refErr != nil {\\n\\t\\t// Branch already gone, nothing to clean up\\n\\t\\treturn nil //nolint:nilerr // intentional: missing branch is not an error\\n\\t}\\n\\tif err := repo.Storer.RemoveReference(ref.Name()); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch reference: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\",\"numLines\":654,\"startLine\":1,\"totalLines\":654}},\"sourceToolAssistantUUID\":\"3089ead1-c50d-4928-b4a2-86c4ca224011\"}\n{\"parentUuid\":\"8f151834-eea0-4270-a9fd-508e78df56bb\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/alex/workspace/cli/.worktrees/3\",\"sessionId\":\"36ba8a60-f1f6-4e5d-b689-9eca8194aa74\",\"version\":\"2.1.37\",\"gitBr