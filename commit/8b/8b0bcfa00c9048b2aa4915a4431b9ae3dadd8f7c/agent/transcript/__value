/ Each package needs its own package-scoped sentinel for git log iteration patterns.\\n    44→var errStop = errors.New(\\\"stop iteration\\\")\\n    45→\\n    46→// IsEmptyRepository returns true if the repository has no commits yet.\\n    47→// After git-init, HEAD points to an unborn branch (e.g., refs/heads/main)\\n    48→// whose target does not yet exist. repo.Head() returns ErrReferenceNotFound\\n    49→// in this case.\\n    50→func IsEmptyRepository(repo *git.Repository) bool {\\n    51→\\t_, err := repo.Head()\\n    52→\\treturn errors.Is(err, plumbing.ErrReferenceNotFound)\\n    53→}\\n    54→\\n    55→// EnsureSetup ensures the strategy is properly set up.\\n    56→func EnsureSetup(ctx context.Context) error {\\n    57→\\tif err := EnsureEntireGitignore(ctx); err != nil {\\n    58→\\t\\treturn err\\n    59→\\t}\\n    60→\\n    61→\\t// Ensure the entire/checkpoints/v1 orphan branch exists for permanent session storage\\n    62→\\trepo, err := OpenRepository(ctx)\\n    63→\\tif err != nil {\\n    64→\\t\\treturn fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    65→\\t}\\n    66→\\tif err := EnsureMetadataBranch(repo); err != nil {\\n    67→\\t\\treturn fmt.Errorf(\\\"failed to ensure metadata branch: %w\\\", err)\\n    68→\\t}\\n    69→\\n    70→\\t// Install generic hooks (they delegate to strategy at runtime)\\n    71→\\tif !IsGitHookInstalled(ctx) {\\n    72→\\t\\tif _, err := InstallGitHook(ctx, true, isLocalDev(ctx)); err != nil {\\n    73→\\t\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n    74→\\t\\t}\\n    75→\\t}\\n    76→\\treturn nil\\n    77→}\\n    78→\\n    79→// IsAncestorOf checks if commit is an ancestor of (or equal to) target.\\n    80→// Returns true if target can reach commit by following parent links.\\n    81→// Limits search to MaxCommitTraversalDepth commits to avoid excessive traversal.\\n    82→func IsAncestorOf(repo *git.Repository, commit, target plumbing.Hash) bool {\\n    83→\\tif commit == target {\\n    84→\\t\\treturn true\\n    85→\\t}\\n    86→\\n    87→\\titer, err := repo.Log(&git.LogOptions{From: target})\\n    88→\\tif err != nil {\\n    89→\\t\\treturn false\\n    90→\\t}\\n    91→\\tdefer iter.Close()\\n    92→\\n    93→\\tfound := false\\n    94→\\tcount := 0\\n    95→\\t_ = iter.ForEach(func(c *object.Commit) error { //nolint:errcheck // Best-effort search, errors are non-fatal\\n    96→\\t\\tcount++\\n    97→\\t\\tif count > MaxCommitTraversalDepth {\\n    98→\\t\\t\\treturn errStop\\n    99→\\t\\t}\\n   100→\\t\\tif c.Hash == commit {\\n   101→\\t\\t\\tfound = true\\n   102→\\t\\t\\treturn errStop\\n   103→\\t\\t}\\n   104→\\t\\treturn nil\\n   105→\\t})\\n   106→\\n   107→\\treturn found\\n   108→}\\n   109→\\n   110→// ListCheckpoints returns all checkpoints from the entire/checkpoints/v1 branch.\\n   111→// Scans sharded paths: <id[:2]>/<id[2:]>/ directories containing metadata.json.\\n   112→func ListCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n   113→\\trepo, err := OpenRepository(ctx)\\n   114→\\tif err != nil {\\n   115→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n   116→\\t}\\n   117→\\n   118→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   119→\\tref, err := repo.Reference(refName, true)\\n   120→\\tif err != nil {\\n   121→\\t\\t//nolint:nilerr // No sessions branch yet is expected, return empty list\\n   122→\\t\\treturn []CheckpointInfo{}, nil\\n   123→\\t}\\n   124→\\n   125→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   126→\\tif err != nil {\\n   127→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   128→\\t}\\n   129→\\n   130→\\ttree, err := commit.Tree()\\n   131→\\tif err != nil {\\n   132→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   133→\\t}\\n   134→\\n   135→\\tvar checkpoints []CheckpointInfo\\n   136→\\n   137→\\t// Scan sharded structure: <2-char-prefix>/<remaining-id>/metadata.json\\n   138→\\t// The tree has 2-character directories (hex buckets)\\n   139→\\tfor _, bucketEntry := range tree.Entries {\\n   140→\\t\\tif bucketEntry.Mode != filemode.Dir {\\n   141→\\t\\t\\tcontinue\\n   142→\\t\\t}\\n   143→\\t\\t// Bucket should be 2 hex chars\\n   144→\\t\\tif len(bucketEntry.Name) != 2 {\\n   145→\\t\\t\\tcontinue\\n   146→\\t\\t}\\n   147→\\n   148→\\t\\tbucketTree, treeErr := repo.TreeObject(bucketEntry.Hash)\\n   149→\\t\\tif treeErr != nil {\\n   150→\\t\\t\\tcontinue\"}]},\"uuid\":\"1b6c0c05-2ebb-4bcf-9ce9-d2e4741a883c\",\"timestamp\":\"2026-02-26T18:45:31.248Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to thoroughly understand how `entire resume` works in this CLI codebase, and how checkpoints/sessions relate to commits. Please explore:\\n\\n1. The `resume` command implementation - find and read the command file(s)\\n2. How sessions are discovered/listed - the session listing logic\\n3. How checkpoints link to commits (the Entire-Checkpoint trailer system)\\n4. The condensation logic - how session data moves from shadow branches to the metadata branch\\n5. How session state is managed in `.git/entire-sessions/`\\n6. Any existing docs about checkpoint scenarios or resume behavior\\n7. The shadow branch naming convention (`entire/<commit-hash>-<worktreeHash>`)\\n8. How the `prepare-commit-msg` hook works and the post-commit condensation\\n\\nFocus on understanding the full lifecycle: session start → checkpoints saved → user commits → condensation → resume. I need to understand what happens to session data when a branch is squash-merged (all commits collapsed into one new commit on the target branch).\\n\\nBe very thorough - read the key implementation files completely.\",\"agentId\":\"a7b1476c2b3da6862\"},\"toolUseID\":\"agent_msg_01Y6erBo2NAW8CAJrZEueBfQ\",\"parentToolUseID\":\"toolu_01Gumx8Eo7ndA8D66MQyBUkh\",\"uuid\":\"5f5a829f-1887-4daa-90b2-0a68d8021e07\",\"timestamp\":\"2026-02-