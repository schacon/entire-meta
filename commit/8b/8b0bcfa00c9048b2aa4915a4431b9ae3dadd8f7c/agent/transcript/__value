veData, err := os.ReadFile(state.TranscriptPath)\\n   513→\\tif err != nil {\\n   514→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   515→\\t}\\n   516→\\n   517→\\tif len(liveData) == 0 {\\n   518→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   519→\\t}\\n   520→\\n   521→\\tfullTranscript := string(liveData)\\n   522→\\tdata.Transcript = liveData\\n   523→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   524→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   525→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   526→\\n   527→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   528→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   529→\\tif len(state.FilesTouched) > 0 {\\n   530→\\t\\tdata.FilesTouched = state.FilesTouched\\n   531→\\t} else {\\n   532→\\t\\t// Use the shared helper which includes subagent transcripts\\n   533→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   534→\\t}\\n   535→\\n   536→\\t// Calculate token usage from the extracted transcript portion\\n   537→\\tif len(data.Transcript) > 0 {\\n   538→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ag, data.Transcript, state.CheckpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   539→\\t}\\n   540→\\n   541→\\treturn data, nil\\n   542→}\\n   543→\\n   544→// countTranscriptItems counts lines (JSONL) or messages (JSON) in a transcript.\\n   545→// For Claude Code and JSONL-based agents, this counts lines.\\n   546→// For Gemini CLI, OpenCode, and JSON-based agents, this counts messages.\\n   547→// Returns 0 if the content is empty or malformed.\\n   548→func countTranscriptItems(agentType agent.AgentType, content string) int {\\n   549→\\tif content == \\\"\\\" {\\n   550→\\t\\treturn 0\\n   551→\\t}\\n   552→\\n   553→\\t// OpenCode uses export JSON format with {\\\"info\\\": {...}, \\\"messages\\\": [...]}\\n   554→\\tif agentType == agent.AgentTypeOpenCode {\\n   555→\\t\\tsession, err := opencode.ParseExportSession([]byte(content))\\n   556→\\t\\tif err == nil && session != nil {\\n   557→\\t\\t\\treturn len(session.Messages)\\n   558→\\t\\t}\\n   559→\\t\\treturn 0\\n   560→\\t}\\n   561→\\n   562→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   563→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   564→\\t\\ttranscript, err := geminicli.ParseTranscript([]byte(content))\\n   565→\\t\\tif err == nil && transcript != nil && len(transcript.Messages) > 0 {\\n   566→\\t\\t\\treturn len(transcript.Messages)\\n   567→\\t\\t}\\n   568→\\t\\t// If agentType is explicitly Gemini but parsing failed, return 0\\n   569→\\t\\tif agentType == agent.AgentTypeGemini {\\n   570→\\t\\t\\treturn 0\\n   571→\\t\\t}\\n   572→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   573→\\t}\\n   574→\\n   575→\\t// Claude Code and other JSONL-based agents\\n   576→\\tallLines := strings.Split(content, \\\"\\\\n\\\")\\n   577→\\t// Trim trailing empty lines (from final \\\\n in JSONL)\\n   578→\\tfor len(allLines) > 0 && strings.TrimSpace(allLines[len(allLines)-1]) == \\\"\\\" {\\n   579→\\t\\tallLines = allLines[:len(allLines)-1]\\n   580→\\t}\\n   581→\\treturn len(allLines)\\n   582→}\\n   583→\\n   584→// extractUserPrompts extracts all user prompts from transcript content.\\n   585→// Returns prompts with IDE context tags stripped (e.g., <ide_opened_file>).\\n   586→func extractUserPrompts(agentType agent.AgentType, content string) []string {\\n   587→\\tif content == \\\"\\\" {\\n   588→\\t\\treturn nil\\n   589→\\t}\\n   590→\\n   591→\\t// OpenCode uses JSONL with a different per-line schema than Claude Code\\n   592→\\tif agentType == agent.AgentTypeOpenCode {\\n   593→\\t\\tprompts, err := opencode.ExtractAllUserPrompts([]byte(content))\\n   594→\\t\\tif err == nil && len(prompts) > 0 {\\n   595→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   596→\\t\\t\\tfor _, prompt := range prompts {\\n   597→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   598→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   599→\\t\\t\\t\\t}\\n   600→\\t\\t\\t}\\n   601→\\t\\t\\treturn cleaned\\n   602→\\t\\t}\\n   603→\\t\\treturn nil\\n   604→\\t}\\n   605→\\n   606→\\t// Try Gemini format first if agentType is Gemini, or as fallback if Unknown\\n   607→\\tif agentType == agent.AgentTypeGemini || agentType == agent.AgentTypeUnknown {\\n   608→\\t\\tprompts, err := geminicli.ExtractAllUserPrompts([]byte(content))\\n   609→\\t\\tif err == nil && len(prompts) > 0 {\\n   610→\\t\\t\\t// Strip IDE context tags for consistency with Claude Code handling\\n   611→\\t\\t\\tcleaned := make([]string, 0, len(prompts))\\n   612→\\t\\t\\tfor _, prompt := range prompts {\\n   613→\\t\\t\\t\\tif stripped := textutil.StripIDEContextTags(prompt); stripped != \\\"\\\" {\\n   614→\\t\\t\\t\\t\\tcleaned = append(cleaned, stripped)\\n   615→\\t\\t\\t\\t}\\n   616→\\t\\t\\t}\\n   617→\\t\\t\\treturn cleaned\\n   618→\\t\\t}\\n   619→\\t\\t// If agentType is explicitly Gemini but parsing failed, return nil\\n   620→\\t\\tif agentType == agent.AgentTypeGemini {\\n   621→\\t\\t\\treturn nil\\n   622→\\t\\t}\\n   623→\\t\\t// Otherwise fall through to JSONL parsing for Unknown type\\n   624→\\t}\\n   625→\\n   626→\\t// Claude Code and other JSONL-based agents\\n   627→\\treturn extractUserPromptsFromLines(strings.Split(content, \\\"\\\\n\\\"))\\n   628→}\\n   629→\\n   630→// extractUserPromptsFromLines extracts user prompts from JSONL transcript lines.\\n   631→// IDE-injected context tags (like <ide_opened_file>) are stripped from the results.\\n   632→func extractUserPromptsFromLines(lines []string) []string {\\n   633→\\tvar prompts []string\\n   634→\\tfor _, line := range lines {\\n   635→\\t\\tline = strings.TrimSpace(line)\\n   636→\\t\\tif line == \\\"\\\" {\\n   637→\\t\\t\\tcontinue\\n   638→\\t\\t}\\n   639→\\n   640→\\t\\tvar entry map[string]interface{}\\n   641→\\t\\tif err := json.Unmarshal([]byte(line), &entry); err != nil {\\n   642→\\t\\t\\tcontinue\\n   643→\\t\\t}\\n   644→\\n   645→\\t\\t// Check for user message:\\n   646→\\t\\t// - Claude Code uses \\\"type\\\": \\\"human\\\" or \\\"type\\\": \\\"user\\\"\\n   647→\\t\\t// - Cursor uses \\\"role\\\": \\\"user\\\"\\n   648→\\t\\tmsgType, _ := entry[\\\"type\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   649→\\t\\tmsgRole, _ := entry[\\\"role\\\"].(string) //nolint:errcheck // type assertion on interface{} from JSON\\n   650→\\t\\tisUser := msgType == \\\"human\\\" || msgType == \\\"user\\\" || msgRole == \\\"user\\\"\\n   651→\\t\\tif !isUser {\\n   652→\\t\\t\\tcontinue\\n   653→\\t\\t}\\n   654→\\n   655→\\t\\t// Extract message content\\n   656→\\t\\tmessage, ok := entry[\\\"message\\\"].(map[string]interface{})\\n   657→\\t\\tif !ok {\\n   658→\\t\\t\\tcontinue\\n   659→\\t\\t}\\n   660→\\n   661→\\t\\t// Handle string content\\n   662→\\t\\tif content, ok := message[\\\"content\\\"].(string); ok && content != \\\"\\\" {\\n   663→\\t\\t\\tcleaned := textutil.StripIDEContextTags(content)\\n   664→\\t\\t\\tif cleaned != \\\"\\\" {\\n   665→\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   666→\\t\\t\\t}\\n   667→\\t\\t\\tcontinue\\n   668→\\t\\t}\\n   669→\\n   670→\\t\\t// Handle array content (e.g., multiple text blocks from VSCode)\\n   671→\\t\\tif arr, ok := message[\\\"content\\\"].([]interface{}); ok {\\n   672→\\t\\t\\tvar texts []string\\n   673→\\t\\t\\tfor _, item := range arr {\\n   674→\\t\\t\\t\\tif m, ok := item.(map[string]interface{}); ok {\\n   675→\\t\\t\\t\\t\\tif m[\\\"type\\\"] == \\\"text\\\" {\\n   676→\\t\\t\\t\\t\\t\\tif text, ok := m[\\\"text\\\"].(string); ok {\\n   677→\\t\\t\\t\\t\\t\\t\\ttexts = append(texts, text)\\n   678→\\t\\t\\t\\t\\t\\t}\\n   679→\\t\\t\\t\\t\\t}\\n   680→\\t\\t\\t\\t}\\n   681→\\t\\t\\t}\\n   682→\\t\\t\\tif len(texts) > 0 {\\n   683→\\t\\t\\t\\tcleaned := textutil.StripIDEContextTags(strings.Join(texts, \\\"\\\\n\\\\n\\\"))\\n   684→\\t\\t\\t\\tif cleaned != \\\"\\\" {\\n   685→\\t\\t\\t\\t\\tprompts = append(prompts, cleaned)\\n   686→\\t\\t\\t\\t}\\n   687→\\t\\t\\t}\\n   688→\\t\\t}\\n   689→\\t}\\n   690→\\treturn prompts\\n   691→}\\n   692→\\n   693→// generateContextFromPrompts generates context.md content from a list of prompts.\\n   694→func generateContextFromPrompts(prompts []string) []byte {\\n   695→\\tif len(prompts) == 0 {\\n   696→\\t\\treturn nil\\n   697→\\t}\\n   698→\\n   699→\\tvar buf strings.Builder\\n   700→\\tbuf.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   701→\\tbuf.WriteString(\\\"## User Prompts\\\\n\\\\n\\\")\\n   702→\\n   703→\\tfor i, prompt := range prompts {\\n   704→\\t\\t// Truncate very long prompts for readability.\\n   705→\\t\\t// Use rune-based truncation to avoid splitting multi-byte UTF-8 characters (e.g. CJK).\\n   706→\\t\\tconst maxDisplayPromptRunes = 500\\n   707→\\t\\tdisplayPrompt := stringutil.TruncateRunes(prompt, maxDisplayPromptRunes, \\\"...\\\")\\n   708→\\t\\tfmt.Fprintf(&buf, \\\"### Prompt %d\\\\n\\\\n\\\", i+1)\\n   709→\\t\\tbuf.WriteString(displayPrompt)\\n   710→\\t\\tbuf.WriteString(\\\"\\\\n\\\\n\\\")\\n   711→\\t}\\n   712→\\n   713→\\treturn []byte(buf.String())\\n   714→}\\n   715→\\n   716→// CondenseSessionByID force-condenses a session by its ID and cleans up.\\n   717→// This is used by \\\"entire doctor\\\" to salvage stuck sessions.\\n   718→func (s *ManualCommitStrategy) CondenseSessionByID(ctx context.Context, sessionID string) error {\\n   719→\\tlogCtx := logging.WithComponent(ctx, \\\"condense-by-id\\\")\\n   720→\\n   721→\\t// Load session state\\n   722→\\tstate, err := s.loadSessionState(ctx, sessionID)\\n   723→\\tif err != nil {\\n   724→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   725→\\t}\\n   726→\\tif state == nil {\\n   727→\\t\\treturn fmt.Errorf(\\\"session not found: %s\\\", sessionID)\\n   728→\\t}\\n   729→\\n   730→\\t// Open repository\\n   731→\\trepo, err := OpenRepository(ctx)\\n   732→\\tif err != nil {\\n   733→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   734→\\t}\\n   735→\\n   736→\\t// Generate a checkpoint ID\\n   737→\\tcheckpointID, err := id.Generate()\\n   738→\\tif err != nil {\\n   739→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   740→\\t}\\n   741→\\n   742→\\t// Check if shadow branch exists (required for condensation)\\n   743→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   744→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   745→\\t_, refErr := repo.Reference(refName, true)\\n   746→\\thasShadowBranch := refErr == nil\\n   747→\\n   748→\\tif !hasShadowBranch {\\n   749→\\t\\t// No shadow branch means no checkpoint data to condense.\\n   750→\\t\\t// Just clean up the state file.\\n   751→\\t\\tlogging.Info(logCtx, \\\"no shadow branch for session, clearing state only\\\",\\n   752→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   753→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   754→\\t\\t)\\n   755→\\t\\tif err := s.clearSessionState(ctx, sessionID); err != nil {\\n   756→\\t\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   757→\\t\\t}\\n   758→\\t\\treturn nil\\n   759→\\t}\\n   760→\\n   761→\\t// Condense the session\\n   762→\\tresult, err := s.CondenseSession(ctx, repo, checkpointID, state, nil)\\n   763→\\tif err != nil {\\n   764→\\t\\treturn fmt.Errorf(\\\"failed to condense session: %w\\\", err)\\n   765→\\t}\\n   766→\\n   767→\\tlogging.Info(logCtx, \\\"session condensed by ID\\\",\\n   768→\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   769→\\t\\tslog.String(\\\"checkpoint_id\\\", result.CheckpointID.String()),\\n   770→\\t\\tslog.Int(\\\"checkpoints_condensed\\\", result.CheckpointsCount),\\n   771→\\t)\\n   772→\\n   773→\\t// Update session state: reset step count and transition to idle\\n   774→\\tstate.StepCount = 0\\n   775→\\tstate.CheckpointTranscriptStart = result.TotalTranscriptLines\\n   776→\\tstate.Phase = session.PhaseIdle\\n   777→\\tstate.LastCheckpointID = checkpointID\\n   778→\\tstate.AttributionBaseCommit = state.BaseCommit\\n   779→\\tstate.PromptAttributions = nil\\n   780→\\tstate.PendingPromptAttribution = nil\\n   781→\\n   782→\\tif err := s.saveSessionState(ctx, state); err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   784→\\t}\\n   785→\\n   786→\\t// Clean up shadow branch if no other sessions need it\\n   787→\\tif err := s.cleanupShadowBranchIfUnused(ctx, repo, shadowBranchName, sessionID); err != nil {\\n   788→\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   789→\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   790→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   791→\\t\\t)\\n   792→\\t\\t// Non-fatal: condensation succeeded, shadow branch cleanup is best-effort\\n   793→\\t}\\n   794→\\n   795→\\treturn nil\\n   796→}\\n   797→\\n   798→// cleanupShadowBranchIfUnused deletes a shadow branch if no other active sessions reference it.\\n   799→func (s *ManualCommitStrategy) cleanupShadowBranchIfUnused(ctx context.Context, _ *git.Repository, shadowBranchName, excludeSessionID string) error {\\n   800→\\t// List all session states to check if any other session uses this shadow branch\\n   801→\\tallStates, err := s.listAllSessionStates(ctx)\\n   802→\\tif err != nil {\\n   803→\\t\\treturn fmt.Errorf(\\\"failed to list session states: %w\\\", err)\\n   804→\\t}\\n   805→\\n   806→\\tfor _, state := range allStates {\\n   807→\\t\\tif state.SessionID == excludeSessionID {\\n   808→\\t\\t\\tcontinue\\n   809→\\t\\t}\\n   810→\\t\\totherShadow := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   811→\\t\\tif otherShadow == shadowBranchName && state.StepCount > 0 {\\n   812→\\t\\t\\t// Another session still needs this shadow branch\\n   813→\\t\\t\\treturn nil\\n   814→\\t\\t}\\n   815→\\t}\\n   816→\\n   817→\\t// No other sessions need it, delete the shadow branch via CLI\\n   818→\\t// (go-git v5's RemoveReference doesn't persist with packed refs/worktrees)\\n   819→\\tif err := DeleteBranchCLI(ctx, shadowBranchName); err != nil {\\n   820→\\t\\t// Branch already gone is not an error\\n   821→\\t\\tif errors.Is(err, ErrBranchNotFound) {\\n   822→\\t\\t\\treturn nil\\n   823→\\t\\t}\\n   824→\\t\\treturn fmt.Errorf(\\\"failed to remove shadow branch: %w\\\", err)\\n   825→\\t}\\n   826→\\treturn nil\\n   827→}\\n   828→\"}]},\"uuid\":\"c2c6a317-f5bf-48ea-98a4-ed14413f94f6\",\"timestamp\":\"2026-02-26T19:00:44.135Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/pfleidi/entire/cli/cmd/entire/cli/strategy/manual_commit_condensation.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/opencode\\\"\\n\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/summarize\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/textutil\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v5\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n)\\n\\n// listCheckpoints returns all checkpoints from the metadata branch.\\n// Uses checkpoint.GitStore.ListCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) listCheckpoints(ctx context.Context) ([]CheckpointInfo, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcommitted, err := store.ListCommitted(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to list committed checkpoints: %w\\\", err)\\n\\t}\\n\\n\\t// Convert from checkpoint.CommittedInfo to strategy.CheckpointInfo\\n\\tresult := make([]CheckpointInfo, 0, len(committed))\\n\\tfor _, c := range committed {\\n\\t\\tresult = append(result, CheckpointInfo{\\n\\t\\t\\tCheckpointID:     c.CheckpointID,\\n\\t\\t\\tSessionID:        c.SessionID,\\n\\t\\t\\tCreatedAt:        c.CreatedAt,\\n\\t\\t\\tCheckpointsCount: c.CheckpointsCount,\\n\\t\\t\\tFilesTouched:     c.FilesTouched,\\n\\t\\t\\tAgent:            c.Agent,\\n\\t\\t\\tIsTask:           c.IsTask,\\n\\t\\t\\tToolUseID:        c.ToolUseID,\\n\\t\\t\\tSessionCount:     c.SessionCount,\\n\\t\\t\\tSessionIDs:       c.SessionIDs,\\n\\t\\t})\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointsForSession returns all checkpoints for a session ID.\\nfunc (s *ManualCommitStrategy) getCheckpointsForSession(ctx context.Context, sessionID string) ([]CheckpointInfo, error) {\\n\\tall, err := s.listCheckpoints(ctx)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\tvar result []CheckpointInfo\\n\\tfor _, cp := range all {\\n\\t\\tif cp.SessionID == sessionID || strings.HasPrefix(cp.SessionID, sessionID) {\\n\\t\\t\\tresult = append(result, cp)\\n\\t\\t}\\n\\t}\\n\\n\\tif len(result) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no checkpoints for session: %s\\\", sessionID)\\n\\t}\\n\\n\\treturn result, nil\\n}\\n\\n// getCheckpointLog returns the transcript for a specific checkpoint ID.\\n// Uses checkpoint.GitStore.ReadCommitted() for reading from entire/checkpoints/v1.\\nfunc (s *ManualCommitStrategy) getCheckpointLog(ctx context.Context, checkpointID id.CheckpointID) ([]byte, error) {\\n\\tstore, err := s.getCheckpointStore()\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n\\t}\\n\\n\\tcontent, err := store.ReadLatestSessionContent(ctx, checkpointID)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n\\t}\\n\\tif content == nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", checkpointID)\\n\\t}\\n\\tif len(content.Transcript) == 0 {\\n\\t\\treturn nil, fmt.Errorf(\\\"no transcript found for checkpoint: %s\\\", checkpointID)\\n\\t}\\n\\n\\treturn content.Transcript, nil\\n}\\n\\n// condenseOpts provides pre-resolved git objects to avoid redundant reads.\\ntype condenseOpts struct {\\n\\tshadowRef *plumbing.Reference // Pre-resolved shadow branch ref (nil = resolve from repo)\\n\\theadTree  *object.Tree        // Pre-resolved HEAD tree (passed through to calculateSessionAttributions)\\n}\\n\\n// CondenseSession condenses a session's shadow branch to permanent storage.\\n// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n//\\n// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n// In this case, data is extracted from the live transcript instead.\\nfunc (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n\\tvar o condenseOpts\\n\\tif len(opts) > 0 {\\n\\t\\to = opts[0]\\n\\t}\\n\\n\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n\\tref := o.shadowRef\\n\\tvar hasShadowBranch bool\\n\\tif ref != nil {\\n\\t\\thasShadowBranch = true\\n\\t} else {\\n\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n\\t\\tvar err error\\n\\t\\tref, err = repo.Reference(refName, true)\\n\\t\\thasShadowBranch = err == nil\\n\\t}\\n\\n\\tvar sessionData *ExtractedSessionData\\n\\tif hasShadowBranch {\\n\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n\\t\\t// Pass agent type to handle different transcript formats (JSONL for Claude, JSON for Gemini).\\n\\t\\t// Pass live transcript path so condensation reads the current file rather than a\\n\\t\\t// potentially stale shadow branch copy (SaveStep may have been skipped if the\\n\\t\\t// last turn had no code changes).\\n\\t\\t// Pass CheckpointTranscriptStart for accurate token calculation (line offset for Claude, message index for Gemini).\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionData(ctx, repo, ref.Hash(), state.SessionID, state.FilesTouched, state.AgentType, state.TranscriptPath, state.CheckpointTranscriptStart, state.Phase.IsActive())\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data: %w\\\", extractErr)\\n\\t\\t}\\n\\t} else {\\n\\t\\t// No shadow branch: mid-session commit before Stop/SaveStep.\\n\\t\\t// Extract data directly from live transcript.\\n\\t\\tif state.TranscriptPath == \\\"\\\" {\\n\\t\\t\\treturn nil, errors.New(\\\"shadow branch not found and no live transcript available\\\")\\n\\t\\t}\\n\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n\\t\\tif state.Phase.IsActive() {\\n\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, state.TranscriptPath)\\n\\t\\t}\\n\\t\\tvar extractErr error\\n\\t\\tsessionData, extractErr = s.extractSessionDataFromLiveTranscript(ctx, state)\\n\\t\\tif extractErr != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to extract session data from live transcript: %w\\\", extractErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// For 1:1 checkpoint model: filter files_touched to only include files actually\\n\\t// committed in this specific commit. This ensures each checkpoint represents\\n\\t// exactly the files in that commit, not all files mentioned in the transcript.\\n\\tif len(committedFiles) > 0 {\\n\\t\\t// Track if we had files before filtering to distinguish between:\\n\\t\\t// - Session had files but none were committed (don't fallback)\\n\\t\\t// - Session had no files to begin with (mid-session commit, fallback OK)\\n\\t\\thadFilesBeforeFiltering := len(sessionData.FilesTouched) > 0\\n\\n\\t\\tif hadFilesBeforeFiltering {\\n\\t\\t\\t// Filter to intersection of transcript-extracted files and committed files\\n\\t\\t\\tfiltered := make([]string, 0, len(sessionData.FilesTouched))\\n\\t\\t\\tfor _, f := range sessionData.FilesTouched {\\n\\t\\t\\t\\tif _, ok := committedFiles[f]; ok {\\n\\t\\t\\t\\t\\tfiltered = append(filtered, f)\\n\\t\\t\\t\\t}\\n\\t\\t\\t}\\n\\t\\t\\tsessionData.FilesTouched = filtered\\n\\t\\t}\\n\\n\\t\\t// Only use committedFiles as fallback for genuine mid-sessio