itMessage)\\n    69→\\tif len(matches) > 1 {\\n    70→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    71→\\t}\\n    72→\\treturn \\\"\\\", false\\n    73→}\\n    74→\\n    75→// ParseMetadata extracts metadata dir from commit message.\\n    76→// Returns the metadata directory and true if found, empty string and false otherwise.\\n    77→func ParseMetadata(commitMessage string) (string, bool) {\\n    78→\\tmatches := metadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    79→\\tif len(matches) > 1 {\\n    80→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    81→\\t}\\n    82→\\treturn \\\"\\\", false\\n    83→}\\n    84→\\n    85→// ParseTaskMetadata extracts task metadata dir from commit message.\\n    86→// Returns the task metadata directory and true if found, empty string and false otherwise.\\n    87→func ParseTaskMetadata(commitMessage string) (string, bool) {\\n    88→\\tmatches := taskMetadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    89→\\tif len(matches) > 1 {\\n    90→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    91→\\t}\\n    92→\\treturn \\\"\\\", false\\n    93→}\\n    94→\\n    95→// ParseBaseCommit extracts the base commit SHA from a commit message.\\n    96→// Returns the full SHA and true if found, empty string and false otherwise.\\n    97→func ParseBaseCommit(commitMessage string) (string, bool) {\\n    98→\\tmatches := baseCommitTrailerRegex.FindStringSubmatch(commitMessage)\\n    99→\\tif len(matches) > 1 {\\n   100→\\t\\treturn matches[1], true\\n   101→\\t}\\n   102→\\treturn \\\"\\\", false\\n   103→}\\n   104→\\n   105→// ParseCondensation extracts the condensation ID from a commit message.\\n   106→// Returns the condensation ID and true if found, empty string and false otherwise.\\n   107→func ParseCondensation(commitMessage string) (string, bool) {\\n   108→\\tmatches := condensationTrailerRegex.FindStringSubmatch(commitMessage)\\n   109→\\tif len(matches) > 1 {\\n   110→\\t\\treturn strings.TrimSpace(m