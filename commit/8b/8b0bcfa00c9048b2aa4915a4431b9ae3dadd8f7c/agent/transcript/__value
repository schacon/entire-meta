oint validates format)\\n   643→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   644→\\tif !found {\\n   645→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   646→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   647→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   648→\\t\\treturn nil\\n   649→\\t}\\n   650→\\n   651→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   652→\\tif err != nil {\\n   653→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   654→\\t}\\n   655→\\n   656→\\t// Find all active sessions for this worktree\\n   657→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   658→\\tif err != nil || len(sessions) == 0 {\\n   659→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   660→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   661→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   662→\\t\\t)\\n   663→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   664→\\t}\\n   665→\\n   666→\\t// Build transition context\\n   667→\\tisRebase := isGitSequenceOperation(ctx)\\n   668→\\ttransitionCtx := session.TransitionContext{\\n   669→\\t\\tIsRebaseInProgress: isRebase,\\n   670→\\t}\\n   671→\\n   672→\\tif isRebase {\\n   673→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   674→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   675→\\t\\t)\\n   676→\\t}\\n   677→\\n   678→\\t// Track shadow branch names and whether they can be deleted\\n   679→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   680→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   681→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   682→\\n   683→\\tnewHead := head.Hash().String()\\n   684→\\n   685→\\