: %v\\\", err)\\n   108→\\t}\\n   109→\\n   110→\\treturn repo, w, commit\\n   111→}\\n   112→\\n   113→func TestBranchExistsLocally(t *testing.T) {\\n   114→\\ttmpDir := t.TempDir()\\n   115→\\tt.Chdir(tmpDir)\\n   116→\\n   117→\\tsetupResumeTestRepo(t, tmpDir, true)\\n   118→\\n   119→\\tt.Run(\\\"returns true for existing branch\\\", func(t *testing.T) {\\n   120→\\t\\texists, err := BranchExistsLocally(context.Background(), \\\"feature\\\")\\n   121→\\t\\tif err != nil {\\n   122→\\t\\t\\tt.Fatalf(\\\"BranchExistsLocally() error = %v\\\", err)\\n   123→\\t\\t}\\n   124→\\t\\tif !exists {\\n   125→\\t\\t\\tt.Error(\\\"BranchExistsLocally() = false, want true for existing branch\\\")\\n   126→\\t\\t}\\n   127→\\t})\\n   128→\\n   129→\\tt.Run(\\\"returns false for nonexistent branch\\\", func(t *testing.T) {\\n   130→\\t\\texists, err := BranchExistsLocally(context.Background(), \\\"nonexistent\\\")\\n   131→\\t\\tif err != nil {\\n   132→\\t\\t\\tt.Fatalf(\\\"BranchExistsLocally() error = %v\\\", err)\\n   133→\\t\\t}\\n   134→\\t\\tif exists {\\n   135→\\t\\t\\tt.Error(\\\"BranchExistsLocally() = true, want false for nonexistent branch\\\")\\n   136→\\t\\t}\\n   137→\\t})\\n   138→}\\n   139→\\n   140→func TestCheckoutBranch(t *testing.T) {\\n   141→\\ttmpDir := t.TempDir()\\n   142→\\tt.Chdir(tmpDir)\\n   143→\\n   144→\\tsetupResumeTestRepo(t, tmpDir, true)\\n   145→\\n   146→\\tt.Run(\\\"successfully checks out existing branch\\\", func(t *testing.T) {\\n   147→\\t\\terr := CheckoutBranch(context.Background(), \\\"feature\\\")\\n   148→\\t\\tif err != nil {\\n   149→\\t\\t\\tt.Fatalf(\\\"CheckoutBranch() error = %v\\\", err)\\n   150→\\t\\t}\\n   151→\\n   152→\\t\\t// Verify we're on the feature branch\\n   153→\\t\\tbranch, err := GetCurrentBranch(context.Background())\\n   154→\\t\\tif err != nil {\\n   155→\\t\\t\\tt.Fatalf(\\\"GetCurrentBranch() error = %v\\\", err)\\n   156→\\t\\t}\\n   157→\\t\\tif branch != \\\"feature\\\" {\\n   158→\\t\\t\\tt.Errorf(\\\"After CheckoutBranch(), current branch = %q, want %q\\\", branch, \\\"feature\\\")\\n   159→\\t\\t}\\n   160→\\t})\\n   161→\\n   162→\\tt.Run(\\\"returns error for nonexistent branch\\\", func(t *testing.T) {\\n   163→\\t\\terr := CheckoutBranch(context.Background(), \\\"nonexistent\\\")\\n   164→\\t\\tif err == nil {\\n   165→\\t\\t\\tt.Error(\\\"CheckoutBranch() expected error for nonexistent branch, got nil\\\")\\n   166→\\t\\t}\\n   167→\\t})\\n   168→\\n   169→\\tt.Run(\\\"rejects ref starting with dash to prevent argument injection\\\", func(t *testing.T) {\\n   170→\\t\\t// \\\"git checkout -b evil\\\" would create a new branch named \\\"evil\\\" instead\\n   171→\\t\\t// of failing, because git interprets \\\"-b\\\" as a flag.\\n   172→\\t\\terr := CheckoutBranch(context.Background(), \\\"-b evil\\\")\\n   173→\\t\\tif err == nil {\\n   174→\\t\\t\\tt.Fatal(\\\"CheckoutBranch() should reject refs starting with '-', got nil\\\")\\n   175→\\t\\t}\\n   176→\\t\\tif !strings.Contains(err.Error(), \\\"invalid ref\\\") {\\n   177→\\t\\t\\tt.Errorf(\\\"CheckoutBranch() error = %q, want error containing 'invalid ref'\\\", err.Error())\\n   178→\\t\\t}\\n   179→\\t})\\n   180→}\\n   181→\\n   182→func TestPerformGitResetHard_RejectsArgumentInjection(t *testing.T) {\\n   183→\\ttmpDir := t.TempDir()\\n   184→\\tt.Chdir(tmpDir)\\n   185→\\n   186→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   187→\\n   188→\\t// \\\"git reset --hard -q\\\" would silently reset to HEAD in quiet mode instead\\n   189→\\t// of failing, because git interprets \\\"-q\\\" as the --quiet flag.\\n   190→\\terr := performGitResetHard(context.Background(), \\\"-q\\\")\\n   191→\\tif err == nil {\\n   192→\\t\\tt.Fatal(\\\"performGitResetHard() should reject hashes starting with '-', got nil\\\")\\n   193→\\t}\\n   194→\\tif !strings.Contains(err.Error(), \\\"invalid commit hash\\\") {\\n   195→\\t\\tt.Errorf(\\\"performGitResetHard() error = %q, want error containing 'invalid commit hash'\\\", err.Error())\\n   196→\\t}\\n   197→}\\n   198→\\n   199→func TestResumeFromCurrentBranch_NoCheckpoint(t *testing.T) {\\n   200→\\ttmpDir := t.TempDir()\\n   201→\\tt.Chdir(tmpDir)\\n   202→\\n   203→\\t// Initialize repo with initial commit (no checkpoint trailer)\\n   204→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   205→\\n   206→\\t// Run resumeFromCurrentBranch - should not error, just report no checkpoint found\\n   207→\\terr := resumeFromCurrentBranch(context.Background(), \\\"master\\\", false)\\n   208→\\tif err != nil {\\n   209→\\t\\tt.Errorf(\\\"resumeFromCurrentBranch() returned error for commit without checkpoint: %v\\\", err)\\n   210→\\t}\\n   211→}\\n   212→\\n   213→func TestRunResume_AlreadyOnBranch(t *testing.T) {\\n   214→\\ttmpDir := t.TempDir()\\n   215→\\tt.Chdir(tmpDir)\\n   216→\\n   217→\\t// Set up a fake Claude project directory for testing\\n   218→\\tclaudeDir := filepath.Join(tmpDir, \\\"claude-projects\\\")\\n   219→\\tt.Setenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\", claudeDir)\\n   220→\\n   221→\\t_, w, _ := setupResumeTestRepo(t, tmpDir, true)\\n   222→\\n   223→\\t// Checkout feature branch\\n   224→\\tif err := w.Checkout(&git.CheckoutOptions{\\n   225→\\t\\tBranch: plumbing.NewBranchReferenceName(\\\"feature\\\"),\\n   226→\\t}); err != nil {\\n   227→\\t\\tt.Fatalf(\\\"Failed to checkout feature branch: %v\\\", err)\\n   228→\\t}\\n   229→\\n   230→\\t// Run resume on the branch we're already on - should skip checkout\\n   231→\\terr := runResume(context.Background(), \\\"feature\\\", false)\\n   232→\\t// Should not error (no session, but shouldn't error)\\n   233→\\tif err != nil {\\n   234→\\t\\tt.Errorf(\\\"runResume() returned error when already on branch: %v\\\", err)\\n   235→\\t}\\n   236→}\\n   237→\\n   238→func TestRunResume_BranchDoesNotExist(t *testing.T) {\\n   239→\\ttmpDir := t.TempDir()\\n   240→\\tt.Chdir(tmpDir)\\n   241→\\n   242→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   243→\\n   244→\\t// Run resume on a branch that doesn't exist\\n   245→\\terr := runResume(context.Background(), \\\"nonexistent\\\", false)\\n   246→\\tif err == nil {\\n   247→\\t\\tt.Error(\\\"runResume() expected error for nonexistent branch, got nil\\\")\\n   248→\\t}\\n   249→}\\n   250→\\n   251→func TestRunResume_UncommittedChanges(t *testing.T) {\\n   252→\\ttmpDir := t.TempDir()\\n   253→\\tt.Chdir(tmpDir)\\n   254→\\n   255→\\tsetupResumeTestRepo(t, tmpDir, true)\\n   256→\\n   257→\\t// Make uncommitted changes\\n   258→\\ttestFile := filepath.Join(tmpDir, \\\"test.txt\\\")\\n   259→\\tif err := os.WriteFile(testFile, []byte(\\\"uncommitted modification\\\"), 0o644); err != nil {\\n   260→\\t\\tt.Fatalf(\\\"Failed to modify test file: %v\\\", err)\\n   261→\\t}\\n   262→\\n   263→\\t// Run resume - should fail due to uncommitted changes\\n   264→\\terr := runResume(context.Background(), \\\"feature\\\", false)\\n   265→\\tif err == nil {\\n   266→\\t\\tt.Error(\\\"runResume() expected error for uncommitted changes, got nil\\\")\\n   267→\\t}\\n   268→}\\n   269→\\n   270→// createCheckpointOnMetadataBranch creates a checkpoint on the entire/checkpoints/v1 branch.\\n   271→// Returns the checkpoint ID.\\n   272→func createCheckpointOnMetadataBranch(t *testing.T, repo *git.Repository, sessionID string) id.CheckpointID {\\n   273→\\tt.Helper()\\n   274→\\n   275→\\tcheckpointID := id.MustCheckpointID(\\\"abc123def456\\\") // Fixed ID for testing\\n   276→\\n   277→\\t// Get existing metadata branch or create it\\n   278→\\tif err := strategy.EnsureMetadataBranch(repo); err != nil {\\n   279→\\t\\tt.Fatalf(\\\"Failed to ensure metadata branch: %v\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   283→\\tref, err := repo.Reference(refName, true)\\n   284→\\tif err != nil {\\n   285→\\t\\tt.Fatalf(\\\"Failed to get metadata branch ref: %v\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\tparentCommit, err := repo.CommitObject(ref.Hash())\\n   289→\\tif err != nil {\\n   290→\\t\\tt.Fatalf(\\\"Failed to get parent commit: %v\\\", err)\\n   291→\\t}\\n   292→\\n   293→\\t// Create metadata content\\n   294→\\tmetadataJSON := fmt.Sprintf(`{\\n   295→  \\\"checkpoint_id\\\": %q,\\n   296→  \\\"session_id\\\": %q,\\n   297→  \\\"created_at\\\": \\\"2025-01-01T00:00:00Z\\\"\\n   298→}`, checkpointID.String(), sessionID)\\n   299→\\n   300→\\t// Create blob for metadata\\n   301→\\tblob := repo.Storer.NewEncodedObject()\\n   302→\\tblob.SetType(plumbing.BlobObject)\\n   303→\\twriter, err := blob.Writer()\\n   304→\\tif err != nil {\\n   305→\\t\\tt.Fatalf(\\\"Failed to create blob writer: %v\\\", err)\\n   306→\\t}\\n   307→\\tif _, err := writer.Write([]byte(metadataJSON)); err != nil {\\n   308→\\t\\tt.Fatalf(\\\"Failed to write blob: %v\\\", err)\\n   309→\\t}\\n   310→\\tif err := writer.Close(); err != nil {\\n   311→\\t\\tt.Fatalf(\\\"Failed to close writer: %v\\\", err)\\n   312→\\t}\\n   313→\\tmetadataBlobHash, err := repo.Storer.SetEncodedObject(blob)\\n   314→\\tif err != nil {\\n   315→\\t\\tt.Fatalf(\\\"Failed to store blob: %v\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\t// Create session log blob\\n   319→\\tlogBlob := repo.Storer.NewEncodedObject()\\n   320→\\tlogBlob.SetType(plumbing.BlobObject)\\n   321→\\tlogWriter, err := logBlob.Writer()\\n   322→\\tif err != nil {\\n   323→\\t\\tt.Fatalf(\\\"Failed to create log blob writer: %v\\\", err)\\n   324→\\t}\\n   325→\\tif _, err := logWriter.Write([]byte(`{\\\"type\\\":\\\"test\\\"}`)); err != nil {\\n   326→\\t\\tt.Fatalf(\\\"Failed to write log blob: %v\\\", err)\\n   327→\\t}\\n   328→\\tif err := logWriter.Close(); err != nil {\\n   329→\\t\\tt.Fatalf(\\\"Failed to close log writer: %v\\\", err)\\n   330→\\t}\\n   331→\\tlogBlobHash, err := repo.Storer.SetEncodedObject(logBlob)\\n   332→\\tif err != nil {\\n   333→\\t\\tt.Fatalf(\\\"Failed to store log blob: %v\\\", err)\\n   334→\\t}\\n   335→\\n   336→\\t// Build tree structure: <id[:2]>/<id[2:]>/metadata.json\\n   337→\\tshardedPath := checkpointID.Path()\\n   338→\\tcheckpointIDStr := checkpointID.String()\\n   339→\\n   340→\\t// Create checkpoint tree with metadata and transcript files\\n   341→\\t// Entries must be sorted alphabetically\\n   342→\\tcheckpointTree := object.Tree{\\n   343→\\t\\tEntries: []object.TreeEntry{\\n   344→\\t\\t\\t{Name: paths.TranscriptFileName, Mode: filemode.Regular, Hash: logBlobHash},\\n   345→\\t\\t\\t{Name: paths.MetadataFileName, Mode: filemode.Regular, Hash: metadataBlobHash},\\n   346→\\t\\t},\\n   347→\\t}\\n   348→\\tcheckpointTreeObj := repo.Storer.NewEncodedObject()\\n   349→\\tif err := checkpointTree.Encode(checkpointTreeObj); err != nil {\\n   350→\\t\\tt.Fatalf(\\\"Failed to encode checkpoint tree: %v\\\", err)\\n   351→\\t}\\n   352→\\tcheckpointTreeHash, err := repo.Storer.SetEncodedObject(checkpointTreeObj)\\n   353→\\tif err != nil {\\n   354→\\t\\tt.Fatalf(\\\"Failed to store checkpoint tree: %v\\\", err)\\n   355→\\t}\\n   356→\\n   357→\\t// Create inner shard tree (id[2:])\\n   358→\\tinnerTree := object.Tree{\\n   359→\\t\\tEntries: []object.TreeEntry{\\n   360→\\t\\t\\t{Name: checkpointIDStr[2:], Mode: filemode.Dir, Hash: checkpointTreeHash},\\n   361→\\t\\t},\\n   362→\\t}\\n   363→\\tinnerTreeObj := repo.Storer.NewEncodedObject()\\n   364→\\tif err := innerTree.Encode(innerTreeObj); err != nil {\\n   365→\\t\\tt.Fatalf(\\\"Failed to encode inner tree: %v\\\", err)\\n   366→\\t}\\n   367→\\tinnerTreeHash, err := repo.Storer.SetEncodedObject(innerTreeObj)\\n   368→\\tif err != nil {\\n   369→\\t\\tt.Fatalf(\\\"Failed to store inner tree: %v\\\", err)\\n   370→\\t}\\n   371→\\n   372→\\t// Get existing tree entries from parent\\n   373→\\tparentTree, err := parentCommit.Tree()\\n   374→\\tif err != nil {\\n   375→\\t\\tt.Fatalf(\\\"Failed to get parent tree: %v\\\", err)\\n   376→\\t}\\n   377→\\n   378→\\t// Build new root tree with shard bucket\\n   379→\\tvar rootEntries []object.TreeEntry\\n   380→\\tfor _, entry := range parentTree.Entries {\\n   381→\\t\\tif entry.Name != shardedPath[:2] {\\n   382→\\t\\t\\trootEntries = append(rootEntries, entry)\\n   383→\\t\\t}\\n   384→\\t}\\n   385→\\trootEntries = append(rootEntries, object.TreeEntry{\\n   386→\\t\\tName: checkpointIDStr[:2],\\n   387→\\t\\tMode: filemode.Dir,\\n   388→\\t\\tHash: innerTreeHash,\\n   389→\\t})\\n   390→\\n   391→\\trootTree := object.Tree{Entries: rootEntries}\\n   392→\\trootTreeObj := repo.Storer.NewEncodedObject()\\n   393→\\tif err := rootTree.Encode(rootTreeObj); err != nil {\\n   394→\\t\\tt.Fatalf(\\\"Failed to encode root tree: %v\\\", err)\\n   395→\\t}\\n   396→\\trootTreeHash, err := repo.Storer.SetEncodedObject(rootTreeObj)\\n   397→\\tif err != nil {\\n   398→\\t\\tt.Fatalf(\\\"Failed to store root tree: %v\\\", err)\\n   399→\\t}\\n   400→\\n   401→\\t// Create commit on metadata branch\\n   402→\\tcommit := &object.Commit{\\n   403→\\t\\tAuthor: object.Signature{\\n   404→\\t\\t\\tName:  \\\"Test\\\",\\n   405→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   406→\\t\\t\\tWhen:  parentCommit.Author.When,\\n   407→\\t\\t},\\n   408→\\t\\tCommitter: object.Signature{\\n   409→\\t\\t\\tName:  \\\"Test\\\",\\n   410→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   411→\\t\\t\\tWhen:  parentCommit.Author.When,\\n   412→\\t\\t},\\n   413→\\t\\tMessage:      \\\"Add checkpoint metadata\\\",\\n   414→\\t\\tTreeHash:     rootTreeHash,\\n   415→\\t\\tParentHashes: []plumbing.Hash{parentCommit.Hash},\\n   416→\\t}\\n   417→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   418→\\tif err := commit.Encode(commitObj); err != nil {\\n   419→\\t\\tt.Fatalf(\\\"Failed to encode commit: %v\\\", err)\\n   420→\\t}\\n   421→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   422→\\tif err != nil {\\n   423→\\t\\tt.Fatalf(\\\"Failed to store commit: %v\\\", err)\\n   424→\\t}\\n   425→\\n   426→\\t// Update metadata branch ref\\n   427→\\tnewRef :