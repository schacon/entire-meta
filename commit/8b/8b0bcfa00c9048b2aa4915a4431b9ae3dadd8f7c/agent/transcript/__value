. Shows the command to resume the session\\n    40→\\n    41→If the branch doesn't exist locally but exists on origin, you'll be prompted\\n    42→to fetch it.\\n    43→\\n    44→If newer commits without checkpoints exist on the branch (e.g., after merging main\\n    45→or cherry-picking from elsewhere), this operation will reset your Git status to the\\n    46→most recent commit with a checkpoint.  You'll be prompted to confirm resuming in this case.`,\\n    47→\\t\\tArgs: cobra.ExactArgs(1),\\n    48→\\t\\tRunE: func(cmd *cobra.Command, args []string) error {\\n    49→\\t\\t\\tif checkDisabledGuard(cmd.Context(), cmd.OutOrStdout()) {\\n    50→\\t\\t\\t\\treturn nil\\n    51→\\t\\t\\t}\\n    52→\\t\\t\\treturn runResume(cmd.Context(), args[0], force)\\n    53→\\t\\t},\\n    54→\\t}\\n    55→\\n    56→\\tcmd.Flags().BoolVarP(&force, \\\"force\\\", \\\"f\\\", false, \\\"Resume from older checkpoint without confirmation\\\")\\n    57→\\n    58→\\treturn cmd\\n    59→}\\n    60→\\n    61→func runResume(ctx context.Context, branchName string, force bool) error {\\n    62→\\t// Check if we're already on this branch\\n    63→\\tcurrentBranch, err := GetCurrentBranch(ctx)\\n    64→\\tif err == nil && currentBranch == branchName {\\n    65→\\t\\t// Already on the branch, skip checkout\\n    66→\\t\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n    67→\\t}\\n    68→\\n    69→\\t// Check if branch exists locally\\n    70→\\texists, err := BranchExistsLocally(ctx, branchName)\\n    71→\\tif err != nil {\\n    72→\\t\\treturn fmt.Errorf(\\\"failed to check branch: %w\\\", err)\\n    73→\\t}\\n    74→\\n    75→\\tif !exists {\\n    76→\\t\\t// Branch doesn't exist locally, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoint(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif result.checkpointID.IsEmpty() {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\tcheckpointID := result.checkpointID\\n   157→\\n   158→\\t// Get metadata branch tree for lookups\\n   159→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   160→\\tif err != nil {\\n   161→\\t\\t// No local metadata branch, check if remote has it\\n   162→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   163→\\t}\\n   164→\\n   165→\\t// Look up metadata from sharded path\\n   166→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   167→\\tif err != nil {\\n   168→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   169→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   170→\\t}\\n   171→\\n   172→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   173→}\\n   174→\\n   175→// branchCheckpointResult contains the result of searching for a checkpoint on a branch.\\n   176→type branchCheckpointResult struct {\\n   177→\\tcheckpointID      id.CheckpointID\\n   178→\\tcommitHash        string\\n   179→\\tcommitMessage     string\\n   180→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   181→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   182→}\\n   183→\\n   184→// findBranchCheckpoint finds the most recent commit with an Entire-Checkpoint trailer\\n   185→// among commits that are unique to this branch (not reachable from the default branch).\\n   186→// This handles the case where main has been merged into the feature branch.\\n   187→func findBranchCheckpoint(repo *git.Repository, branchName string) (*branchCheckpointResult, error) {\\n   188→\\tresult := &branchCheckpointResult{}\\n   189→\\n   190→\\t// Get HEAD commit\\n   191→\\thead, err := repo.Head()\\n   192→\\tif err != nil {\\n   193→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   194→\\t}\\n   195→\\n   196→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   197→\\tif err != nil {\\n   198→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   199→\\t}\\n   200→\\n   201→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   202→\\tif cpID, found := trailers.ParseCheckpoint(headCommit.Message); found {\\n   203→\\t\\tresult.checkpointID = cpID\\n   204→\\t\\tresult.commitHash = head.Hash().String()\\n   205→\\t\\tresult.commitMessage = headCommit.Message\\n   206→\\t\\tresult.newerCommitsExist = false\\n   207→\\t\\treturn result, nil\\n   208→\\t}\\n   209→\\n   210→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   211→\\t// Get the default branch name\\n   212→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   213→\\tif defaultBranch == \\\"\\\" {\\n   214→\\t\\t// Fallback: try common names\\n   215→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   216→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   217→\\t\\t\\t\\tdefaultBranch = name\\n   218→\\t\\t\\t\\tbreak\\n   219→\\t\\t\\t}\\n   220→\\t\\t}\\n   221→\\t}\\n   222→\\n   223→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   224→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   225→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   226→\\t}\\n   227→\\n   228→\\t// Get the default branch reference\\n   229→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   230→\\tif err != nil {\\n   231→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   232→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   233→\\t}\\n   234→\\n   235→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   236→\\tif err != nil {\\n   237→\\t\\t// Can't get default commit, fall back to walking all commits\\n   238→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   239→\\t}\\n   240→\\n   241→\\t// Find merge base\\n   242→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   243→\\tif err != nil || len(mergeBase) == 0 {\\n   244→\\t\\t// No common ancestor, fall back to walking all commits\\n   245→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   246→\\t}\\n   247→\\n   248→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   249→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   250→}\\n   251→\\n   252→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   253→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   254→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   255→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   256→// (actual branch work) to avoid false warnings after merging main.\\n   257→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointResult {\\n   258→\\tresult := &branchCheckpointResult{}\\n   259→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   260→\\tconst maxCommits = 100 // Limit search depth\\n   261→\\ttotalChecked := 0\\n   262→\\n   263→\\tcurrent := start\\n   264→\\tfor current != nil && totalChecked < maxCommits {\\n   265→\\t\\t// Stop if we've reached the boundary\\n   266→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   267→\\t\\t\\tbreak\\n   268→\\t\\t}\\n   269→\\n   270→\\t\\t// Check for checkpoint trailer\\n   271→\\t\\tif cpID, found := trailers.ParseCheckpoint(current.Message); found {\\n   272→\\t\\t\\tresult.checkpointID = cpID\\n   273→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   274→\\t\\t\\tresult.commitMessage = current.Message\\n   275→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   276→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   277→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   278→\\t\\t\\treturn result\\n   279→\\t\\t}\\n   280→\\n   281→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   282→\\t\\tif current.NumParents() <= 1 {\\n   283→\\t\\t\\tbranchWorkCommits++\\n   284→\\t\\t}\\n   285→\\n   286→\\t\\ttotalChecked++\\n   287→\\n   288→\\t\\t// Move to parent (first parent for merge commits - follows the main line)\\n   289→\\t\\tif current.NumParents() == 0 {\\n   290→\\t\\t\\tbreak\\n   291→\\t\\t}\\n   292→\\t\\tparent, err := current.Parent(0)\\n   293→\\t\\tif err != nil {\\n   294→\\t\\t\\t// Can't get parent, treat as end of history\\n   295→\\t\\t\\tbreak\\n   296→\\t\\t}\\n   297→\\t\\tcurrent = parent\\n   298→\\t}\\n   299→\\n   300→\\t// No checkpoint found\\n   301→\\treturn result\\n   302→}\\n   303→\\n   304→// promptResumeFromOlderCheckpoint asks the user if they want to resume from an older checkpoint.\\n   305→func promptResumeFromOlderCheckpoint() (bool, error) {\\n   306→\\tvar confirmed bool\\n   307→\\n   308→\\tform := NewAccessibleForm(\\n   309→\\t\\thuh.NewGroup(\\n   310→\\t\\t\\thuh.NewConfirm().\\n   311→\\t\\t\\t\\tTitle(\\\"Resume from this older checkpoint?\\\").\\n   312→\\t\\t\\t\\tValue(&confirmed),\\n   313→\\t\\t),\\n   314→\\t)\\n   315→\\n   316→\\tif err := form.Run(); err != nil {\\n   317→\\t\\tif errors.Is(err, huh.ErrUserAborted) {\\n   318→\\t\\t\\treturn false, nil\\n   319→\\t\\t}\\n   320→\\t\\treturn false, fmt.Errorf(\\\"failed to get confirmation: %w\\\", err)\\n   321→\\t}\\n   322→\\n   323→\\treturn confirmed, nil\\n   324→}\\n   325→\\n   326→// checkRemoteMetadata checks if checkpoint metadata exists on origin/entire/checkpoints/v1\\n   327→// and automatically fetches it if available.\\n   328→func checkRemoteMetadata(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID) error {\\n   329→\\t// Try to get remote metadata branch tree\\n   330→\\tremoteTree, err := strategy.GetRemoteMetadataBranchTree(repo)\\n   331→\\tif err != nil {\\n   332→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   333→\\t\\tfmt.Fprintf(os.Stderr, \\\"The entire/checkpoints/v1 branch may not exist locally or on the remote.\\\\n\\\")\\n   334→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   335→\\t}\\n   336→\\n   337→\\t// Check if the checkpoint exists on the remote\\n   338→\\tmetadata, err := strategy.ReadCheckpointMetadata(remoteTree, checkpointID.Path())\\n   339→\\tif err != nil {\\n   340→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint '%s' found in commit but session metadata not available\\\\n\\\", checkpointID)\\n   341→\\t\\treturn nil //nolint:nilerr // Informational message, not a fatal error\\n   342→\\t}\\n   343→\\n   344→\\t// Metadata exists on remote but not locally - fetch it automatically\\n   345→\\tfmt.Fprintf(os.Stderr, \\\"Fetching session metadata from origin...\\\\n\\\")\\n   346→\\tif err := FetchMetadataBranch(ctx); err != nil {\\n   347→\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to fetch metadata: %v\\\\n\\\", err)\\n   348→\\t\\tfmt.Fprintf(os.Stderr, \\\"You can try manually: git fetch origin entire/checkpoints/v1:entire/checkpoints/v1\\\\n\\\")\\n   349→\\t\\treturn NewSilentError(errors.New(\\\"failed to fetch metadata\\\"))\\n   350→\\t}\\n   351→\\n   352→\\t// Now resume the session with the fetched metadata\\n   353→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, false)\\n   354→}\\n   355→\\n   356→// resumeSession restores and displays the resume command for a specific session.\\n   357→// For multi-session checkpoints, restores ALL sessions and shows commands for each.\\n   358→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   359→func resumeSession(ctx context.Context, sessionID string, checkpointID id.CheckpointID, force bool) error {\\n   360→\\t// Read checkpoint metadata first to get agent type (matching rewind pattern)\\n   361→\\trepo, err := openRepository(ctx)\\n   362→\\tif err != nil {\\n   363→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   364→\\t}\\n   365→\\n   366→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   3