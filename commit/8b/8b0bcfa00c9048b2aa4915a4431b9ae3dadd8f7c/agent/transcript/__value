s.Join(result, \\\"\\\\n\\\")\\n   183→}\\n   184→\\n   185→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   186→// cherry-pick, or revert operation. During these operations, commits are being\\n   187→// replayed and should not be linked to agent sessions.\\n   188→//\\n   189→// Detects:\\n   190→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   191→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   192→//   - revert: .git/REVERT_HEAD file\\n   193→func isGitSequenceOperation(ctx context.Context) bool {\\n   194→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   195→\\tgitDir, err := GetGitDir(ctx)\\n   196→\\tif err != nil {\\n   197→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   198→\\t}\\n   199→\\n   200→\\t// Check for rebase state directories\\n   201→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   202→\\t\\treturn true\\n   203→\\t}\\n   204→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   205→\\t\\treturn true\\n   206→\\t}\\n   207→\\n   208→\\t// Check for cherry-pick and revert state files\\n   209→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   210→\\t\\treturn true\\n   211→\\t}\\n   212→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   213→\\t\\treturn true\\n   214→\\t}\\n   215→\\n   216→\\treturn false\\n   217→}\\n   218→\\n   219→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   220→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   221→// Only adds a trailer if there's actually new session content to condense.\\n   222→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   223→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   224→// For amended commits, preserves the existing checkpoint ID.\\n   225→//\\n   226→// The source parameter indicates how the commit was initiated:\\n   227→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   228→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   229→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   230→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   231→//\\n   232→\\n   233→func (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   234→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   235→\\n   236→\\t// Skip during rebase, cherry-pick, or revert operations\\n   237→\\t// These are replaying existing commits and should not be linked to agent sessions\\n   238→\\tif isGitSequenceOperation(ctx) {\\n   239→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   240→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   241→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   242→\\t\\t)\\n   243→\\t\\treturn nil\\n   244→\\t}\\n   245→\\n   246→\\t// Skip for merge and squash sources\\n   247→\\t// These are auto-generated messages - not from Claude sessions\\n   248→\\tswitch source {\\n   249→\\tcase \\\"merge\\\", \\\"squash\\\":\\n   250→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   251→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   252→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   253→\\t\\t)\\n   254→\\t\\treturn nil\\n   255→\\t}\\n   256→\\n   257→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   258→\\tif source == \\\"commit\\\" {\\n   259→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   260→\\t}\\n   261→\\n   262→\\trepo, err := OpenRepository(ctx)\\n   263→\\tif err != nil {\\n   264→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   265→\\t}\\n   266→\\n   267→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   268→\\tif err != nil {\\n   269→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   270→\\t}\\n   271→\\n   272→\\t// Find all active sessions for this worktree\\n   273→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   274→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   275→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   276→\\tif err != nil || len(sessions) == 0 {\\n   277→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   278→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   279→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   280→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   281→\\t\\t)\\n   282→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   283→\\t}\\n   284→\\n   285→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   286→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   287→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   288→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   289→\\t// add the trailer directly.\\n   290→\\tif !hasTTY() {\\n   291→\\t\\tfor _, state := range sessions {\\n   292→\\t\\t\\tif state.Phase.IsActive() {\\n   293→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   294→\\t\\t\\t}\\n   295→\\t\\t}\\n   296→\\t}\\n   297→\\n   298→\\t// Check if any session has new content to condense\\n   299→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   300→\\n   301→\\tif len(sessionsWithContent) == 0 {\\n   302→\\t\\t// No new content — no trailer needed\\n   303→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   304→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   305→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   306→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   307→\\t\\t)\\n   308→\\t\\treturn nil\\n   309→\\t}\\n   310→\\n   311→\\t// Read current commit message\\n   312→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   313→\\tif err != nil {\\n   314→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   315→\\t}\\n   316→\\n   317→\\tmessage := string(content)\\n   318→\\n   319→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   320→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   321→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   322→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   323→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   324→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   325→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   326→\\t\\t)\\n   327→\\t\\treturn nil\\n   328→\\t}\\n   329→\\n   330→\\t// Generate a fresh checkpoint ID\\n   331→\\tcheckpointID, err := id.Generate()\\n   332→\\tif err != nil {\\n   333→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   334→\\t}\\n   335→\\n   336→\\t// Determine agent type and last prompt from session\\n   337→\\tvar agentType agent.AgentType\\n   338→\\tvar lastPrompt string\\n   339→\\tif len(sessionsWithContent) > 0 {\\n   340→\\t\\tfirstSession := sessionsWithContent[0]\\n   341→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   342→\\t\\t\\tagentType = firstSession.AgentType\\n   343→\\t\\t}\\n   344→\\t\\tlastPrompt = s.getLastPrompt(ctx, repo, firstSession)\\n   345→\\t}\\n   346→\\n   347→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   348→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   349→\\n   350→\\t// Add trailer differently based on commit source\\n   351→\\tswitch source {\\n   352→\\tcase \\\"message\\\":\\n   353→\\t\\t// Using -m or -F: ask user interactively whether to add trailer\\n   354→\\t\\t// (comments won't be stripped by git in this mode)\\n   355→\\n   356→\\t\\t// Build context string for interactive prompt\\n   357→\\t\\tvar promptContext string\\n   358→\\t\\tif displayPrompt != \\\"\\\" {\\n   359→\\t\\t\\tpromptContext = \\\"You have an active \\\" + string(agentType) + \\\" session.\\\\nLast Prompt: \\\" + displayPrompt\\n   360→\\t\\t}\\n   361→\\n   362→\\t\\tif !askConfirmTTY(\\\"Link this commit to \\\"+string(agentType)+\\\" session context?\\\", promptContext, true) {\\n   363→\\t\\t\\t// User declined - don't add trailer\\n   364→\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   365→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   366→\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   367→\\t\\t\\t)\\n   368→\\t\\t\\treturn nil\\n   369→\\t\\t}\\n   370→\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   371→\\tdefault:\\n   372→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   373→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   374→\\t}\\n   375→\\n   376→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   377→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   378→\\t\\tslog.String(\\\"source\\\", source),\\n   379→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   380→\\t)\\n   381→\\n   382→\\t// Write updated message back\\n   383→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   384→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   385→\\t}\\n   386→\\n   387→\\treturn nil\\n   388→}\\n   389→\\n   390→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   391→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   392→func (s *ManualCommitStrategy) handleAmendCommitMsg(ctx context.Context, commitMsgFile string) error {\\n   393→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   394→\\t// Read current commit message\\n   395→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   396→\\tif err != nil {\\n   397→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   398→\\t}\\n   399→\"}]},\"uuid\":\"47c234a0-f062-4a3e-8d81-e67586a7682c\",\"timestamp\":\"2026-02-26T18:45:30.673Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to thoroughly understand how `entire resume` works in this CLI codebase, and how checkpoints/sessions relate to commits. Please explore:\\n\\n1. The `resume` command implementation - find and read the command file(s)\\n2. How sessions are discovered/listed - the session listing logic\\n3. How checkpoints link to commits (the Entire-Checkpoint trailer system)\\n4. The condensation logic - how session data moves from shadow branches to the metadata branch\\n5. How session state is managed in `.git/entire-sessions/`\\n6. Any existing docs about checkpoint scenarios or resume behavior\\n7. The shadow branch naming convention (`entire/<commit-hash>-<worktreeHash>`)\\n8. How the `prepare-commit-msg` hook works and the post-commit condensation\\n\\nFocus on understanding the full lifecycle: session start → checkpoints saved → user commits → condensation → resume. I need to understand what happens to session data when a branch is 