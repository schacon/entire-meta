\tslog.String(\\\"source\\\", source),\\n   459→\\t\\t)\\n   460→\\t\\treturn nil\\n   461→\\t}\\n   462→\\n   463→\\t// No checkpoint ID found - leave message unchanged\\n   464→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   465→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   466→\\t)\\n   467→\\treturn nil\\n   468→}\\n   469→\\n   470→// PostCommit is called by the git post-commit hook after a commit is created.\\n   471→// Uses the session state machine to determine what action to take per session:\\n   472→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   473→//   - IDLE → condense immediately\\n   474→//   - ENDED → condense if files touched, discard if empty\\n   475→//\\n   476→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   477→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   478→//\\n   479→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   480→// and were condensed during this PostCommit.\\n   481→\\n   482→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   483→// Each session in the loop gets its own handler with per-session context.\\n   484→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   485→// as the state being transitioned) rather than capturing state separately.\\n   486→type postCommitActionHandler struct {\\n   487→\\ts                      *ManualCommitStrategy\\n   488→\\tctx                    context.Context\\n   489→\\trepo                   *git.Repository\\n   490→\\tcheckpointID           id.CheckpointID\\n   491→\\thead                   *plumbing.Reference\\n   492→\\tcommit                 *object.Commit\\n   493→\\tnewHead                string\\n   494→\\tshadowBranchName       string\\n   495→\\tshadowBranchesToDelete map[string]struct{}\\n   496→\\tcommittedFileSet       map[string]struct{}\\n   497→\\thasNew                 bool\\n   498→\\tfilesTouchedBefore     []string\\n   499→\\n   500→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   501→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   502→\\t// CondenseSession, and calculateSessionAttributions.\\n   503→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   504→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   505→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   506→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   507→\\n   508→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   509→\\tcondensed bool\\n   510→}\\n   511→\\n   512→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   513→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   514→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive())\\n   515→\\n   516→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   517→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   518→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   519→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   520→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   521→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   522→\\t)\\n   523→\\n   524→\\tif shouldCondense {\\n   525→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   526→\\t\\t\\tshadowRef: h.shadowRef,\\n   527→\\t\\t\\theadTree:  h.headTree,\\n   528→\\t\\t})\\n   529→\\t} else {\\n   530→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state,