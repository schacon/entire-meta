5d-e779-4d53-9743-bc1d5c383f4f\",\"timestamp\":\"2026-02-26T18:45:52.258Z\"}\n{\"parentUuid\":\"e478d15d-e779-4d53-9743-bc1d5c383f4f\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli\",\"sessionId\":\"3f1e469e-cc70-4a20-80b9-4d66e624b432\",\"version\":\"2.1.52\",\"gitBranch\":\"squash-merge-resume\",\"slug\":\"sparkling-petting-kahn\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01DVQWTz9hS7n7woVmFVmjqS\",\"type\":\"tool_result\",\"content\":\"     1→# Sessions and Checkpoints\\n     2→\\n     3→## Overview\\n     4→\\n     5→Entire CLI creates checkpoints for AI coding sessions. The system is agent-agnostic - it works with Claude Code, Gemini CLI, OpenCode, Cursor, or any tool that triggers Entire hooks.\\n     6→\\n     7→## Domain Model\\n     8→\\n     9→### Session\\n    10→\\n    11→A **Session** is a unit of work. Defined in `strategy/session.go`:\\n    12→\\n    13→```go\\n    14→type Session struct {\\n    15→    ID          string       // e.g., \\\"2025-12-01-8f76b0e8-b8f1-4a87-9186-848bdd83d62e\\\"\\n    16→    Description string       // Human-readable summary (first prompt or derived)\\n    17→    Strategy    string       // Strategy that created this session\\n    18→    StartTime   time.Time\\n    19→    Checkpoints []Checkpoint\\n    20→}\\n    21→```\\n    22→\\n    23→### Checkpoint\\n    24→\\n    25→A **Checkpoint** captures a point-in-time within a session. Defined in `strategy/session.go`:\\n    26→\\n    27→```go\\n    28→type Checkpoint struct {\\n    29→    CheckpointID     id.CheckpointID // Stable 12-hex-char identifier\\n    30→    Message          string          // Commit message or checkpoint description\\n    31→    Timestamp        time.Time\\n    32→    IsTaskCheckpoint bool            // Task checkpoint (subagent) vs session checkpoint\\n    33→    ToolUseID        string          // Tool use ID for task checkpoints (empty for session)\\n    34→}\\n    35→```\\n    36→\\n    37→### Checkpoint Types\\n    38→\\n    39→The low-level `checkpoint.Type` (from `checkpoint/checkpoint.go`) indicates storage location:\\n    40→\\n    41→```go\\n    42→type Type int\\n    43→\\n    44→const (\\n    45→    Temporary Type = iota // Full state snapshot, shadow branch\\n    46→    Committed             // Metadata + commit ref, entire/checkpoints/v1\\n    47→)\\n    48→```\\n    49→\\n    50→| Type | Contents | Use Case |\\n    51→|------|----------|----------|\\n    52→| Temporary | Full state (code + metadata) | Intra-session rewind, pre-commit |\\n    53→| Committed | Metadata + commit reference | Permanent record, post-commit rewind |\\n    54→\\n    55→## Interface\\n    56→\\n    57→### Session Operations\\n    58→\\n    59→Sessions are accessed via standalone functions in `strategy/session.go`:\\n    60→\\n    61→```go\\n    62→// ListSessions returns all sessions from entire/checkpoints/v1,\\n    63→// plus additional sessions from strategies implementing SessionSource.\\n    64→func ListSessions() ([]Session, error)\\n    65→\\n    66→// GetSession finds a session by ID (supports prefix matching).\\n    67→func GetSession(sessionID string) (*Session, error)\\n    68→```\\n    69→\\n    70→### Checkpoint Storage (Low-Level)\\n    71→\\n    72→The `checkpoint.Store` interface (from `checkpoint/checkpoint.go`) provides primitives for reading/writing checkpoints. Used by strategies.\\n    73→\\n    74→```go\\n    75→type Store interface {\\n    76→    // Temporary checkpoint operations (shadow branches - full state)\\n    77→    WriteTemporary(ctx context.Context, opts WriteTemporaryOptions) (WriteTemporaryResult, error)\\n    78→    ReadTemporary(ctx context.Context, baseCommit, worktreeID string) (*ReadTemporaryResult, error)\\n    79→    ListTemporary(ctx context.Context) ([]TemporaryInfo, error)\\n    80→\\n    81→    // Committed checkpoint operations (entire/checkpoints/v1 