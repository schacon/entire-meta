  330→\\n   331→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   332→\\t\\tif commitErr != nil {\\n   333→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   334→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   335→\\t\\t\\treturn nil\\n   336→\\t\\t}\\n   337→\\n   338→\\t\\tvar treeErr error\\n   339→\\t\\theadTree, treeErr = headCommit.Tree()\\n   340→\\t\\tif treeErr != nil {\\n   341→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   342→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   343→\\t\\t\\treturn nil\\n   344→\\t\\t}\\n   345→\\t}\\n   346→\\n   347→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   348→\\tshadowTree := o.shadowTree\\n   349→\\tif shadowTree == nil {\\n   350→\\t\\tif shadowRef != nil {\\n   351→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   352→\\t\\t\\tif shadowErr != nil {\\n   353→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   354→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   355→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   356→\\t\\t\\t\\treturn nil\\n   357→\\t\\t\\t}\\n   358→\\t\\t\\tvar shadowTreeErr error\\n   359→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   360→\\t\\t\\tif shadowTreeErr != nil {\\n   361→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   362→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   363→\\t\\t\\t\\treturn nil\\n   364→\\t\\t\\t}\\n   365→\\t\\t} else {\\n   366→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   367→\\t\\t\\t// because the agent's work is the commit itself.\\n   368→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   369→\\t\\t\\tshadowTree = headTree\\n   370→\\t\\t}\\n   371→\\t}\\n   372→\\n   373→\\t// Get base tree (state before session started)\\n   374→\\tvar baseTree *object.Tree\\n   375→\\tattrBase := state.AttributionBaseCommit\\n   376→\\tif attrBase == \\\"\\\" {\\n   377→\\t\\tattrBase = state.BaseCommit // backward compat\\n   378→\\t}\\n   379→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   380→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   381→\\t\\t\\tbaseTree = tree\\n   382→\\t\\t} else {\\n   383→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   384→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   385→\\t\\t}\\n   386→\\t} else {\\n   387→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   388→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   389→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   390→\\t}\\n   391→\\n   392→\\t// Log accumulated prompt attributions for debugging\\n   393→\\tvar totalUserAdded, totalUserRemoved int\\n   394→\\tfor i, pa := range state.PromptAttributions {\\n   395→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   396→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   397→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   398→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   399→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   400→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   401→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   402→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   403→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   404→\\t}\\n   405→\\n   406→\\tattribution := CalculateAttributionWithAccumulated(\\n   407→\\t\\tbaseTree,\\n   408→\\t\\tshadowTree,\\n   409→\\t\\theadTree,\\n   410→\\t\\tsessionData.FilesTouched,\\n   411→\\t\\tstate.PromptAttributions,\\n   412→\\t)\\n   413→\\n   414→\\tif attribution != nil {\\n   415→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   416→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   417→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   418→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   419→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   420→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   421→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   422→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   423→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   424→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   425→\\t}\\n   426→\\n   427→\\treturn attribution\\n   428→}\\n   429→\\n   430→// extractSessionData extracts session data from the shadow branch.\\n   431→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   432→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   433→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   434→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   435→// continued growing — the shadow branch copy would be stale.\\n   436→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   437→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType agent.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   438→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   439→\\tcommit, err := repo.CommitObject(shadowRef)\\n   440→\\tif err != nil {\\n   441→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   442→\\t}\\n   443→\\n   444→\\ttree, err := commit.Tree()\\n   445→\\tif err != nil {\\n   446→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   447→\\t}\\n   448→\\n   449→\\tdata := &ExtractedSessionData{}\\n   450→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   451→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   452→\\n   453→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   454→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   455→\\t// (SaveStep is only called when there are file modifications).\\n   456→\\tvar fullTranscript string\\n   457→\\tif liveTranscriptPath != \\\"\\\" {\\n   458→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   459→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   460→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   461→\\t\\tif isActive {\\n   462→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   463→\\t\\t}\\n   464→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   465→\\t\\t\\tfullTranscript = string(liveData)\\n   466→\\t\\t}\\n   467→\\t}\\n   468→\\tif fullTranscript == \\\"\\\" {\\n   469→\\t\\t// Fall back to shadow branch copy\\n   470→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   471→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   472→\\t\\t\\t\\tfullTranscript = content\\n   473→\\t\\t\\t}\