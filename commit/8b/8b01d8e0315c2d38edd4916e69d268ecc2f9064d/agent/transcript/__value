s orphan branch if it doesn't exist.\\n    39→func (s *Store) EnsureBranch() error {\\n    40→\\trefName := plumbing.NewBranchReferenceName(paths.TrailsBranchName)\\n    41→\\t_, err := s.repo.Reference(refName, true)\\n    42→\\tif err == nil {\\n    43→\\t\\treturn nil // Branch already exists\\n    44→\\t}\\n    45→\\n    46→\\t// Create orphan branch with empty tree\\n    47→\\temptyTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, make(map[string]object.TreeEntry))\\n    48→\\tif err != nil {\\n    49→\\t\\treturn fmt.Errorf(\\\"failed to build empty tree: %w\\\", err)\\n    50→\\t}\\n    51→\\n    52→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n    53→\\tcommitHash, err := s.createCommit(emptyTreeHash, plumbing.ZeroHash, \\\"Initialize trails branch\\\", authorName, authorEmail)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn fmt.Errorf(\\\"failed to create initial commit: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n    59→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n    60→\\t\\treturn fmt.Errorf(\\\"failed to set branch reference: %w\\\", err)\\n    61→\\t}\\n    62→\\treturn nil\\n    63→}\\n    64→\\n    65→// Write writes trail metadata, discussion, and checkpoints to the entire/trails branch.\\n    66→// If checkpoints is nil, an empty checkpoints list is written.\\n    67→func (s *Store) Write(metadata *Metadata, discussion *Discussion, checkpoints *Checkpoints) error {\\n    68→\\tif metadata.TrailID.IsEmpty() {\\n    69→\\t\\treturn errors.New(\\\"trail ID is required\\\")\\n    70→\\t}\\n    71→\\n    72→\\tif err := s.EnsureBranch(); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"failed to ensure trails branch: %w\\\", err)\\n    74→\\t}\\n    75→\\n    76→\\t// Get current branch tree\\n    77→\\tref, entries, err := s.getBranchEntries()\\n    78→\\tif err != nil {\\n    79→\\t\\treturn fmt.Errorf(\\\"failed to get branch entries: %w\\\", err)\\n    80→\\t}\\n    81→\\n    82→\\t// Build sharded path\\n    83→\\tbasePath := metadata.TrailID.Path() + \\\"/\\\"\\n    84→\\n    85→\\t// Create metadata blob\\n    86→\\tmetadataJSON, err := json.MarshalIndent(metadata, \\\"\\\", \\\"  \\\")\\n    87→\\tif err != nil {\\n    88→\\t\\treturn fmt.Errorf(\\\"failed to marshal metadata: %w\\\", err)\\n    89→\\t}\\n    90→\\tmetadataBlob, err := checkpoint.CreateBlobFromContent(s.repo, metadataJSON)\\n    91→\\tif err != nil {\\n    92→\\t\\treturn fmt.Errorf(\\\"failed to create metadata blob: %w\\\", err)\\n    93→\\t}\\n    94→\\tentries[basePath+metadataFile] = object.TreeEntry{\\n    95→\\t\\tName: basePath + metadataFile,\\n    96→\\t\\tMode: filemode.Regular,\\n    97→\\t\\tHash: metadataBlob,\\n    98→\\t}\\n    99→\\n   100→\\t// Create discussion blob\\n   101→\\tif discussion == nil {\\n   102→\\t\\tdiscussion = &Discussion{Comments: []Comment{}}\\n   103→\\t}\\n   104→\\tdiscussionJSON, err := json.MarshalIndent(discussion, \\\"\\\", \\\"  \\\")\\n   105→\\tif err != nil {\\n   106→\\t\\treturn fmt.Errorf(\\\"failed to marshal discussion: %w\\\", err)\\n   107→\\t}\\n   108→\\tdiscussionBlob, err := checkpoint.CreateBlobFromContent(s.repo, discussionJSON)\\n   109→\\tif err != nil {\\n   110→\\t\\treturn fmt.Errorf(\\\"failed to create discussion blob: %w\\\", err)\\n   111→\\t}\\n   112→\\tentries[basePath+discussionFile] = object.TreeEntry{\\n   113→\\t\\tName: basePath + discussionFile,\\n   114→\\t\\tMode: filemode.Regular,\\n   115→\\t\\tHash: discussionBlob,\\n   116→\\t}\\n   117→\\n   118→\\t// Create checkpoints blob\\n   119→\\tif checkpoints == nil {\\n   120→\\t\\tcheckpoints = &Checkpoints{Checkpoints: []CheckpointRef{}}\\n   121→\\t}\\n   122→\\tcheckpointsJSON, err := json.MarshalIndent(checkpoints, \\\"\\\", \\\"  \\\")\\n   123→\\tif err != nil {\\n   124→\\t\\treturn fmt.Errorf(\\\"failed to marshal checkpoints: %w\\\", err)\\n   125→\\t}\\n   126→\\tcheckpointsBlob, err := checkpoint.CreateBlobFromContent(s.repo, checkpointsJSON)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn fmt.Errorf(\\\"failed to create checkpoints blob: %w\\\", err)\\n   129→\\t}\\n   130→\\tentries[basePath+checkpointsFile] = object.TreeEntry{\\n   131→\\t\\tName: basePath + checkpointsFile,\\n   132→\\t\\tMode: filemode.Regular,\\n   133→\\t\\tHash: checkpointsBlob,\\n   134→\\t}\\n   135→\\n   136→\\t// Build tree and commit\\n   137→\\tnewTreeHash, err := checkpoint.BuildTreeFromEntries(s.repo, entries)\\n   138→\\tif err != nil {\\n   139→\\t\\treturn fmt.Errorf(\\\"failed to build tree: %w\\\", err)\\n   140→\\t}\\n   141→\\n   142→\\tauthorName, authorEmail := checkpoint.GetGitAuthorFromRepo(s.repo)\\n   143→\\tcommitMsg := fmt.Sprintf(\\\"Trail: %s (%s)\\\", metadata.Title, metadata.TrailID)\\n   144→\\tcommitHash, err := s.createCommit(newTreeHash, ref.Hash(), commitMsg, authorName, authorEmail)\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"failed to create commit: %w\\\", err)\\n   147→\\t}\\n   148→\\n   149→\\t// Update branch ref\\n   150→\\tnewRef := plumbing.NewHashReference(plumbing.NewBranchReferenceName(paths.TrailsBranchName), commitHash)\\n   151→\\tif err := s.repo.Storer.SetReference(newRef); err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"failed to update branch reference: %w\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\treturn nil\\n   156→}\\n   157→\\n   158→// Read reads a trail by its ID from the entire/trails branch.\\n   159→func (s *Store) Read(trailID ID) (*Metadata, *Discussion, *Checkpoints, error) {\\n   160→\\ttree, err := s.getBranchTree()\\n   161→\\tif err != nil {\\n   162→\\t\\treturn nil, nil, nil, err\\n   163→\\t}\\n   164→\\n   165→\\tbasePath := trailID.Path() + \\\"/\\\"\\n   166→\\n   167→\\t// Read metadata\\n   168→\\tmetadataEntry, err := tree.FindEntry(basePath + metadataFile)\\n   169→\\tif err != nil {\\n   170→\\t\\treturn nil, nil, nil, fmt.Errorf(\\\"trail %s not found: %w\\\",