er(checkpointsReader).Decode(&checkpoints)\\n   212→\\t\\t\\t\\t_ = checkpointsReader.Close()\\n   213→\\t\\t\\t}\\n   214→\\t\\t}\\n   215→\\t}\\n   216→\\n   217→\\treturn &metadata, &discussion, &checkpoints, nil\\n   218→}\\n   219→\\n   220→// FindByBranch finds a trail for the given branch name.\\n   221→// Returns (nil, nil) if no trail exists for the branch.\\n   222→func (s *Store) FindByBranch(branchName string) (*Metadata, error) {\\n   223→\\ttrails, err := s.List()\\n   224→\\tif err != nil {\\n   225→\\t\\treturn nil, err\\n   226→\\t}\\n   227→\\n   228→\\tfor _, t := range trails {\\n   229→\\t\\tif t.Branch == branchName {\\n   230→\\t\\t\\treturn t, nil\\n   231→\\t\\t}\\n   232→\\t}\\n   233→\\treturn nil, nil //nolint:nilnil // nil, nil means \\\"not found\\\" — callers check both\\n   234→}\\n   235→\\n   236→// List returns all trail metadata from the entire/trails branch.\\n   237→func (s *Store) List() ([]*Metadata, error) {\\n   238→\\ttree, err := s.getBranchTree()\\n   239→\\tif err != nil {\\n   240→\\t\\t// Branch doesn't exist yet — no trails\\n   241→\\t\\treturn nil, nil //nolint:nilerr // Expected when no trails exist yet\\n   242→\\t}\\n   243→\\n   244→\\tvar trails []*Metadata\\n   245→\\tentries := make(map[string]object.TreeEntry)\\n   246→\\tif err := checkpoint.FlattenTree(s.repo, tree, \\\"\\\", entries); err != nil {\\n   247→\\t\\treturn nil, fmt.Errorf(\\\"failed to flatten tree: %w\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\t// Find all metadata.json files\\n   251→\\tfor path, entry := range entries {\\n   252→\\t\\tif !strings.HasSuffix(path, \\\"/\\\"+metadataFile) {\\n   253→\\t\\t\\tcontinue\\n   254→\\t\\t}\\n   255→\\n   256→\\t\\tblob, err := s.repo.BlobObject(entry.Hash)\\n   257→\\t\\tif err != nil {\\n   258→\\t\\t\\tcontinue\\n   259→\\t\\t}\\n   260→\\t\\treader, err := blob.Reader()\\n   261→\\t\\tif err != nil {\\n   262→\\t\\t\\tcontinue\\n   263→\\t\\t}\\n   264→\\n   265→\\t\\tvar metadata Metadata\\n 