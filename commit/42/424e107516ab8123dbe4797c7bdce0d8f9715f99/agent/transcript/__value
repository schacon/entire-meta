ta,\\n   133â†’\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   134â†’\\t}, nil\\n   135â†’}\\n   136â†’\\n   137â†’// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   138â†’// Uses the NativeData field which contains raw JSONL bytes.\\n   139â†’// The session must have been created by Claude Code (AgentName check).\\n   140â†’func (c *ClaudeCodeAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   141â†’\\tif session == nil {\\n   142â†’\\t\\treturn errors.New(\\\"session is nil\\\")\\n   143â†’\\t}\\n   144â†’\\n   145â†’\\t// Verify this session belongs to Claude Code\\n   146â†’\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   147â†’\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   148â†’\\t}\\n   149â†’\\n   150â†’\\tif session.SessionRef == \\\"\\\" {\\n   151â†’\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   152â†’\\t}\\n   153â†’\\n   154â†’\\tif len(session.NativeData) == 0 {\\n   155â†’\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   156â†’\\t}\\n   157â†’\\n   158â†’\\t// Write the raw JSONL data\\n   159â†’\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   160â†’\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   161â†’\\t}\\n   162â†’\\n   163â†’\\treturn nil\\n   164â†’}\\n   165â†’\\n   166â†’// FormatResumeCommand returns the command to resume a Claude Code session.\\n   167â†’func (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   168â†’\\treturn \\\"claude -r \\\" + sessionID\\n   169â†’}\\n   170â†’\\n   171â†’// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   172â†’\\n   173â†’// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   174â†’// This is used for rewind operations to restore transcript state.\\n   175â†’// Requires NativeData to be populated.\\n   176â†’func (c *ClaudeCodeAgent) TruncateAtUUID(session *agent.AgentSession, uuid string) (*agent.AgentSession, error) {\\n   177â†’\\tif session == nil {\\n   178â†’\\t\\treturn nil, errors.New(\\\"session is nil\\\")\\n   179â†’\\t}\\n   180â†’\\n   181â†’\\tif len(session.NativeData) == 0 {\\n   182â†’\\t\\treturn nil, errors.New(\\\"session has no native data\\\")\\n   183â†’\\t}\\n   184â†’\\n   185â†’\\tif uuid == \\\"\\\" {\\n   186â†’\\t\\t// No truncation needed, return copy\\n   187â†’\\t\\treturn &agent.AgentSession{\\n   188â†’\\t\\t\\tSessionID:     session.SessionID,\\n   189â†’\\t\\t\\tAgentName:     session.AgentName,\\n   190â†’\\t\\t\\tRepoPath:      session.RepoPath,\\n   191â†’\\t\\t\\tSessionRef:    session.SessionRef,\\n   192â†’\\t\\t\\tStartTime:     session.StartTime,\\n   193â†’\\t\\t\\tNativeData:    session.NativeData,\\n   194â†’\\t\\t\\tModifiedFiles: session.ModifiedFiles,\\n   195â†’\\t\\t}, nil\\n   196â†’\\t}\\n   197â†’\\n   198â†’\\t// Parse, truncate, re-serialize\\n   199â†’\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   200â†’\\tif err != nil {\\n   201â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   202â†’\\t}\\n   203â†’\\n   204â†’\\ttruncated := TruncateAtUUID(lines, uuid)\\n   205â†’\\n   206â†’\\tnewData, err := SerializeTranscript(truncated)\\n   207â†’\\tif err != nil {\\n   208â†’\\t\\treturn nil, fmt.Errorf(\\\"failed to serialize truncated transcript: %w\\\", err)\\n   209â†’\\t}\\n   210â†’\\n   211â†’\\treturn &agent.AgentSession{\\n   212â†’\\t\\tSessionID:     session.SessionID,\\n   213â†’\\t\\tAgentName:     session.AgentName,\\n   214â†’\\t\\tRepoPath:      session.RepoPath,\\n   215â†’\\t\\tSessionRef:    session.SessionRef,\\n   216â†’\\t\\tStartTime:     session.StartTime,\\n   217â†’\\t\\tNativeData:    newData,\\n   218â†’\\t\\tModifiedFiles: ExtractModifiedFiles(truncated),\\n   219â†’\\t}, 