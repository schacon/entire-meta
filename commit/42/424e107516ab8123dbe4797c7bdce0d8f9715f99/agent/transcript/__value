sitions it to IDLE.\\n   234â†’// Returns the checkpoint ID string (empty if condensation failed).\\n   235â†’func condenseAndFinalizeSession(ctx context.Context, strat *strategy.ManualCommitStrategy, sessionID string) string {\\n   236â†’\\tvar checkpointIDStr string\\n   237â†’\\tif err := strat.CondenseSessionByID(ctx, sessionID); err != nil {\\n   238â†’\\t\\tlogging.Warn(ctx, \\\"failed to condense session â€” checkpoint saved on shadow branch only\\\")\\n   239â†’\\t} else {\\n   240â†’\\t\\tif condensedState, loadErr := strategy.LoadSessionState(ctx, sessionID); loadErr == nil && condensedState != nil {\\n   241â†’\\t\\t\\tcheckpointIDStr = condensedState.LastCheckpointID.String()\\n   242â†’\\t\\t}\\n   243â†’\\t}\\n   244â†’\\n   245â†’\\tif finalState, loadErr := strategy.LoadSessionState(ctx, sessionID); loadErr == nil && finalState != nil {\\n   246â†’\\t\\tnow := time.Now()\\n   247â†’\\t\\tfinalState.LastInteractionTime = &now\\n   248â†’\\t\\tif transErr := strategy.TransitionAndLog(ctx, finalState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   249â†’\\t\\t\\tlogging.Warn(ctx, \\\"failed to transition session to idle\\\")\\n   250â†’\\t\\t}\\n   251â†’\\t\\tif saveErr := strategy.SaveSessionState(ctx, finalState); saveErr != nil {\\n   252â†’\\t\\t\\tlogging.Warn(ctx, \\\"failed to save session state after transition\\\")\\n   253â†’\\t\\t}\\n   254â†’\\t}\\n   255â†’\\n   256â†’\\treturn checkpointIDStr\\n   257â†’}\\n   258â†’\\n   259â†’// promptAmendCommit shows the last commit and asks whether to amend it with the checkpoint trailer.\\n   260â†’// When force is true, it amends without prompting.\\n   261â†’func promptAmendCommit(ctx context.Context, w io.Writer, checkpointIDStr string, force bool) error {\\n   262â†’\\t// Get HEAD commit info\\n   263â†’\\trepo, err := openRepository(ctx)\\n   264â†’\\tif err != nil {\\n   265â†’\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\"