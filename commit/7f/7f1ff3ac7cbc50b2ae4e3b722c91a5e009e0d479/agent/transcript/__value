dUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   615→\\t\\t\\tshadowRef: h.shadowRef,\\n   616→\\t\\t\\theadTree:  h.headTree,\\n   617→\\t\\t})\\n   618→\\t} else {\\n   619→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   620→\\t}\\n   621→\\treturn nil\\n   622→}\\n   623→\\n   624→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   625→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   626→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   627→\\n   628→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   629→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   630→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   631→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   632→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   633→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   634→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   635→\\t)\\n   636→\\n   637→\\tif shouldCondense {\\n   638→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   639→\\t\\t\\tshadowRef: h.shadowRef,\\n   640→\\t\\t\\theadTree:  h.headTree,\\n   641→\\t\\t})\\n   642→\\t} else {\\n   643→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   644→\\t}\\n   645→\\treturn nil\\n   646→}\\n   647→\\n   648→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   649→// into this commit. Active sessions with recent interaction always condense\\n   650→// (bypasses overlap check). Stale ACTIVE and IDLE/ENDED sessions require\\n   651→// file overlap evidence between tracked files and committed files.\\n   652→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool, lastInteraction *time.Time) bool {\\n   653→\\tif !h.hasNew {\\n   654→\\t\\treturn false\\n   655→\\t}\\n   656→\\t// ACTIVE sessions with recent interaction: skip the overlap check.\\n   657→\\t// PrepareCommitMsg already validated this commit is session-related\\n   658→\\t// (added trailer). The overlap check is only meaningful when we need\\n   659→\\t// heuristic evidence that a commit was related to the session.\\n   660→\\t//\\n   661→\\t// We check LastInteractionTime to avoid condensing stale ACTIVE sessions\\n   662→\\t// (agent killed without Stop hook) into every subsequent commit. A stale\\n   663→\\t// session has no recent interaction and falls through to the overlap check.\\n   664→\\tif isActive && isRecentInteraction(lastInteraction) {\\n   665→\\t\\treturn true\\n   666→\\t}\\n   667→\\tif len(h.filesTouchedBefore) == 0 {\\n   668→\\t\\treturn false // No files tracked = no overlap evidence\\n   669→\\t}\\n   670→\\t// Only check files that were actually changed in this commit.\\n   671→\\t// Without this, files that exist in the tree but weren't changed\\n   672→\\t// would pass the \\\"modified file\\\" check in filesOverlapWithContent\\n   673→\\t// (because the file exists in the parent tree), causing stale\\n   674→\\t// sessions to be incorrectly condensed.\\n   675→\\tvar committedTouchedFiles []string\\n   676→\\tfor _, f := range h.filesTouchedBefore {\\n   677→\\t\\tif _, ok := h.committedFileSet[f]; ok {\\n   678→\\t\\t\\tcommittedTouchedFiles = append(committedTouchedFiles, f)\\n   679→\\t\\t}\\n   680→\\t}\\n   681→\\tif len(committedTouchedFiles) == 0 {\\n   682→\\t\\treturn false\\n   683→\\t}\\n   684→\\treturn filesOverlapWithContent(h.ctx, h.repo, h.shadowBranchName, h.commit, committedTouchedFiles, overlapOpts{\\n   685→\\t\\theadTree:      h.headTree,\\n   686→\\t\\tshadowTree:    h.shadowTree,\\n   687→\\t\\tparentTree:    h.parentTree,\\n   688→\\t\\thasParentTree: true,\\n   689→\\t})\\n   690→}\\n   691→\\n   692→// activeSessionInteractionThreshold is the maximum age of LastInteractionTime\\n   693→// for an ACTIVE session to be considered genuinely active. 24h is generous\\n   694→// because LastInteractionTime only updates at TurnStart, not per-tool-call.\\n   695→const activeSessionInteractionThreshold = 24 * time.Hour\\n   696→\\n   697→// isRecentInteraction returns true if lastInteraction is non-nil and within\\n   698→// activeSessionInteractionThreshold of now.\\n   699→func isRecentInteraction(lastInteraction *time.Time) bool {\\n   700→\\treturn lastInteraction != nil && time.Since(*lastInteraction) < activeSessionInteractionThreshold\\n   701→}\\n   702→\\n   703→func (h *postCommitActionHandler) HandleDiscardIfNoFiles(state *session.State) error {\\n   704→\\tif len(state.FilesTouched) == 0 {\\n   705→\\t\\tlogging.Debug(logging.WithComponent(h.ctx, \\\"checkpoint\\\"), \\\"post-commit: skipping empty ended session (no files to condense)\\\",\\n   706→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   707→\\t\\t)\\n   708→\\t}\\n   709→\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   710→\\treturn nil\\n   711→}\\n   712→\\n   713→func (h *postCommitActionHandler) HandleWarnStaleSession(_ *session.State) error {\\n   714→\\t// Not produced by EventGitCommit; no-op for exhaustiveness.\\n   715→\\treturn nil\\n   716→}\\n   717→\\n   718→// During rebase/cherry-pick/revert operations, phase transitions are skipped entirely.\\n   719→//\\n   720→\\n   721→func (s *ManualCommitStrategy) PostCommit(ctx context.Context) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   722→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   723→\\n   724→\\trepo, err := OpenRepository(ctx)\\n   725→\\tif err != nil {\\n   726→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   727→\\t}\\n   728→\\n   729→\\t// Get HEAD commit to check for trailer\\n   730→\\thead, err := repo.Head()\\n   731→\\tif err != nil {\\n   732→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   733→\\t}\\n   734→\\n   735→\\tcommit, err := repo.CommitObject(head.Hash())\\n   736→\\tif err != nil {\\n   737→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   738→\\t}\\n   739→\\n   740→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   741→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   742→\\tif !found {\\n   743→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   744→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   745→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   746→\\t\\treturn nil\\n   747→\\t}\\n   748→\"}]},\"uuid\":\"21325499-52ea-4331-9eb3-1d7e30ee3780\",\"timestamp\":\"2026-03-04T01:02:45.255Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a8aacd9d7c18afbba\"},\"toolUseID\":\"agent_msg_01V3Lk9WVFZ617vzUj53rSuV\",\"parentToolUseID\":\"toolu_01FxNLG775GdFhXkL5G7DZvp\",\"uuid\":\"c6b81355-2d20-44b5-9ad7-109a25352cf4\",\"timestamp\":\"2026-03-04T01:02:45.392Z\"}\n{\"parentUuid\":\"c6b81355-2d20-44b5-9ad7-109a25352cf4\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation\",\"sessionId\":\"2d62938d-a5d3-4bac-9d0f-bf8056720e6d\",\"version\":\"2.1.63\",\"gitBranch\":\"performance-logging-investigation\",\"slug\":\"wiggly-weaving-crayon\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T01:02:45.429Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01DyXgxh4kNLjNupjbK7GtyF\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01QqGWpu17Fbxz5jvQbdBmEw\",\"name\":\"Rea