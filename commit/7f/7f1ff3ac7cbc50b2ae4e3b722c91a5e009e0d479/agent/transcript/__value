nd completes the span. For root spans, emits a single DEBUG log line\\n    43→// with the full timing tree. For child spans, records the duration only.\\n    44→// Safe to call multiple times -- subsequent calls are no-ops.\\n    45→func (s *Span) End() {\\n    46→\\tif s.ended {\\n    47→\\t\\treturn\\n    48→\\t}\\n    49→\\ts.ended = true\\n    50→\\ts.duration = time.Since(s.start)\\n    51→\\n    52→\\t// Only root spans emit log output\\n    53→\\tif s.parent != nil {\\n    54→\\t\\treturn\\n    55→\\t}\\n    56→\\n    57→\\t// Build log attributes: component, op, duration_ms, then child step durations.\\n    58→\\t// The \\\"component\\\" key is intentionally set to \\\"perf\\\" for easy filtering,\\n    59→\\t// even if the context already has a component set via logging.WithComponent().\\n    60→\\tattrs := make([]any, 0, 3+len(s.children)+len(s.attrs))\\n    61→\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n    62→\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n    63→\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n    64→\\n    65→\\t// Add child step durations as flat keys\\n    66→\\tfor _, child := range s.children {\\n    67→\\t\\t// Auto-end children that were not explicitly ended\\n    68→\\t\\tif !child.ended {\\n    69→\\t\\t\\tchild.ended = true\\n    70→\\t\\t\\tchild.duration = time.Since(child.start)\\n    71→\\t\\t}\\n    72→\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n    73→\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n    74→\\t}\\n    75→\\n    76→\\t// Add any extra attributes from Start()\\n    77→\\tfor _, a := range s.attrs {\\n    78→\\t\\tattrs = append(attrs, a)\\n    79→\\t}\\n    80→\\n    81→\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n    82→}\\n    83→\\n    84→// Measure times a function as a child substep of this span.\\n    85→func (s *Span) Measure(name string, fn func()) {\\n    86→\\tctx := contextWithSpan(s.ctx, s)\\n    87→\\t_, child := Start(ctx, name)\\n    88→\\tfn()\\n    89→\\tchild.End()\\n    90→}\\n    91→\"}]},\"uuid\":\"f33231db-487c-4bce-b6d3-0bc099d2fe4e\",\"timestamp\":\"2026-03-04T23:47:41.792Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a1ad7b0137ec330cc\"},\"toolUseID\":\"agent_msg_01LmZeA4zuwYd8d5Bc8kFerP\",\"parentToolUseID\":\"toolu_01QqEPy52SJMuFyv8km8cQaV\",\"uuid\":\"e917b4c8-2b50-4ba9-ac54-8cca27641619\",\"timestamp\":\"2026-03-04T23:47:41.802Z\"}\n{\"parentUuid\":\"e917b4c8-2b50-4ba9-ac54-8cca27641619\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation\",\"sessionId\":\"2d62938d-a5d3-4bac-9d0f-bf8056720e6d\",\"version\":\"2.1.63\",\"gitBranch\":\"performance-logging-investigation\",\"slug\":\"wiggly-weaving-crayon\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T23:47:41.903Z\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01EAqbosL4RHdDXWsteYkpfn\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01NXBk3ZiVS4C3HuCTck6Enw\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation/perf/context.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":212,\"cache_read_input_tokens\":34457,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":212},\"output_tokens\":25,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYiw5A6KugiAK9zDm99Qe\",\"uuid\":\"f1220f3a-8028-46da-a687-ef6abffc7382\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a1ad7b0137ec330cc\"},\"toolUseID\":\"agent_msg_01LmZeA4zuwYd8d5Bc8kFerP\",\"parentToolUseID\":\"to