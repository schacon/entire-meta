he shadow tree. This is correct because the agent's\\n   318→\\t// commit IS HEAD — there are no user edits between agent work and commit.\\n   319→\\tlogCtx := logging.WithComponent(ctx, \\\"attribution\\\")\\n   320→\\n   321→\\tvar o attributionOpts\\n   322→\\tif len(opts) > 0 {\\n   323→\\t\\to = opts[0]\\n   324→\\t}\\n   325→\\n   326→\\theadTree := o.headTree\\n   327→\\tif headTree == nil {\\n   328→\\t\\theadRef, headErr := repo.Head()\\n   329→\\t\\tif headErr != nil {\\n   330→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD\\\",\\n   331→\\t\\t\\t\\tslog.String(\\\"error\\\", headErr.Error()))\\n   332→\\t\\t\\treturn nil\\n   333→\\t\\t}\\n   334→\\n   335→\\t\\theadCommit, commitErr := repo.CommitObject(headRef.Hash())\\n   336→\\t\\tif commitErr != nil {\\n   337→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD commit\\\",\\n   338→\\t\\t\\t\\tslog.String(\\\"error\\\", commitErr.Error()))\\n   339→\\t\\t\\treturn nil\\n   340→\\t\\t}\\n   341→\\n   342→\\t\\tvar treeErr error\\n   343→\\t\\theadTree, treeErr = headCommit.Tree()\\n   344→\\t\\tif treeErr != nil {\\n   345→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get HEAD tree\\\",\\n   346→\\t\\t\\t\\tslog.String(\\\"error\\\", treeErr.Error()))\\n   347→\\t\\t\\treturn nil\\n   348→\\t\\t}\\n   349→\\t}\\n   350→\\n   351→\\t// Get shadow tree: from pre-resolved cache, shadow branch, or HEAD (agent committed directly).\\n   352→\\tshadowTree := o.shadowTree\\n   353→\\tif shadowTree == nil {\\n   354→\\t\\tif shadowRef != nil {\\n   355→\\t\\t\\tshadowCommit, shadowErr := repo.CommitObject(shadowRef.Hash())\\n   356→\\t\\t\\tif shadowErr != nil {\\n   357→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow commit\\\",\\n   358→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowErr.Error()),\\n   359→\\t\\t\\t\\t\\tslog.String(\\\"shadow_ref\\\", shadowRef.Hash().String()))\\n   360→\\t\\t\\t\\treturn nil\\n   361→\\t\\t\\t}\\n   362→\\t\\t\\tvar shadowTreeErr error\\n   363→\\t\\t\\tshadowTree, shadowTreeErr = shadowCommit.Tree()\\n   364→\\t\\t\\tif shadowTreeErr != nil {\\n   365→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"attribution skipped: failed to get shadow tree\\\",\\n   366→\\t\\t\\t\\t\\tslog.String(\\\"error\\\", shadowTreeErr.Error()))\\n   367→\\t\\t\\t\\treturn nil\\n   368→\\t\\t\\t}\\n   369→\\t\\t} else {\\n   370→\\t\\t\\t// No shadow branch: agent committed mid-turn. Use HEAD as shadow\\n   371→\\t\\t\\t// because the agent's work is the commit itself.\\n   372→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: using HEAD as shadow (no shadow branch)\\\")\\n   373→\\t\\t\\tshadowTree = headTree\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\t// Get base tree (state before session started)\\n   378→\\tvar baseTree *object.Tree\\n   379→\\tattrBase := state.AttributionBaseCommit\\n   380→\\tif attrBase == \\\"\\\" {\\n   381→\\t\\tattrBase = state.BaseCommit // backward compat\\n   382→\\t}\\n   383→\\tif baseCommit, baseErr := repo.CommitObject(plumbing.NewHash(attrBase)); baseErr == nil {\\n   384→\\t\\tif tree, baseTErr := baseCommit.Tree(); baseTErr == nil {\\n   385→\\t\\t\\tbaseTree = tree\\n   386→\\t\\t} else {\\n   387→\\t\\t\\tlogging.Debug(logCtx, \\\"attribution: base tree unavailable\\\",\\n   388→\\t\\t\\t\\tslog.String(\\\"error\\\", baseTErr.Error()))\\n   389→\\t\\t}\\n   390→\\t} else {\\n   391→\\t\\tlogging.Debug(logCtx, \\\"attribution: base commit unavailable\\\",\\n   392→\\t\\t\\tslog.String(\\\"error\\\", baseErr.Error()),\\n   393→\\t\\t\\tslog.String(\\\"attribution_base\\\", attrBase))\\n   394→\\t}\\n   395→\\n   396→\\t// Log accumulated prompt attributions for debugging\\n   397→\\tvar totalUserAdded, totalUserRemoved int\\n   398→\\tfor i, pa := range state.PromptAttributions {\\n   399→\\t\\ttotalUserAdded += pa.UserLinesAdded\\n   400→\\t\\ttotalUserRemoved += pa.UserLinesRemoved\\n   401→\\t\\tlogging.Debug(logCtx, \\\"prompt attribution data\\\",\\n   402→\\t\\t\\tslog.Int(\\\"checkpoint\\\", pa.CheckpointNumber),\\n   403→\\t\\t\\tslog.Int(\\\"user_added\\\", pa.UserLinesAdded),\\n   404→\\t\\t\\tslog.Int(\\\"user_removed\\\", pa.UserLinesRemoved),\\n   405→\\t\\t\\tslog.Int(\\\"agent_added\\\", pa.AgentLinesAdded),\\n   406→\\t\\t\\tslog.Int(\\\"agent_removed\\\", pa.AgentLinesRemoved),\\n   407→\\t\\t\\tslog.Int(\\\"index\\\", i))\\n   408→\\t}\\n   409→\\n   410→\\tattribution := CalculateAttributionWithAccumulated(\\n   411→\\t\\tctx,\\n   412→\\t\\tbaseTree,\\n   413→\\t\\tshadowTree,\\n   414→\\t\\theadTree,\\n   415→\\t\\tsessionData.FilesTouched,\\n   416→\\t\\tstate.PromptAttributions,\\n   417→\\t)\\n   418→\\n   419→\\tif attribution != nil {\\n   420→\\t\\tlogging.Info(logCtx, \\\"attribution calculated\\\",\\n   421→\\t\\t\\tslog.Int(\\\"agent_lines\\\", attribution.AgentLines),\\n   422→\\t\\t\\tslog.Int(\\\"human_added\\\", attribution.HumanAdded),\\n   423→\\t\\t\\tslog.Int(\\\"human_modified\\\", attribution.HumanModified),\\n   424→\\t\\t\\tslog.Int(\\\"human_removed\\\", attribution.HumanRemoved),\\n   425→\\t\\t\\tslog.Int(\\\"total_committed\\\", attribution.TotalCommitted),\\n   426→\\t\\t\\tslog.Float64(\\\"agent_percentage\\\", attribution.AgentPercentage),\\n   427→\\t\\t\\tslog.Int(\\\"accumulated_user_added\\\", totalUserAdded),\\n   428→\\t\\t\\tslog.Int(\\\"accumulated_user_removed\\\", totalUserRemoved),\\n   429→\\t\\t\\tslog.Int(\\\"files_touched\\\", len(sessionData.FilesTouched)))\\n   430→\\t}\\n   431→\\n   432→\\treturn attribution\\n   433→}\\n   434→\\n   435→// extractSessionData extracts session data from the shadow branch.\\n   436→// filesTouched is the list of files tracked during the session (from SessionState.FilesTouched).\\n   437→// agentType identifies the agent (e.g., \\\"Gemini CLI\\\", \\\"Claude Code\\\") to determine transcript format.\\n   438→// liveTranscriptPath, when non-empty and readable, is preferred over the shadow branch copy.\\n   439→// This handles the case where SaveStep was skipped (no code changes) but the transcript\\n   440→// continued growing — the shadow branch copy would be stale.\\n   441→// checkpointTranscriptStart is the line offset (Claude) or message index (Gemini) where the current checkpoint began.\\n   442→func (s *ManualCommitStrategy) extractSessionData(ctx context.Context, repo *git.Repository, shadowRef plumbing.Hash, sessionID string, filesTouched []string, agentType types.AgentType, liveTranscriptPath string, checkpointTranscriptStart int, isActive bool) (*ExtractedSessionData, error) {\\n   443→\\tag, _ := agent.GetByAgentType(agentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   444→\\tcommit, err := repo.CommitObject(shadowRef)\\n   445→\\tif err != nil {\\n   446→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit object: %w\\\", err)\\n   447→\\t}\\n   448→\\n   449→\\ttree, err := commit.Tree()\\n   450→\\tif err != nil {\\n   451→\\t\\treturn nil, fmt.Errorf(\\\"failed to get commit tree: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tdata := &ExtractedSessionData{}\\n   455→\\t// sessionID is already an \\\"entire session ID\\\" (with date prefix)\\n   456→\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   457→\\n   458→\\t// Extract transcript — prefer the live file when available, fall back to shadow branch.\\n   459→\\t// The shadow branch copy may be stale if the last turn ended without code changes\\n   460→\\t// (SaveStep is only called when there are file modifications).\\n   461→\\tvar fullTranscript string\\n   462→\\tif liveTranscriptPath != \\\"\\\" {\\n   463→\\t\\t// Ensure transcript file exists (OpenCode creates it lazily via `opencode export`).\\n   464→\\t\\t// Only wait for flush when the session is active — for idle/ended sessions the\\n   465→\\t\\t// transcript is already fully flushed (the Stop hook completed the flush).\\n   466→\\t\\tif isActive {\\n   467→\\t\\t\\tprepareTranscriptIfNeeded(ctx, ag, liveTranscriptPath)\\n   468→\\t\\t}\\n   469→\\t\\tif liveData, readErr := os.ReadFile(liveTranscriptPath); readErr == nil && len(liveData) > 0 { //nolint:gosec // path from session state\\n   470→\\t\\t\\tfullTranscript = string(liveData)\\n   471→\\t\\t}\\n   472→\\t}\\n   473→\\tif fullTranscript == \\\"\\\" {\\n   474→\\t\\t// Fall back to shadow branch copy\\n   475→\\t\\tif file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileName); fileErr == nil {\\n   476→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   477→\\t\\t\\t\\tfullTranscript = content\\n   478→\\t\\t\\t}\\n   479→\\t\\t} else if file, fileErr := tree.File(metadataDir + \\\"/\\\" + paths.TranscriptFileNameLegacy); fileErr == nil {\\n   480→\\t\\t\\tif content, contentErr := file.Contents(); contentErr == nil {\\n   481→\\t\\t\\t\\tfullTranscript = content\\n   482→\\t\\t\\t}\\n   483→\\t\\t}\\n   484→\\t}\\n   485→\\n   486→\\t// Process transcript based on agent type\\n   487→\\tif fullTranscript != \\\"\\\" {\\n   488→\\t\\tdata.Transcript = []byte(fullTranscript)\\n   489→\\t\\tdata.FullTranscriptLines = countTranscriptItems(agentType, fullTranscript)\\n   490→\\t\\tdata.Prompts = extractUserPrompts(agentType, fullTranscript)\\n   491→\\t\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   492→\\t}\\n   493→\\n   494→\\t// Use tracked files from session state (not all files in tree)\\n   495→\\tdata.FilesTouched = filesTouched\\n   496→\\n   497→\\t// Calculate token usage from the extracted transcript portion\\n   498→\\tif len(data.Transcript) > 0 {\\n   499→\\t\\tdata.TokenUsage = agent.CalculateTokenUsage(ctx, ag, data.Transcript, checkpointTranscriptStart, \\\"\\\") //TODO: why do we not use here subagents dir?\\n   500→\\t}\\n   501→\\n   502→\\treturn data, nil\\n   503→}\\n   504→\\n   505→// extractSessionDataFromLiveTranscript extracts session data directly from the live transcript file.\\n   506→// This is used for mid-session commits where no shadow branch exists yet.\\n   507→func (s *ManualCommitStrategy) extractSessionDataFromLiveTranscript(ctx context.Context, state *SessionState) (*ExtractedSessionData, error) {\\n   508→\\tdata := &ExtractedSessionData{}\\n   509→\\n   510→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   511→\\n   512→\\t// Read the live transcript\\n   513→\\tif state.TranscriptPath == \\\"\\\" {\\n   514→\\t\\treturn nil, errors.New(\\\"no transcript path in session state\\\")\\n   515→\\t}\\n   516→\\n   517→\\tliveData, err := os.ReadFile(state.TranscriptPath)\\n   518→\\tif err != nil {\\n   519→\\t\\treturn nil, fmt.Errorf(\\\"failed to read live transcript: %w\\\", err)\\n   520→\\t}\\n   521→\\n   522→\\tif len(liveData) == 0 {\\n   523→\\t\\treturn nil, errors.New(\\\"live transcript is empty\\\")\\n   524→\\t}\\n   525→\\n   526→\\tfullTranscript := string(liveData)\\n   527→\\tdata.Transcript = liveData\\n   528→\\tdata.FullTranscriptLines = countTranscriptItems(state.AgentType, fullTranscript)\\n   529→\\tdata.Prompts = extractUserPrompts(state.AgentType, fullTranscript)\\n   530→\\tdata.Context = generateContextFromPrompts(data.Prompts)\\n   531→\\n   532→\\t// Extract files from transcript since state.FilesTouched may be empty for mid-session commits\\n   533→\\t// (no SaveStep/Stop has been called yet to populate it)\\n   534→\\tif len(state.FilesTouched) > 0 {\\n   535→\\t\\tdata.FilesTouched = state.FilesTouched\\n   536→\\t} else {\\n   537→\\t\\t// Use the shared helper which includes subagent transcripts\\n   538→\\t\\tdata.FilesTouched = s.extractModifiedFilesFromLiveTranscript(ctx, state, state.CheckpointTranscriptStart)\\n   539→\\t}\\n   540→\\n   541→\\t// Calculate token usage from the extracted transcript portion\\n   542→\\tif len(data.Transcript) > 