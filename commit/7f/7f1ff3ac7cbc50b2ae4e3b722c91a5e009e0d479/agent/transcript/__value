\n    71→\\tb.Helper()\\n    72→\\n    73→\\tdir := b.TempDir()\\n    74→\\t// Resolve symlinks (macOS /var -> /private/var)\\n    75→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    76→\\t\\tdir = resolved\\n    77→\\t}\\n    78→\\n    79→\\trepo, err := git.PlainInit(dir, false)\\n    80→\\tif err != nil {\\n    81→\\t\\tb.Fatalf(\\\"git init: %v\\\", err)\\n    82→\\t}\\n    83→\\n    84→\\t// Configure git user\\n    85→\\tcfg, err := repo.Config()\\n    86→\\tif err != nil {\\n    87→\\t\\tb.Fatalf(\\\"config: %v\\\", err)\\n    88→\\t}\\n    89→\\tcfg.User.Name = \\\"Bench User\\\"\\n    90→\\tcfg.User.Email = \\\"bench@example.com\\\"\\n    91→\\tif err := repo.SetConfig(cfg); err != nil {\\n    92→\\t\\tb.Fatalf(\\\"set config: %v\\\", err)\\n    93→\\t}\\n    94→\\n    95→\\t// Create initial files and commit\\n    96→\\twt, err := repo.Worktree()\\n    97→\\tif err != nil {\\n    98→\\t\\tb.Fatalf(\\\"worktree: %v\\\", err)\\n    99→\\t}\\n   100→\\n   101→\\t// Create multiple files to make file overlap checks realistic\\n   102→\\tfor i := range 5 {\\n   103→\\t\\tname := fmt.Sprintf(\\\"src/file_%d.go\\\", i)\\n   104→\\t\\tabs := filepath.Join(dir, name)\\n   105→\\t\\tif err := os.MkdirAll(filepath.Dir(abs), 0o755); err != nil {\\n   106→\\t\\t\\tb.Fatalf(\\\"mkdir: %v\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tcontent := fmt.Sprintf(\\\"package main\\\\nfunc f%d() {}\\\\n\\\", i)\\n   109→\\t\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   110→\\t\\t\\tb.Fatalf(\\\"write: %v\\\", err)\\n   111→\\t\\t}\\n   112→\\t\\tif _, err := wt.Add(name); err != nil {\\n   113→\\t\\t\\tb.Fatalf(\\\"add: %v\\\", err)\\n   114→\\t\\t}\\n   115→\\t}\\n   116→\\n   117→\\tif _, err := wt.Commit(\\\"initial commit\\\", &git.CommitOptions{\\n   118→\\t\\tAuthor: &object.Signature{Name: \\\"Bench\\\", Email: \\\"bench@test.com\\\", When: time.Now()},\\n   119→\\t}); err != nil {\\n   120→\\t\\tb.Fatalf(\\\"commit: %v\\\", err