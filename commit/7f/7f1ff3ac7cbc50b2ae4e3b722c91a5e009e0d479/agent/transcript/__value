le from a task metadata directory.\\n   267→// This is used during rewind to get the checkpoint UUID for transcript truncation.\\n   268→func ReadTaskCheckpoint(taskMetadataDir string) (*TaskCheckpoint, error) {\\n   269→\\tcheckpointFile := taskMetadataDir + \\\"/checkpoint.json\\\"\\n   270→\\n   271→\\tdata, err := os.ReadFile(checkpointFile) //nolint:gosec // Reading from controlled git metadata path\\n   272→\\tif err != nil {\\n   273→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   274→\\t}\\n   275→\\n   276→\\tvar checkpoint TaskCheckpoint\\n   277→\\tif err := json.Unmarshal(data, &checkpoint); err != nil {\\n   278→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   279→\\t}\\n   280→\\n   281→\\treturn &checkpoint, nil\\n   282→}\\n   283→\\n   284→// RestoredSession describes a single session that was restored by RestoreLogsOnly.\\n   285→// Each session may come from a different agent, so callers use this to print\\n   286→// per-session resume commands without re-reading the metadata tree.\\n   287→type RestoredSession struct {\\n   288→\\tSessionID string\\n   289→\\tAgent     types.AgentType\\n   290→\\tPrompt    string\\n   291→\\tCreatedAt time.Time // From session metadata; used by resume to determine most recent\\n   292→}\\n   293→\"}]},\"uuid\":\"3e37e58d-7dcc-47e5-94bf-da24fd98dec8\",\"timestamp\":\"2026-03-03T23:30:17.047Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"ab0f22a9ee552dfa8\"},\"toolUseID\":\"agent_msg_01WTiWCvbvCfFrf6K5Npv1AE\",\"parentToolUseID\":\"toolu_01Rwvjn6dcXa8DL75SWQh7Ti\",\"uuid\":\"8edf3249-2bd2-4b30-b6cb-ca8a77ea4d01\",\"timestamp\":\"2026-03-03T23:30:17.047Z\"}\n{\"parentUuid\":\"8edf3249-2bd2-4b30-b6cb-ca8a77ea4d01\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation\",\"sessionId\":\"2d62938d-a5d3-4bac-9d0f-bf8056720e6d\",\"version\":\"2.1.63\",