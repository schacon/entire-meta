or Claude:** REQUIRED SUB-SKILL: Use superpowers:executing-plans to implement this plan task-by-task.\\n     4→\\n     5→**Goal:** Add a reusable `perf` package with span-based timing that instruments all hooks impacting git workflow and agent lifecycle.\\n     6→\\n     7→**Architecture:** Context-propagated spans that nest automatically. Root spans emit a single DEBUG log line via the existing `logging` package. The `perf` package has no external dependencies — just stdlib + the `logging` package.\\n     8→\\n     9→**Tech Stack:** Go stdlib (`context`, `time`, `log/slog`), existing `cmd/entire/cli/logging` package.\\n    10→\\n    11→**Design Doc:** `docs/plans/2026-03-03-perf-framework-design.md`\\n    12→\\n    13→---\\n    14→\\n    15→### Task 1: Create `perf` package — context.go\\n    16→\\n    17→**Files:**\\n    18→- Create: `cmd/entire/cli/perf/context.go`\\n    19→\\n    20→**Step 1: Write context.go**\\n    21→\\n    22→This file stores/retrieves spans from context. Follow the same pattern as `cmd/entire/cli/logging/context.go`.\\n    23→\\n    24→```go\\n    25→package perf\\n    26→\\n    27→import \\\"context\\\"\\n    28→\\n    29→type contextKey struct{}\\n    30→\\n    31→// spanFromContext retrieves the current span from context, or nil if none.\\n    32→func spanFromContext(ctx context.Context) *Span {\\n    33→\\tif v := ctx.Value(contextKey{}); v != nil {\\n    34→\\t\\tif s, ok := v.(*Span); ok {\\n    35→\\t\\t\\treturn s\\n    36→\\t\\t}\\n    37→\\t}\\n    38→\\treturn nil\\n    39→}\\n    40→\\n    41→// contextWithSpan returns a new context with the span stored.\\n    42→func contextWithSpan(ctx context.Context, s *Span) context.Context {\\n    43→\\treturn context.WithValue(ctx, contextKey{}, s)\\n    44→}\\n    45→```\\n    46→\\n    47→**Step 2: Commit**\\n    48→\\n    49→```bash\\n    50→git add cmd/entire/cli/perf/context.go\\n    51→git commit -m \\\"perf: add context propagation for spans\\\"\\n    52→```\\n    53→\\n    54→---\\n    55→\\n    56→### Task 2: Create `perf` package — span.go\\n    57→\\n    58→**Files:**\\n    59→- Create: `cmd/entire/cli/perf/span.go`\\n    60→\\n    61→**Step 1: Write span.go**\\n    62→\\n    63→The core Span type with Start(), End(), and Measure(). Root spans log via `logging.Debug()` on End(). Child spans record duration only.\\n    64→\\n    65→```go\\n    66→package perf\\n    67→\\n    68→import (\\n    69→\\t\\\"context\\\"\\n    70→\\t\\\"fmt\\\"\\n    71→\\t\\\"log/slog\\\"\\n    72→\\t\\\"time\\\"\\n    73→\\n    74→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    75→)\\n    76→\\n    77→// Span tracks timing for an operation and its substeps.\\n    78→type Span struct {\\n    79→\\tname     string\\n    80→\\tstart    time.Time\\n    81→\\tparent   *Span\\n    82→\\tchildren []*Span\\n    83→\\tduration time.Duration\\n    84→\\tattrs    []slog.Attr\\n    85→\\tctx      context.Context\\n    86→\\tended    bool\\n    87→}\\n    88→\\n    89→// Start begins a new span. If ctx already has a span, the new one becomes a child.\\n    90→// Returns the updated context and the span. Call span.End() when the operation completes.\\n    91→func Start(ctx context.Context, name string, attrs ...slog.Attr) (context.Context, *Span) {\\n    92→\\tparent := spanFromContext(ctx)\\n    93→\\ts := &Span{\\n    94→\\t\\tname:   name,\\n    95→\\t\\tstart:  time.Now(),\\n    96→\\t\\tparent: parent,\\n    97→\\t\\tattrs:  attrs,\\n    98→\\t\\tctx:    ctx,\\n    99→\\t}\\n   100→\\tif parent != nil {\\n   101→\\t\\tparent.children = append(parent.children, s)\\n   102→\\t}\\n   103→\\treturn contextWithSpan(ctx, s), s\\n   104→}\\n   105→\\n   106→// End completes the span. For root spans, emits a single DEBUG log line\\n   107→// with the full timing tree. For child spans, records the duration only.\\n   108→// Safe to call multiple times — subsequent calls are no-ops.\\n   109→func (s *Span) End() {\\n   110→\\tif s.ended {\\n   111→\\t\\treturn\\n   112→\\t}\\n   113→\\ts.ended = true\\n   114→\\ts.duration = time.Since(s.start)\\n   115→\\n   116→\\t// Only root spans emit log output\\n   117→\\tif s.parent != nil {\\n   118→\\t\\treturn\\n   119→\\t}\\n   120→\\n   121→\\t// Build log attributes: op, duration_ms, then child step durations\\n   122→\\tattrs := make([]any, 0, 3+len(s.children)+len(s.attrs))\\n   123→\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n   124→\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n   125→\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n   126→\\n   127→\\t// Add child step durations as flat keys\\n   128→\\tfor _, child := range s.children {\\n   129→\\t\\t// Auto-end children that weren't explicitly ended\\n   130→\\t\\tif !child.ended {\\n   131→\\t\\t\\tchild.ended = true\\n   132→\\t\\t\\tchild.duration = time.Since(child.start)\\n   133→\\t\\t}\\n   134→\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n   135→\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n   136→\\t}\\n   137→\\n   138→\\t// Add any extra attributes from Start()\\n   139→\\tfor _, a := range s.attrs {\\n   140→\\t\\tattrs = append(attrs, a)\\n   141→\\t}\\n   142→\\n   143→\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n   144→}\\n   145→\\n   146→// Measure times a function as a child substep of this span.\\n   147→func (s *Span) Measure(name string, fn func()) {\\n   148→\\t_, child := Start(s.ctx, name)\\n   149→\\tfn()\\n   150→\\tchild.End()\\n   151→}\\n   152→```\\n   153→\\n   154→**Step 2: Run fmt and lint**\\n   155→\\n   156→Run: `mise run fmt && mise run lint`\\n   157→\\n   158→**Step 3: Commit**\\n   159→\\n   160→```bash\\n   161→git add cmd/entire/cli/perf/span.go\\n   162→git commit -m \\\"perf: add Span type with Start/End/Measure API\\\"\\n   163→```\\n   164→\\n   165→---\\n   166→\\n   167→### Task 3: Write unit tests for `perf` package\\n   168→\\n   169→**Files:**\\n   170→- Create: `cmd/entire/cli/perf/span_test.go`\\n   171→\\n   172→**Step 1: Write span_test.go**\\n   173→\\n   174→Tests verify: basic span timing, child nesting, Measure helper, double-End safety, auto-end of children, and log output format. The tests use a similar pattern to `cmd/entire/cli/logging/logger_test.go` — writing to a buffer via the logging package then parsing JSON.\\n   175→\\n   176→```go\\n   177→package perf\\n   178→\\n   179→import (\\n   180→\\t\\\"context\\\"\\n   181→\\t\\\"testing\\\"\\n   182→\\t\\\"time\\\"\\n   183→)\\n   184→\\n   185→func TestStart_CreatesRootSpan(t *testing.T) {\\n   186→\\tt.Parallel()\\n   187→\\tctx := context.Background()\\n   188→\\n   189→\\tctx, span := Start(ctx, \\\"test_op\\\")\\n   190→\\tif span == nil {\\n   191→\\t\\tt.Fatal(\\\"Start() returned nil span\\\")\\n   192→\\t}\\n   193→\\tif span.name != \\\"test_op\\\" {\\n   194→\\t\\tt.Errorf(\\\"span.name = %q, want %q\\\", span.name, \\\"test_op\\\")\\n   195→\\t}\\n   196→\\tif span.parent != nil {\\n   197→\\t\\tt.Error(\\\"root span should have nil parent\\\")\\n   198→\\t}\\n   199→\\n   200→\\t// Verify span is in context\\n   201→\\tgot := spanFromContext(ctx)\\n   202→\\tif got != span {\\n   203→\\t\\tt.Error(\\\"spanFromContext should return the span set by Start\\\")\\n   204→\\t}\\n   205→\\n   206→\\tspan.End()\\n   207→}\\n   208→\\n   209→func TestStart_NestsChildSpan(t *testing.T) {\\n   210→\\tt.Parallel()\\n   211→\\tctx := context.Background()\\n   212→\\n   213→\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   214→\\t_, child := Start(ctx, \\\"child\\\")\\n   215→\\n   216→\\tif child.parent != parent {\\n   217→\\t\\tt.Error(\\\"child span should reference parent\\\")\\n   218→\\t}\\n   219→\\tif len(parent.children) != 1 {\\n   220→\\t\\tt.Fatalf(\\\"parent should have 1 child, got %d\\\", len(parent.children))\\n   221→\\t}\\n   222→\\tif parent.children[0] != child {\\n   223→\\t\\tt.Error(\\\"parent.children[0] should be the child span\\\")\\n   224→\\t}\\n   225→\\n   226→\\tchild.End()\\n   227→\\tparent.End()\\n   228→}\\n   229→\\n   230→func TestEnd_RecordsDuration(t *testing.T) {\\n   231→\\tt.Parallel()\\n   232→\\tctx := context.Background()\\n   233→\\n   234→\\t_, span := Start(ctx, \\\"timed_op\\\")\\n   235→\\ttime.Sleep(10 * time.Millisecond)\\n   236→\\tspan.End()\\n   237→\\n   238→\\tif span.duration < 10*time.Millisecond {\\n   239→\\t\\tt.Errorf(\\\"span.duration = %v, want >= 10ms\\\", span.duration)\\n   240→\\t}\\n   241→}\\n   242→\\n   243→func TestEnd_Idempotent(t *testing.T) {\\n   244→\\tt.Parallel()\\n   245→\\tctx := context.Background()\\n   246→\\n   247→\\t_, span := Start(ctx, \\\"double_end\\\")\\n   248→\\ttime.Sleep(10 * time.Millisecond)\\n   249→\\tspan.End()\\n   250→\\n   251→\\tfirstDuration := span.duration\\n   252→\\n   253→\\t// Second End should be a no-op\\n   254→\\ttime.Sleep(10 * time.Millisecond)\\n   255→\\tspan.End()\\n   256→\\n   257→\\tif span.duration != firstDuration {\\n   258→\\t\\tt.Errorf(\\\"second End() changed duration from %v to %v\\\", firstDuration, span.duration)\\n   259→\\t}\\n   260→}\\n   261→\\n   262→func TestEnd_AutoEndsChildren(t *testing.T) {\\n   263→\\tt.Parallel()\\n   264→\\tctx := context.Background()\\n   265→\\n   266→\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   267→\\t_, child := Start(ctx, \\\"child\\\")\\n   268→\\n   269→\\t// Don't explicitly end child\\n   270→\\ttime.Sleep(10 * time.Millisecond)\\n   271→\\tparent.End()\\n   272→\\n   273→\\tif !child.ended {\\n   274→\\t\\tt.Error(\\\"child should be auto-ended when parent ends\\\")\\n   275→\\t}\\n   276→\\tif child.duration == 0 {\\n   277→\\t\\tt.Error(\\\"child should have non-zero duration after auto-end\\\")\\n   278→\\t}\\n   279→}\\n   280→\\n   281→func TestMeasure_TimesFunction(t *testing.T) {\\n   282→\\tt.Parallel()\\n   283→\\tctx := context.Background()\\n   284→\\n   285→\\t_, span := Start(ctx, \\\"parent\\\")\\n   286→\\n   287→\\tspan.Measure(\\\"substep\\\", func() {\\n   288→\\t\\ttime.Sleep(10 * time.Millisecond)\\n   289→\\t})\\n   290→\\n   291→\\tspan.End()\\n   292→\\n   293→\\tif len(span.children) != 1 {\\n   294→\\t\\tt.Fatalf(\\\"expected 1 child from Measure, got %d\\\", len(span.children))\\n   295→\\t}\\n   296→\\tchild := span.children[0]\\n   297→\\tif child.name != \\\"substep\\\" {\\n   298→\\t\\tt.Errorf(\\\"child.name = %q, want %q\\\", child.name, \\\"substep\\\")\\n   299→\\t}\\n   300→\\tif child.duration < 10*time.Millisecond {\\n   301→\\t\\tt.Errorf(\\\"child.duration = %v, want >= 10ms\\\", child.duration)\\n   302→\\t}\\n   303→}\\n   304→\\n   305→func TestSpanFromContext_ReturnsNilWhenEmpty(t *testing.T) {\\n   306→\\tt.Parallel()\\n   307→\\tctx := context.Background()\\n   308→\\n   309→\\tif got := spanFromContext(ctx); got != nil {\\n   310→\\t\\tt.Errorf(\\\"spanFromContext on empty context = %v, want nil\\\", got)\\n   311→\\t}\\n   312→}\\n   313→\\n   314→func TestStart_MultipleChildren(t *testing.T) {\\n   315→\\tt.Parallel()\\n   316→\\tctx := context.Background()\\n   317→\\n   318→\\tctx, parent := Start(ctx, \\\"parent\\\")\\n   319→\\n   320→\\tctx2, child1 := Start(ctx, \\\"child1\\\")\\n   321→\\t_ = ctx2\\n   322→\\tchild1.End()\\n   323→\\n   324→\\tctx3, child2 := Start(ctx, \\\"child2\\\")\\n   325→\\t_ = ctx3\\n   326→\\tchild2.End()\\n   327→\\n   328→\\tparent.End()\\n   329→\\n   330→\\tif len(parent.children) != 2 {\\n   331→\\t\\tt.Fatalf(\\\"expected 2 children, got %d\\\", len(parent.children))\\n   332→\\t}\\n   333→\\tif parent.children[0].name != \\\"child1\\\" {\\n   334→\\t\\tt.Errorf(\\\"first child name = %q, want %q\\\", parent.children[0].name, \\\"child1\\\")\\n   335→\\t}\\n   336→\\tif parent.children[1].name != \\\"child2\\\" {\\n   337→\\t\\tt.Errorf(\\\"second child name = %q, want %q\\\", parent.children[1].name, \\\"child2\\\")\\n   338→\\t}\\n   339→}\\n   340→```\\n   341→\\n   342→**Step 2: Run the tests