767→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   768→\\t\\treturn nil\\n   769→\\t}\\n   770→\\n   771→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   772→\\tif err != nil {\\n   773→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   774→\\t}\\n   775→\\n   776→\\t// Find all active sessions for this worktree\\n   777→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   778→\\tif err != nil || len(sessions) == 0 {\\n   779→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   780→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   781→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   782→\\t\\t)\\n   783→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   784→\\t}\\n   785→\\n   786→\\t// Build transition context\\n   787→\\tisRebase := isGitSequenceOperation(ctx)\\n   788→\\ttransitionCtx := session.TransitionContext{\\n   789→\\t\\tIsRebaseInProgress: isRebase,\\n   790→\\t}\\n   791→\\n   792→\\tif isRebase {\\n   793→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   794→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   795→\\t\\t)\\n   796→\\t}\\n   797→\\n   798→\\t// Track shadow branch names and whether they can be deleted\\n   799→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   800→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   801→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   802→\\n   803→\\tnewHead := head.Hash().String()\\n   804→\\n   805→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   806→\\t// These are immutable within this hook invocation and used by multiple\\n   807→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   808→\\t// filesWithRemainingAgentChanges, calculateSessionA