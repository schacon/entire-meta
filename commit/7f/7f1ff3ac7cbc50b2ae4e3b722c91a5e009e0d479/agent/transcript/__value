message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01FmzffDqj1DSXLfLLrkynHe\",\"type\":\"tool_result\",\"content\":\"     1→// Package benchutil provides test fixture helpers for CLI benchmarks.\\n     2→//\\n     3→// It creates realistic git repositories, transcripts, session states,\\n     4→// and checkpoint data for benchmarking the hot paths (SaveStep, PostCommit/Condense).\\n     5→package benchutil\\n     6→\\n     7→import (\\n     8→\\t\\\"context\\\"\\n     9→\\t\\\"encoding/json\\\"\\n    10→\\t\\\"fmt\\\"\\n    11→\\t\\\"os\\\"\\n    12→\\t\\\"os/exec\\\"\\n    13→\\t\\\"path/filepath\\\"\\n    14→\\t\\\"strings\\\"\\n    15→\\t\\\"testing\\\"\\n    16→\\t\\\"time\\\"\\n    17→\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    19→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    25→\\n    26→\\t\\\"github.com/go-git/go-git/v5\\\"\\n    27→\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    28→\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    29→)\\n    30→\\n    31→// BenchRepo is a fully initialized git repository with Entire configured,\\n    32→// ready for checkpoint benchmarks.\\n    33→type BenchRepo struct {\\n    34→\\t// Dir is the absolute path to the repository root.\\n    35→\\tDir string\\n    36→\\n    37→\\t// Repo is the go-git repository handle.\\n    38→\\tRepo *git.Repository\\n    39→\\n    40→\\t// Store is the checkpoint GitStore for this repo.\\n    41→\\tStore *checkpoint.GitStore\\n    42→\\n    43→\\t// HeadHash is the current HEAD commit hash string.\\n    44→\\tHeadHash string\\n    45→\\n    46→\\t// WorktreeID is the worktree identifier (empty for main worktree).\\n    47→\\tWorktreeID string\\n    48→\\n    49→\\t// Strategy is the strategy name used in .entire/settings.json.\\n    50→\\tStrategy string\\n    51→}\\n    52→\\n    53→// RepoOpts configures how NewBenchRepo creates the test repository.\\n    54→type RepoOpts struct {\\n    55→\\t// FileCount is the number of tracked files to create in the initial commit.\\n    56→\\t// Each file is ~100 lines of Go code. Defaults to 10.\\n    57→\\tFileCount int\\n    58→\\n    59→\\t// FileSizeLines is the number of lines per file. Defaults to 100.\\n    60→\\tFileSizeLines int\\n    61→\\n    62→\\t// CommitCount is the number of commits to create. Defaults to 1.\\n    63→\\tCommitCount int\\n    64→\\n    65→\\t// Strategy is the strategy name for .entire/settings.json.\\n    66→\\t// Defaults to \\\"manual-commit\\\".\\n    67→\\tStrategy string\\n    68→\\n    69→\\t// FeatureBranch, if non-empty, creates and checks out this branch\\n    70→\\t// after the initial commits.\\n    71→\\tFeatureBranch string\\n    72→}\\n    73→\\n    74→func (o *RepoOpts) withDefaults() RepoOpts {\\n    75→\\tout := *o\\n    76→\\tif out.FileCount == 0 {\\n    77→\\t\\tout.FileCount = 10\\n    78→\\t}\\n    79→\\tif out.FileSizeLines == 0 {\\n    80→\\t\\tout.FileSizeLines = 100\\n    81→\\t}\\n    82→\\tif out.CommitCount == 0 {\\n    83→\\t\\tout.CommitCount = 1\\n    84→\\t}\\n    85→\\tif out.Strategy == \\\"\\\" {\\n    86→\\t\\tout.Strategy = \\\"manual-commit\\\"\\n    87→\\t}\\n    88→\\treturn out\\n    89→}\\n    90→\\n    91→// NewBenchRepo creates an isolated git repository for benchmarks.\\n    92→// The repo has an initial commit with the configured number of files,\\n    93→// a .gitignore excluding .entire/, and Entire settings initialized.\\n    94→//\\n    95→// Uses b.TempDir() so cleanup is automatic.\\n    96→func NewBenchRepo(b *testing.B, opts RepoOpts) *BenchRepo {\\n    97→\\tb.Helper()\\n    98→\\topts = opts.withDefaults()\\n    99→\\n   100→\\tdir := b.TempDir()\\n   101→\\t// Resolve symlinks (macOS /var -> /private/var)\\n   102→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n   103→\\t\\tdir = resolved\\n   104→\\t}\\n   105→\\n   106→\\t// Init repo\\n   107→\\trepo, err := git.PlainInit(dir, false)\\n   108→\\tif err != nil {\\n   109→\\t\\tb.Fatalf(\\\"git init: %v\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\t// Create .gitignore and .entire settings\\n   113→\\twriteFile(b, dir, \\\".gitignore\\\", \\\".entire/\\\\n\\\")\\n   114→\\tinitEntireSettings(b, dir, opts.Strategy)\\n   115→\\n   116→\\t// Generate initial files\\n   117→\\twt, err := repo.Worktree()\\n   118→\\tif err != nil {\\n   119→\\t\\tb.Fatalf(\\\"worktree: %v\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\tfor i := range opts.FileCount {\\n   123→\\t\\tname := fmt.Sprintf(\\\"src/file_%03d.go\\\", i)\\n   124→\\t\\tcontent := GenerateGoFile(i, opts.FileSizeLines)\\n   125→\\t\\twriteFile(b, dir, name, content)\\n   126→\\t\\tif _, err := wt.Add(name); err != nil {\\n   127→\\t\\t\\tb.Fatalf(\\\"add %s: %v\\\", name, err)\\n   128→\\t\\t}\\n   129→\\t}\\n   130→\\tif _, err := wt.Add(\\\".gitignore\\\"); err != nil {\\n   131→\\t\\tb.Fatalf(\\\"add .gitignore: %v\\\", err)\\n   132→\\t}\\n   133→\\n   134→\\t// Create commits\\n   135→\\tvar headHash plumbing.Hash\\n   136→\\tfor c := range opts.CommitCount {\\n   137→\\t\\tif c > 0 {\\n   138→\\t\\t\\t// Modify a file for subsequent commits\\n   139→\\t\\t\\tname := fmt.Sprintf(\\\"src/file_%03d.go\\\", c%opts.FileCount)\\n   140→\\t\\t\\tcontent := GenerateGoFile(c*1000, opts.FileSizeLines)\\n   141→\\t\\t\\twriteFile(b, dir, name, content)\\n   142→\\t\\t\\tif _, err := wt.Add(name); err != nil {\\n   143→\\t\\t\\t\\tb.Fatalf(\\\"add %s: %v\\\", name, err)\\n   144→\\t\\t\\t}\\n   145→\\t\\t}\\n   146→\\t\\theadHash, err = wt.Commit(fmt.Sprintf(\\\"Commit %d\\\", c+1), &git.CommitOptions{\\n   147→\\t\\t\\tAuthor: &object.Signature{\\n   148→\\t\\t\\t\\tName:  \\\"Bench User\\\",\\n   149→\\t\\t\\t\\tEmail: \\\"bench@example.com\\\",\\n   150→\\t\\t\\t\\tWhen:  time.Now(),\\n   151→\\t\\t\\t},\\n   152→\\t\\t})\\n   153→\\t\\tif err != nil {\\n   154→\\t\\t\\tb.Fatalf(\\\"commit %d: %v\\\", c+1, err)\\n   155→\\t\\t}\\n   156→\\t}\\n   157→\\n   158→\\t// Optionally create feature branch\\n   159→\\tif opts.FeatureBranch != \\\"\\\" {\\n   160→\\t\\tref := plumbing.NewHashReference(\\n   161→\\t\\t\\tplumbing.NewBranchReferenceName(opts.FeatureBranch), headHash)\\n   162→\\t\\tif err := repo.Storer.SetReference(ref); err != nil {\\n   163→\\t\\t\\tb.Fatalf(\\\"create branch: %v\\\", err)\\n   164→\\t\\t}\\n   165→\\t\\t// Checkout via git CLI (go-git v5 checkout bug)\\n   166→\\t\\tcheckoutBranch(b, dir, opts.FeatureBranch)\\n   167→\\t}\\n   168→\\n   169→\\tbr := &BenchRepo{\\n   170→\\t\\tDir:      dir,\\n   171→\\t\\tRepo:     repo,\\n   172→\\t\\tStore:    checkpoint.NewGitStore(repo),\\n   173→\\t\\tHeadHash: headHash.String(),\\n   174→\\t\\tStrategy: opts.Strategy,\\n   175→\\t}\\n   176→\\n   177→\\t// Determine worktree ID\\n   178→\\twtID, err := paths.GetWorktreeID(dir)\\n   179→\\tif err == nil {\\n   180→\\t\\tbr.WorktreeID = wtID\\n   181→\\t}\\n   182→\\n   183→\\treturn br\\n   184→}\\n   185→\\n   186→// WriteFile creates or overwrites a file relative to the repo root.\\n   187→func (br *BenchRepo) WriteFile(b *testing.B, relPath, content string) {\\n   188→\\tb.Helper()\\n   189→\\twriteFile(b, br.Dir, relPath, content)\\n   190→}\\n   191→\\n   192→// AddAndCommit stages the given files and creates a commit.\\n   193→// Returns the new HEAD hash.\\n   194→func (br *BenchRepo) AddAndCommit(b *testing.B, message string, files ...string) string {\\n   195→\\tb.Helper()\\n   196→\\twt, err := br.Repo.Worktree()\\n   197→\\tif err != nil {\\n   198→\\t\\tb.Fatalf(\\\"worktree: %v\\\", err)\\n   199→\\t}\\n   200→\\tfor _, f := range files {\\n   201→\\t\\tif _, err := wt.Add(f); err != nil {\\n   202→\\t\\t\\tb.Fatalf(\\\"add %s: %v\\\", f, err)\\n   203→\\t\\t}\\n   204→\\t}\\n   205→\\thash, err := wt.Commit(message, &git.CommitOptions{\\n   206→\\t\\tAuthor: &object.Signature{\\n   207→\\t\\t\\tName:  \\\"Bench User\\\",\\n   208→\\t\\t\\tEmail: \\\"bench@example.com\\\",\\n   209→\\t\\t\\tWhen:  time.Now(),\\n   210→\\t\\t},\\n   211→\\t})\\n   212→\\tif err != nil {\\n   213→\\t\\tb.Fatalf(\\\"commit: %v\\\", err)\\n   214→\\t}\\n   215→\\tbr.HeadHash = hash.String()\\n   216→\\treturn hash.String()\\n   217→}\\n   218→\\n   219→// SessionOpts configures how CreateSessionState creates a session state file.\\n   220→type SessionOpts struct {\\n   221→\\t// SessionID is the session identifier. Auto-generated if empty.\\n   222→\\tSessionID string\\n   223→\\n   224→\\t// Phase is the session phase. Defaults to session.PhaseActive.\\n   225→\\tPhase session.Phase\\n   226→\\n   227→\\t// StepCount is the number of prior checkpoints. Defaults to 0.\\n   228→\\tStepCount int\\n   229→\\n   230→\\t// FilesTouched is the list of files tracked by this session.\\n   231→\\tFilesTouched []string\\n   232→\\n   233→\\t// TranscriptPath is the path to the live transcript file.\\n   234→\\tTranscriptPath string\\n   235→\\n   236→\\t// AgentType is the agent type. Defaults to agent.AgentTypeClaudeCode.\\n   237→\\tAgentType types.AgentType\\n   238→}\\n   239→\\n   240→// CreateSessionState writes a session state file to .git/entire-sessions/.\\n   241→// Returns the session ID used.\\n   242→func (br *BenchRepo) CreateSessionState(b *testing.B, opts SessionOpts) string {\\n   243→\\tb.Helper()\\n   244→\\n   245→\\tif opts.SessionID == \\\"\\\" {\\n   246→\\t\\tcpID, err := id.Generate()\\n   247→\\t\\tif err != nil {\\n   248→\\t\\t\\tb.Fatalf(\\\"generate session ID: %v\\\", err)\\n   249→\\t\\t}\\n   250→\\t\\topts.SessionID = fmt.Sprintf(\\\"bench-%s\\\", cpID)\\n   251→\\t}\\n   252→\\tif opts.Phase == \\\"\\\" {\\n   253→\\t\\topts.Phase = session.PhaseActive\\n   254→\\t}\\n   255→\\n   256→\\tif opts.AgentType == \\\"\\\" {\\n   257→\\t\\topts.AgentType = agent.AgentTypeClaudeCode\\n   258→\\t}\\n   259→\\n   260→\\tnow := time.Now()\\n   261→\\tstate := &session.State{\\n   262→\\t\\tSessionID:      opts.SessionID,\\n   263→\\t\\tBaseCommit:     br.HeadHash,\\n   264→\\t\\tWorktreePath:   br.Dir,\\n   265→\\t\\tWorktreeID:     br.WorktreeID,\\n   266→\\t\\tStartedAt:      now,\\n   267→\\t\\tPhase:          opts.Phase,\\n   268→\\t\\tStepCount:      opts.StepCount,\\n   269→\\t\\tFilesTouched:   opts.FilesTouched,\\n   270→\\t\\tTranscriptPath: opts.TranscriptPath,\\n   271→\\t\\tAgentType:      opts.AgentType,\\n   272→\\t}\\n   273→\\n   274→\\t// Write to .git/entire-sessions/<session-id>.json\\n   275→\\tgitDir := filepath.Join(br.Dir, \\\".git\\\")\\n   276→\\tsessDir := filepath.Join(gitDir, session.SessionStateDirName)\\n   277→\\tif err := os.MkdirAll(sessDir, 0o750); err != nil {\\n   278→\\t\\tb.Fatalf(\\\"mkdir sessions: %v\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   282→\\tif err != nil {\\n   283→\\t\\tb.Fatalf(\\\"marshal state: %v\\\", err)\\n   284→\\t}\\n   285→\\n   286→\\tstatePath := filepath.Join(sessDir, opts.SessionID+\\\".json\\\")\\n   287→\\tif err := os.WriteFile(statePath, data, 0o600); err != nil {\\n   288→\\t\\tb.Fatalf(\\\"write state: %v\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\treturn opts.SessionID\\n   292→}\\n   293→\\n   294→// TranscriptOpts configures how GenerateTranscript creates JSONL data.\\n   295→type TranscriptOpts struct {\\n   296→\\t// MessageCount is the number of JSONL messages to generate.\\n   297→\\tMessageCount int\\n   298→\\n   299→\\t// AvgMessageBytes is the approximate size of each message's content field.\\n   300→\\t// Defaults to 500.\\n   301→\\tAvgMessageBytes int\\n   302→\\n   303→\\t// IncludeToolUse adds realistic tool_use messages (file edits, bash commands).\\n   304→\\tIncludeToolUse bool\\n   305→\\n   306→\\t// FilesTouched is the list of files to reference in tool_use messages.\\n   307→\\t// Only used when IncludeToolUse is true.\\n   308→\\tFilesTouched []string\\n   309→}\\n   310→\\n   311→// GenerateTranscript creates realistic Claude Code JSONL transcript data.\\n   312→// Returns the raw bytes suitable for writing to full.jsonl.\\n   313→func GenerateTranscript(opts TranscriptOpts) []byte {\\n   314→\\tif opts.AvgMessageBytes == 0 {\\n   315→\\t\\topts.AvgMessageBytes = 500\\n   316→\\t}\\n   317→\\n   318→\\tvar buf strings.Builder\\n   319→\\tfor i := range opts.MessageCount {\\n   320→\\t\\tmsg := generateTranscriptMessage(i, opts)\\n   321→\\t\\tdata, err := json.Marshal(msg)\\n   322→\\t\\tif err != nil {\\n   323→\\t\\t\\t// Should never happen with map[string]any, but satisfy errcheck\\n   324→\\t\\t\\tcontinue\\n   325→\\t\\t}\\n   326→\\t\\tbuf.Write(data)\\n   327→\\t\\tbuf.WriteByte('\\\\n')\\n   328→\\t}\\n   329→\\treturn []byte(buf.String())\\n   330→}\\n   331→\\n   332→// WriteTranscriptFile writes transcript data to a file and returns the path.\\n   333→func (br *BenchRepo) WriteTranscriptFile(b *testing.B, sessionID string, data []byte) string {\\n   334→\\tb.Helper()\\n   335→\\t// Write to .entire/metadata/<session-id>/full.jsonl (matching real layout)\\n   336→\\trelDir := filepath.Join(\\\".entire\\\", \\\"metadata\\\", sessionID)\\n   337→\\trelPath := filepath.Join(relDir, \\\"full.jsonl\\\")\\n   338→\\tabsDir := filepath.Join(br.Dir, relDir)\\n   339→\\tif err := os.MkdirAll(absDir, 0o750); err != nil {\\n   340→\\t\\tb.Fatalf(\\\"mkdir transcript dir: %v\\\", err)\\n   341→\\t}\\n   342→\\tabsPath := filepath.Join(br.Dir, relPath)\\n   343→\\tif err := os.WriteFile(absPath, data, 0o600); err != nil {\\n   344→\\t\\tb.Fatalf(\\\"write transcript: %v\\\", err)\\n   345→\\t}\\n   346→\\treturn absPath\\n   347→}\\n   348→\\n   349→// SeedShadowBranch creates N checkpoint commits on the shadow branch\\n   350→// for the current HEAD. This simulates a session that already has\\n   351→// prior checkpoints saved.\\n   352→//\\n   353→// Temporarily changes cwd to br.Dir because WriteTemporary uses\\n   354→// paths.WorktreeRoot() which depends on os.Getwd().\\n   355→func (br *BenchRepo) SeedShadowBranch(b *testing.B, sessionID string, checkpointCount int, filesPerCheckpoint int) {\\n   356→\\tb.Helper()\\n   357→\\n   358→\\t// WriteTemporary internally calls paths.WorktreeRoot() which uses os.Getwd().\\n   359→\\t// Switch cwd so it resolves to the bench repo.\\n   360→\\tb.Chdir(br.Dir)\\n   361→\\tpaths.ClearWorktreeRootCache()\\n   362→\\n   363→\\tfor i := range checkpointCount {\\n   364→\\t\\tvar modified []string\\n   365→\\t\\tfor j := range filesPerCheckpoint {\\n   366→\\t\\t\\tname := fmt.Sprintf(\\\"src/file_%03d.go\\\", j)\\n   367→\\t\\t\\tcontent := GenerateGoFile(i*1000+j, 100)\\n   368→\\t\\t\\twriteFile(b, br.Dir, name, content)\\n   369→\\t\\t\\tmodified = append(modified, name)\\n   370→\\t\\t}\\n   371→\\n   372→\\t\\tmetadataDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   373→\\t\\tmetadataDirAbs := filepath.Join(br.Dir, metadataDir)\\n   374→\\t\\tif err := os.MkdirAll(metadataDirAbs, 0o750); err != nil {\\n   375→\\t\\t\\tb.Fatalf(\\\"mkdir metadata: %v\\\", err)\\n   376→\\t\\t}\\n   377→\\n   378→\\t\\t// Write a minimal transcript to the metadata dir\\n   379→\\t\\ttranscriptPath := filepath.Join(metadataDirAbs, \\\"full.jsonl\\\")\\n   380→\\t\\ttranscript := GenerateTranscript(TranscriptOpts{MessageCount: 5, AvgMessageBytes: 200})\\n   381→\\t\\tif err := os.WriteFile(transcriptPath, transcript, 0o600); err != nil {\\n   382→\\t\\t\\tb.Fatalf(\\\"write transcript: %v\\\", err)\\n   383→\\t\\t}\\n   384→\\n   385→\\t\\t_, err := br.Store.WriteTemporary(context.Background(), checkpoint.WriteTemporaryOptions{\\n   386→\\t\\t\\tSessionID:         sessionID,\\n   387→\\t\\t\\tBaseCommit:        br.HeadHash,\\n   388→\\t\\t\\tWorktreeID:        br.WorktreeID,\\n   389→\\t\\t\\tModifiedFiles:     modified,\\n   390→\\t\\t\\tMetadataDir:       metadataDir,\\n   391→\\t\\t\\tMetadataDirAbs:    metadataDirAbs,\\n   392→\\t\\t\\tCommitMessage:     fmt.Sprintf(\\\"Checkpoint %d\\\", i+1),\\n   393→\\t\\t\\tAuthorName:        \\\"Bench User\\\",\\n   394→\\t\\t\\tAuthorEmail:       \\\"bench@example.com\\\",\\n   395→\\t\\t\\tIsFirstCheckpoint: i == 0,\\n   396→\\t\\t})\\n   397→\\t\\tif err != nil {\\n   398→\\t\\t\\tb.Fatalf(\\\"write temporary checkpoint %d: %v\\\", i+1, err)\\n   399→\\t\\t}\\n   400→\\t}\\n   401→}\\n   402→\\n   403→// SeedMetadataBranch creates N committed checkpoints on the entire/checkpoints/v1\\n   404→// branch. This simulates a repository with prior checkpoint history.\\n   405→func (br *BenchRepo) SeedMetadataBranch(b *testing.B, checkpointCount int) {\\n   406→\\tb.Helper()\\n   407→\\n   408→\\tfor i := range checkpointCount {\\n   409→\\t\\tcpID, err := id.Generate()\\n   410→\\t\\tif err != nil {\\n   411→\\t\\t\\tb.Fatalf(\\\"generate checkpoint ID: %v\\\", err)\\n   412→\\t\\t}\\n   413→\\t\\tsessionID := fmt.Sprintf(\\\"seed-session-%04d\\\", i)\\n   414→\\t\\ttranscript := GenerateTranscript(TranscriptOpts{\\n   415→\\t\\t\\tMessageCount:    20,\\n   416→\\t\\t\\tAvgMessageBytes: 300,\\n   417→\\t\\t})\\n   418→\\n   419→\\t\\tfiles := make([]string, 0, 5)\\n   420→\\t\\tfor j := range 5 {\\n   421→\\t\\t\\tfiles = append(files, fmt.Sprintf(\\\"src/file_%03d.go\\\", (i*5+j)%100))\\n   422→\\t\\t}\\n   423→\\n   424→\\t\\terr = br.Store.WriteCommitted(context.Background(), checkpoint.WriteCommittedOptions{\\n   425→\\t\\t\\tCheckpointID:     cpID,\\n   426→\\t\\t\\tSessionID:        sessionID,\\n   427→\\t\\t\\tStrategy:         br.Strategy,\\n   428→\\t\\t\\tTranscript:       transcript,\\n   429→\\t\\t\\tPrompts:          []string{fmt.Sprintf(\\\"Implement feature %d\\\", i)},\\n   430→\\t\\t\\tFilesTouched:     files,\\n   431→\\t\\t\\tCheckpointsCount: 3,\\n   432→\\t\\t\\tAuthorName:       \\\"Bench User\\\",\\n   433→\\t\\t\\tAuthorEmail:      \\\"bench@example.com\\\",\\n   434→\\t\\t\\tAgent:            agent.AgentTypeClaudeCode,\\n   435→\\t\\t})\\n   436→\\t\\tif err != nil {\\n   437→\\t\\t\\tb.Fatalf(\\\"write committed checkpoint %d: %v\\\", i+1, err)\\n   438→\\t\\t}\\n   439→\\t}\\n   440→}\\n   441→\\n   442→// GenerateGoFile creates a synthetic Go source file with the given number of lines.\\n   443→// The seed value ensures unique content for each file.\\n   444→func GenerateGoFile(seed, lines int) string {\\n   445→\\tvar buf strings.Builder\\n   446→\\tfmt.Fprintf(&buf, \\\"package pkg%d\\\\n\\\\n\\\", seed%100)\\n   447→\\n   448→\\tlineNum := 2\\n   449→\\tfuncNum := 0\\n   450→\\tfor lineNum < lines {\\n   451→\\t\\tfuncName := fmt.Sprintf(\\\"func%d_%d\\\", seed, funcNum)\\n   452→\\t\\tfmt.Fprintf(&buf, \\\"func %s(ctx context.Context, input string) (string, error) {\\\\n\\\", funcName)\\n   453→\\t\\tlineNum++\\n   454→\\n   455→\\t\\tbodyLines := min(8, lines-lineNum-1)\\n   456→\\t\\tfor j := range bodyLines {\\n   457→\\t\\t\\tfmt.Fprintf(&buf, \\\"\\\\tv%d := fmt.Sprintf(\\\\\\\"processing %%s step %d seed %d\\\\\\\", input)\\\\n\\\", j, j, seed)\\n   458→\\t\\t\\tlineNum++\\n   459→\\t\\t}\\n   460→\\t\\tbuf.WriteString(\\\"\\\\treturn \\\\\\\"\\\\\\\", nil\\\\n}\\\\n\\\\n\\\")\\n   461→\\t\\tlineNum += 2\\n   462→\\t\\tfuncNum++\\n   463→\\t}\\n   464→\\treturn buf.String()\\n   465→}\\n   466→\\n   467→// GenerateFileContent creates generic file content of approximately the given byte size.\\n   468→func GenerateFileContent(seed, sizeBytes int) string {\\n   469→\\tvar buf strings.Builder\\n   470→\\tline := fmt.Sprintf(\\\"// Line content seed=%d \\\", seed)\\n   471→\\tpadding := strings.Repeat(\\\"x\\\", max(1, 80-len(line)))\\n   472→\\tfullLine := line + padding + \\\"\\\\n\\\"\\n   473→\\n   474→\\tfor buf.Len() < sizeBytes {\\n   475→\\t\\tbuf.WriteString(fullLine)\\n   476→\\t}\\n   477→\\treturn buf.String()\\n   478→}\\n   479→\\n   480→//nolint:gosec // G301/G306: benchmark fixtures use standard permissions in temp dirs\\n   481→func writeFile(b *testing.B, dir, relPath, content string) {\\n   482→\\tb.Helper()\\n   483→\\tabs := filepath.Join(dir, relPath)\\n   484→\\tif err := os.MkdirAll(filepath.Dir(abs), 0o755); err != nil {\\n   485→\\t\\tb.Fatalf(\\\"mkdir %s: %v\\\", filepath.Dir(relPath), err)\\n   486→\\t}\\n   487→\\tif err := os.WriteFile(abs, []byte(content), 0o644); err != nil {\\n   488→\\t\\tb.Fatalf(\\\"write %s: %v\\\", relPath, err)\\n   489→\\t}\\n   490→}\\n   491→\\n   492→//nolint:gosec // G301/G306: benchmark fixtures use standard permissions in temp dirs\\n   493→func initEntireSettings(b *testing.B, dir, strategy string) {\\n   494→\\tb.Helper()\\n   495→\\tentireDir := filepath.Join(dir, \\\".entire\\\")\\n   496→\\tif err := os.MkdirAll(filepath.Join(entireDir, \\\"tmp\\\"), 0o755); err != nil {\\n   497→\\t\\tb.Fatalf(\\\"mkdir .entire: %v\\\", err)\\n   498→\\t}\\n   499→\\n   500→\\tsettings := map[string]any{\\n   501→\\t\\t\\\"strategy\\\":  strategy,\\n   502→\\t\\t\\\"local_dev\\\": true,\\n   503→\\t}\\n   504→\\tdata, err := jsonutil.MarshalIndentWithNewline(settings, \\\"\\\", \\\"  \\\")\\n   505→\\tif err != nil {\\n   506→\\t\\tb.Fatalf(\\\"marshal settings: %v\\\", err)\\n   507→\\t}\\n   508→\\tif err := os.WriteFile(filepath.Join(entireDir, paths.SettingsFileName), data, 0o644); err != nil {\\n   509→\\t\\tb.Fatalf(\\\"write settings: %v\\\", err)\\n   510→\\t}\\n   511→}\\n   512→\\n   513→func checkoutBranch(b *testing.B, dir, branch string) {\\n   514→\\tb.Helper()\\n   515→\\tc := exec.CommandContext(context.Background(), \\\"git\\\", \\\"checkout\\\", branch)\\n   516→\\tc.Dir = dir\\n   517→\\tif output, err := c.CombinedOutput(); err != nil {\\n   518→\\t\\tb.Fatalf(\\\"git checkout %s: %v\\\\n%s\\\", branch, err, output)\\n   519→\\t}\\n   520→}\\n   521→\\n   522→// generateTranscriptMessage creates a single JSONL message for a Claude Code transcript.\\n   523→func generateTranscriptMessage(index int, opts TranscriptOpts) map[string]any {\\n   524→\\tmsg := map[string]any{\\n   525→\\t\\t\\\"uuid\\\":        fmt.Sprintf(\\\"msg_%06d\\\", index),\\n   526→\\t\\t\\\"timestamp\\\":   time.Now().Add(time.Duration(index) * time.Second).Format(time.RFC3339),\\n   527→\\t\\t\\\"parent_uuid\\\": fmt.Sprintf(\\\"msg_%06d\\\", max(0, index-1)),\\n   528→\\t}\\n   529→\\n   530→\\tswitch {\\n   531→\\tcase opts.IncludeToolUse && index%3 == 2 && len(opts.FilesTouched) > 0:\\n   532→\\t\\t// Tool use message (every 3rd message)\\n   533→\\t\\tfile := opts.FilesTouched[index%len(opts.FilesTouched)]\\n   534→\\t\\tmsg[\\\"type\\\"] = \\\"tool_use\\\"\\n   535→\\t\\tmsg[\\\"tool_name\\\"] = \\\"write_to_file\\\"\\n   536→\\t\\tmsg[\\\"tool_input\\\"] = map[string]any{\\n   537→\\t\\t\\t\\\"path\\\":    file,\\n   538→\\t\\t\\t\\\"content\\\": GenerateFileContent(index, opts.AvgMessageBytes/2),\\n   539→\\t\\t}\\n   540→\\tcase index%2 == 0:\\n   541→\\t\\t// Assistant message\\n   542→\\t\\tmsg[\\\"type\\\"] = \\\"assistant\\\"\\n   543→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"I'll help you implement this feature. \\\", opts.AvgMessageBytes)\\n   544→\\tdefault:\\n   545→\\t\\t// Human message\\n   546→\\t\\tmsg[\\\"type\\\"] = \\\"human\\\"\\n   547→\\t\\tmsg[\\\"content\\\"] = generatePadding(\\\"Please update the implementation. \\\", opts.AvgMessageBytes/3)\\n   548→\\t}\\n   549→\\n   550→\\treturn msg\\n   551→}\\n   552→\\n   553→// SeedBranches creates N branches pointing at the current HEAD.\\n   554→// The branches are named with the given prefix (e.g., \\\"feature/bench-\\\" → \\\"feature/bench-000\\\").\\n   555→// This simulates a repo with many refs, which affects go-git ref scanning performance.\\n   556→func (br *BenchRepo) SeedBranches(b *testing.B, prefix string, count int) {\\n   557→\\tb.Helper()\\n   558→\\theadHash := plumbing.NewHash(br.HeadHash)\\n   559→\\tfor i := range count {\\n   560→\\t\\tname := fmt.Sprintf(\\\"%s%03d\\\", prefix, i)\\n   561→\\t\\tref := plumbing.NewHashReference(plumbing.NewBranchReferenceName(name), headHash)\\n   562→\\t\\tif err := br.Repo.Storer.SetReference(ref); err != nil {\\n   563→\\t\\t\\tb.Fatalf(\\\"create branch %s: %v\\\", name, err)\\n   564→\\t\\t}\\n   565→\\t}\\n   566→}\\n   567→\\n   568→// PackRefs runs `git pack-refs --all` to simulate a real repo where most refs\\n   569→// are in the packed-refs file. Large repos almost always have packed refs.\\n   570→func (br *BenchRepo) PackRefs(b *testing.B) {\\n   571→\\tb.Helper()\\n   572→\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"pack-refs\\\", \\\"--all\\\")\\n   573→\\tcmd.Dir = br.Dir\\n   574→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   575→\\t\\tb.Fatalf(\\\"git pack-refs: %v\\\\n%s\\\", err, output)\\n   576→\\t}\\n   577→}\\n   578→\\n   579→// SeedGitObjects creates loose git objects to bloat .git/objects/.\\n   580→// Each call creates N blob objects via `git hash-object -w`.\\n   581→// After seeding, runs `git gc` to pack them into a packfile (realistic).\\n   582→func (br *BenchRepo) SeedGitObjects(b *testing.B, count int) {\\n   583→\\tb.Helper()\\n   584→\\n   585→\\tfor i := range count {\\n   586→\\t\\tcontent := GenerateFileContent(i, 4096)\\n   587→\\t\\tcmd := exec.CommandContext(context.Background(), \\\"git\\\", \\\"hash-object\\\", \\\"-w\\\", \\\"--stdin\\\")\\n   588→\\t\\tcmd.Dir = br.Dir\\n   589→\\t\\tcmd.Stdin = strings.NewReader(content)\\n   590→\\t\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   591→\\t\\t\\tb.Fatalf(\\\"git hash-object %d: %v\\\\n%s\\\", i, err, output)\\n   592→\\t\\t}\\n   593→\\t}\\n   594→\\n   595→\\t// Pack into a packfile like a real repo\\n   596→\\tgc := exec.CommandContext(context.Background(), \\\"git\\\", \\\"gc\\\", \\\"--quiet