\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    17\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    18\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    19\\t\\n    20\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    21\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    22\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    23\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    24\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    25\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    26\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/stringutil\\\"\\n    27\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/trail\\\"\\n    28\\t\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    29\\t\\t\\\"github.com/entireio/cli/redact\\\"\\n    30\\t\\n    31\\t\\t\\\"github.com/go-git/go-git/v5\\\"\\n    32\\t\\t\\\"github.com/go-git/go-git/v5/plumbing\\\"\\n    33\\t\\t\\\"github.com/go-git/go-git/v5/plumbing/object\\\"\\n    34\\t\\t\\\"github.com/go-git/go-git/v5/utils/binary\\\"\\n    35\\t)\\n    36\\t\\n    37\\t// hasTTY checks if /dev/tty is available for interactive prompts.\\n    38\\t// Returns false when running as an agent subprocess (no controlling terminal).\\n    39\\t//\\n    40\\t// In test environments, ENTIRE_TEST_TTY overrides the real check:\\n    41\\t//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n    42\\t//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\n    43\\tfunc hasTTY() bool {\\n    44\\t\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n    45\\t\\t\\treturn v == \\\"1\\\"\\n    46\\t\\t}\\n    47\\t\\n    48\\t\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n    49\\t\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n    50\\t\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n    51\\t\\t// See: https://geminicli.com/docs/tools/shell/\\n    52\\t\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    53\\t\\t\\treturn false\\n    54\\t\\t}\\n    55\\t\\n    56\\t\\t// GIT_TERMINAL_PROMPT=0 disables git's own terminal prompts.\\n    57\\t\\t// Factory AI Droid (and other non-interactive environments like CI) set this.\\n    58\\t\\t// Since we run as a git hook, respect it — if the environment doesn't want\\n    59\\t\\t// git prompting, our hook shouldn't prompt either.\\n    60\\t\\tif os.Getenv(\\\"GIT_TERMINAL_PROMPT\\\") == \\\"0\\\" {\\n    61\\t\\t\\treturn false\\n    62\\t\\t}\\n    63\\t\\n    64\\t\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    65\\t\\tif err != nil {\\n    66\\t\\t\\treturn false\\n    67\\t\\t}\\n    68\\t\\t_ = tty.Close()\\n    69\\t\\treturn true\\n    70\\t}\\n    71\\t\\n    72\\t// ttyResult represents the outcome of a TTY confirmation prompt.\\n    73\\ttype ttyResult int\\n    74\\t\\n    75\\tconst (\\n    76\\t\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    77\\t\\tttyResultSkip                        // Skip: don't add the trailer\\n    78\\t\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    79\\t)\\n    80\\t\\n    81\\t// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    82\\t// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    83\\t// the no-TTY case (agent subprocesses, CI) themselves.\\n    84\\t//\\n    85\\t// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    86\\t// detail lines are displayed indented below the header.\\n    87\\tfunc askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    88\\t\\tdefaultResult := ttyResultSkip\\n    89\\t\\tif defaultYes {\\n    90\\t\\t\\tdefaultResult = ttyResultLink\\n    91\\t\\t}\\n    92\\t\\n    93\\t\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    94\\t\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    95\\t\\t// but we can't actually read from the TTY in tests.\\n    96\\t\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    97\\t\\t\\treturn defaultResult\\n    98\\t\\t}\\n    99\\t\\n   100\\t\\t// Open /dev/tty for both reading and writing.\\n   101\\t\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n   102\\t\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n   103\\t\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   104\\t\\tif err != nil {\\n   105\\t\\t\\treturn defaultResult\\n   106\\t\\t}\\n   107\\t\\tdefer tty.Close()\\n   108\\t\\n   109\\t\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   110\\t\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   111\\t\\tfor _, line := range details {\\n   112\\t\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   113\\t\\t}\\n   114\\t\\n   115\\t\\t// Show prompt with option descriptions\\n   116\\t\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   117\\t\\tif defaultYes {\\n   118\\t\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   119\\t\\t} else {\\n   120\\t\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   121\\t\\t}\\n   122\\t\\n   123\\t\\t// Read response\\n   124\\t\\treader := bufio.NewReader(tty)\\n   125\\t\\tresponse, err := reader.ReadString('\\\\n')\\n   126\\t\\tif err != nil {\\n   127\\t\\t\\treturn defaultResult\\n   128\\t\\t}\\n   129\\t\\n   130\\t\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   131\\t\\tswitch response {\\n   132\\t\\tcase \\\"y\\\", \\\"yes\\\":\\n   133\\t\\t\\treturn ttyResultLink\\n   134\\t\\tcase \\\"n\\\", \\\"no\\\":\\n   135\\t\\t\\treturn ttyResultSkip\\n   136\\t\\tcase \\\"a\\\", \\\"always\\\":\\n   137\\t\\t\\treturn ttyResultLinkAlways\\n   138\\t\\tdefault:\\n   139\\t\\t\\t// Empty or invalid input - use default\\n   140\\t\\t\\treturn defaultResult\\n   141\\t\\t}\\n   142\\t}\\n   143\\t\\n   144\\t// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   145\\t// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   146\\t// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   147\\t// local settings file doesn't exist yet.\\n   148\\tfunc saveCommitLinkingAlways(ctx context.Context) error {\\n   149\\t\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   150\\t\\tif err != nil {\\n   151\\t\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   152\\t\\t}\\n   153\\t\\n   154\\t\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   155\\t\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   156\\t\\tvar raw map[string]json.RawMessage\\n   157\\t\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   158\\t\\tif readErr == nil {\\n   159\\t\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   160\\t\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   161\\t\\t\\t}\\n   162\\t\\t} else if !os.IsNotExist(readErr) {\\n   163\\t\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   164\\t\\t}\\n   165\\t\\tif raw == nil {\\n   166\\t\\t\\traw = make(map[string]json.RawMessage)\\n   167\\t\\t}\\n   168\\t\\n   169\\t\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   170\\t\\n   171\\t\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   172\\t\\tif err != nil {\\n   173\\t\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   174\\t\\t}\\n   175\\t\\tout = append(out, '\\\\n')\\n   176\\t\\n   177\\t\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   178\\t\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   179\\t\\t}\\n   180\\t\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   181\\t\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   182\\t\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   183\\t\\t}\\n   184\\t\\treturn nil\\n   185\\t}\\n   186\\t\\n   187\\t// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   188\\t// If the message contains only our trailer (no actual user content), strip it\\n   189\\t// so git will abort the commit due to empty message.\\n   190\\t\\n   191\\tfunc (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   192\\t\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   193\\t\\tif err != nil {\\n   194\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   195\\t\\t}\\n   196\\t\\n   197\\t\\tmessage := string(content)\\n   198\\t\\n   199\\t\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   200\\t\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   201\\t\\t\\t// No trailer, nothing to do\\n   202\\t\\t\\treturn nil\\n   203\\t\\t}\\n   204\\t\\n   205\\t\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   206\\t\\tif !hasUserContent(message) {\\n   207\\t\\t\\t// No user content - strip the trailer so git aborts\\n   208\\t\\t\\tmessage = stripCheckpointTrailer(message)\\n   209\\t\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   210\\t\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   211\\t\\t\\t}\\n   212\\t\\t}\\n   213\\t\\n   214\\t\\treturn nil\\n   215\\t}\\n   216\\t\\n   217\\t// hasUserContent checks if the message has any content besides comments and our trailer.\\n   218\\tfunc hasUserContent(message string) bool {\\n   219\\t\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   220\\t\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   221\\t\\t\\ttrimmed := strings.TrimSpace(line)\\n   222\\t\\t\\t// Skip empty lines\\n   223\\t\\t\\tif trimmed == \\\"\\\" {\\n   224\\t\\t\\t\\tcontinue\\n   225\\t\\t\\t}\\n   226\\t\\t\\t// Skip comment lines\\n   227\\t\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   228\\t\\t\\t\\tcontinue\\n   229\\t\\t\\t}\\n   230\\t\\t\\t// Skip our trailer line\\n   231\\t\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   232\\t\\t\\t\\tcontinue\\n   233\\t\\t\\t}\\n   234\\t\\t\\t// Found user content\\n   235\\t\\t\\treturn true\\n   236\\t\\t}\\n   237\\t\\treturn false\\n   238\\t}\\n   239\\t\\n   240\\t// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   241\\tfunc stripCheckpointTrailer(message string) string {\\n   242\\t\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   243\\t\\tvar result []string\\n   244\\t\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   245\\t\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   246\\t\\t\\t\\tresult = append(result, line)\\n   247\\t\\t\\t}\\n   248\\t\\t}\\n   249\\t\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   250\\t}\\n   251\\t\\n   252\\t// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   253\\t// cherry-pick, or revert operation. During these operations, commits are being\\n   254\\t// replayed and should not be linked to agent sessions.\\n   255\\t//\\n   256\\t// Detects:\\n   257\\t//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   258\\t//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   259\\t//   - revert: .git/REVERT_HEAD file\\n   260\\tfunc isGitSequenceOperation(ctx context.Context) bool {\\n   261\\t\\t// Get git directory (handles worktrees and relative paths correctly)\\n   262\\t\\tgitDir, err := GetGitDir(ctx)\\n   263\\t\\tif err != nil {\\n   264\\t\\t\\treturn false // Can't determine, assume not in sequence operation\\n   265\\t\\t}\\n   266\\t\\n   267\\t\\t// Check for rebase state directories\\n   268\\t\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   269\\t\\t\\treturn true\\n   270\\t\\t}\\n   271\\t\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   272\\t\\t\\treturn true\\n   273\\t\\t}\\n   274\\t\\n   275\\t\\t// Check for cherry-pick and revert state files\\n   276\\t\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   277\\t\\t\\treturn true\\n   278\\t\\t}\\n   279\\t\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   280\\t\\t\\treturn true\\n   281\\t\\t}\\n   282\\t\\n   283\\t\\treturn false\\n   284\\t}\\n   285\\t\\n   286\\t// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   287\\t// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   288\\t// Only adds a trailer if there's actually new session content to condense.\\n   289\\t// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   290\\t// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   291\\t// For amended commits, preserves the existing checkpoint ID.\\n   292\\t//\\n   293\\t// The source parameter indicates how the commit was initiated:\\n   294\\t//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   295\\t//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   296\\t//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   297\\t//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   298\\t//\\n   299\\t\\n   300\\tfunc (s *ManualCommitStrategy) PrepareCommitMsg(ctx context.Context, commitMsgFile string, source string) error {\\n   301\\t\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   302\\t\\n   303\\t\\t// Skip during rebase, cherry-pick, or revert operations\\n   304\\t\\t// These are replaying existing commits and should not be linked to agent sessions\\n   305\\t\\tif isGitSequenceOperation(ctx) {\\n   306\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped during git sequence operation\\\",\\n   307\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   308\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   309\\t\\t\\t)\\n   310\\t\\t\\treturn nil\\n   311\\t\\t}\\n   312\\t\\n   313\\t\\t// Skip for merge and squash sources\\n   314\\t\\t// These are auto-generated messages - not from Claude sessions\\n   315\\t\\tswitch source {\\n   316\\t\\tcase \\\"merge\\\", \\\"squash\\\":\\n   317\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: skipped for source\\\",\\n   318\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   319\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   320\\t\\t\\t)\\n   321\\t\\t\\treturn nil\\n   322\\t\\t}\\n   323\\t\\n   324\\t\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   325\\t\\tif source == \\\"commit\\\" {\\n   326\\t\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   327\\t\\t}\\n   328\\t\\n   329\\t\\trepo, err := OpenRepository(ctx)\\n   330\\t\\tif err != nil {\\n   331\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   332\\t\\t}\\n   333\\t\\n   334\\t\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   335\\t\\tif err != nil {\\n   336\\t\\t\\treturn nil //nolint:nilerr // Hook