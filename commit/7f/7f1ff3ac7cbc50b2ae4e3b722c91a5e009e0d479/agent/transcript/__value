Sleep(10 * time.Millisecond)\\n    59→\\tspan.End()\\n    60→\\n    61→\\tif span.duration < 10*time.Millisecond {\\n    62→\\t\\tt.Errorf(\\\"span.duration = %v, want >= 10ms\\\", span.duration)\\n    63→\\t}\\n    64→}\\n    65→\\n    66→func TestEnd_Idempotent(t *testing.T) {\\n    67→\\tt.Parallel()\\n    68→\\tctx := context.Background()\\n    69→\\n    70→\\t_, span := Start(ctx, \\\"double_end\\\")\\n    71→\\ttime.Sleep(10 * time.Millisecond)\\n    72→\\tspan.End()\\n    73→\\n    74→\\tfirstDuration := span.duration\\n    75→\\n    76→\\ttime.Sleep(10 * time.Millisecond)\\n    77→\\tspan.End()\\n    78→\\n    79→\\tif span.duration != firstDuration {\\n    80→\\t\\tt.Errorf(\\\"second End() changed duration from %v to %v\\\", firstDuration, span.duration)\\n    81→\\t}\\n    82→}\\n    83→\\n    84→func TestEnd_AutoEndsChildren(t *testing.T) {\\n    85→\\tt.Parallel()\\n    86→\\tctx := context.Background()\\n    87→\\n    88→\\tctx, parent := Start(ctx, \\\"parent\\\")\\n    89→\\t_, child := Start(ctx, \\\"child\\\")\\n    90→\\n    91→\\ttime.Sleep(10 * time.Millisecond)\\n    92→\\tparent.End()\\n    93→\\n    94→\\tif !child.ended {\\n    95→\\t\\tt.Error(\\\"child should be auto-ended when parent ends\\\")\\n    96→\\t}\\n    97→\\tif child.duration == 0 {\\n    98→\\t\\tt.Error(\\\"child should have non-zero duration after auto-end\\\")\\n    99→\\t}\\n   100→}\\n   101→\\n   102→func TestMeasure_TimesFunction(t *testing.T) {\\n   103→\\tt.Parallel()\\n   104→\\tctx := context.Background()\\n   105→\\n   106→\\t_, span := Start(ctx, \\\"parent\\\")\\n   107→\\n   108→\\tspan.Measure(\\\"substep\\\", func() {\\n   109→\\t\\ttime.Sleep(10 * time.Millisecond)\\n   110→\\t})\\n   111→\\n   112→\\tspan.End()\\n   113→\\n   114→\\tif len(span.children) != 1 {\\n   115→\\t\\tt.Fatalf(\\\"expected 1 child from Measure, got %d\\\", len(span.children))\\n   116→\\t}\\n   117→\\tchild := span.children[0]\\n   118→\\tif child.name != \\\"substep\\\" {\\n   119→\