rshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   172→\\tif err != nil {\\n   173→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   174→\\t}\\n   175→\\tout = append(out, '\\\\n')\\n   176→\\n   177→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   178→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   179→\\t}\\n   180→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   181→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   182→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   183→\\t}\\n   184→\\treturn nil\\n   185→}\\n   186→\\n   187→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   188→// If the message contains only our trailer (no actual user content), strip it\\n   189→// so git will abort the commit due to empty message.\\n   190→\\n   191→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   192→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   193→\\tif err != nil {\\n   194→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   195→\\t}\\n   196→\\n   197→\\tmessage := string(content)\\n   198→\\n   199→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   200→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   201→\\t\\t// No trailer, nothing to do\\n   202→\\t\\treturn nil\\n   203→\\t}\\n   204→\\n   205→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   206→\\tif !hasUserContent(message) {\\n   207→\\t\\t// No user content - strip the trailer so git aborts\\n   208→\\t\\tmessage = stripCheckpointTrailer(message)\\n   209→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   210→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   211→\\t\\t}\\n   212→\\t}\\n   213→\\n   214→\\treturn nil\\n   215→}\\n   216→\\n   217→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   218→func hasUserContent(message string) bool {\\n   219→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   220→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   221→\\t\\ttrimmed := strings.TrimSpace(line)\\n   222→\\t\\t// Skip empty lines\\n   223→\\t\\tif trimmed == \\\"\\\" {\\n   224→\\t\\t\\tcontinue\\n   225→\\t\\t}\\n   226→\\t\\t// Skip comment lines\\n   227→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   228→\\t\\t\\tcontinue\\n   229→\\t\\t}\\n   230→\\t\\t// Skip our trailer line\\n   231→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   232→\\t\\t\\tcontinue\\n   233→\\t\\t}\\n   234→\\t\\t// Found user content\\n   235→\\t\\treturn true\\n   236→\\t}\\n   237→\\treturn false\\n   238→}\\n   239→\\n   240→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   241→func stripCheckpointTrailer(message string) string {\\n   242→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   243→\\tvar result []string\\n   244→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   245→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   246→\\t\\t\\tresult = append(result, line)\\n   247→\\t\\t}\\n   248→\\t}\\n   249→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   250→}\\n   251→\\n   252→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   253→// cherry-pick, or revert operation. During these operations, commits are being\\n   254→// replayed and should not be linked to agent sessions.\\n   255→//\\n   256→// Detects:\\n   257→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   258→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   259→//   - revert: .git/REVERT_HEAD file\\n   260→func isGitSequenceOperation(ctx context.Context) bool {\\n   261→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   262→\\tgitDir, err := GetGitDir(ctx)\\n   263→\\tif err != nil {\\n   264→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   265→\\t}\\n   266→\\n   267→\\t// Check for rebase state directories\\n   268→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   269→\\t\\treturn true\\n   270→\\t}\\n   271→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   272→\\t\\treturn true\\n   273→\\t}\\n   274→\\n   275→\\t// Check for cherry-pick and revert state files\\n   276→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   277→\\t\\treturn true\\n   278→\\t}\\n   279→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   280→\\t\\treturn true\\n   281→\\t}\\n   282→\\n   283→\\treturn false\\n   284→}\\n   285→\\n   286→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   287→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   288→// Only adds a trailer if there's actually new session content to condense.\\n   289→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   290→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   291→// For amended commits, preserves the existing checkpoint ID.\\n   292→//\\n   293→// The source parameter indicates how the commit was initiated:\\n   294→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   295→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   296→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   297→/