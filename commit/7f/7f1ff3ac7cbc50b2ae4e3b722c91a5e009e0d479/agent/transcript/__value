culateSessionAttributions)\\n   113→}\\n   114→\\n   115→// CondenseSession condenses a session's shadow branch to permanent storage.\\n   116→// checkpointID is the 12-hex-char value from the Entire-Checkpoint trailer.\\n   117→// Metadata is stored at sharded path: <checkpoint_id[:2]>/<checkpoint_id[2:]>/\\n   118→// Uses checkpoint.GitStore.WriteCommitted for the git operations.\\n   119→//\\n   120→// For mid-session commits (no Stop/SaveStep called yet), the shadow branch may not exist.\\n   121→// In this case, data is extracted from the live transcript instead.\\n   122→func (s *ManualCommitStrategy) CondenseSession(ctx context.Context, repo *git.Repository, checkpointID id.CheckpointID, state *SessionState, committedFiles map[string]struct{}, opts ...condenseOpts) (*CondenseResult, error) {\\n   123→\\tag, _ := agent.GetByAgentType(state.AgentType) //nolint:errcheck // ag may be nil for unknown agent types; callers use type assertions so nil is safe\\n   124→\\tvar o condenseOpts\\n   125→\\tif len(opts) > 0 {\\n   126→\\t\\to = opts[0]\\n   127→\\t}\\n   128→\\n   129→\\t// Get shadow branch — use pre-resolved ref if available, otherwise resolve from repo.\\n   130→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   131→\\tref := o.shadowRef\\n   132→\\tvar hasShadowBranch bool\\n   133→\\tif ref != nil {\\n   134→\\t\\thasShadowBranch = true\\n   135→\\t} else {\\n   136→\\t\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n   137→\\t\\tvar err error\\n   138→\\t\\tref, err = repo.Reference(refName, true)\\n   139→\\t\\thasShadowBranch = err == nil\\n   140→\\t}\\n   141→\\n   142→\\tvar sessionData *ExtractedSessionData\\n   143→\\tif hasShadowBranch {\\n   144→\\t\\t// Extract session data from the shadow branch (with live transcript fallback).\\n   145→\\t\\t// Use tracked files from session state instead of collecting all files from tree.\\n   146→\\t\\t// Pass agent type to handle different trans