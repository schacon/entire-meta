   372\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   373\\t\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   374\\t\\t\\t)\\n   375\\t\\t\\treturn nil\\n   376\\t\\t}\\n   377\\t\\n   378\\t\\t// Read current commit message\\n   379\\t\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   380\\t\\tif err != nil {\\n   381\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   382\\t\\t}\\n   383\\t\\n   384\\t\\tmessage := string(content)\\n   385\\t\\n   386\\t\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   387\\t\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   388\\t\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   389\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   390\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   391\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   392\\t\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   393\\t\\t\\t)\\n   394\\t\\t\\treturn nil\\n   395\\t\\t}\\n   396\\t\\n   397\\t\\t// Generate a fresh checkpoint ID\\n   398\\t\\tcheckpointID, err := id.Generate()\\n   399\\t\\tif err != nil {\\n   400\\t\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   401\\t\\t}\\n   402\\t\\n   403\\t\\t// Determine agent type and last prompt from session\\n   404\\t\\tvar agentType types.AgentType\\n   405\\t\\tvar lastPrompt string\\n   406\\t\\tif len(sessionsWithContent) > 0 {\\n   407\\t\\t\\tfirstSession := sessionsWithContent[0]\\n   408\\t\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   409\\t\\t\\t\\tagentType = firstSession.AgentType\\n   410\\t\\t\\t}\\n   411\\t\\t\\tlastPrompt = s.getLastPrompt(ctx, repo, firstSession)\\n   412\\t\\t}\\n   413\\t\\n   414\\t\\t// Prepare prompt for display: collapse newlines/whitespace, then trunc