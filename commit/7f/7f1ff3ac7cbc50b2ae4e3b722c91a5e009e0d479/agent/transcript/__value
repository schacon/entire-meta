ommand registration for agents.\\n     2→// The lifecycle dispatcher (DispatchLifecycleEvent) handles all lifecycle events.\\n     3→// PostTodo is the only hook that's handled directly (not via lifecycle dispatcher).\\n     4→package cli\\n     5→\\n     6→import (\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"log/slog\\\"\\n    10→\\t\\\"time\\\"\\n    11→\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/claudecode\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/types\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    19→\\n    20→\\t\\\"github.com/spf13/cobra\\\"\\n    21→)\\n    22→\\n    23→// agentHookLogCleanup stores the cleanup function for agent hook logging.\\n    24→// Set by PersistentPreRunE, called by PersistentPostRunE.\\n    25→var agentHookLogCleanup func()\\n    26→\\n    27→// currentHookAgentName stores the agent name for the currently executing hook.\\n    28→// Set by newAgentHookVerbCmdWithLogging before calling the handler.\\n    29→// This allows handlers to know which agent invoked the hook without guessing.\\n    30→var currentHookAgentName types.AgentName\\n    31→\\n    32→// GetCurrentHookAgent returns the agent for the currently executing hook.\\n    33→// Returns the agent based on the hook command structure (e.g., \\\"entire hooks claude-code ...\\\")\\n    34→// rather than guessing from directory presence.\\n    35→// Falls back to GetAgent() if not in a hook context.\\n    36→func GetCurrentHookAgent() (agent.Agent, error) {\\n    37→\\tif currentHookAgentName == \\\"\\\" {\\n    38→\\t\\treturn nil, errors.New(\\\"not in a hook context: agent name not set\\\")\\n    39→\\t}\\n    40→\\n    41→\\tag, err := agent.Get(currentHookAgentName)\\n    42→\\tif err != nil {\\n    43→\\t\\treturn nil, fmt.Errorf(\\\"getting hook agent %q: %w\\\", currentHookAgentName, err)\\n    44→\\t}\\n    45→\\treturn ag, nil\\n    46→}\\n    47→\\n    48→// newAgentHooksCmd creates a hooks subcommand for an agent that implements HookSupport.\\n    49→// It dynamically creates subcommands for each hook the agent supports.\\n    50→func newAgentHooksCmd(agentName types.AgentName, handler agent.HookSupport) *cobra.Command {\\n    51→\\tcmd := &cobra.Command{\\n    52→\\t\\tUse:    string(agentName),\\n    53→\\t\\tShort:  handler.Description() + \\\" hook handlers\\\",\\n    54→\\t\\tHidden: true,\\n    55→\\t\\tPersistentPreRunE: func(cmd *cobra.Command, _ []string) error {\\n    56→\\t\\t\\tagentHookLogCleanup = initHookLogging(cmd.Context())\\n    57→\\t\\t\\treturn nil\\n    58→\\t\\t},\\n    59→\\t\\tPersistentPostRunE: func(_ *cobra.Command, _ []string) error {\\n    60→\\t\\t\\tif agentHookLogCleanup != nil {\\n    61→\\t\\t\\t\\tagentHookLogCleanup()\\n    62→\\t\\t\\t}\\n    63→\\t\\t\\treturn nil\\n    64→\\t\\t},\\n    65→\\t}\\n    66→\\n    67→\\tfor _, hookName := range handler.HookNames() {\\n    68→\\t\\tcmd.AddCommand(newAgentHookVerbCmdWithLogging(agentName, hookName))\\n    69→\\t}\\n    70→\\n    71→\\treturn cmd\\n    72→}\\n    73→\\n    74→// getHookType returns the hook type based on the hook name.\\n    75→// Returns \\\"subagent\\\" for task-related hooks (pre-task, post-task, post-todo),\\n    76→// \\\"tool\\\" for tool-related hooks (before-tool, after-tool),\\n    77→// \\\"agent\\\" for all other agent hooks.\\n    78→func getHookType(hookName string) string {\\n    79→\\tswitch hookName {\\n    80→\\tcase claudecode.HookNamePreTask, claudecode.HookNamePostTask, claudecode.HookNamePostTodo:\\n    81→\\t\\treturn \\\"subagent\\\"\\n    82→\\tcase geminicli.HookNameBeforeTool, geminicli.HookNameAfterTool:\\n    83→\\t\\treturn \\\"tool\\\"\\n    84→\\tdefault:\\n    85→\\t\\treturn \\\"agent\\\"\\n    86→\\t}\\n    87→}\\n    88→\\n    89→// newAgentHookVerbCmdWithLogging creates a command for a specific hook verb with structured logging.\\n    90→// It uses the lifecycle dispatcher (ParseHookEvent → DispatchLifecycleEvent) as the primary path.\\n    91→// PostTodo is handled directly as it's Claude-specific and not part of the lifecycle dispatcher.\\n    92→func newAgentHookVerbCmdWithLogging(agentName types.AgentName, hookName string) *cobra.Command {\\n    93→\\treturn &cobra.Command{\\n    94→\\t\\tUse:    hookName,\\n    95→\\t\\tHidden: true,\\n    96→\\t\\tShort:  \\\"Called on \\\" + hookName,\\n    97→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    98→\\t\\t\\t// Skip silently if not in a git repository - hooks shouldn't prevent the agent from working\\n    99→\\t\\t\\tif _, err := paths.WorktreeRoot(cmd.Context()); err != nil {\\n   100→\\t\\t\\t\\treturn nil\\n   101→\\t\\t\\t}\\n   102→\\n   103→\\t\\t\\t// Skip if Entire is not enabled\\n   104→\\t\\t\\tenabled, err := IsEnabled(cmd.Context())\\n   105→\\t\\t\\tif err == nil && !enabled {\\n   106→\\t\\t\\t\\treturn nil\\n   107→\\t\\t\\t}\\n   108→\\n   109→\\t\\t\\tstart := time.Now()\\n   110→\\n   111→\\t\\t\\t// Initialize logging context with agent name\\n   112→\\t\\t\\tctx := logging.WithAgent(logging.WithComponent(cmd.Context(), \\\"hooks\\\"), agentName)\\n   113→\\n   114→\\t\\t\\t// Strategy name for logging\\n   115→\\t\\t\\tstrategyName := strategy.StrategyNameManualCommit\\n   116→\\n   117→\\t\\t\\thookType := getHookType(hookName)\\n   118→\\n   119→\\t\\t\\tlogging.Debug(ctx, \\\"hook invoked\\\",\\n   120→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   121→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   122→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   123→\\t\\t\\t)\\n   124→\\n   125→\\t\\t\\t// Set the current hook agent so handlers can retrieve it\\n   126→\\t\\t\\tcurrentHookAgentName = agentName\\n   127→\\t\\t\\tdefer func() { currentHookAgentName = \\\"\\\" }()\\n   128→\\n   129→\\t\\t\\t// Use the lifecycle dispatcher for all hooks\\n   130→\\t\\t\\tvar hookErr error\\n   131→\\t\\t\\tag, agentErr := agent.Get(agentName)\\n   132→\\t\\t\\tif agentErr != nil {\\n   133→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get agent %q: %w\\\", agentName, agentErr)\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\thandler, ok := ag.(agent.HookSupport)\\n   137→\\t\\t\\tif !ok {\\n   138→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent %q does not support hooks\\\", agentName)\\n   139→\\t\\t\\t}\\n   140→\\n   141→\\t\\t\\t// Use cmd.InOrStdin() to support testing with cmd.SetIn()\\n   142→\\t\\t\\tevent, parseErr := handler.ParseHookEvent(ctx, hookName, cmd.InOrStdin())\\n   143→\\t\\t\\tif parseErr != nil {\\n   144→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hook event: %w\\\", parseErr)\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\tif event != nil {\\n   148→\\t\\t\\t\\t// Lifecycle event — use the generic dispatcher\\n   149→\\t\\t\\t\\thookErr = DispatchLifecycleEvent(ctx, ag, event)\\n   150→\\t\\t\\t} else if agentName == agent.AgentNameClaudeCode && hookName == claudecode.HookNamePostTodo {\\n   151→\\t\\t\\t\\t// PostTodo is Claude-specific: creates incremental checkpoints during subagent execution\\n   152→\\t\\t\\t\\thookErr = handleClaudeCodePostTodo(ctx)\\n   153→\\t\\t\\t}\\n   154→\\t\\t\\t// Other pass-through hooks (nil event, no special handling) are no-ops\\n   155→\\n   156→\\t\\t\\tlogging.LogDuration(ctx, slog.LevelDebug, \\\"hook completed\\\", start,\\n   157→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   158→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   159→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   160→\\t\\t\\t\\tslog.Bool(\\\"success\\\", hookErr == nil),\\n   161→\\t\\t\\t)\\n   162→\\n   163→\\t\\t\\treturn hookErr\\n   164→\\t\\t},\\n   165→\\t}\\n   166→}\\n   167→\"}]},