ranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   230→\\tif err != nil {\\n   231→\\t\\tsubCopy.End()\\n   232→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   233→\\t}\\n   234→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   235→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   236→\\t\\tsubCopy.End()\\n   237→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   238→\\t}\\n   239→\\tlogging.Debug(logCtx, \\\"copied transcript\\\",\\n   240→\\t\\tslog.String(\\\"path\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName))\\n   241→\\tsubCopy.End()\\n   242→\\n   243→\\t// Load pre-prompt state (captured on TurnStart)\\n   244→\\tctx, subExtract := perf.Start(ctx, \\\"extract_metadata\\\")\\n   245→\\tpreState, err := LoadPrePromptState(ctx, sessionID)\\n   246→\\tif err != nil {\\n   247→\\t\\tlogging.Warn(logCtx, \\\"failed to load pre-prompt state\\\",\\n   248→\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   249→\\t}\\n   250→\\n   251→\\t// Determine transcript offset\\n   252→\\ttranscriptOffset := resolveTranscriptOffset(ctx, preState, sessionID)\\n   253→\\n   254→\\t// Compute subagents directory for agents that support subagent extraction.\\n   255→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   256→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   257→\\n   258→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   259→\\tvar allPrompts []string\\n   260→\\tvar summary string\\n   261→\\tvar modifiedFiles []string\\n   262→\\n   263→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   264→\\t\\t// Extract prompts\\n   265→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   266→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to extract prompts\\\",\\n   267→\\t\\t\\t\\ts