nfo(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   544→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   545→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   546→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   547→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   548→\\t\\t)\\n   549→\\t\\treturn nil\\n   550→\\t}\\n   551→\\n   552→\\t// No checkpoint ID found - leave message unchanged\\n   553→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   554→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   555→\\t)\\n   556→\\treturn nil\\n   557→}\\n   558→\\n   559→// PostCommit is called by the git post-commit hook after a commit is created.\\n   560→// Uses the session state machine to determine what action to take per session:\\n   561→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   562→//   - IDLE → condense immediately\\n   563→//   - ENDED → condense if files touched, discard if empty\\n   564→//\\n   565→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   566→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   567→//\\n   568→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   569→// and were condensed during this PostCommit.\\n   570→\\n   571→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   572→// Each session in the loop gets its own handler with per-session context.\\n   573→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   574→// as the state being transitioned) rather than capturing state separately.\\n   575→type postCommitActionHandler struct {\\n   576→\\ts                      *ManualCommitStrategy\\n   577→\\tctx                    context.Context\\n   578→\\trepo                   *git.Repository\\n   579→\\tcheckpointID  