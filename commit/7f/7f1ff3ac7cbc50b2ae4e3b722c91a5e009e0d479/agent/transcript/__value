// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   512\\t\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   513\\t\\t// was created from this base). This prevents stale sessions from injecting\\n   514\\t\\t// unrelated checkpoint IDs.\\n   515\\t\\trepo, repoErr := OpenRepository(ctx)\\n   516\\t\\tif repoErr != nil {\\n   517\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   518\\t\\t}\\n   519\\t\\thead, headErr := repo.Head()\\n   520\\t\\tif headErr != nil {\\n   521\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   522\\t\\t}\\n   523\\t\\tcurrentHead := head.Hash().String()\\n   524\\t\\n   525\\t\\t// Find first matching session with LastCheckpointID to restore.\\n   526\\t\\t// LastCheckpointID is set after condensation completes.\\n   527\\t\\tfor _, state := range sessions {\\n   528\\t\\t\\tif state.BaseCommit != currentHead {\\n   529\\t\\t\\t\\tcontinue\\n   530\\t\\t\\t}\\n   531\\t\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   532\\t\\t\\t\\tcontinue\\n   533\\t\\t\\t}\\n   534\\t\\t\\tcpID := state.LastCheckpointID\\n   535\\t\\t\\tsource := \\\"LastCheckpointID\\\"\\n   536\\t\\n   537\\t\\t\\t// Restore the trailer\\n   538\\t\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   539\\t\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   540\\t\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   541\\t\\t\\t}\\n   542\\t\\n   543\\t\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   544\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   545\\t\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   546\\t\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   547\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   548\\t\\t\\t)\\n   549\\t\\t\\treturn nil\\n   550\\t\\t}\\n   551\\t\\n   552\\t\\t// No checkpoint ID found - leave message unchanged\\n   553\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   554\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   555\\t\\t)\\n   556\\t\\treturn nil\\n   557\\t}\\n   558\\t\\n   559\\t// PostCommit is called by the git post-commit hook after a commit is created.\\n   560\\t// Uses the session state machine to determine what action to take per session:\\n   561\\t//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   562\\t//   - IDLE → condense immediately\\n   563\\t//   - ENDED → condense if files touched, discard if empty\\n   564\\t//\\n   565\\t// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   566\\t// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   567\\t//\\n   568\\t// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   569\\t// and were condensed during this PostCommit.\\n   570\\t\\n   571\\t// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   572\\t// Each session in the loop gets its own handler with per-session context.\\n   573\\t// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   574\\t// as the state being transitioned) rather than capturing state separately.\\n   575\\ttype postCommitActionHandler struct {\\n   576\\t\\ts                      *ManualCommitStrategy\\n   577\\t\\tctx                    context.Context\\n   578\\t\\trepo                   *git.Repository\\n   579\\t\\tcheckpointID           id.CheckpointID\\n   580\\t\\thead                   *plumbing.Reference\\n   581\\t\\tcommit                 *object.Commit\\n   582\\t\\tnewHead                string\\n   583\\t\\tshadowBranchName       string\\n   584\\t\\tshadowBranchesToDelete map[string]struct{}\\n   585\\t\\tcommittedFileSet       map[string]struct{}\\n   586\\t\