.String(\\\"component\\\", \\\"perf\\\"))\\n    62→\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n    63→\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n    64→\\n    65→\\t// Add child step durations as flat keys\\n    66→\\tfor _, child := range s.children {\\n    67→\\t\\t// Auto-end children that were not explicitly ended\\n    68→\\t\\tif !child.ended {\\n    69→\\t\\t\\tchild.ended = true\\n    70→\\t\\t\\tchild.duration = time.Since(child.start)\\n    71→\\t\\t}\\n    72→\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n    73→\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n    74→\\t}\\n    75→\\n    76→\\t// Add any extra attributes from Start()\\n    77→\\tfor _, a := range s.attrs {\\n    78→\\t\\tattrs = append(attrs, a)\\n    79→\\t}\\n    80→\\n    81→\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n    82→}\\n    83→\\n    84→// Measure times a function as a child substep of this span.\\n    85→func (s *Span) Measure(name string, fn func()) {\\n    86→\\tctx := contextWithSpan(s.ctx, s)\\n    87→\\t_, child := Start(ctx, name)\\n    88→\\tfn()\\n    89→\\tchild.End()\\n    90→}\\n    91→\"}]},\"uuid\":\"e3ff1383-e83b-44e0-8a67-4f7e3cb7466a\",\"timestamp\":\"2026-03-04T23:47:45.630Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a565360802e3fcc09\"},\"toolUseID\":\"agent_msg_01LmZeA4zuwYd8d5Bc8kFerP\",\"parentToolUseID\":\"toolu_014fAKXEBkD95rhHKEeTjpoT\",\"uuid\":\"eb1a5c0f-a8d7-47d0-b478-6d956b510b93\",\"timestamp\":\"2026-03-04T23:47:45.669Z\"}\n{\"parentUuid\":\"eb1a5c0f-a8d7-47d0-b478-6d956b510b93\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli/.worktrees/performance-logging-investigation\",\"sessionId\":\"2d62938d-a5d3-4bac-9d0f-bf8056720e6d\",\"version\":\"2.1.63\",\"gitBranch\":\"performance-logging-investigation\",\"slug\":\"wiggly-weaving-crayon\",\"type\":\"progress\",\"dat