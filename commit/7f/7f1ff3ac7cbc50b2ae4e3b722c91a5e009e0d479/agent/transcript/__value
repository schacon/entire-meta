ualCommitStrategy) PostCommit(ctx context.Context, ...) error {\\n   551→    ctx, span := perf.Start(ctx, \\\"post_commit\\\")\\n   552→    defer span.End()\\n   553→\\n   554→    ctx, sub := perf.Start(ctx, \\\"load_sessions\\\")\\n   555→    // ... open repo, get HEAD, parse trailer, find sessions ...\\n   556→    sub.End()\\n   557→\\n   558→    ctx, sub = perf.Start(ctx, \\\"resolve_git_objects\\\")\\n   559→    // ... pre-resolve headTree, parentTree ...\\n   560→    sub.End()\\n   561→\\n   562→    // Session processing loop — each session gets a Measure call\\n   563→    for _, session := range sessions {\\n   564→        span.Measure(\\\"process_session\\\", func() {\\n   565→            postCommitProcessSession(ctx, ...)\\n   566→        })\\n   567→    }\\n   568→\\n   569→    ctx, sub = perf.Start(ctx, \\\"cleanup_branches\\\")\\n   570→    // ... shadow branch cleanup ...\\n   571→    sub.End()\\n   572→\\n   573→    return nil\\n   574→}\\n   575→```\\n   576→\\n   577→**Step 2: Add substeps inside postCommitProcessSession**\\n   578→\\n   579→```go\\n   580→func (s *ManualCommitStrategy) postCommitProcessSession(ctx context.Context, ...) error {\\n   581→    ctx, sub := perf.Start(ctx, \\\"resolve_shadow\\\")\\n   582→    // ... resolve shadow branch ref + tree ...\\n   583→    sub.End()\\n   584→\\n   585→    ctx, sub = perf.Start(ctx, \\\"condense\\\")\\n   586→    // ... state machine transition + CondenseSession call ...\\n   587→    sub.End()\\n   588→\\n   589→    ctx, sub = perf.Start(ctx, \\\"carry_forward\\\")\\n   590→    // ... carry-forward computation + final state save ...\\n   591→    sub.End()\\n   592→\\n   593→    return nil\\n   594→}\\n   595→```\\n   596→\\n   597→**Step 3: Run fmt, lint, and tests**\\n   598→\\n   599→Run: `mise run fmt && mise run lint && mise run test:ci`\\n   600→\\n   601→**Step 4: Commit**\\n   602→\\n   603→```bash\\n   604→git add cmd/entire/cli/strategy/manual_commit_hooks.go\\n   605→git commit -m \\\"per