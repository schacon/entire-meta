34→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   335→\\t}\\n   336→\\topenRepoSpan.End()\\n   337→\\n   338→\\t_, findSessionsSpan := perf.Start(ctx, \\\"find_sessions_for_worktree\\\")\\n   339→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   340→\\tif err != nil {\\n   341→\\t\\tfindSessionsSpan.End()\\n   342→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   343→\\t}\\n   344→\\n   345→\\t// Find all active sessions for this worktree\\n   346→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   347→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   348→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   349→\\tif err != nil || len(sessions) == 0 {\\n   350→\\t\\tfindSessionsSpan.End()\\n   351→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   352→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   353→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   354→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   355→\\t\\t)\\n   356→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   357→\\t}\\n   358→\\tfindSessionsSpan.End()\\n   359→\\n   360→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   361→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   362→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   363→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   364→\\t// add the trailer directly.\\n   365→\\tif !hasTTY() {\\n   366→\\t\\tfor _, state := range sessions {\\n   367→\\t\\t\\tif state.Phase.IsActive() {\\n   368→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   369→\\t\\t\\t}\\n   370→\\t\\t}\\n   371→\\t}\\n   372→\\n   373→\\t// Check if any sessi