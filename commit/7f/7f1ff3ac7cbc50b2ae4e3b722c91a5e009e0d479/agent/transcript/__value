rue\\n    49→\\ts.duration = time.Since(s.start)\\n    50→\\n    51→\\t// Only root spans emit log output\\n    52→\\tif s.parent != nil {\\n    53→\\t\\treturn\\n    54→\\t}\\n    55→\\n    56→\\t// Build log attributes: component, op, duration_ms, then child step durations\\n    57→\\tattrs := make([]any, 0, 3+len(s.children)+len(s.attrs))\\n    58→\\tattrs = append(attrs, slog.String(\\\"component\\\", \\\"perf\\\"))\\n    59→\\tattrs = append(attrs, slog.String(\\\"op\\\", s.name))\\n    60→\\tattrs = append(attrs, slog.Int64(\\\"duration_ms\\\", s.duration.Milliseconds()))\\n    61→\\n    62→\\t// Add child step durations as flat keys\\n    63→\\tfor _, child := range s.children {\\n    64→\\t\\t// Auto-end children that were not explicitly ended\\n    65→\\t\\tif !child.ended {\\n    66→\\t\\t\\tchild.ended = true\\n    67→\\t\\t\\tchild.duration = time.Since(child.start)\\n    68→\\t\\t}\\n    69→\\t\\tkey := fmt.Sprintf(\\\"steps.%s_ms\\\", child.name)\\n    70→\\t\\tattrs = append(attrs, slog.Int64(key, child.duration.Milliseconds()))\\n    71→\\t}\\n    72→\\n    73→\\t// Add any extra attributes from Start()\\n    74→\\tfor _, a := range s.attrs {\\n    75→\\t\\tattrs = append(attrs, a)\\n    76→\\t}\\n    77→\\n    78→\\tlogging.Debug(s.ctx, \\\"perf\\\", attrs...)\\n    79→}\\n    80→\\n    81→// Measure times a function as a child substep of this span.\\n    82→func (s *Span) Measure(name string, fn func()) {\\n    83→\\tctx := contextWithSpan(s.ctx, s)\\n    84→\\t_, child := Start(ctx, name)\\n    85→\\tfn()\\n    86→\\tchild.End()\\n    87→}\\n    88→\"}]},\"uuid\":\"b24a5e85-00dd-4947-8f91-ddf6710050fe\",\"timestamp\":\"2026-03-04T22:41:12.293Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a063b227087435b38\"},\"toolUseID\":\"agent_msg_01HtmDDLuEniSsoimi53M5cW\",\"parentToolUseID\":\"toolu_01Fx78q7HjzgFctguZnZVm2M\",\"uuid\":\"0d6ca92f-199c-49da-8d1f-1ecb190adf81\",\"timestamp\":\"2026-03-04T22:41:12.604Z\"}