 err := repo.Head()\\n   731→\\tif err != nil {\\n   732→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   733→\\t}\\n   734→\\n   735→\\tcommit, err := repo.CommitObject(head.Hash())\\n   736→\\tif err != nil {\\n   737→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   738→\\t}\\n   739→\\n   740→\\t// Check if commit has checkpoint trailer (ParseCheckpoint validates format)\\n   741→\\tcheckpointID, found := trailers.ParseCheckpoint(commit.Message)\\n   742→\\tif !found {\\n   743→\\t\\t// No trailer — user removed it or it was never added (mid-turn commit).\\n   744→\\t\\t// Still update BaseCommit for active sessions so future commits can match.\\n   745→\\t\\ts.postCommitUpdateBaseCommitOnly(ctx, head)\\n   746→\\t\\treturn nil\\n   747→\\t}\\n   748→\\n   749→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   750→\\tif err != nil {\\n   751→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   752→\\t}\\n   753→\\n   754→\\t// Find all active sessions for this worktree\\n   755→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   756→\\tif err != nil || len(sessions) == 0 {\\n   757→\\t\\tlogging.Warn(logCtx, \\\"post-commit: no active sessions despite trailer\\\",\\n   758→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   759→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   760→\\t\\t)\\n   761→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   762→\\t}\\n   763→\\n   764→\\t// Build transition context\\n   765→\\tisRebase := isGitSequenceOperation(ctx)\\n   766→\\ttransitionCtx := session.TransitionContext{\\n   767→\\t\\tIsRebaseInProgress: isRebase,\\n   768→\\t}\\n   769→\\n   770→\\tif isRebase {\\n   771→\\t\\tlogging.Debug(logCtx, \\\"post-commit: rebase/sequence in progress, skipping phase transitions\\\",\\n   772→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   773→\\t\\t)\\n   774→\\t}\\n   775→\\n   776→\\t// Track shadow branch names and whether they can be deleted\\n   777→\\tshadowBranchesToDelete := make(map[string]struct{})\\n   778→\\t// Track active sessions that were NOT condensed — their shadow branches must be preserved\\n   779→\\tuncondensedActiveOnBranch := make(map[string]bool)\\n   780→\\n   781→\\tnewHead := head.Hash().String()\\n   782→\\n   783→\\t// Pre-resolve HEAD tree and parent tree once for the entire PostCommit.\\n   784→\\t// These are immutable within this hook invocation and used by multiple\\n   785→\\t// per-session functions (filesChangedInCommit, filesOverlapWithContent,\\n   786→\\t// filesWithRemainingAgentChanges, calculateSessionAttributions).\\n   787→\\tvar headTree *object.Tree\\n   788→\\tif t, err := commit.Tree(); err == nil {\\n   789→\\t\\theadTree = t\\n   790→\\t}\\n   791→\\tvar parentTree *object.Tree\\n   792→\\tif commit.NumParents() > 0 {\\n   793→\\t\\tif parent, err := commit.Parent(0); err == nil {\\n   794→\\t\\t\\tif t, err := parent.Tree(); err == nil {\\n   795→\\t\\t\\t\\tparentTree = t\\n   796→\\t\\t\\t}\\n   797→\\t\\t}\\n   798→\\t}\\n   799→\\n   800→\\tcommittedFileSet := filesChangedInCommit(commit, headTree, parentTree)\\n   801→\\n   802→\\tfor _, state := range sessions {\\n   803→\\t\\t// Skip fully-condensed ended sessions — no work remains.\\n   804→\\t\\t// These sessions only persist for LastCheckpointID (amend trailer reuse).\\n   805→\\t\\tif state.FullyCondensed && state.Phase == session.PhaseEnded {\\n   806→\\t\\t\\tcontinue\\n   807→\\t\\t}\\n   808→\\t\\ts.postCommitProcessSession(ctx, repo, state, &transitionCtx, checkpointID,\\n   809→\\t\\t\\thead, commit, newHead, headTree, parentTree, committedFileSet,\\n   810→\\t\\t\\tshadowBranchesToDelete, uncondensedActiveOnBranch)\\n   811→\\t}\\n   812→\\n   813→\\t// Clean up shadow branches — only delete when ALL sessions on the branch are non-active\\n   814→\\t// or were condensed during this PostCommit.\\n   815→\\tfor shadowBranchName := range shadowBranchesToDelete {\\n   816→\\t\\tif uncondensedActiveOnBranch[shadowBranchName] {\\n   817→\\t\\t\\tlogging.Debug(logCtx, \\\"post-commit: preserving shadow branch (active session exists)\\\",\\n   818→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   819→\\t\\t\\t)\\n   820→\\t\\t\\tcontinue\\n   821→\\t\\t}\\n   822→\\t\\tif err := deleteShadowBranch(ctx, repo, shadowBranchName); err != nil {\\n   823→\\t\\t\\tlogging.Warn(logCtx, \\\"failed to clean up shadow branch\\\",\\n   824→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   825→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()))\\n   826→\\t\\t} else {\\n   827→\\t\\t\\tlogging.Info(logCtx, \\\"shadow branch deleted\\\",\\n   828→\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   829→\\t\\t\\t\\tslog.String(\\\"shadow_branch\\\", shadowBranchName),\\n   830→\\t\\t\\t)\\n   831→\\t\\t}\\n   832→\\t}\\n   833→\\n   834→\\treturn nil\\n   835→}\\n   836→\\n   837→// postCommitProcessSession handles a single session within the PostCommit loop.\\n   838→// Pre-resolved git objects (headTree, parentTree) are shared across all sessions;\\n   839→// per-session shadow ref/tree are resolved once here and threaded through sub-calls.\\n   840→func (s *ManualCommitStrategy) postCommitProcessSession(\\n   841→\\tctx context.Context,\\n   842→\\trepo *git.Repository,\\n   843→\\tstate *SessionState,\\n   844→\\ttransitionCtx *session.TransitionContext,\\n   845→\\tcheckpointID id.CheckpointID,\\n   846→\\thead *plumbing.Reference,\\n   847→\\tcommit *object.Commit,\\n   848→\\tnewHead string,\\n   849→\\theadTree, parentTree *object.Tree,\\n   850→\\tcommittedFileSet map[string]struct{},\\n   851→\\tshadowBranchesToDelete map[string]struct{},\\n   852→\\tuncondensedActiveOnBranch map[string]bool,\\n   853→) {\\n   854→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   855→\\tshadowBranchName := getShadowBranchNameForCommit(state.BaseCommit, state.WorktreeID)\\n   856→\\n   857→\\t// Pre-resolve shadow branch ref and tree for this session.\\n   858→\\t// These are read 4+ times across sessionHasNewContent, filesOverlapWithContent,\\n   859→\\t// CondenseSession, filesWithRemainingAgentChanges, and calculateSessionAttributions.\\n   860→\\tvar shadowRef *plumbing.Reference\\n   861→\\tvar shadowTree *object.Tree\\n   862→\\tif ref, refErr := repo.Reference(plumbing.NewBranchReferenceName(shadowBranchName), true); refErr == nil {\\n   863→\\t\\tshadowRef = ref\\n   864→\\t\\tif sc, scErr := repo.CommitObject(ref.Hash()); scErr == nil {\\n   865→\\t\\t\\tif st, stErr := sc.Tree(); stErr == nil {\\n   866→\\t\\t\\t\\tshadowTree = st\\n   867→\\t\\t\\t}\\n   868→\\t\\t}\\n   869→\\t}\\n   870→\\n   871→\\t// Check for new content (needed for TransitionContext and condensation).\\n   872→\\t// Fail-open: if content check errors, assume new content exists so we\\n   873→\\t// don't silently skip data that should have been condensed.\\n   874→\\t//\\n   875→\\t// For ACTIVE sessions: the commit has a checkpoint trailer (verified above),\\n   876→\\t// meaning PrepareCommitMsg already determined this commit is session-related.\\n   877→\\t// The trailer is only added when either:\\n   878→\\t//   - No TTY (agent/subagent committing) — added unconditionally\\n   879→\\t//   - TTY (human committing) — added after content detection confirmed agent work\\n   880→\\t// In both cases, PrepareCommitMsg already validated this commit. We trust\\n   881→\\t// that decision here. Transcript-based re-validation is unreliable because\\n   882→\\t// subagent transcripts may not be available yet (subagent still running).\\n   883→\\tvar hasNew bool\\n   884→\\tif state.Phase.IsActive() {\\n   885→\\t\\thasNew = true\\n   886→\\t} else {\\n   887→\\t\\tvar contentErr error\\n   888→\\t\\thasNew, contentErr = s.sessionHasNewContent(ctx, repo, state, contentCheckOpts{shadowTree: shadowT