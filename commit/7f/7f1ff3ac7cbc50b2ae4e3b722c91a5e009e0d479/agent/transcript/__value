\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   122→\\t\\t\\t\\tslog.String(\\\"strategy\\\", strategyName),\\n   123→\\t\\t\\t)\\n   124→\\n   125→\\t\\t\\t// Set the current hook agent so handlers can retrieve it\\n   126→\\t\\t\\tcurrentHookAgentName = agentName\\n   127→\\t\\t\\tdefer func() { currentHookAgentName = \\\"\\\" }()\\n   128→\\n   129→\\t\\t\\t// Use the lifecycle dispatcher for all hooks\\n   130→\\t\\t\\tvar hookErr error\\n   131→\\t\\t\\tag, agentErr := agent.Get(agentName)\\n   132→\\t\\t\\tif agentErr != nil {\\n   133→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to get agent %q: %w\\\", agentName, agentErr)\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\thandler, ok := ag.(agent.HookSupport)\\n   137→\\t\\t\\tif !ok {\\n   138→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent %q does not support hooks\\\", agentName)\\n   139→\\t\\t\\t}\\n   140→\\n   141→\\t\\t\\t// Use cmd.InOrStdin() to support testing with cmd.SetIn()\\n   142→\\t\\t\\tevent, parseErr := handler.ParseHookEvent(ctx, hookName, cmd.InOrStdin())\\n   143→\\t\\t\\tif parseErr != nil {\\n   144→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hook event: %w\\\", parseErr)\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\tif event != nil {\\n   148→\\t\\t\\t\\t// Lifecycle event — use the generic dispatcher\\n   149→\\t\\t\\t\\thookErr = DispatchLifecycleEvent(ctx, ag, event)\\n   150→\\t\\t\\t} else if agentName == agent.AgentNameClaudeCode && hookName == claudecode.HookNamePostTodo {\\n   151→\\t\\t\\t\\t// PostTodo is Claude-specific: creates incremental checkpoints during subagent execution\\n   152→\\t\\t\\t\\thookErr = handleClaudeCodePostTodo(ctx)\\n   153→\\t\\t\\t}\\n   154→\\t\\t\\t// Other pass-through hooks (nil event, no special handling) are no-ops\\n   155→\\n   156→\\t\\t\\tlogging.LogDuration(ctx, slog.LevelDebug, \\\"hook completed\\\", start,\\n   157→\\t\\t\\t\\tslog.String(\\\"hook\\\", hookName),\\n   158→\\t\\t\\t\\tslog.String(\\\"hook_type\\\", hookType),\\n   159→