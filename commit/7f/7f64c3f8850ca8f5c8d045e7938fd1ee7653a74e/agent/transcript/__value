/ SimulateGeminiSessionEnd simulates the SessionEnd hook for Gemini CLI.\\n   633→// This is a cleanup/fallback hook that fires on explicit exit.\\n   634→func (r *GeminiHookRunner) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   635→\\tr.T.Helper()\\n   636→\\n   637→\\tinput := map[string]string{\\n   638→\\t\\t\\\"session_id\\\":      sessionID,\\n   639→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   640→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   641→\\t\\t\\\"hook_event_name\\\": \\\"SessionEnd\\\",\\n   642→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   643→\\t\\t\\\"reason\\\":          \\\"exit\\\",\\n   644→\\t}\\n   645→\\n   646→\\treturn r.runGeminiHookWithInput(\\\"session-end\\\", input)\\n   647→}\\n   648→\\n   649→// GeminiSession represents a simulated Gemini CLI session.\\n   650→type GeminiSession struct {\\n   651→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   652→\\tTranscriptPath string\\n   653→\\tenv            *TestEnv\\n   654→}\\n   655→\\n   656→// NewGeminiSession creates a new simulated Gemini session.\\n   657→func (env *TestEnv) NewGeminiSession() *GeminiSession {\\n   658→\\tenv.T.Helper()\\n   659→\\n   660→\\tenv.SessionCounter++\\n   661→\\tsessionID := fmt.Sprintf(\\\"gemini-session-%d\\\", env.SessionCounter)\\n   662→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".json\\\")\\n   663→\\n   664→\\treturn &GeminiSession{\\n   665→\\t\\tID:             sessionID,\\n   666→\\t\\tTranscriptPath: transcriptPath,\\n   667→\\t\\tenv:            env,\\n   668→\\t}\\n   669→}\\n   670→\\n   671→// CreateGeminiTranscript creates a Gemini JSON transcript file for the session.\\n   672→func (s *GeminiSession) CreateGeminiTranscript(prompt string, changes []FileChange) string {\\n   673→\\t// Build Gemini-format transcript (JSON, not JSONL)\\n   674→\\tmessages := []map[string]interface{}{\\n   675→\\t\\t{\\n   676→\\t\\t\\t\\\"type\\\":    \\\"user\\\",\\n   677→\\t\\t\\t\\\"content\\\": prompt,\\n   678→\\t\\t},\\n   679→\\t\\t{\\n   680→\\t\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   681→\\t\\t\\t\\\"content\\\": \\\"I'll help you with that.\\\",\\n   682→\\t\\t},\\n   683→\\t}\\n   684→\\n   685→\\tfor _, change := range changes {\\n   686→\\t\\tmessages = append(messages, map[string]interface{}{\\n   687→\\t\\t\\t\\\"type\\\": \\\"tool_use\\\",\\n   688→\\t\\t\\t\\\"name\\\": \\\"write_file\\\",\\n   689→\\t\\t\\t\\\"input\\\": map[string]string{\\n   690→\\t\\t\\t\\t\\\"path\\\":    change.Path,\\n   691→\\t\\t\\t\\t\\\"content\\\": change.Content,\\n   692→\\t\\t\\t},\\n   693→\\t\\t})\\n   694→\\t\\tmessages = append(messages, map[string]interface{}{\\n   695→\\t\\t\\t\\\"type\\\":   \\\"tool_result\\\",\\n   696→\\t\\t\\t\\\"output\\\": \\\"File written successfully\\\",\\n   697→\\t\\t})\\n   698→\\t}\\n   699→\\n   700→\\tmessages = append(messages, map[string]interface{}{\\n   701→\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   702→\\t\\t\\\"content\\\": \\\"Done!\\\",\\n   703→\\t})\\n   704→\\n   705→\\ttranscript := map[string]interface{}{\\n   706→\\t\\t\\\"sessionId\\\": s.ID,\\n   707→\\t\\t\\\"messages\\\":  messages,\\n   708→\\t}\\n   709→\\n   710→\\t// Ensure directory exists\\n   711→\\tif err := os.MkdirAll(filepath.Dir(s.TranscriptPath), 0o755); err != nil {\\n   712→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript dir: %v\\\", err)\\n   713→\\t}\\n   714→\\n   715→\\t// Write transcript\\n   716→\\tdata, err := json.MarshalIndent(transcript, \\\"\\\", \\\"  \\\")\\n   717→\\tif err != nil {\\n   718→\\t\\ts.env.T.Fatalf(\\\"failed to marshal transcript: %v\\\", err)\\n   719→\\t}\\n   720→\\tif err := os.WriteFile(s.TranscriptPath, data, 0o644); err != nil {\\n   721→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   722→\\t}\\n   723→\\n   724→\\treturn s.TranscriptPath\\n   725→}\\n   726→\\n   727→// SimulateGemini