.Stdout = &stdout\\n   399→\\tcmd.Stderr = &stderr\\n   400→\\n   401→\\terr := cmd.Run()\\n   402→\\treturn HookOutput{\\n   403→\\t\\tStdout: stdout.Bytes(),\\n   404→\\t\\tStderr: stderr.Bytes(),\\n   405→\\t\\tErr:    err,\\n   406→\\t}\\n   407→}\\n   408→\\n   409→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output.\\n   410→func (r *HookRunner) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   411→\\tr.T.Helper()\\n   412→\\n   413→\\tinput := map[string]string{\\n   414→\\t\\t\\\"session_id\\\":      sessionID,\\n   415→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   416→\\t}\\n   417→\\n   418→\\tinputJSON, err := json.Marshal(input)\\n   419→\\tif err != nil {\\n   420→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   421→\\t}\\n   422→\\n   423→\\treturn r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n   424→}\\n   425→\\n   426→// SimulateUserPromptSubmitWithOutput is a convenience method on TestEnv.\\n   427→func (env *TestEnv) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   428→\\tenv.T.Helper()\\n   429→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   430→\\treturn runner.SimulateUserPromptSubmitWithOutput(sessionID)\\n   431→}\\n   432→\\n   433→// SimulateSessionStartWithOutput simulates the SessionStart hook and returns the output.\\n   434→func (r *HookRunner) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n   435→\\tr.T.Helper()\\n   436→\\n   437→\\tinput := map[string]string{\\n   438→\\t\\t\\\"session_id\\\":      sessionID,\\n   439→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   440→\\t}\\n   441→\\n   442→\\tinputJSON, err := json.Marshal(input)\\n   443→\\tif err != nil {\\n   444→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   445→\\t}\\n   446→\\n   447→\\treturn r.runHookWithOutput(\\\"session-start\\\", inputJSON