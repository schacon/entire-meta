 for the given repo directory.\\n   769→func NewOpenCodeHookRunner(repoDir, openCodeProjectDir string, t interface {\\n   770→\\tHelper()\\n   771→\\tFatalf(format string, args ...interface{})\\n   772→\\tLogf(format string, args ...interface{})\\n   773→}) *OpenCodeHookRunner {\\n   774→\\treturn &OpenCodeHookRunner{\\n   775→\\t\\tRepoDir:            repoDir,\\n   776→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n   777→\\t\\tT:                  t,\\n   778→\\t}\\n   779→}\\n   780→\\n   781→func (r *OpenCodeHookRunner) runOpenCodeHookWithInput(hookName string, input interface{}) error {\\n   782→\\tr.T.Helper()\\n   783→\\n   784→\\tinputJSON, err := json.Marshal(input)\\n   785→\\tif err != nil {\\n   786→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   787→\\t}\\n   788→\\n   789→\\treturn r.runOpenCodeHookInRepoDir(hookName, inputJSON)\\n   790→}\\n   791→\\n   792→func (r *OpenCodeHookRunner) runOpenCodeHookInRepoDir(hookName string, inputJSON []byte) error {\\n   793→\\t// Command structure: entire hooks opencode <hook-name>\\n   794→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"opencode\\\", hookName)\\n   795→\\tcmd.Dir = r.RepoDir\\n   796→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   797→\\tcmd.Env = append(os.Environ(),\\n   798→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+r.OpenCodeProjectDir,\\n   799→\\t\\t\\\"ENTIRE_TEST_OPENCODE_MOCK_EXPORT=1\\\", // Use pre-written mock transcript instead of calling opencode export\\n   800→\\t)\\n   801→\\n   802→\\toutput, err := cmd.CombinedOutput()\\n   803→\\tif err != nil {\\n   804→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   805→\\t\\t\\thookName, err, inputJSON, output)\\n   806→\\t}\\n   807→\\n   808→\\tr.T.Logf(\\\"OpenCode hook %s output: %s\\\", hookName, output)\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// SimulateOpenCodeSessionStart simulates the session-start hook for OpenCode.\\n   813→// Note: The plugin now sends only session_id, not transcript_path.\\n   814→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionStart(sessionID, _ string) error {\\n   815→\\tr.T.Helper()\\n   816→\\n   817→\\tinput := map[string]string{\\n   818→\\t\\t\\\"session_id\\\": sessionID,\\n   819→\\t}\\n   820→\\n   821→\\treturn r.runOpenCodeHookWithInput(\\\"session-start\\\", input)\\n   822→}\\n   823→\\n   824→// SimulateOpenCodeTurnStart simulates the turn-start hook for OpenCode.\\n   825→// This is equivalent to Claude Code's UserPromptSubmit.\\n   826→// Note: The plugin now sends only session_id and prompt, not transcript_path.\\n   827→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnStart(sessionID, _, prompt string) error {\\n   828→\\tr.T.Helper()\\n   829→\\n   830→\\tinput := map[string]string{\\n   831→\\t\\t\\\"session_id\\\": sessionID,\\n   832→\\t\\t\\\"prompt\\\":     prompt,\\n   833→\\t}\\n   834→\\n   835→\\treturn r.runOpenCodeHookWithInput(\\\"turn-start\\\", input)\\n   836→}\\n   837→\\n   838→// SimulateOpenCodeTurnEnd simulates the turn-end hook for OpenCode.\\n   839→// This is equivalent to Claude Code's Stop hook.\\n   840→// Note: The plugin now sends only session_id. The Go handler calls `opencode export`\\n   841→// to get the transcript. For tests, we write a mock export JSON file first.\\n   842→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n   843→\\tr.T.Helper()\\n   844→\\n   845→\\t// For integration tests, write the mock transcript to the location where the\\n   846→\\t// lifecycle handler expects it (.entire/tmp/<session_id>.json)\\n   847→\\tif transcriptPath != \\\"\\\" {\\n   848→\\t\\tsrcData, err := os.ReadFile(transcriptPath)\\n   849→\\t\\tif err != nil {\\n   850→\\t\\t\\tr.T.Fatalf(\\\"SimulateOpenCodeTurnEnd: failed to read transcript from %q: %v\\\", transcriptPath, err)\\n   851→\\t\\t}\\n   852→\\t\\tdestDir := filepath.Join(r.RepoDir, \\\".entire\\\", \\\"tmp\\\")\\n   853→\\