→\\tif err != nil {\\n   492→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   493→\\t}\\n   494→\\n   495→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   496→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   497→\\t}\\n   498→\\treturn nil\\n   499→}\\n   500→\\n   501→// GeminiHookRunner executes Gemini CLI hooks in the test environment.\\n   502→type GeminiHookRunner struct {\\n   503→\\tRepoDir          string\\n   504→\\tGeminiProjectDir string\\n   505→\\tT                interface {\\n   506→\\t\\tHelper()\\n   507→\\t\\tFatalf(format string, args ...interface{})\\n   508→\\t\\tLogf(format string, args ...interface{})\\n   509→\\t}\\n   510→}\\n   511→\\n   512→// NewGeminiHookRunner creates a new Gemini hook runner for the given repo directory.\\n   513→func NewGeminiHookRunner(repoDir, geminiProjectDir string, t interface {\\n   514→\\tHelper()\\n   515→\\tFatalf(format string, args ...interface{})\\n   516→\\tLogf(format string, args ...interface{})\\n   517→}) *GeminiHookRunner {\\n   518→\\treturn &GeminiHookRunner{\\n   519→\\t\\tRepoDir:          repoDir,\\n   520→\\t\\tGeminiProjectDir: geminiProjectDir,\\n   521→\\t\\tT:                t,\\n   522→\\t}\\n   523→}\\n   524→\\n   525→// runGeminiHookWithInput runs a Gemini hook with the given input.\\n   526→func (r *GeminiHookRunner) runGeminiHookWithInput(hookName string, input interface{}) error {\\n   527→\\tr.T.Helper()\\n   528→\\n   529→\\tinputJSON, err := json.Marshal(input)\\n   530→\\tif err != nil {\\n   531→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   532→\\t}\\n   533→\\n   534→\\treturn r.runGeminiHookInRepoDir(hookName, inputJSON)\\n   535→}\\n   536→\\n   537→func (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n   538→\\t// Run using the shared test binary\\n   539→\\t// Command structure: entire hooks gemini <hook-name>\\n   540→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   541→\\tcmd.Dir = r.RepoDir\\n   542→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   543→\\tcmd.Env = append(os.Environ(),\\n   544→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   545→\\t)\\n   546→\\n   547→\\toutput, err := cmd.CombinedOutput()\\n   548→\\tif err != nil {\\n   549→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   550→\\t\\t\\thookName, err, inputJSON, output)\\n   551→\\t}\\n   552→\\n   553→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   554→\\treturn nil\\n   555→}\\n   556→\\n   557→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   558→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   559→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   560→\\tcmd.Dir = r.RepoDir\\n   561→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   562→\\tcmd.Env = append(os.Environ(),\\n   563→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   564→\\t)\\n   565→\\n   566→\\tvar stdout, stderr bytes.Buffer\\n   567→\\tcmd.Stdout = &stdout\\n   568→\\tcmd.Stderr = &stderr\\n   569→\\n   570→\\terr := cmd.Run()\\n   571→\\treturn HookOutput{\\n   572→\\t\\tStdout: stdout.Bytes(),\\n   573→\\t\\tStderr: stderr.Bytes(),\\n   574→\\t\\tErr:    err,\\n   575→\\t}\\n   576→}\\n   577→\\n   578→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   579→// This is equivalent to Claude Code's UserPromptSubmit.\\n   580→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   581→\\tr.T.Helper()\\n   582→\\n   583→\\tinput := map[string]string{\\n   584→\\t\\t\\\"session_id\\\":      sessionID,\\n   585→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   586→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   587→\\t\\t\\\"hook_event_