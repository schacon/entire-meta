shal transcript: %v\\\", err)\\n   984→\\t}\\n   985→\\tif err := os.WriteFile(s.TranscriptPath, data, 0o644); err != nil {\\n   986→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   987→\\t}\\n   988→\\n   989→\\treturn s.TranscriptPath\\n   990→}\\n   991→\\n   992→// SimulateOpenCodeSessionStart is a convenience method on TestEnv.\\n   993→func (env *TestEnv) SimulateOpenCodeSessionStart(sessionID, transcriptPath string) error {\\n   994→\\tenv.T.Helper()\\n   995→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n   996→\\treturn runner.SimulateOpenCodeSessionStart(sessionID, transcriptPath)\\n   997→}\\n   998→\\n   999→// SimulateOpenCodeTurnStart is a convenience method on TestEnv.\\n  1000→func (env *TestEnv) SimulateOpenCodeTurnStart(sessionID, transcriptPath, prompt string) error {\\n  1001→\\tenv.T.Helper()\\n  1002→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n  1003→\\treturn runner.SimulateOpenCodeTurnStart(sessionID, transcriptPath, prompt)\\n  1004→}\\n  1005→\\n  1006→// SimulateOpenCodeTurnEnd is a convenience method on TestEnv.\\n  1007→func (env *TestEnv) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n  1008→\\tenv.T.Helper()\\n  1009→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n  1010→\\treturn runner.SimulateOpenCodeTurnEnd(sessionID, transcriptPath)\\n  1011→}\\n  1012→\\n  1013→// SimulateOpenCodeSessionEnd is a convenience method on TestEnv.\\n  1014→func (env *TestEnv) SimulateOpenCodeSessionEnd(sessionID, transcriptPath string) error {\\n  1015→\\tenv.T.Helper()\\n  1016→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n  1017→\\treturn runner.SimulateOpenCodeSessionEnd(sessionID, transcriptPath)\\n  1018→}\\n  1019→\\n  1020→// CopyTranscriptToEntireTmp copies an OpenCode transcript to .entire/tmp/<sessionID>.json.\\n  1021→// This simulates what `opencode export` doe