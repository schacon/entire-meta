5→\\t\\t\\treturn nil\\n   366→\\t\\t}\\n   367→\\n   368→\\t\\tcontents, err := f.Contents()\\n   369→\\t\\tif err != nil {\\n   370→\\t\\t\\treturn fmt.Errorf(\\\"failed to read file %s: %w\\\", f.Name, err)\\n   371→\\t\\t}\\n   372→\\n   373→\\t\\t// Ensure directory exists\\n   374→\\t\\tdir := filepath.Dir(f.Name)\\n   375→\\t\\tif dir != \\\".\\\" {\\n   376→\\t\\t\\t//nolint:gosec // G301: Need 0o755 for user directories during rewind\\n   377→\\t\\t\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n   378→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to create directory %s: %w\\\", dir, err)\\n   379→\\t\\t\\t}\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\t// Write file with appropriate permissions\\n   383→\\t\\tvar perm os.FileMode = 0o644\\n   384→\\t\\tif f.Mode == filemode.Executable {\\n   385→\\t\\t\\tperm = 0o755\\n   386→\\t\\t}\\n   387→\\t\\tif err := os.WriteFile(f.Name, []byte(contents), perm); err != nil {\\n   388→\\t\\t\\treturn fmt.Errorf(\\\"failed to write file %s: %w\\\", f.Name, err)\\n   389→\\t\\t}\\n   390→\\n   391→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Restored: %s\\\\n\\\", f.Name)\\n   392→\\t\\treturn nil\\n   393→\\t})\\n   394→\\tif err != nil {\\n   395→\\t\\treturn fmt.Errorf(\\\"failed to iterate tree files: %w\\\", err)\\n   396→\\t}\\n   397→\\n   398→\\tfmt.Println()\\n   399→\\tif len(point.ID) >= 7 {\\n   400→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID[:7])\\n   401→\\t} else {\\n   402→\\t\\tfmt.Printf(\\\"Restored files from shadow commit %s\\\\n\\\", point.ID)\\n   403→\\t}\\n   404→\\tfmt.Println()\\n   405→\\n   406→\\treturn nil\\n   407→}\\n   408→\\n   409→// resetShadowBranchToCheckpoint resets the shadow branch HEAD to the given checkpoint.\\n   410→// This ensures that when the user commits after rewinding, the next checkpoint will only\\n   411→// include prompts from the rewound point, not prompts from later checkpoints.\\n   412→func (s *ManualCommitStrategy) resetShadowBranchToCheck