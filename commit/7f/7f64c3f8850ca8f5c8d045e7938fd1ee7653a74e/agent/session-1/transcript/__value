ROJECT_DIR via cmd.Env instead\\n    91→\\n    92→\\treturn env\\n    93→}\\n    94→\\n    95→// Cleanup is a no-op retained for backwards compatibility.\\n    96→//\\n    97→// Previously this method restored the working directory after NewTestEnv changed it.\\n    98→// With the refactor to remove os.Chdir from NewTestEnv:\\n    99→// - Temp directories are now cleaned up automatically by t.TempDir()\\n   100→// - Working directory is never changed, so no restoration is needed\\n   101→//\\n   102→// This method is kept to avoid breaking existing tests that call defer env.Cleanup().\\n   103→// New tests should not call this method as it serves no purpose.\\n   104→//\\n   105→// Deprecated: This method is a no-op and will be removed in a future version.\\n   106→func (env *TestEnv) Cleanup() {\\n   107→\\t// No-op - temp dirs are cleaned up by t.TempDir()\\n   108→}\\n   109→\\n   110→// cliEnv returns the environment variables for CLI execution.\\n   111→// Includes Claude, Gemini, and OpenCode project dirs so tests work for any agent.\\n   112→func (env *TestEnv) cliEnv() []string {\\n   113→\\treturn append(os.Environ(),\\n   114→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+env.ClaudeProjectDir,\\n   115→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+env.GeminiProjectDir,\\n   116→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+env.OpenCodeProjectDir,\\n   117→\\t\\t\\\"ENTIRE_TEST_TTY=0\\\", // Prevent interactive prompts from blocking in tests\\n   118→\\t)\\n   119→}\\n   120→\\n   121→// RunCLI runs the entire CLI with the given arguments and returns stdout.\\n   122→func (env *TestEnv) RunCLI(args ...string) string {\\n   123→\\tenv.T.Helper()\\n   124→\\toutput, err := env.RunCLIWithError(args...)\\n   125→\\tif err != nil {\\n   126→\\t\\tenv.T.Fatalf(\\\"CLI command failed: %v\\\\nArgs: %v\\\\nOutput: %s\\\", err, args, output)\\n   127→\\t}\\n   128→\\treturn output\\n   129→}\\n   130→\\n   131→// RunCLIWithError runs the entire CLI and returns outpu