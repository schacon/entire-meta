de session-end hook.\\n   121→// This transitions a session from IDLE (or ACTIVE) to ENDED phase.\\n   122→func (r *HookRunner) SimulateSessionEnd(sessionID string) error {\\n   123→\\tr.T.Helper()\\n   124→\\n   125→\\tinput := map[string]string{\\n   126→\\t\\t\\\"session_id\\\":      sessionID,\\n   127→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   128→\\t}\\n   129→\\n   130→\\treturn r.runHookWithInput(\\\"session-end\\\", input)\\n   131→}\\n   132→\\n   133→// PreTaskInput contains the input for PreToolUse[Task] hook.\\n   134→type PreTaskInput struct {\\n   135→\\tSessionID      string\\n   136→\\tTranscriptPath string\\n   137→\\tToolUseID      string\\n   138→\\tSubagentType   string // Optional: type of subagent (e.g., \\\"dev\\\", \\\"reviewer\\\")\\n   139→\\tDescription    string // Optional: task description\\n   140→}\\n   141→\\n   142→// SimulatePreTask simulates the PreToolUse[Task] hook.\\n   143→func (r *HookRunner) SimulatePreTask(sessionID, transcriptPath, toolUseID string) error {\\n   144→\\tr.T.Helper()\\n   145→\\n   146→\\treturn r.SimulatePreTaskWithInput(PreTaskInput{\\n   147→\\t\\tSessionID:      sessionID,\\n   148→\\t\\tTranscriptPath: transcriptPath,\\n   149→\\t\\tToolUseID:      toolUseID,\\n   150→\\t})\\n   151→}\\n   152→\\n   153→// SimulatePreTaskWithInput simulates the PreToolUse[Task] hook with full input.\\n   154→func (r *HookRunner) SimulatePreTaskWithInput(input PreTaskInput) error {\\n   155→\\tr.T.Helper()\\n   156→\\n   157→\\thookInput := map[string]interface{}{\\n   158→\\t\\t\\\"session_id\\\":      input.SessionID,\\n   159→\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n   160→\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n   161→\\t\\t\\\"tool_input\\\": map[string]string{\\n   162→\\t\\t\\t\\\"subagent_type\\\": input.SubagentType,\\n   163→\\t\\t\\t\\\"description\\\":   input.Description,\\n   164→\\t\\t},\\n   165→\\t}\\n   166→\\n   167→\\treturn r.runHookWithInput(\\\"pre-task\\\", hookInput)\\