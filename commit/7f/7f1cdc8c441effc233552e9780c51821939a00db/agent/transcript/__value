  359→\\t// Build a Droid transcript with non-message entries interspersed:\\n   360→\\t// Line 0: session_start (non-message)\\n   361→\\t// Line 1: user message (no tokens)\\n   362→\\t// Line 2: assistant message with 10 input, 20 output tokens\\n   363→\\t// Line 3: session_event (non-message)\\n   364→\\t// Line 4: assistant message with 5 input, 30 output tokens\\n   365→\\ttranscript := \\\"\\\" +\\n   366→\\t\\t`{\\\"type\\\":\\\"session_start\\\",\\\"id\\\":\\\"s1\\\"}` + \\\"\\\\n\\\" +\\n   367→\\t\\tdroidMessage(t, \\\"m1\\\", \\\"user\\\", nil) + \\\"\\\\n\\\" +\\n   368→\\t\\tdroidMessage(t, \\\"m2\\\", \\\"assistant\\\", map[string]int{\\n   369→\\t\\t\\t\\\"input_tokens\\\": 10, \\\"output_tokens\\\": 20,\\n   370→\\t\\t}) + \\\"\\\\n\\\" +\\n   371→\\t\\t`{\\\"type\\\":\\\"session_event\\\",\\\"data\\\":\\\"heartbeat\\\"}` + \\\"\\\\n\\\" +\\n   372→\\t\\tdroidMessage(t, \\\"m3\\\", \\\"assistant\\\", map[string]int{\\n   373→\\t\\t\\t\\\"input_tokens\\\": 5, \\\"output_tokens\\\": 30,\\n   374→\\t\\t}) + \\\"\\\\n\\\"\\n   375→\\n   376→\\tdata := []byte(transcript)\\n   377→\\n   378→\\t// With startOffset=0: should count all messages (m2 + m3)\\n   379→\\tusageAll := calculateTokenUsage(agent.AgentTypeFactoryAIDroid, data, 0)\\n   380→\\tif usageAll.InputTokens != 15 {\\n   381→\\t\\tt.Errorf(\\\"startOffset=0: InputTokens = %d, want 15\\\", usageAll.InputTokens)\\n   382→\\t}\\n   383→\\tif usageAll.OutputTokens != 50 {\\n   384→\\t\\tt.Errorf(\\\"startOffset=0: OutputTokens = %d, want 50\\\", usageAll.OutputTokens)\\n   385→\\t}\\n   386→\\tif usageAll.APICallCount != 2 {\\n   387→\\t\\tt.Errorf(\\\"startOffset=0: APICallCount = %d, want 2\\\", usageAll.APICallCount)\\n   388→\\t}\\n   389→\\n   390→\\t// With startOffset=3: skip lines 0-2 (session_start, m1, m2).\\n   391→\\t// Only line 3 (session_event, filtered) and line 4 (m3) remain.\\n   392→\\t// Should count only m3's tokens.\\n   393→\\tusageFrom3 := calculateTokenUsage(agent.AgentTyp