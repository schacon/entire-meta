(\\\"failed to set repo config: %v\\\", err)\\n    57→\\t}\\n    58→}\\n    59→\\n    60→// WriteFile creates a file with the given content in the repo directory.\\n    61→// It creates parent directories as needed.\\n    62→func WriteFile(t *testing.T, repoDir, path, content string) {\\n    63→\\tt.Helper()\\n    64→\\n    65→\\tfullPath := filepath.Join(repoDir, path)\\n    66→\\n    67→\\t// Create parent directories\\n    68→\\tdir := filepath.Dir(fullPath)\\n    69→\\t//nolint:gosec // test code, permissions are intentionally standard\\n    70→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n    71→\\t\\tt.Fatalf(\\\"failed to create directory %s: %v\\\", dir, err)\\n    72→\\t}\\n    73→\\n    74→\\t//nolint:gosec // test code, permissions are intentionally standard\\n    75→\\tif err := os.WriteFile(fullPath, []byte(content), 0o644); err != nil {\\n    76→\\t\\tt.Fatalf(\\\"failed to write file %s: %v\\\", path, err)\\n    77→\\t}\\n    78→}\\n    79→\\n    80→// ReadFile reads a file from the repo directory.\\n    81→func ReadFile(t *testing.T, repoDir, path string) string {\\n    82→\\tt.Helper()\\n    83→\\n    84→\\tfullPath := filepath.Join(repoDir, path)\\n    85→\\t//nolint:gosec // test code, path is from test setup\\n    86→\\tdata, err := os.ReadFile(fullPath)\\n    87→\\tif err != nil {\\n    88→\\t\\tt.Fatalf(\\\"failed to read file %s: %v\\\", path, err)\\n    89→\\t}\\n    90→\\treturn string(data)\\n    91→}\\n    92→\\n    93→// TryReadFile reads a file from the repo directory, returning empty string if not found.\\n    94→func TryReadFile(t *testing.T, repoDir, path string) string {\\n    95→\\tt.Helper()\\n    96→\\n    97→\\tfullPath := filepath.Join(repoDir, path)\\n    98→\\t//nolint:gosec // test code, path is from test setup\\n    99→\\tdata, err := os.ReadFile(fullPath)\\n   100→\\tif err != nil {\\n   101→\\t\\treturn \\\"\\\"\\n   102→\\t}\\n   103→\\treturn string(data)\\n   104→}\\n   105→\\n   106→// FileExists checks if a file exists in the repo directory.\\n   107→func FileExists(repoDir, path string) bool {\\n   108→\\tfullPath := filepath.Join(repoDir, path)\\n   109→\\t_, err := os.Stat(fullPath)\\n   110→\\treturn err == nil\\n   111→}\\n   112→\\n   113→// GitAdd stages files for commit.\\n   114→func GitAdd(t *testing.T, repoDir string, paths ...string) {\\n   115→\\tt.Helper()\\n   116→\\n   117→\\trepo, err := git.PlainOpen(repoDir)\\n   118→\\tif err != nil {\\n   119→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   120→\\t}\\n   121→\\n   122→\\tworktree, err := repo.Worktree()\\n   123→\\tif err != nil {\\n   124→\\t\\tt.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\tfor _, path := range paths {\\n   128→\\t\\tif _, err := worktree.Add(path); err != nil {\\n   129→\\t\\t\\tt.Fatalf(\\\"failed to add file %s: %v\\\", path, err)\\n   130→\\t\\t}\\n   131→\\t}\\n   132→}\\n   133→\\n   134→// GitCommit creates a commit with all staged files.\\n   135→func GitCommit(t *testing.T, repoDir, message string) {\\n   136→\\tt.Helper()\\n   137→\\n   138→\\trepo, err := git.PlainOpen(repoDir)\\n   139→\\tif err != nil {\\n   140→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\tworktree, err := repo.Worktree()\\n   144→\\tif err != nil {\\n   145→\\t\\tt.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n   146→\\t}\\n   147→\\n   148→\\t_, err = worktree.Commit(message, &git.CommitOptions{\\n   149→\\t\\tAuthor: &object.Signature{\\n   150→\\t\\t\\tName:  \\\"Test User\\\",\\n   151→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   152→\\t\\t\\tWhen:  time.Now(),\\n   153→\\t\\t},\\n   154→\\t})\\n   155→\\tif err != nil {\\n   156→\\t\\tt.Fatalf(\\\"failed to commit: %v\\\", err)\\n   157→\\t}\\n   158→}\\n   159→\\n   160→// GitCheckoutNewBranch creates and checks out a new branch.\\n   161→// Uses git CLI to work around go-git v5 bug with checkout deleting untracked files.\\n   162→func GitCheckoutNewBranch(t *testing.T, repoDir, branchName string) {\\n   163→\\tt.Helper()\\n   164→\\n   165→\\t//nolint:noctx // test code, no context needed for git checkout\\n   166→\\tcmd := exec.Command(\\\"git\\\", \\\"checkout\\\", \\\"-b\\\", branchName)\\n   167→\\tcmd.Dir = repoDir\\n   168→\\tif output, err := cmd.CombinedOutput(); err != nil {\\n   169→\\t\\tt.Fatalf(\\\"failed to checkout new branch %s: %v\\\\nOutput: %s\\\", branchName, err, output)\\n   170→\\t}\\n   171→}\\n   172→\\n   173→// GetHeadHash returns the current HEAD commit hash.\\n   174→func GetHeadHash(t *testing.T, repoDir string) string {\\n   175→\\tt.Helper()\\n   176→\\n   177→\\trepo, err := git.PlainOpen(repoDir)\\n   178→\\tif err != nil {\\n   179→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   180→\\t}\\n   181→\\n   182→\\thead, err := repo.Head()\\n   183→\\tif err != nil {\\n   184→\\t\\tt.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   185→\\t}\\n   186→\\n   187→\\treturn head.Hash().String()\\n   188→}\\n   189→\\n   190→// BranchExists checks if a branch exists in the repository.\\n   191→func BranchExists(t *testing.T, repoDir, branchName string) bool {\\n   192→\\tt.Helper()\\n   193→\\n   194→\\trepo, err := git.PlainOpen(repoDir)\\n   195→\\tif err != nil {\\n   196→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   197→\\t}\\n   198→\\n   199→\\trefs, err := repo.References()\\n   200→\\tif err != nil {\\n   201→\\t\\tt.Fatalf(\\\"failed to get references: %v\\\", err)\\n   202→\\t}\\n   203→\\n   204→\\tfound := false\\n   205→\\t//nolint:errcheck,gosec // ForEach callback doesn't return errors we need to handle\\n   206→\\trefs.ForEach(func(ref *plumbing.Reference) error {\\n   207→\\t\\tif ref.Name().Short() == branchName {\\n   208→\\t\\t\\tfound = true\\n   209→\\t\\t}\\n   210→\\t\\treturn nil\\n   211→\\t})\\n   212→\\n   213→\\treturn found\\n   214→}\\n   215→\\n   216→// GetCommitMessage returns the commit message for the given commit hash.\\n   217→func GetCommitMessage(t *testing.T, repoDir, hash string) string {\\n   218→\\tt.Helper()\\n   219→\\n   220→\\trepo, err := git.PlainOpen(repoDir)\\n   221→\\tif err != nil {\\n   222→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   223→\\t}\\n   224→\\n   225→\\tcommitHash := plumbing.NewHash(hash)\\n   226→\\tcommit, err := repo.CommitObject(commitHash)\\n   227→\\tif err != nil {\\n   228→\\t\\tt.Fatalf(\\\"failed to get commit %s: %v\\\", hash, err)\\n   229→\\t}\\n   230→\\n   231→\\treturn commit.Message\\n   232→}\\n   233→\\n   234→// GetLatestCheckpointIDFromHistory walks backwards from HEAD and returns\\n   235→// the checkpoint ID from the first commit with an Entire-Checkpoint trailer.\\n   236→// Returns an error if no checkpoint trailer is found in any commit.\\n   237→func GetLatestCheckpointIDFromHistory(t *testing.T, repoDir string) (string, error) {\\n   238→\\tt.Helper()\\n   239→\\n   240→\\trepo, err := git.PlainOpen(repoDir)\\n   241→\\tif err != nil {\\n   242→\\t\\tt.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   243→\\t}\\n   244→\\n   245→\\thead, err := repo.Head()\\n   246→\\tif err != nil {\\n   247→\\t\\tt.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   248→\\t}\\n   249→\\n   250→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   251→\\tif err != nil {\\n   252→\\t\\tt.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   253→\\t}\\n   254→\\n   255→\\tvar checkpointID string\\n   256→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration\\n   257→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   258→\\t\\t// Look for Entire-Checkpoint trailer\\n   259→\\t\\tfor line := range strings.SplitSeq(c.Message, \\\"\\\\n\\\") {\\n   260→\\t\\t\\tline = strings.TrimSpace(line)\\n   261→\\t\\t\\tif value, found := strings.CutPrefix(line, \\\"Entire-Checkpoint:\\\"); found {\\n   262→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(value)\\n   263→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   264→\\t\\t\\t}\\n   265→\\t\\t}\\n   266→\\t\\treturn nil\\n   267→\\t})\\n   268→\\n   269→\\tif checkpointID == \\\"\\\" {\\n   270→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   271→\\t}\\n   272→\\n   273→\\treturn checkpointID, nil\\n   274→}\\n   275→\\n   276→// SafeIDPrefix returns first 12 chars of ID or the full ID if shorter.\\n   277→// Use this when logging checkpoint IDs to avoid index out of bounds panic.\\n   278→func SafeIDPrefix(id string) string {\\n   279→\\tif len(id) >= 12 {\\n   280→\\t\\treturn id[:12]\\n   281→\\t}\\n   282→\\treturn id\\n   283→}\\n   284→\\n   285→// GitIsolatedEnv returns os.Environ() with git isolation variables set.\\n   286→// This prevents user/system git config (global gitignore, aliases, etc.) from\\n   287→// affecting test behavior. Use this for any exec.Command that runs git or the\\n   288→// CLI binary in integration tests.\\n   289→//\\n   290→// See https://git-scm.com/docs/git#Documentation/git.txt-GITCONFIGGLOBAL\\n   291→//\\n   292→// Existing GIT_CONFIG_GLOBAL/GIT_CONFIG_SYSTEM entries are filtered out before\\n   293→// appending overrides to ensure they take effect regardless of parent env.\\n   294→func GitIsolatedEnv() []string {\\n   295→\\tenv := os.Environ()\\n   296→\\tfiltered := make([]string, 0, len(env)+2)\\n   297→\\tfor _, e := range env {\\n   298→\\t\\tif strings.HasPrefix(e, \\\"GIT_CONFIG_GLOBAL=\\\") || strings.HasPrefix(e, \\\"GIT_CONFIG_SYSTEM=\\\") {\\n   299→\\t\\t\\tcontinue\\n   300→\\t\\t}\\n   301→\\t\\tfiltered = append(filtered, e)\\n   302→\\t}\\n   303→\\treturn append(filtered,\\n   304→\\t\\t\\\"GIT_CONFIG_GLOBAL=/dev/null\\\", // Isolate from user's global git config (e.g. global gitignore)\\n   305→\\t\\t\\\"GIT_CONFIG_SYSTEM=/dev/null\\\", // Isolate from system git config\\n   306→\\t)\\n   307→}\\n   308→\"}]},\"uuid\":\"4f511594-8b35-4c69-b540-fcd1d2d62090\",\"ti