/ Get current working directory to check cache validity\\n    65→\\tcwd, err := os.Getwd() //nolint:forbidigo // already present in codebase\\n    66→\\tif err != nil {\\n    67→\\t\\tcwd = \\\"\\\"\\n    68→\\t}\\n    69→\\n    70→\\t// Check cache with read lock first\\n    71→\\tworktreeRootMu.RLock()\\n    72→\\tif worktreeRootCache != \\\"\\\" && worktreeRootCacheDir == cwd {\\n    73→\\t\\tcached := worktreeRootCache\\n    74→\\t\\tworktreeRootMu.RUnlock()\\n    75→\\t\\treturn cached, nil\\n    76→\\t}\\n    77→\\tworktreeRootMu.RUnlock()\\n    78→\\n    79→\\t// Cache miss - get worktree root and update cache with write lock\\n    80→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--show-toplevel\\\")\\n    81→\\toutput, err := cmd.Output()\\n    82→\\tif err != nil {\\n    83→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git worktree root: %w\\\", err)\\n    84→\\t}\\n    85→\\n    86→\\troot := strings.TrimSpace(string(output))\\n    87→\\n    88→\\tworktreeRootMu.Lock()\\n    89→\\tworktreeRootCache = root\\n    90→\\tworktreeRootCacheDir = cwd\\n    91→\\tworktreeRootMu.Unlock()\\n    92→\\n    93→\\treturn root, nil\\n    94→}\\n    95→\\n    96→// ClearWorktreeRootCache clears the cached worktree root.\\n    97→// This is primarily useful for testing when changing directories.\\n    98→func ClearWorktreeRootCache() {\\n    99→\\tworktreeRootMu.Lock()\\n   100→\\tworktreeRootCache = \\\"\\\"\\n   101→\\tworktreeRootCacheDir = \\\"\\\"\\n   102→\\tworktreeRootMu.Unlock()\\n   103→}\\n   104→\\n   105→// AbsPath returns the absolute path for a relative path within the repository.\\n   106→// If the path is already absolute, it is returned as-is.\\n   107→// Uses WorktreeRoot() to resolve paths relative to the worktree root.\\n   108→func AbsPath(ctx context.Context, relPath string) (string, error) {\\n   109→\\tif filepath.IsAbs(relPath) {\\n   110→\\t\\treturn relPath, nil\\n   111→\\t}\\n   112→\\n   113→\\troot, err := Work