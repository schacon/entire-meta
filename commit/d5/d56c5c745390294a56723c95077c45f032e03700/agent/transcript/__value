l(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   201→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   202→\\t\\tif strings.TrimSpace(line) == entry {\\n   203→\\t\\t\\treturn nil\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\n   207→\\tvar b strings.Builder\\n   208→\\tif len(data) > 0 {\\n   209→\\t\\tb.Write(data)\\n   210→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   211→\\t\\t\\tb.WriteByte('\\\\n')\\n   212→\\t\\t}\\n   213→\\t}\\n   214→\\tb.WriteString(entry)\\n   215→\\tb.WriteByte('\\\\n')\\n   216→\\n   217→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   219→\\t}\\n   220→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   222→\\t}\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   227→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   228→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   229→//\\n   230→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   231→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   232→// panic and restarts the entire scenario with a fresh repository, up to\\n   233→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   234→// failed attempt poisoning the retry.\\n   235→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   236→\\tt.Helper()\\n   237→\\tt.Parallel()\\n   238→\\tall := agents.All()\\n   239→\\tif len(all) == 0 {\\n   240→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   241→\\t}\\n   242→\\tfor _, agent := range all {\\n   243→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   244→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   245→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   246→\\t\\t\\tslotCtx := context.Background()\\n   247→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   248→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   249→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   250→\\t\\t\\t\\tdefer cancel()\\n   251→\\t\\t\\t}\\n   252→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   253→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   254→\\t\\t\\t}\\n   255→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   256→\\n   257→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   258→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   259→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   260→\\n   261→\\t\\t\\tvar prevState *RepoState\\n   262→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   263→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   264→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   265→\\n   266→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   267→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   268→\\t\\t\\t\\tif prevState != nil {\\n   269→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   270→\\t\\t\\t\\t}\\n   271→\\n   272→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   273→\\t\\t\\t\\tcancel()\\n   274→\\n   275→\\t\\t\\t\\tif !restarted {\\n   276→\\t\\t\\t\\t\\treturn\\n   277→\\t\\t\\t\\t}\\n   278→\\t\\t\\t\\tprevState = s\\n   279→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   280→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   281→\\t\\t\\t\\t}\\n   282→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   283→\\t\\t\\t}\\n   284→\\t\\t})\\n   285→\\t}\\n   286→}\\n   287→\\n   288→// runScenario runs the test function and recovers from errScenarioRestart\\n   289→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   290→// the scenario should be restarted with a fresh repository.\\n   291→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   292→\\tt.Helper()\\n   293→\\tdefer func() {\\n   294→\\t\\tif r := recover(); r != nil {\\n   295→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   296→\\t\\t\\t\\trestarted = true\\n   297→\\t\\t\\t\\treturn\\n   298→\\t\\t\\t}\\n   299→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   300→\\t\\t}\\n   301→\\t}()\\n   302→\\tfn(t, s, ctx)\\n   303→\\treturn false\\n   304→}\\n   305→\\n   306→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   307→\\n   308→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   309→// detected. ForEachAgent recovers from this panic and restarts the test\\n   310→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   311→// attempt.\\n   312→type errScenarioRestart struct {\\n   313→\\tmsg string\\n   314→}\\n   315→\\n   316→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   317→// and returns the result. If the agent reports a transient API error, it\\n   318→// panics with errScenarioRestart to trigger a full scenario restart in\\n   319→// ForEachAgent (see runScenario).\\n   320→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   321→\\tt.Helper()\\n   322→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   323→\\ts.logPromptResult(out)\\n   324→\\n   325→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   326→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   327→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   328→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   329→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   330→\\t}\\n   331→\\n   332→\\treturn out, err\\n   333→}\\n   334→\\n   335→func (s *RepoState) logPromptResult(out agents.Output) {\\n   336→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   337→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   338→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   339→}\\n   340→\\n   341→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   342→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   343→\\tt.Helper()\\n   344→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   345→\\tGit(t, s.Dir, args...)\\n   346→}\\n   347→\\n   348→// StartSession starts an interactive session and registers it for pane\\n   349→// capture in artifacts. Returns nil if the agent does not support interactive\\n   350→// mode. The session is closed automatically during test cleanup.\\n   351→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   352→\\tt.Helper()\\n   353→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   354→\\tif err != nil {\\n   355→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   356→\\t}\\n   357→\\tif session == nil {\\n   358→\\t\\treturn nil\\n   359→\\t}\\n   360→\\ts.session = session\\n   361→\\treturn session\\n   362→}\\n   363→\\n   364→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   365→// pane content to ConsoleLog after the wait completes (success or failure).\\n   366→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   367→\\tt.Helper()\\n   368→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   369→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   370→\\tif err != nil {\\n   371→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   372→\\t}\\n   373→}\\n   374→\\n   375→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   376→// Fails the test on error.\\n   377→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   378→\\tt.Helper()\\n   379→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   380→\\tif err := session.Send(input); err != nil {\\n   381→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   382→\\t}\\n   383→}\\n   384→\\n   385→// PatchSettings merges extra keys into .entire/settings.json.\\n   386→func PatchSettings(t *testing.T, dir string, extra map[string]any) {\\n   387→\\tt.Helper()\\n   388→\\tpath := filepath.Join(dir, \\\".entire\\\", \\\"settings.json\\\")\\n   389→\\tdata, err := os.ReadFile(path)\\n   390→\\tif err != nil {\\n   391→\\t\\tt.Fatalf(\\\"read settings: %v\\\", err)\\n   392→\\t}\\n   393→\\tvar settings map[string]any\\n   394→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   395→\\t\\tt.Fatalf(\\\"parse settings: %v\\\", err)\\n   396→\\t}\\n   397→\\tfor k, v := range extra {\\n   398→\\t\\tsettings[k] = v\\n   399→\\t}\\n   400→\\tout, err := json.MarshalIndent(settings, \\\"\\\", \\\"  \\\")\\n   401→\\tif err != nil {\\n   402→\\t\\tt.Fatalf(\\\"marshal settings: %v\\\", err)\\n   403→\\t}\\n   404→\\tif err := os.WriteFile(path, out, 0o644); err != nil {\\n   405→\\t\\tt.Fatalf(\\\"write settings: %v\\\", err)\\n   406→\\t}\\n   407→}\\n   408→\\n   409→// Git runs a git command in the given directory and fails the test if it\\n   410→// returns a non-zero exit code.\\n   411→func Git(t *testing.T, dir string, args ...string) {\\n   412→\\tt.Helper()\\n   413→\\n   414→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   415→\\tif dir != \\\"\\\" {\\n   416→\\t\\tcmd.Dir = dir\\n   417→\\t}\\n   418→\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n   419→\\n   420→\\tout, err := cmd.CombinedOutput()\\n   421→\\tif err != nil {\\n   422→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n   423→\\t}\\n   424→}\\n   425→\\n   426→// GitOutput runs a git command in the given directory, returns its trimmed\\n   427→// stdout, and fails the test on error.\\n   428→func GitOutput(t *testing.T, dir string, args ...string) string {\\n   429→\\tt.Helper()\\n   430→\\n   431→\\tcmd := exec.Command(\\\"git\\\", args...)\\n   432→\\tif dir != \\\"\\\" {\\n   433→\\t\\tcmd.Dir = dir\\n   434→\\t}\\n   435→\\n   436→\\tout, err := cmd.Output()\\n   437→\\tif err != nil {\\n   438→\\t\\tvar stderr string\\n   439→\\t\\tee := &exec.ExitError{}\\n   440→\\t\\tif errors.As(err, &ee) {\\n   441→\\t\\t\\tstderr = string(ee.Stderr)\\n   442→\\t\\t}\\n   443→\\t\\tt.Fatalf(\\\"git %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, stderr)\\n   444→\\t}\\n   445→\\n   446→\\treturn strings.TrimSpace(string(out))\\n   447→}\\n   448→\\n   449→// NewCheckpointCommits returns the SHAs of commits added to the\\n   450→// entire/checkpoints/v1 branch since the test was set up, oldest first.\\n   451→func NewCheckpointCommits(t *testing.T, s *RepoState) []string {\\n   452→\\tt.Helper()\\n   453→\\n   454→\\tlog := GitOutput(t, s.Dir, \\\"log\\\", \\\"--reverse\\\", \\\"--format=%H\\\", s.CheckpointBefore+\\\"..entire/checkpoints/v1\\\")\\n   455→\\tif log == \\\"\\\" {\\n   456→\\t\\treturn nil\\n   457→\\t}\\n   458→\\treturn strings.Split(log, \\\"\\\\n\\\")\\n   459→}\\n   460→\\n   461→// CheckpointIDs lists all checkpoint IDs from the tree at the tip of the\\n   462→// checkpoint branch. It parses the two-level directory structure\\n   463→// ({prefix}/{suffix}/metadata.json) and returns the 