emplate (without chain call).\\n    32→type hookSpec struct {\\n    33→\\tname    string\\n    34→\\tcontent string\\n    35→}\\n    36→\\n    37→// GetGitDir returns the actual git directory path by delegating to git itself.\\n    38→// This handles both regular repositories and worktrees, and inherits git's\\n    39→// security validation for gitdir references.\\n    40→func GetGitDir(ctx context.Context) (string, error) {\\n    41→\\treturn getGitDirInPath(ctx, \\\".\\\")\\n    42→}\\n    43→\\n    44→// hooksDirCache caches the hooks directory to avoid repeated git subprocess spawns.\\n    45→// Keyed by current working directory to handle directory changes.\\n    46→var (\\n    47→\\thooksDirMu       sync.RWMutex\\n    48→\\thooksDirCache    string\\n    49→\\thooksDirCacheDir string\\n    50→)\\n    51→\\n    52→// GetHooksDir returns the active hooks directory path.\\n    53→// This respects core.hooksPath and correctly resolves to the common hooks\\n    54→// directory when called from a linked worktree.\\n    55→// The result is cached per working directory.\\n    56→func GetHooksDir(ctx context.Context) (string, error) {\\n    57→\\tcwd, err := os.Getwd() //nolint:forbidigo // cache key for hooks dir, same pattern as paths.WorktreeRoot()\\n    58→\\tif err != nil {\\n    59→\\t\\tcwd = \\\"\\\"\\n    60→\\t}\\n    61→\\n    62→\\thooksDirMu.RLock()\\n    63→\\tif hooksDirCache != \\\"\\\" && hooksDirCacheDir == cwd {\\n    64→\\t\\tcached := hooksDirCache\\n    65→\\t\\thooksDirMu.RUnlock()\\n    66→\\t\\treturn cached, nil\\n    67→\\t}\\n    68→\\thooksDirMu.RUnlock()\\n    69→\\n    70→\\tresult, err := getHooksDirInPath(ctx, \\\".\\\")\\n    71→\\tif err != nil {\\n    72→\\t\\treturn \\\"\\\", err\\n    73→\\t}\\n    74→\\n    75→\\thooksDirMu.Lock()\\n    76→\\thooksDirCache = result\\n    77→\\thooksDirCacheDir = cwd\\n    78→\\thooksDirMu.Unlock()\\n    79→\\n    80→\\treturn result, nil\\n    81→}\\n    82→\\n    83→// ClearHooksDirCache clears the cached hooks directory.\\n    84→// This is primarily useful for testing when changing directories.\\n    85→func ClearHooksDirCache() {\\n    86→\\thooksDirMu.Lock()\\n    87→\\thooksDirCache = \\\"\\\"\\n    88→\\thooksDirCacheDir = \\\"\\\"\\n    89→\\thooksDirMu.Unlock()\\n    90→}\\n    91→\\n    92→// getGitDirInPath returns the git directory for a repository at the given path.\\n    93→// It delegates to `git rev-parse --git-dir` to leverage git's own validation.\\n    94→func getGitDirInPath(ctx context.Context, dir string) (string, error) {\\n    95→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-dir\\\")\\n    96→\\tcmd.Dir = dir\\n    97→\\toutput, err := cmd.Output()\\n    98→\\tif err != nil {\\n    99→\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n   100→\\t}\\n   101→\\n   102→\\tgitDir := strings.TrimSpace(string(output))\\n   103→\\n   104→\\t// git rev-parse --git-dir returns relative paths from the working directory,\\n   105→\\t// so we need to make it absolute if it isn't already\\n   106→\\tif !filepath.IsAbs(gitDir) {\\n   107→\\t\\tgitDir = filepath.Join(dir, gitDir)\\n   108→\\t}\\n   109→\\n   110→\\treturn filepath.Clean(gitDir), nil\\n   111→}\\n   112→\\n   113→// getHooksDirInPath returns the active hooks directory for a repository at the given path.\\n   114→// It delegates to `git rev-parse --git-path hooks` so Git resolves:\\n   115→// - linked-worktree common hooks directory\\n   116→// - core.hooksPath (relative or absolute)\\n   117→func getHooksDirInPath(ctx context.Context, dir string) (string, error) {\\n   118→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-path\\\", \\\"hooks\\\")\\n   119→\\tcmd.Dir = dir\\n   120→\\toutput, err := cmd.Output()\\n   121→\\tif err != nil {\\n   122→\\t\\treturn \\\"\\\", errors.New(\\\"not a git repository\\\")\\n   123→\\t}\\n   124→\\n   125→\\thooksDir := strings.TrimSpace(string(output))\\n   126→\\tif !filepath.IsAbs(hooksDir) {\\n   127→\\t\\thooksDir = filepath.Join(dir, hooksDir)\\n   128→\\t}\\n   129→\\n   130→\\treturn filepath.Clean(hooksDir), nil\\n   131→}\\n   132→\\n   133→// IsGitHookInstalled checks if all generic Entire CLI hooks are installed.\\n   134→func IsGitHookInstalled(ctx context.Context) bool {\\n   135→\\thooksDir, err := GetHooksDir(ctx)\\n   136→\\tif err != nil {\\n   137→\\t\\treturn false\\n   138→\\t}\\n   139→\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n   140→}\\n   141→\\n   142→// IsGitHookInstalledInDir checks if all Entire CLI hooks are installed in the given repo directory.\\n   143→// This is useful for tests that need to check hooks without changing the working directory.\\n   144→func IsGitHookInstalledInDir(ctx context.Context, repoDir string) bool {\\n   145→\\thooksDir, err := getHooksDirInPath(ctx, repoDir)\\n   146→\\tif err != nil {\\n   147→\\t\\treturn false\\n   148→\\t}\\n   149→\\treturn isGitHookInstalledInHooksDir(hooksDir)\\n   150→}\\n   151→\\n   152→// isGitHookInstalledInHooksDir checks if all hooks are installed in the given hooks directory.\\n   153→func isGitHookInstalledInHooksDir(hooksDir string) bool {\\n   154→\\tfor _, hook := range gitHookNames {\\n   155→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   156→\\t\\tdata, err := os.ReadFile(hookPath) //nolint:gosec // Path is constructed from constants\\n   157→\\t\\tif err != nil {\\n   158→\\t\\t\\treturn false\\n   159→\\t\\t}\\n   160→\\t\\tif !strings.Contains(string(data), entireHookMarker) {\\n   161→\\t\\t\\treturn false\\n   162→\\t\\t}\\n   163→\\t}\\n   164→\\treturn true\\n   165→}\\n   166→\\n   167→// buildHookSpecs returns the hook specifications for all managed hooks.\\n   168→func buildHookSpecs(cmdPrefix string) []hookSpec {\\n   169→\\treturn []hookSpec{\\n   170→\\t\\t{\\n   171→\\t\\t\\tname: \\\"prepare-commit-msg\\\",\\n   172→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   173→# %s\\n   174→%s hooks git prepare-commit-msg \\\"$1\\\" \\\"$2\\\" 2>/dev/null || true\\n   175→`, entireHookMarker, cmdPrefix),\\n   176→\\t\\t},\\n   177→\\t\\t{\\n   178→\\t\\t\\tname: \\\"commit-msg\\\",\\n   179→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   180→# %s\\n   181→# Commit-msg hook: strip trailer if no user content (allows aborting empty commits)\\n   182→%s hooks git commit-msg \\\"$1\\\" || exit 1\\n   183→`, entireHookMarker, cmdPrefix),\\n   184→\\t\\t},\\n   185→\\t\\t{\\n   186→\\t\\t\\tname: \\\"post-commit\\\",\\n   187→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   188→# %s\\n   189→# Post-commit hook: condense session data if commit has Entire-Checkpoint trailer\\n   190→%s hooks git post-commit 2>/dev/null || true\\n   191→`, entireHookMarker, cmdPrefix),\\n   192→\\t\\t},\\n   193→\\t\\t{\\n   194→\\t\\t\\tname: \\\"pre-push\\\",\\n   195→\\t\\t\\tcontent: fmt.Sprintf(`#!/bin/sh\\n   196→# %s\\n   197→# Pre-push hook: push session logs alongside user's push\\n   198→# $1 is the remote name (e.g., \\\"origin\\\")\\n   199→%s hooks git pre-push \\\"$1\\\" || true\\n   200→`, entireHookMarker, cmdPrefix),\\n   201→\\t\\t},\\n   202→\\t}\\n   203→}\\n   204→\\n   205→// InstallGitHook installs generic git hooks that delegate to `entire hook` commands.\\n   206→// These hooks work with any strategy - the strategy is determined at runtime.\\n   207→// If silent is true, no output is printed (except backup notifications, which always print).\\n   208→// localDev controls whether hooks use \\\"go run\\\" (true) or the \\\"entire\\\" binary (false).\\n   209→// absolutePath embeds the full binary path in hooks for GUI git clients.\\n   210→// Returns the number of hooks that were installed (0 if all already up to date).\\n   211→func InstallGitHook(ctx context.Context, silent, localDev, absolutePath bool) (int, error) {\\n   212→\\thooksDir, err := GetHooksDir(ctx)\\n   213→\\tif err != nil {\\n   214→\\t\\treturn 0, err\\n   215→\\t}\\n   216→\\n   217→\\tif err := os.MkdirAll(hooksDir, 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   218→\\t\\treturn 0, fmt.Errorf(\\\"failed to create hooks directory: %w\\\", err)\\n   219→\\t}\\n   220→\\n   221→\\tcmdPrefix, err := hookCmdPrefix(localDev, absolutePath)\\n   222→\\tif err != nil {\\n   223→\\t\\treturn 0, err\\n   224→\\t}\\n   225→\\tspecs := buildHookSpecs(cmdPrefix)\\n   226→\\tinstalledCount := 0\\n   227→\\n   228→\\tfor _, spec := range specs {\\n   229→\\t\\thookPath := filepath.Join(hooksDir, spec.name)\\n   230→\\t\\tbackupPath := hookPath + backupSuffix\\n   231→\\t\\tbackupExists := fileExists(backupPath)\\n   232→\\n   233→\\t\\t// Back up existing non-Entire hooks\\n   234→\\t\\texisting, existingErr := os.ReadFile(hookPath) //nolint:gosec // path is controlled\\n   235→\\t\\tif existingErr == nil && !strings.Contains(string(existing), entireHookMarker) {\\n   236→\\t\\t\\tif !backupExists {\\n   237→\\t\\t\\t\\tif err := os.Rename(hookPath, backupPath); err != nil {\\n   238→\\t\\t\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to back up %s: %w\\\", spec.name, err)\\n   239→\\t\\t\\t\\t}\\n   240→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Backed up existing %s to %s%s\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   241→\\t\\t\\t} else {\\n   242→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] Warning: replacing %s (backup %s%s already exists from a previous install)\\\\n\\\", spec.name, spec.name, backupSuffix)\\n   243→\\t\\t\\t}\\n   244→\\t\\t\\tbackupExists = true\\n   245→\\t\\t}\\n   246→\\n   247→\\t\\t// Chain to backup if one exists\\n   248→\\t\\tcontent := spec.content\\n   249→\\t\\tif backupExists {\\n   250→\\t\\t\\tcontent = generateChainedContent(spec.content, spec.name)\\n   251→\\t\\t}\\n   252→\\n   253→\\t\\twritten, err := writeHookFile(hookPath, content)\\n   254→\\t\\tif err != nil {\\n   255→\\t\\t\\treturn installedCount, fmt.Errorf(\\\"failed to install %s hook: %w\\\", spec.name, err)\\n   256→\\t\\t}\\n   257→\\t\\tif written {\\n   258→\\t\\t\\tinstalledCount++\\n   259→\\t\\t}\\n   260→\\t}\\n   261→\\n   262→\\tif !silent {\\n   263→\\t\\tfmt.Println(\\\"✓ Installed git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\\")\\n   264→\\t\\tfmt.Println(\\\"  Hooks delegate to the current strategy at runtime\\\")\\n   265→\\t}\\n   266→\\n   267→\\treturn installedCount, nil\\n   268→}\\n   269→\\n   270→// writeHookFile writes a hook file if it doesn't exist or has different content.\\n   271→// Returns true if the file was written, false if it already had the same content.\\n   272→func writeHookFile(path, content string) (bool, error) {\\n   273→\\t// Check if file already exists with same content\\n   274→\\texisting, err := os.ReadFile(path) //nolint:gosec // path is controlled\\n   275→\\tif err == nil && string(existing) == content {\\n   276→\\t\\treturn false, nil // Already up to date\\n   277→\\t}\\n   278→\\n   279→\\t// Git hooks must be executable (0o755)\\n   280→\\tif err := os.WriteFile(path, []byte(content), 0o755); err != nil { //nolint:gosec // Git hooks require executable permissions\\n   281→\\t\\treturn false, fmt.Errorf(\\\"failed to write hook file %s: %w\\\", path, err)\\n   282→\\t}\\n   283→\\treturn true, nil\\n   284→}\\n   285→\\n   286→// RemoveGitHook removes all Entire CLI git hooks from the repository.\\n   287→// If a .pre-entire backup exists, it is restored.\\n   288→// Returns the number of hooks removed.\\n   289→func RemoveGitHook(ctx context.Context) (int, error) {\\n   290→\\thooksDir, err := GetHooksDir(ctx)\\n   291→\\tif err != nil {\\n   292→\\t\\treturn 0, err\\n   293→\\t}\\n   294→\\n   295→\\tremoved := 0\\n   296→\\tvar removeErrors []string\\n   297→\\n   298→\\tfor _, hook := range gitHookNames {\\n   299→\\t\\thookPath := filepath.Join(hooksDir, hook)\\n   300→\\t\\tbackupPath := hookPath + backupSuffix\\n   301→\\n   302→\\t\\t// Remove the hook if it contains our marker\\n   303→\\t\\tdata, err := os.Read