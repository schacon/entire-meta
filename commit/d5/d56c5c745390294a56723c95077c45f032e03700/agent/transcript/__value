→\\n    18→const (\\n    19→\\tPhaseActive Phase = \\\"active\\\"\\n    20→\\tPhaseIdle   Phase = \\\"idle\\\"\\n    21→\\tPhaseEnded  Phase = \\\"ended\\\"\\n    22→)\\n    23→\\n    24→// allPhases is the canonical list of phases for enumeration (e.g., diagram generation).\\n    25→var allPhases = []Phase{PhaseIdle, PhaseActive, PhaseEnded}\\n    26→\\n    27→// PhaseFromString normalizes a phase string, treating empty or unknown values\\n    28→// as PhaseIdle for backward compatibility with pre-state-machine session files.\\n    29→func PhaseFromString(s string) Phase {\\n    30→\\tswitch Phase(s) {\\n    31→\\tcase PhaseActive, \\\"active_committed\\\":\\n    32→\\t\\t// \\\"active_committed\\\" was removed with the 1:1 checkpoint model.\\n    33→\\t\\t// It previously meant \\\"agent active + commit happened during turn\\\".\\n    34→\\t\\t// Normalize to ACTIVE so HandleTurnEnd can finalize any pending checkpoints.\\n    35→\\t\\treturn PhaseActive\\n    36→\\tcase PhaseIdle:\\n    37→\\t\\treturn PhaseIdle\\n    38→\\tcase PhaseEnded:\\n    39→\\t\\treturn PhaseEnded\\n    40→\\tdefault:\\n    41→\\t\\t// Backward compat: truly unknown phases normalize to idle.\\n    42→\\t\\treturn PhaseIdle\\n    43→\\t}\\n    44→}\\n    45→\\n    46→// IsActive reports whether the phase represents an active agent turn.\\n    47→func (p Phase) IsActive() bool {\\n    48→\\treturn p == PhaseActive\\n    49→}\\n    50→\\n    51→// Event represents something that happened to a session.\\n    52→type Event int\\n    53→\\n    54→const (\\n    55→\\tEventTurnStart    Event = iota // Agent begins working on a prompt\\n    56→\\tEventTurnEnd                   // Agent finishes its turn\\n    57→\\tEventGitCommit                 // A git commit was made (PostCommit hook)\\n    58→\\tEventSessionStart              // Session process started (SessionStart hook)\\n    59→\\tEventSessionStop               // Session process ended (SessionStop hook)\\n    60→\\tEventCompaction                // Agent compacted context mid-turn (PreCompress hook)\\n    61→)\\n    62→\\n    63→// allEvents is the canonical list of events for enumeration.\\n    64→var allEvents = []Event{EventTurnStart, EventTurnEnd, EventGitCommit, EventSessionStart, EventSessionStop, EventCompaction}\\n    65→\\n    66→// String returns a human-readable name for the event.\\n    67→func (e Event) String() string {\\n    68→\\tswitch e {\\n    69→\\tcase EventTurnStart:\\n    70→\\t\\treturn \\\"TurnStart\\\"\\n    71→\\tcase EventTurnEnd:\\n    72→\\t\\treturn \\\"TurnEnd\\\"\\n    73→\\tcase EventGitCommit:\\n    74→\\t\\treturn \\\"GitCommit\\\"\\n    75→\\tcase EventSessionStart:\\n    76→\\t\\treturn \\\"SessionStart\\\"\\n    77→\\tcase EventSessionStop:\\n    78→\\t\\treturn \\\"SessionStop\\\"\\n    79→\\tcase EventCompaction:\\n    80→\\t\\treturn \\\"Compaction\\\"\\n    81→\\tdefault:\\n    82→\\t\\treturn fmt.Sprintf(\\\"Event(%d)\\\", int(e))\\n    83→\\t}\\n    84→}\\n    85→\\n    86→// Action represents a side effect that should be performed after a transition.\\n    87→// The caller is responsible for executing these -- the state machine only declares them.\\n    88→type Action int\\n    89→\\n    90→const (\\n    91→\\tActionCondense               Action = iota // Condense session data to permanent storage\\n    92→\\tActionCondenseIfFilesTouched               // Condense only if FilesTouched is non-empty\\n    93→\\tActionDiscardIfNoFiles                     // Discard session if FilesTouched is empty\\n    94→\\tActionWarnStaleSession                     // Warn user about stale session(s)\\n    95→\\tActionClearEndedAt                         // Clear EndedAt timestamp (session re-entering)\\n    96→\\tActionUpdateLastInteraction                // Update LastInteractionTime\\n    97→)\\n    98→\\n    99→// String returns a human-readable name for the action.\\n   100→func (a Action) String() string {\\n   101→\\tswitch a {\\n   102→\\tcase ActionCondense:\\n   103→\\t\\treturn \\\"Condense\\\"\\n   104→\\tcase ActionCondenseIfFilesTouched:\\n   105→\\t\\treturn \\\"CondenseIfFilesTouched\\\"\\n   106→\\tcase ActionDiscardIfNoFiles:\\n   107→\\t\\treturn \\\"DiscardIfNoFiles\\\"\\n   108→\\tcase ActionWarnStaleSession:\\n   109→\\t\\treturn \\\"WarnStaleSession\\\"\\n   110→\\tcase ActionClearEndedAt:\\n   111→\\t\\treturn \\\"ClearEndedAt\\\"\\n   112→\\tcase ActionUpdateLastInteraction:\\n   113→\\t\\treturn \\\"UpdateLastInteraction\\\"\\n   114→\\tdefault:\\n   115→\\t\\treturn fmt.Sprintf(\\\"Action(%d)\\\", int(a))\\n   116→\\t}\\n   117→}\\n   118→\\n   119→// TransitionContext provides read-only context for transitions that need\\n   120→// to inspect session state without mutating it.\\n   121→type TransitionContext struct {\\n   122→\\tHasFilesTouched    bool // len(FilesTouched) > 0\\n   123→\\tIsRebaseInProgress bool // .git/rebase-merge/ or .git/rebase-apply/ exists\\n   124→}\\n   125→\\n   126→// TransitionResult holds the outcome of a state machine transition.\\n   127→type TransitionResult struct {\\n   128→\\tNewPhase Phase\\n   129→\\tActions  []Action\\n   130→}\\n   131→\\n   132→// Transition computes the next phase and required actions given the current\\n   133→// phase and an event. This is a pure function with no side effects.\\n   134→//\\n   135→// Empty or unknown phase values are normalized to PhaseIdle for backward\\n   136→// compatibility with session state files created before phase tracking.\\n   137→func Transition(current Phase, event Event, ctx TransitionContext) TransitionResult {\\n   138→\\t// Normalize empty/unknown phase to idle for backward compatibility.\\n   139→\\tcurrent = PhaseFromString(string(current))\\n   140→\\n   141→\\tswitch current {\\n   142→\\tcase PhaseIdle:\\n   143→\\t\\treturn transitionFromIdle(event, ctx)\\n   144→\\tcase PhaseActive:\\n   145→\\t\\treturn transitionFromActive(event, ctx)\\n   146→\\tcase PhaseEnded:\\n   147→\\t\\treturn transitionFromEnded(event, ctx)\\n   148→\\tdefault:\\n   149→\\t\\t// PhaseFromString guarantees we only get known phases, but the\\n   150→\\t\\t// exhaustive linter requires handling the default case.\\n   151→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   152→\\t}\\n   153→}\\n   154→\\n   155→func transitionFromIdle(event Event, ctx TransitionContext) TransitionResult {\\n   156→\\tswitch event {\\n   157→\\tcase EventTurnStart:\\n   158→\\t\\treturn TransitionResult{\\n   159→\\t\\t\\tNewPhase: PhaseActive,\\n   160→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   161→\\t\\t}\\n   162→\\tcase EventTurnEnd:\\n   163→\\t\\t// Turn end while idle is a no-op (no active turn to end).\\n   164→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   165→\\tcase EventGitCommit:\\n   166→\\t\\tif ctx.IsRebaseInProgress {\\n   167→\\t\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   168→\\t\\t}\\n   169→\\t\\treturn TransitionResult{\\n   170→\\t\\t\\tNewPhase: PhaseIdle,\\n   171→\\t\\t\\tActions:  []Action{ActionCondense},\\n   172→\\t\\t}\\n   173→\\tcase EventSessionStart:\\n   174→\\t\\t// Already condensable, no-op.\\n   175→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   176→\\tcase EventSessionStop:\\n   177→\\t\\treturn TransitionResult{\\n   178→\\t\\t\\tNewPhase: PhaseEnded,\\n   179→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   180→\\t\\t}\\n   181→\\tcase EventCompaction:\\n   182→\\t\\t// Compaction while idle shouldn't happen, but condense if there's work.\\n   183→\\t\\treturn TransitionResult{\\n   184→\\t\\t\\tNewPhase: PhaseIdle,\\n   185→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   186→\\t\\t}\\n   187→\\tdefault:\\n   188→\\t\\treturn TransitionResult{NewPhase: PhaseIdle}\\n   189→\\t}\\n   190→}\\n   191→\\n   192→func transitionFromActive(event Event, ctx TransitionContext) TransitionResult {\\n   193→\\tswitch event {\\n   194→\\tcase EventTurnStart:\\n   195→\\t\\t// Ctrl-C recovery: agent crashed or user interrupted mid-turn.\\n   196→\\t\\treturn TransitionResult{\\n   197→\\t\\t\\tNewPhase: PhaseActive,\\n   198→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   199→\\t\\t}\\n   200→\\tcase EventTurnEnd:\\n   201→\\t\\treturn TransitionResult{\\n   202→\\t\\t\\tNewPhase: PhaseIdle,\\n   203→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   204→\\t\\t}\\n   205→\\tcase EventGitCommit:\\n   206→\\t\\tif ctx.IsRebaseInProgress {\\n   207→\\t\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   208→\\t\\t}\\n   209→\\t\\treturn TransitionResult{\\n   210→\\t\\t\\tNewPhase: PhaseActive,\\n   211→\\t\\t\\tActions:  []Action{ActionCondense},\\n   212→\\t\\t}\\n   213→\\tcase EventSessionStart:\\n   214→\\t\\treturn TransitionResult{\\n   215→\\t\\t\\tNewPhase: PhaseActive,\\n   216→\\t\\t\\tActions:  []Action{ActionWarnStaleSession},\\n   217→\\t\\t}\\n   218→\\tcase EventSessionStop:\\n   219→\\t\\treturn TransitionResult{\\n   220→\\t\\t\\tNewPhase: PhaseEnded,\\n   221→\\t\\t\\tActions:  []Action{ActionUpdateLastInteraction},\\n   222→\\t\\t}\\n   223→\\tcase EventCompaction:\\n   224→\\t\\t// Compaction mid-turn: save current progress but stay active.\\n   225→\\t\\t// The transcript offset will be reset by the compaction handler.\\n   226→\\t\\treturn TransitionResult{\\n   227→\\t\\t\\tNewPhase: PhaseActive,\\n   228→\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched, ActionUpdateLastInteraction},\\n   229→\\t\\t}\\n   230→\\tdefault:\\n   231→\\t\\treturn TransitionResult{NewPhase: PhaseActive}\\n   232→\\t}\\n   233→}\\n   234→\\n   235→func transitionFromEnded(event Event, ctx TransitionContext) TransitionResult {\\n   236→\\tswitch event {\\n   237→\\tcase EventTurnStart:\\n   238→\\t\\treturn TransitionResult{\\n   239→\\t\\t\\tNewPhase: PhaseActive,\\n   240→\\t\\t\\tActions:  []Action{ActionClearEndedAt, ActionUpdateLastInteraction},\\n   241→\\t\\t}\\n   242→\\tcase EventTurnEnd:\\n   243→\\t\\t// Turn end while ended is a no-op.\\n   244→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   245→\\tcase EventGitCommit:\\n   246→\\t\\tif ctx.IsRebaseInProgress {\\n   247→\\t\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   248→\\t\\t}\\n   249→\\t\\tif ctx.HasFilesTouched {\\n   250→\\t\\t\\treturn TransitionResult{\\n   251→\\t\\t\\t\\tNewPhase: PhaseEnded,\\n   252→\\t\\t\\t\\tActions:  []Action{ActionCondenseIfFilesTouched},\\n   253→\\t\\t\\t}\\n   254→\\t\\t}\\n   255→\\t\\treturn TransitionResult{\\n   256→\\t\\t\\tNewPhase: PhaseEnded,\\n   257→\\t\\t\\tActions:  []Action{ActionDiscardIfNoFiles},\\n   258→\\t\\t}\\n   259→\\tcase EventSessionStart:\\n   260→\\t\\treturn TransitionResult{\\n   261→\\t\\t\\tNewPhase: PhaseIdle,\\n   262→\\t\\t\\tActions:  []Action{ActionClearEndedAt},\\n   263→\\t\\t}\\n   264→\\tcase EventSessionStop:\\n   265→\\t\\t// Already ended, no-op.\\n   266→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   267→\\tcase EventCompaction:\\n   268→\\t\\t// Compaction while ended shouldn't happen, no-op.\\n   269→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   270→\\tdefault:\\n   271→\\t\\treturn TransitionResult{NewPhase: PhaseEnded}\\n   272→\\t}\\n   273→}\\n   274→\\n   275→// ActionHandler defines strategy-specific side effects for state transitions.\\n   276→// The compiler enforces that every strategy-specific action has a handler.\\n   277→type ActionHandler interface {\\n   278→\\tHandleCondense(state *State) error\\n   279→\\tHandleCondenseIfFilesTouched(state *State) error\\n   280→\\tHandleDiscardIfNoFiles(state *State) error\\n   281→\\tHandleWarnStaleSession(state *State) error\\n   282→}\\n   283→\\n   284→// NoOpActionHandler is a default ActionHandler where all methods are no-ops.\\n   285→// Embed this in handler structs to only override the methods you need.\\n   286→type NoOpActionHandler struct{}\\n   287→\\n   288→func (NoOpActionHandler) HandleCondense(_ *State) error               { return nil }\\n   289→func (NoOpActionHandler) HandleCondenseIfFilesTouched(_ *State) error { return nil }\\n   290→func (NoOpActionHandler) HandleDiscardIfNoFiles(_ *State) error       { return nil }\\n   291→func (NoOpActionHandler) HandleWarnStaleSession(_ *State) error       { return nil }\\n   292→\\n   293→// ApplyTransition applies a TransitionResult to state: sets the new phase\\n   294→// unconditionally, then executes all actions. Common actions\\n   295→// (UpdateLastInteraction, ClearEndedAt) always run regardless of handler\\n   296→// errors so that bookkeeping fields stay consistent with the new phase.\\n   297→// Strategy-specific handler actions stop on the first error; subsequent\\n   298→// handler actions are skipped but common actions continue. Returns the\\n   299→// first handler error, or nil.\\n   300→func ApplyTransition(ctx context.Context, state *State, result TransitionResult, handler ActionHandler) error {\\n   301→\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   302→\\n   303→\\tactionStrs := make([]string, len(result.Actions))\\n   304→\\tfor i, a := range result.Actions {\\n   305→\\t\\tactionStrs[i] = a.String()\\n   306→\\t}\\n   307→\\tlogging.Debug(logCtx, \\\"ApplyTransition\\\",\\n   308→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   309→\\t\\tslog.String(\\\"old_phase\\\", string(state.Phase)),\\n   310→\\t\\tslog.String(\\\"new_phase\\\", string(result.NewPhase)),\\n   311→\\t\\tslog.String(\\\"actions\\\", strings.Join(actionStrs, \\\",\\\")),\\n   312→\\t)\\n   313→\\n   314→\\tstate.Phase = result.NewPhase\\n   315→\\n   316→\\tvar handlerErr error\\n   317→\\tfor _, action := range result.Actions {\\n   318→\\t\\tswitch action {\\n   319→\\t\\t// Common actions: always applied, even after a handler error.\\n   320→\\t\\tcase ActionUpdateLastInteraction:\\n   321→\\t\\t\\tnow := time.Now()\\n   322→\\t\\t\\tstate.LastInteractionTime = &now\\n   323→\\t\\tcase ActionClearEndedAt:\\n   324→\\t\\t\\tstate.EndedAt = nil\\n   325→\\t\\t\\tstate.FullyCondensed = false\\n   326→\\n   327→\\t\\t// Strategy-specific actions: skip remaining after the first handler error.\\n   328→\\t\\tcase ActionCondense:\\n   329→\\t\\t\\tif handlerErr == nil {\\n   330→\\t\\t\\t\\tif err := handler.HandleCondense(state); err != nil {\\n   331→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   332→\\t\\t\\t\\t}\\n   333→\\t\\t\\t}\\n   334→\\t\\tcase ActionCondenseIfFilesTouched:\\n   335→\\t\\t\\tif handlerErr == nil {\\n   336→\\t\\t\\t\\tif err := handler.HandleCondenseIfFilesTouched(state); err != nil {\\n   337→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   338→\\t\\t\\t\\t}\\n   339→\\t\\t\\t}\\n   340→\\t\\tcase ActionDiscardIfNoFiles:\\n   341→\\t\\t\\tif handlerErr == nil {\\n   342→\\t\\t\\t\\tif err := handler.HandleDiscardIfNoFiles(state); err != nil {\\n   343→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   344→\\t\\t\\t\\t}\\n   345→\\t\\t\\t}\\n   346→\\t\\tcase ActionWarnStaleSession:\\n   347→\\t\\t\\tif handlerErr == nil {\\n   348→\\t\\t\\t\\tif err := handler.HandleWarnStaleSession(state); err != nil {\\n   349→\\t\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"%s: %w\\\", action, err)\\n   350→\\t\\t\\t\\t}\\n   351→\\t\\t\\t}\\n   352→\\t\\tdefault:\\n   353→\\t\\t\\tif handlerErr == nil {\\n   354→\\t\\t\\t\\thandlerErr = fmt.Errorf(\\\"unhandled action: %s\\\", action)\\n   355→\\t\\t\\t}\\n   356→\\t\\t}\\n   357→\\t}\\n   358→\\treturn handlerErr\\n   359→}\\n   360→\\n   361→// MermaidDiagram generates a Mermaid state diagram from the transition table.\\n   362→// The diagram is derived by calling Transition() for representative context\\n   363→// variants per phase/event, so it stays in sync with the implementation.\\n   364→func MermaidDiagram() string {\\n   365→\\tvar b strings.Builder\\n   366→\\tb.WriteString(\\\"stateDiagram-v2\\\\n\\\")\\n   367→\\n   368→\\t// State declarations with descriptions.\\n   369→\\tb.WriteString(\\\"    state \\\\\\\"IDLE\\\\\\\" as idle\\\\n\\\")\\n   370→\\tb.WriteString(\\\"    state \\\\\\\"ACTIVE\\\\\\\" as active\\\\n\\\")\\n   371→\\tb.WriteString(\\\"    state \\\\\\\"ENDED\\\\\\\" as ended\\\\n\\\")\\n   372→\\tb.WriteString(\\\"\\\\n\\\")\\n   373→\\n   374→\\t// Context variants for GitCommit: rebase, files/no-files.\\n   375→\\ttype contextVariant struct {\\n   376→\\t\\tlabel string\\n   377→\\t\\tctx   TransitionContext\\n   378→\\t}\\n   379→\\n   380→\\t// For each phase/event, generate edges.\\n   381→\\tfor _, phase := range allPhases {\\n   382→\\t\\tfor _, event := range allEvents {\\n   383→\\t\\t\\tvar variants []contextVariant\\n   384→\\t\\t\\tswitch {\\n   385→\\t\\t\\tcase event == EventGitCommit && phase == PhaseEnded:\\n   386→\\t\\t\\t\\t// HasFilesTouched only affects PhaseEnded transitions;\\n   387→\\t\\t\\t\\t// other phases produce identical edges for both values.\\n   388→\\t\\t\\t\\tvariants = []contextVariant{\\n   389→\\t\\t\\t\\t\\t{\\\"[files]\\\", TransitionContext{HasFilesTouched: true}},\\n   390→\\t\\t\\t\\t\\t{\\\"[no files]\\\", TransitionContext{HasFilesTouched: false}},\\n   391→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   392→\\t\\t\\t\\t}\\n   393→\\t\\t\\tcase event == EventGitCommit:\\n   394→\\t\\t\\t\\tvariants = []contextVariant{\\n   395→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   396→\\t\\t\\t\\t\\t{\\\"[rebase]\\\", TransitionContext{IsRebaseInProgress: true}},\\n   397→\\t\\t\\t\\t}\\n   398→\\t\\t\\tdefault:\\n   399→\\t\\t\\t\\tvariants = []contextVariant{\\n   400→\\t\\t\\t\\t\\t{\\\"\\\", TransitionContext{}},\\n   401→\\t\\t\\t\\t}\\n   402→\\t\\t\\t}\\n   403→\\n   404→\\t\\t\\tfor _, v := range variants {\\n   405→\\t\\t\\t\\tresult := Transition(phase, event, v.ctx)\\n   406→\\n   407→\\t\\t\\t\\t// Build edge label.\\n   408→\\t\\t\\t\\tlabel := event.String()\\n   409→\\t\\t\\t\\tif v.label != \\\"\\\" {\\n   410→\\t\\t\\t\\t\\tlabel += \\\" \\\" + v.label\\n   411→\\t\\t\\t\\t}\\n   412→\\t\\t\\t\\tif len(result.Actions) > 0 {\\n   413→\\t\\t\\t\\t\\tactionNames := make([]string, 0, len(result.Actions))\\n   414→\\t\\t\\t\\t\\tfor _, a := range result.Actions {\\n   415→\\t\\t\\t\\t\\t\\tactionNames = append(actionNames, a.String())\\n   416→\\t\\t\\t\\t\\t}\\n   417→\\t\\t\\t\\t\\tlabel += \\\" / \\\" + strings.Join(actionNames, \\\", \\\")\\n   418→\\t\\t\\t\\t}\\n   419→\\n   420→\\t\\t\\t\\tfrom := string(phase)\\n   421→\\t\\t\\t\\tto := string(result.NewPhase)\\n   422→\\n   423→\\t\\t\\t\\tfmt.Fprintf(&b, \\\"    %s --> %s : %s\\\\n\\\", from, to, label)\\n   424→\\t\\t\\t}\\n   425→\\t\\t}\\n   426→\\t}\\n   427→\\n   428→\\treturn b.String()\\n   429→}\\n   430→\"}]},\"uuid\":\"71f9ad64-d329-48b7-ad39-1dc2c92f619d\",\"timestamp\":\"2026-03-02T14:30:30.725Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the hook architecture across all supported agents. Specifically:\\n\\n1. What hooks does each agent support? Look in `cmd/entire/cli/agent/` for each agent implementation (claudecode, geminicli, opencode, cursor, factoryai).\\n2. How are hooks configured/installed? Look at `cmd/entire/cli/strategy/hooks.go` and the hook installation code.\\n3. What events does the session phase state machine support? Look at `cmd/entire/cli/session/phase.go` for the Event types.\\n4. How does Claude Code configure its hooks? Look for the hooks configuration (likely in claude code agent setup or `.claude/settings.json` template).\\n5. What tool-level hooks exist for Claude Code? (e.g., PreToolUse, PostToolUse patterns)\\n\\nBe very thorough - look at all agent implementations and their hook configurations.\",\"agentId\":\"a8d4bc45d72b22e23\"},\"toolUseID\":\"agent_msg_01YBybkrKyP1mPckkPQDBJDQ\",\"parentToolUseID\":\"toolu_01MeZwExF6D373JfhfhC8zZt\",\"uuid\":\"81522175-7132-42bb-9e5d-3c5b2ccbe74b\",\"timestamp