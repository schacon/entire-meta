\n   698→\\t}\\n   699→\\treturn filesOverlapWithContent(h.ctx, h.repo, h.shadowBranchName, h.commit, committedTouchedFiles, overlapOpts{\\n   700→\\t\\theadTree:      h.headTree,\\n   701→\\t\\tshadowTree:    h.shadowTree,\\n   702→\\t\\tparentTree:    h.parentTree,\\n   703→\\t\\thasParentTree: true,\\n   704→\\t})\\n   705→}\\n   706→\\n   707→// activeSessionInteractionThreshold is the maximum age of LastInteractionTime\\n   708→// for an ACTIVE session to be considered \\\"genuinely active\\\" (agent currently running).\\n   709→// Sessions with interactions older than this are treated as stale (agent was killed)\\n   710→// and must pass the overlap check to be condensed.\\n   711→//\\n   712→// This must be generous because LastInteractionTime is only updated on agent\\n   713→// lifecycle events (TurnStart, TurnEnd, SessionStop), NOT on individual tool\\n   714→// calls or git hooks. During a long turn, the only update is at TurnStart, so\\n   715→// LastInteractionTime reflects when the turn began — not when the agent last\\n   716→// did something. A complex multi-hour refactoring turn would have\\n   717→// LastInteractionTime several hours old when the agent finally commits.\\n   718→//\\n   719→// 24 hours is safe: no single agent turn lasts a full day, but a killed agent\\n   720→// from yesterday is clearly stale. The worst case is a stale session killed\\n   721→// <24h ago gets one extra condensation — it preserves the data and on the next\\n   722→// commit (>24h later) the overlap check prevents further zombie condensation.\\n   723→const activeSessionInteractionThreshold = 24 * time.Hour\\n   724→\\n   725→// isRecentInteraction returns true if lastInteraction is non-nil and within\\n   726→// activeSessionInteractionThreshold of now.\\n   727→func isRecentInteraction(lastInteraction *time.Time) bool {\\n   728→\\treturn lastInteraction != nil && time.Since(*lastInteraction) < activeSessionInteractionThreshold\\n   729→}\\n   730→\\n   731→func (