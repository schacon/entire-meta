sPath := filepath.Join(repoRoot, \\\".factory\\\", FactorySettingsFileName)\\n   394→\\tdata, err := os.ReadFile(settingsPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   395→\\tif err != nil {\\n   396→\\t\\treturn false\\n   397→\\t}\\n   398→\\n   399→\\tvar settings FactorySettings\\n   400→\\tif err := json.Unmarshal(data, &settings); err != nil {\\n   401→\\t\\treturn false\\n   402→\\t}\\n   403→\\n   404→\\t// Check for at least one of our hooks (new or old format)\\n   405→\\treturn hookCommandExists(settings.Hooks.Stop, \\\"entire hooks factoryai-droid stop\\\") ||\\n   406→\\t\\thookCommandExists(settings.Hooks.Stop, \\\"go run ${FACTORY_PROJECT_DIR}/cmd/entire/main.go hooks factoryai-droid stop\\\")\\n   407→}\\n   408→\\n   409→// Helper functions for hook management\\n   410→\\n   411→func hookCommandExists(matchers []FactoryHookMatcher, command string) bool {\\n   412→\\tfor _, matcher := range matchers {\\n   413→\\t\\tfor _, hook := range matcher.Hooks {\\n   414→\\t\\t\\tif hook.Command == command {\\n   415→\\t\\t\\t\\treturn true\\n   416→\\t\\t\\t}\\n   417→\\t\\t}\\n   418→\\t}\\n   419→\\treturn false\\n   420→}\\n   421→\\n   422→func hookCommandExistsWithMatcher(matchers []FactoryHookMatcher, matcherName, command string) bool {\\n   423→\\tfor _, matcher := range matchers {\\n   424→\\t\\tif matcher.Matcher == matcherName {\\n   425→\\t\\t\\tfor _, hook := range matcher.Hooks {\\n   426→\\t\\t\\t\\tif hook.Command == command {\\n   427→\\t\\t\\t\\t\\treturn true\\n   428→\\t\\t\\t\\t}\\n   429→\\t\\t\\t}\\n   430→\\t\\t}\\n   431→\\t}\\n   432→\\treturn false\\n   433→}\\n   434→\\n   435→func addHookToMatcher(matchers []FactoryHookMatcher, matcherName, command string) []FactoryHookMatcher {\\n   436→\\tentry := FactoryHookEntry{Type: \\\"command\\\", Command: command}\\n   437→\\tfor i := range matchers {\\n   438→\\t\\tif matchers[i].Matcher == matcherName {\\n   439→\\t\\t\\tmatchers[i].Hooks = append(matchers[i].Hooks, entry)\\n   440→\\t\\t\\treturn matchers\\n   441→\\t\\t}\\n   442→\\t}\\n   443→\\treturn append(matchers, FactoryHookMatcher{Matcher: matcherName, Hooks: []FactoryHookEntry{entry}})\\n   444→}\\n   445→\\n   446→// isEntireHook checks if a command is an Entire hook (old or new format)\\n   447→func isEntireHook(command string) bool {\\n   448→\\tfor _, prefix := range entireHookPrefixes {\\n   449→\\t\\tif strings.HasPrefix(command, prefix) {\\n   450→\\t\\t\\treturn true\\n   451→\\t\\t}\\n   452→\\t}\\n   453→\\treturn false\\n   454→}\\n   455→\\n   456→// removeEntireHooks removes all Entire hooks from a list of matchers (for simple hooks like Stop)\\n   457→func removeEntireHooks(matchers []FactoryHookMatcher) []FactoryHookMatcher {\\n   458→\\tresult := make([]FactoryHookMatcher, 0, len(matchers))\\n   459→\\tfor _, matcher := range matchers {\\n   460→\\t\\tfilteredHooks := make([]FactoryHookEntry, 0, len(matcher.Hooks))\\n   461→\\t\\tfor _, hook := range matcher.Hooks {\\n   462→\\t\\t\\tif !isEntireHook(hook.Command) {\\n   463→\\t\\t\\t\\tfilteredHooks = append(filteredHooks, hook)\\n   464→\\t\\t\\t}\\n   465→\\t\\t}\\n   466→\\t\\t// Only keep the matcher if it has hooks remaining\\n   467→\\t\\tif len(filteredHooks) > 0 {\\n   468→\\t\\t\\tmatcher.Hooks = filteredHooks\\n   469→\\t\\t\\tresult = append(result, matcher)\\n   470→\\t\\t}\\n   471→\\t}\\n   472→\\treturn result\\n   473→}\\n   474→\"}]},\"uuid\":\"e0828425-74a8-4dd9-a327-65a7583e65ad\",\"timestamp\":\"2026-03-02T14:30:45.632Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"I need to understand the hook architecture across all supported agents. Specifically:\\n\\n1. What hooks does each agent support? Look in `cmd/entire/cli/agent/` for each agent implementation (claudecode, geminicli, opencode, cursor, factoryai).\\n2. How are hooks configured/installed? Look at `cmd/entire/cli/strategy/hooks.go` and the hook installation code.\\n3. What events does the se