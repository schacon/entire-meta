ons)\\n   592→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   593→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   594→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   595→\\n   596→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   597→\\tcondensed bool\\n   598→}\\n   599→\\n   600→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   601→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   602→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   603→\\n   604→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   605→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   606→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   607→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   608→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   609→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   610→\\t)\\n   611→\\n   612→\\tif shouldCondense {\\n   613→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   614→\\t\\t\\tshadowRef: h.shadowRef,\\n   615→\\t\\t\\theadTree:  h.headTree,\\n   616→\\t\\t})\\n   617→\\t} else {\\n   618→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   619→\\t}\\n   620→\\treturn nil\\n   621→}\\n   622→\\n   623→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   624→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   625→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   626→\\n   627→\\tlogging.Debug(logCtx, 