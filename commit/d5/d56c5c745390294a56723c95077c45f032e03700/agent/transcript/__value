   24→\\tagent.Register(agent.AgentNameClaudeCode, NewClaudeCodeAgent)\\n    25→}\\n    26→\\n    27→// ClaudeCodeAgent implements the Agent interface for Claude Code.\\n    28→//\\n    29→//nolint:revive // ClaudeCodeAgent is clearer than Agent in this context\\n    30→type ClaudeCodeAgent struct{}\\n    31→\\n    32→// NewClaudeCodeAgent creates a new Claude Code agent instance.\\n    33→func NewClaudeCodeAgent() agent.Agent {\\n    34→\\treturn &ClaudeCodeAgent{}\\n    35→}\\n    36→\\n    37→// Name returns the agent registry key.\\n    38→func (c *ClaudeCodeAgent) Name() types.AgentName {\\n    39→\\treturn agent.AgentNameClaudeCode\\n    40→}\\n    41→\\n    42→// Type returns the agent type identifier.\\n    43→func (c *ClaudeCodeAgent) Type() types.AgentType {\\n    44→\\treturn agent.AgentTypeClaudeCode\\n    45→}\\n    46→\\n    47→// Description returns a human-readable description.\\n    48→func (c *ClaudeCodeAgent) Description() string {\\n    49→\\treturn \\\"Claude Code - Anthropic's CLI coding assistant\\\"\\n    50→}\\n    51→\\n    52→func (c *ClaudeCodeAgent) IsPreview() bool { return false }\\n    53→\\n    54→// DetectPresence checks if Claude Code is configured in the repository.\\n    55→func (c *ClaudeCodeAgent) DetectPresence(ctx context.Context) (bool, error) {\\n    56→\\t// Get worktree root to check for .claude directory\\n    57→\\t// This is needed because the CLI may be run from a subdirectory\\n    58→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n    59→\\tif err != nil {\\n    60→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    61→\\t\\trepoRoot = \\\".\\\"\\n    62→\\t}\\n    63→\\n    64→\\t// Check for .claude directory\\n    65→\\tclaudeDir := filepath.Join(repoRoot, \\\".claude\\\")\\n    66→\\tif _, err := os.Stat(claudeDir); err == nil {\\n    67→\\t\\treturn true, nil\\n    68→\\t}\\n    69→\\t// Check for .claude/settings.json\\n    70→\\tsettingsFile := filepath.Join(repoRoot, \\\".claude\\\", \\\"settings.json\\\")\\n    71→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    72→\\t\\treturn true, nil\\n    73→\\t}\\n    74→\\treturn false, nil\\n    75→}\\n    76→\\n    77→// GetSessionID extracts the session ID from hook input.\\n    78→func (c *ClaudeCodeAgent) GetSessionID(input *agent.HookInput) string {\\n    79→\\treturn input.SessionID\\n    80→}\\n    81→\\n    82→// ResolveSessionFile returns the path to a Claude session file.\\n    83→// Claude names files directly as <id>.jsonl.\\n    84→func (c *ClaudeCodeAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n    85→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".jsonl\\\")\\n    86→}\\n    87→\\n    88→// ProtectedDirs returns directories that Claude uses for config/state.\\n    89→func (c *ClaudeCodeAgent) ProtectedDirs() []string { return []string{\\\".claude\\\"} }\\n    90→\\n    91→// GetSessionDir returns the directory where Claude stores session transcripts.\\n    92→func (c *ClaudeCodeAgent) GetSessionDir(repoPath string) (string, error) {\\n    93→\\t// Check for test environment override\\n    94→\\tif override := os.Getenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\"); override != \\\"\\\" {\\n    95→\\t\\treturn override, nil\\n    96→\\t}\\n    97→\\n    98→\\thomeDir, err := os.UserHomeDir()\\n    99→\\tif err != nil {\\n   100→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   101→\\t}\\n   102→\\n   103→\\tprojectDir := SanitizePathForClaude(repoPath)\\n   104→\\treturn filepath.Join(homeDir, \\\".claude\\\", \\\"projects\\\", projectDir), nil\\n   105→}\\n   106→\\n   107→// ReadSession reads a session from Claude's storage (JSONL transcript file).\\n   108→// The session data is stored in NativeData as raw JSONL bytes.\\n   109→// ModifiedFiles is computed by parsing the transcript.\\n   110→func (c *ClaudeCodeAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   111→\\tif input.SessionRef == \\\"\\\" {\\n   112→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   113→\\t}\\n   114→\\n   115→\\t// Read the raw JSONL file\\n   116→\\tdata, err := os.ReadFile(input.SessionRef)\\n   117→\\tif err != nil {\\n   118→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   119→\\t}\\n   120→\\n   121→\\t// Parse to extract computed fields\\n   122→\\tlines, err := transcript.ParseFromBytes(data)\\n   123→\\tif err != nil {\\n   124→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   125→\\t}\\n   126→\\n   127→\\treturn &agent.AgentSession{\\n   128→\\t\\tSessionID:     input.SessionID,\\n   129→\\t\\tAgentName:     c.Name(),\\n   130→\\t\\tSessionRef:    input.SessionRef,\\n   131→\\t\\tStartTime:     time.Now(),\\n   132→\\t\\tNativeData:    data,\\n   133→\\t\\tModifiedFiles: ExtractModifiedFiles(lines),\\n   134→\\t}, nil\\n   135→}\\n   136→\\n   137→// WriteSession writes a session to Claude's storage (JSONL transcript file).\\n   138→// Uses the NativeData field which contains raw JSONL bytes.\\n   139→// The session must have been created by Claude Code (AgentName check).\\n   140→func (c *ClaudeCodeAgent) WriteSession(_ context.Context, session *agent.AgentSession) error {\\n   141→\\tif session == nil {\\n   142→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   143→\\t}\\n   144→\\n   145→\\t// Verify this session belongs to Claude Code\\n   146→\\tif session.AgentName != \\\"\\\" && session.AgentName != c.Name() {\\n   147→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, c.Name())\\n   148→\\t}\\n   149→\\n   150→\\tif session.SessionRef == \\\"\\\" {\\n   151→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   152→\\t}\\n   153→\\n   154→\\tif len(session.NativeData) == 0 {\\n   155→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   156→\\t}\\n   157→\\n   158→\\t// Write the raw JSONL data\\n   159→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   160→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   161→\\t}\\n   162→\\n   163→\\treturn nil\\n   164→}\\n   165→\\n   166→// FormatResumeCommand returns the command to resume a Claude Code session.\\n   167→func (c *ClaudeCodeAgent) FormatResumeCommand(sessionID string) string {\\n   168→\\treturn \\\"claude -r \\\" + sessionID\\n   169→}\\n   170→\\n   171→// Session helper methods - work on AgentSession with Claude's native JSONL data\\n   172→\\n   173→// GetLastUserPrompt extracts the last user prompt from the session.\\n   174→// Requires NativeData to be populated (call ReadSession first).\\n   175→func (c *ClaudeCodeAgent) GetLastUserPrompt(session *agent.AgentSession) string {\\n   176→\\tif session == nil || len(session.NativeData) == 0 {\\n   177→\\t\\treturn \\\"\\\"\\n   178→\\t}\\n   179→\\n   180→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   181→\\tif err != nil {\\n   182→\\t\\treturn \\\"\\\"\\n   183→\\t}\\n   184→\\n   185→\\treturn ExtractLastUserPrompt(lines)\\n   186→}\\n   187→\\n   188→// TruncateAtUUID returns a new session truncated at the given UUID (inclusive).\\n   189→// This is used for rewind operations to restore transcript state.\\n   190→// Requires NativeData to be populated.\\n   191→func (c *ClaudeCodeAgent) TruncateAtUUID(session *agent.AgentSession, uuid string) (*agent.AgentSession, error) {\\n   192→\\tif session == nil {\\n   193→\\t\\treturn nil, errors.New(\\\"session is nil\\\")\\n   194→\\t}\\n   195→\\n   196→\\tif len(session.NativeData) == 0 {\\n   197→\\t\\treturn nil, errors.New(\\\"session has no native data\\\")\\n   198→\\t}\\n   199→\\n   200→\\tif uuid == \\\"\\\" {\\n   201→\\t\\t// No truncation needed, return copy\\n   202→\\t\\treturn &agent.AgentSession{\\n   203→\\t\\t\\tSessionID:     session.SessionID,\\n   204→\\t\\t\\tAgentName:     session.AgentName,\\n   205→\\t\\t\\tRepoPath:      session.RepoPath,\\n   206→\\t\\t\\tSessionRef:    session.SessionRef,\\n   207→\\t\\t\\tStartTime:     session.StartTime,\\n   208→\\t\\t\\tNativeData:    session.NativeData,\\n   209→\\t\\t\\tModifiedFiles: session.ModifiedFiles,\\n   210→\\t\\t}, nil\\n   211→\\t}\\n   212→\\n   213→\\t// Parse, truncate, re-serialize\\n   214→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   215→\\tif err != nil {\\n   216→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   217→\\t}\\n   218→\\n   219→\\ttruncated := TruncateAtUUID(lines, uuid)\\n   220→\\n   221→\\tnewData, err := SerializeTranscript(truncated)\\n   222→\\tif err != nil {\\n   223→\\t\\treturn nil, fmt.Errorf(\\\"failed to serialize truncated transcript: %w\\\", err)\\n   224→\\t}\\n   225→\\n   226→\\treturn &agent.AgentSession{\\n   227→\\t\\tSessionID:     session.SessionID,\\n   228→\\t\\tAgentName:     session.AgentName,\\n   229→\\t\\tRepoPath:      session.RepoPath,\\n   230→\\t\\tSessionRef:    session.SessionRef,\\n   231→\\t\\tStartTime:     session.StartTime,\\n   232→\\t\\tNativeData:    newData,\\n   233→\\t\\tModifiedFiles: ExtractModifiedFiles(truncated),\\n   234→\\t}, nil\\n   235→}\\n   236→\\n   237→// FindCheckpointUUID finds the UUID of the message containing the tool_result\\n   238→// for the given tool use ID. Used for task checkpoint rewind.\\n   239→// Returns the UUID and true if found, empty string and false otherwise.\\n   240→func (c *ClaudeCodeAgent) FindCheckpointUUID(session *agent.AgentSession, toolUseID string) (string, bool) {\\n   241→\\tif session == nil || len(session.NativeData) == 0 {\\n   242→\\t\\treturn \\\"\\\", false\\n   243→\\t}\\n   244→\\n   245→\\tlines, err := transcript.ParseFromBytes(session.NativeData)\\n   246→\\tif err != nil {\\n   247→\\t\\treturn \\\"\\\", false\\n   248→\\t}\\n   249→\\n   250→\\treturn FindCheckpointUUID(lines, toolUseID)\\n   251→}\\n   252→\\n   253→// ReadSessionFromPath is a convenience method that reads a session directly from a file path.\\n   254→// This is useful when you have the path but not a HookInput.\\n   255→func (c *ClaudeCodeAgent) ReadSessionFromPath(transcriptPath, sessionID string) (*agent.AgentSession, error) {\\n   256→\\treturn c.ReadSession(&agent.HookInput{\\n   257→\\t\\tSessionID:  sessionID,\\n   258→\\t\\tSessionRef: transcriptPath,\\n   259→\\t})\\n   260→}\\n   261→\\n   262→// SanitizePathForClaude converts a path to Claude's project directory format.\\n   263→// Claude replaces any non-alphanumeric character with a dash.\\n   264→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   265→\\n   266→func SanitizePathForClaude(path string) string {\\n   267→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   268→}\\n   269→\\n   270→// TranscriptAnalyzer interface implementation\\n   271→\\n   272→// GetTranscriptPosition returns the current line count of a Claude Code transcript.\\n   273→// Claude Code uses JSONL format, so position is the number of lines.\\n   274→// This is a lightweight operation that only counts lines without parsing JSON.\\n   275→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   276→// Returns 0 if the file doesn't exist or is empty.\\n   277→func (c *ClaudeCodeAgent) GetTranscriptPosition(path string) (int, error) {\\n   278→\\tif path == \\\"\\\" {\\n   279→\\t\\treturn 0, nil\\n   280→\\t}\\n   281→\\n   282→\\tfile, err := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   283→\\tif err != nil {\\n   284→\\t\\tif os.IsNotExist(err) {\\n   285→\\t\\t\\treturn 0, nil\\n   286→\\t\\t}\\n   287→\\t\\treturn 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", err)\\n   288→\\t}\\n   289→\\tdefer file.Close()\\n   290→\\n   291→\\treader := bufio.NewReader(file)\\n   292→\\tlineCount := 0\\n   293→\\n   294→\\tfor {\\n   295→\\t\\tline, err := reader.ReadBytes('\\\\n')\\n   296→\\t\\tif err != nil {\\n   297→\\t\\t\\tif err == io.EOF {\\n   298→\\t\\t\\t\\tif len(line) > 0 {\\n   299→\\t\\t\\t\\t\\tlineCount++ // Count final line without trailing newline\\n   300→\\t\\t\\t\\t}\\n   301→\\t\\t\\t\\tbreak\\n   302→\\t\\t\\t}\\n   303→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   304→\\t\\t}\\n   305→\\t\\tlineCount++\\n   306→\\t}\\n   307→\\n   308→\\treturn lineCount, nil\\n   309→}\\n   310→\\n   311→// ExtractModifiedFilesFromOffset extracts files modified since a given line number.\\n   312→// For Claude Code (JSONL format), offset is the starting line number.\\n   313→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n   314→// Returns:\\n   315→//   - files: list of file paths modified by Claude (from Write/Edit tools)\\n   316→//   - currentPosition: total number of lines in the file\\n   317→//   - error: any error encountered during reading\\n   318→func (c *ClaudeCodeAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   319→\\tif path == \\\"\\\" {\\n   320→\\t\\treturn nil, 0, nil\\n   321→\\t}\\n   322→\\n   323→\\tfile, openErr := os.Open(path) //nolint:gosec // Path comes from Claude Code transcript location\\n   324→\\tif openErr != nil {\\n   325→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript file: %w\\\", openErr)\\n   326→\\t}\\n   327→\\tdefer file.Close()\\n   328→\\n   329→\\treader := bufio.NewReader(file)\\n   330→\\tvar lines []TranscriptLine\\n   331→\\tlineNum := 0\\n   332→\\n   333→\\tfor {\\n   334→\\t\\tlineData, readErr := reader.ReadBytes('\\\\n')\\n   335→\\t\\tif readErr != nil && readErr != io.EOF {\\n   336→\\t\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   337→\\t\\t}\\n   338→\\n   339→\\t\\tif len(lineData) > 0 {\\n   340→\\t\\t\\tlineNum++\\n   341→\\t\\t\\tif lineNum > startOffset {\\n   342→\\t\\t\\t\\tv