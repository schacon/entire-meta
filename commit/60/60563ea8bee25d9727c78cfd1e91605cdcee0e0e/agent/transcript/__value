cal.json if it exists.\\n    29→// Returns default settings if neither file exists.\\n    30→// Works correctly from any subdirectory within the repository.\\n    31→func LoadEntireSettings(ctx context.Context) (*settings.EntireSettings, error) {\\n    32→\\ts, err := settings.Load(ctx)\\n    33→\\tif err != nil {\\n    34→\\t\\treturn nil, fmt.Errorf(\\\"loading settings: %w\\\", err)\\n    35→\\t}\\n    36→\\treturn s, nil\\n    37→}\\n    38→\\n    39→// SaveEntireSettings saves the Entire settings to .entire/settings.json.\\n    40→func SaveEntireSettings(ctx context.Context, s *settings.EntireSettings) error {\\n    41→\\tif err := settings.Save(ctx, s); err != nil {\\n    42→\\t\\treturn fmt.Errorf(\\\"saving settings: %w\\\", err)\\n    43→\\t}\\n    44→\\treturn nil\\n    45→}\\n    46→\\n    47→// SaveEntireSettingsLocal saves the Entire settings to .entire/settings.local.json.\\n    48→func SaveEntireSettingsLocal(ctx context.Context, s *settings.EntireSettings) error {\\n    49→\\tif err := settings.SaveLocal(ctx, s); err != nil {\\n    50→\\t\\treturn fmt.Errorf(\\\"saving local settings: %w\\\", err)\\n    51→\\t}\\n    52→\\treturn nil\\n    53→}\\n    54→\\n    55→// IsEnabled returns whether Entire is currently enabled.\\n    56→// Returns true by default if settings cannot be loaded.\\n    57→func IsEnabled(ctx context.Context) (bool, error) {\\n    58→\\ts, err := settings.Load(ctx)\\n    59→\\tif err != nil {\\n    60→\\t\\treturn true, err //nolint:wrapcheck // already present in codebase\\n    61→\\t}\\n    62→\\treturn s.Enabled, nil\\n    63→}\\n    64→\\n    65→// GetStrategy returns the manual-commit strategy instance.\\n    66→func GetStrategy(_ context.Context) *strategy.ManualCommitStrategy {\\n    67→\\treturn strategy.NewManualCommitStrategy()\\n    68→}\\n    69→\\n    70→// GetLogLevel returns the configured log level from settings.\\n    71→// Returns empty string if not configured (caller should use default).\\n    72→// Note: ENTIRE_LOG_LEVEL env var takes precedence; check it first.\\n    73→func GetLogLevel() string {\\n    74→\\ts, err := settings.Load(context.TODO()) //nolint:contextcheck // Called as a callback via SetLogLevelGetter, no ctx available\\n    75→\\tif err != nil {\\n    76→\\t\\treturn \\\"\\\"\\n    77→\\t}\\n    78→\\treturn s.LogLevel\\n    79→}\\n    80→\\n    81→// GetAgentsWithHooksInstalled returns names of agents that have hooks installed.\\n    82→func GetAgentsWithHooksInstalled(ctx context.Context) []types.AgentName {\\n    83→\\tvar installed []types.AgentName\\n    84→\\tfor _, name := range agent.List() {\\n    85→\\t\\tag, err := agent.Get(name)\\n    86→\\t\\tif err != nil {\\n    87→\\t\\t\\tcontinue\\n    88→\\t\\t}\\n    89→\\t\\tif hs, ok := agent.AsHookSupport(ag); ok && hs.AreHooksInstalled(ctx) {\\n    90→\\t\\t\\tinstalled = append(installed, name)\\n    91→\\t\\t}\\n    92→\\t}\\n    93→\\treturn installed\\n    94→}\\n    95→\\n    96→// JoinAgentNames joins agent names into a comma-separated string.\\n    97→func JoinAgentNames(names []types.AgentName) string {\\n    98→\\tstrs := make([]string, len(names))\\n    99→\\tfor i, n := range names {\\n   100→\\t\\tstrs[i] = string(n)\\n   101→\\t}\\n   102→\\treturn strings.Join(strs, \\\",\\\")\\n   103→}\\n   104→\"}]},\"uuid\":\"e2a9848b-8881-43da-bdb8-ffb7fa8e449c\",\"timestamp\":\"2026-03-10T12:20:53.032Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a1041a40dde61de34\"},\"toolUseID\":\"agent_msg_011NsSArh2BonnNmgzdDiVhg\",\"parentToolUseID\":\"toolu_01CdRVnbZwsVrBmKQjRY4cRW\",\"uuid\":\"1afcdf26-49e8-4b14-bd2f-5d9495ca694c\",\"timestamp\":\"2026-03-10T12:20:53.034Z\"}\n{\"parentUuid\":\"1afcdf26-49e8-4b14-bd2f-5d9495ca694c\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli_worktree1\",\"sessionId\":\"460b7f6a-8219-478a-b1bd-4df8d5db96a5\",\"version\":\"2.1.72\",\"gitBranch\":\"soph/improve-enable\",\"slug\":\"lucky-strolling-origami\",\"t