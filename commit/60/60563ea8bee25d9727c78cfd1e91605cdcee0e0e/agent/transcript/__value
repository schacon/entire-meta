registryMu sync.RWMutex\\n    14→\\tregistry   = make(map[types.AgentName]Factory)\\n    15→)\\n    16→\\n    17→// Factory creates a new agent instance\\n    18→type Factory func() Agent\\n    19→\\n    20→// Register adds an agent factory to the registry.\\n    21→// Called from init() in each agent implementation.\\n    22→func Register(name types.AgentName, factory Factory) {\\n    23→\\tregistryMu.Lock()\\n    24→\\tdefer registryMu.Unlock()\\n    25→\\tregistry[name] = factory\\n    26→}\\n    27→\\n    28→// Get retrieves an agent by name.\\n    29→//\\n    30→\\n    31→func Get(name types.AgentName) (Agent, error) {\\n    32→\\tregistryMu.RLock()\\n    33→\\tdefer registryMu.RUnlock()\\n    34→\\n    35→\\tfactory, ok := registry[name]\\n    36→\\tif !ok {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"unknown agent: %s (available: %v)\\\", name, List())\\n    38→\\t}\\n    39→\\treturn factory(), nil\\n    40→}\\n    41→\\n    42→// List returns all registered agent names in sorted order.\\n    43→func List() []types.AgentName {\\n    44→\\tregistryMu.RLock()\\n    45→\\tdefer registryMu.RUnlock()\\n    46→\\n    47→\\tnames := make([]types.AgentName, 0, len(registry))\\n    48→\\tfor name := range registry {\\n    49→\\t\\tnames = append(names, name)\\n    50→\\t}\\n    51→\\tslices.Sort(names)\\n    52→\\treturn names\\n    53→}\\n    54→\\n    55→// StringList returns user-facing agent names, excluding test-only agents.\\n    56→func StringList() []string {\\n    57→\\tregistryMu.RLock()\\n    58→\\tdefer registryMu.RUnlock()\\n    59→\\n    60→\\tnames := make([]string, 0, len(registry))\\n    61→\\tfor name, factory := range registry {\\n    62→\\t\\tif to, ok := factory().(TestOnly); ok && to.IsTestOnly() {\\n    63→\\t\\t\\tcontinue\\n    64→\\t\\t}\\n    65→\\t\\tnames = append(names, string(name))\\n    66→\\t}\\n    67→\\tslices.Sort(names)\\n    68→\\treturn names\\n    69→}\\n    70→\\n    71→// DetectAll returns all agents whose DetectPresence reports true.\\n    72→// Agents are checked in sorted name order (via List()) for deterministic results.\\n    73→// Returns an empty slice when no agent is detected.\\n    74→func DetectAll(ctx context.Context) []Agent {\\n    75→\\tnames := List() // sorted, lock-safe\\n    76→\\n    77→\\tvar detected []Agent\\n    78→\\tfor _, name := range names {\\n    79→\\t\\tag, err := Get(name)\\n    80→\\t\\tif err != nil {\\n    81→\\t\\t\\tcontinue\\n    82→\\t\\t}\\n    83→\\t\\tif present, err := ag.DetectPresence(ctx); err == nil && present {\\n    84→\\t\\t\\tdetected = append(detected, ag)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\treturn detected\\n    88→}\\n    89→\\n    90→// Detect attempts to auto-detect which agent is being used.\\n    91→// Iterates registered agents in sorted name order for deterministic results.\\n    92→// Returns the first agent whose DetectPresence reports true.\\n    93→func Detect(ctx context.Context) (Agent, error) {\\n    94→\\tdetected := DetectAll(ctx)\\n    95→\\tif len(detected) == 0 {\\n    96→\\t\\treturn nil, fmt.Errorf(\\\"no agent detected (available: %v)\\\", List())\\n    97→\\t}\\n    98→\\treturn detected[0], nil\\n    99→}\\n   100→\\n   101→// Agent name constants (registry keys)\\n   102→const (\\n   103→\\tAgentNameClaudeCode     types.AgentName = \\\"claude-code\\\"\\n   104→\\tAgentNameCopilotCLI     types.AgentName = \\\"copilot-cli\\\"\\n   105→\\tAgentNameCursor         types.AgentName = \\\"cursor\\\"\\n   106→\\tAgentNameFactoryAIDroid types.AgentName = \\\"factoryai-droid\\\"\\n   107→\\tAgentNameGemini         types.AgentName = \\\"gemini\\\"\\n   108→\\tAgentNameOpenCode       types.AgentName = \\\"opencode\\\"\\n   109→)\\n   110→\\n   111→// Agent type constants (type identifiers stored in metadata/trailers)\\n   112→const (\\n   113→\\tAgentTypeClaudeCode     types.AgentType = \\\"Claude Code\\\"\\n   114→\\tAgentTypeCopilotCLI     types.AgentType = \\\"Copilot CLI\\\"\\n   115→\\tAgentTypeCursor         t