rOrStderr(), \\\"Not a git repository. Please run 'entire enable' from within a git repository.\\\")\\n    61→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n    62→\\t\\t\\t}\\n    63→\\n    64→\\t\\t\\tif err := validateSetupFlags(opts.UseLocalSettings, opts.UseProjectSettings); err != nil {\\n    65→\\t\\t\\t\\treturn err\\n    66→\\t\\t\\t}\\n    67→\\n    68→\\t\\t\\t// Discover external agent plugins so they appear in agent selection.\\n    69→\\t\\t\\texternal.DiscoverAndRegister(ctx)\\n    70→\\n    71→\\t\\t\\t// Warn if repo has no commits yet\\n    72→\\t\\t\\tif repo, err := strategy.OpenRepository(ctx); err == nil && strategy.IsEmptyRepository(repo) {\\n    73→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Note: This repository has no commits yet. Entire will be configured, but\\\")\\n    74→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"session checkpoints won't work until you create your first commit.\\\")\\n    75→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout())\\n    76→\\t\\t\\t}\\n    77→\\n    78→\\t\\t\\t// Non-interactive mode if --agent flag is provided\\n    79→\\t\\t\\tif cmd.Flags().Changed(\\\"agent\\\") && agentName == \\\"\\\" {\\n    80→\\t\\t\\t\\tprintMissingAgentError(cmd.ErrOrStderr())\\n    81→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n    82→\\t\\t\\t}\\n    83→\\n    84→\\t\\t\\tif agentName != \\\"\\\" {\\n    85→\\t\\t\\t\\tag, err := agent.Get(types.AgentName(agentName))\\n    86→\\t\\t\\t\\tif err != nil {\\n    87→\\t\\t\\t\\t\\tprintWrongAgentError(cmd.ErrOrStderr(), agentName)\\n    88→\\t\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"wrong agent name\\\"))\\n    89→\\t\\t\\t\\t}\\n    90→\\t\\t\\t\\t// --agent is a targeted operation: set up this specific agent without\\n    91→\\t\\t\\t\\t// affecting other agents. Unlike the interactive path, it does not\\n    92→\\t\\t\\t\\t// uninstall hooks for other previously-enabled agents.\\n    93→\\t\\t\\t\\treturn setupAgentHooksNonInteractive(ctx, cmd.OutOrStdout(), ag, opts)\\n    94→\\t\\t\\t}\\n    95→\\t\\t\\t// Detect or prompt for agents\\n    96→\\t\\t\\tagents, err := detectOrSelectAgent(ctx, cmd.OutOrStdout(), nil)\\n    97→\\t\\t\\tif err != nil {\\n    98→\\t\\t\\t\\treturn fmt.Errorf(\\\"agent selection failed: %w\\\", err)\\n    99→\\t\\t\\t}\\n   100→\\n   101→\\t\\t\\treturn runEnableInteractive(ctx, cmd.OutOrStdout(), agents, opts)\\n   102→\\t\\t},\\n   103→\\t}\\n   104→\\n   105→\\tcmd.Flags().BoolVar(&opts.LocalDev, \\\"local-dev\\\", false, \\\"Use go run instead of entire binary for hooks\\\")\\n   106→\\tcmd.Flags().MarkHidden(\\\"local-dev\\\") //nolint:errcheck,gosec // flag is defined above\\n   107→\\tcmd.Flags().BoolVar(&ignoreUntracked, \\\"ignore-untracked\\\", false, \\\"Commit all new files without tracking pre-existing untracked files\\\")\\n   108→\\tcmd.Flags().MarkHidden(\\\"ignore-untracked\\\") //nolint:errcheck,gosec // flag is defined above\\n   109→\\tcmd.Flags().BoolVar(&opts.UseLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   110→\\tcmd.Flags().BoolVar(&opts.UseProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   111→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to set up hooks for (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\"). Enables non-interactive mode.\\\")\\n   112→\\tcmd.Flags().BoolVarP(&opts.ForceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   113→\\tcmd.Flags().BoolVar(&opts.SkipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   114→\\tcmd.Flags().BoolVar(&opts.Telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   115→\\tcmd.Flags().BoolVar(&opts.AbsoluteGitHookPath, \\\"absolute-git-hook-path\\\", false, \\\"Embed full binary path in git hooks (for GUI git clients that don't source shell profiles)\\\")\\n   116→\\n   117→\\t// Provide a helpful error when --agent is used without a value\\n   118→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   119→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   120→\\t\\tvar valErr *pflag.ValueRequiredError\\n   121→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   122→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   123→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   124→\\t\\t}\\n   125→\\t\\treturn defaultFlagErr(c, err)\\n   126→\\t})\\n   127→\\n   128→\\t// Add subcommands for automation/testing\\n   129→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   130→\\n   131→\\treturn cmd\\n   132→}\\n   133→\\n   134→func newDisableCmd() *cobra.Command {\\n   135→\\tvar useProjectSettings bool\\n   136→\\tvar uninstall bool\\n   137→\\tvar force bool\\n   138→\\n   139→\\tcmd := &cobra.Command{\\n   140→\\t\\tUse:   \\\"disable\\\",\\n   141→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   142→\\t\\tLong: `Disable Entire integrations in the current project.\\n   143→\\n   144→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   145→show a disabled message.\\n   146→\\n   147→To completely remove Entire integrations from this repository, use --uninstall:\\n   148→  - .entire/ directory (settings, logs, metadata)\\n   149→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   150→  - Session state files (.git/entire-sessions/)\\n   151→  - Shadow branches (entire/<hash>)\\n   152→  - Agent hooks`,\\n   153→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   154→\\t\\t\\tctx := cmd.Context()\\n   155→\\t\\t\\tif uninstall {\\n   156→\\t\\t\\t\\treturn runUninstall(ctx, cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   157→\\t\\t\\t}\\n   158→\\t\\t\\treturn runDisable(ctx, cmd.OutOrStdout(), useProjectSettings)\\n   159→\\t\\t},\\n   160→\\t}\\n   161→\\n   162→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   163→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   164→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   165→\\n   166→\\treturn cmd\\n   167→}\\n   168→\\n   169→// runEnableInteractive runs the interactive enable flow.\\n   170→// agents must be provided by the caller (via detectOrSelectAgent).\\n   171→func runEnableInteractive(ctx context.Context, w io.Writer, agents []agent.Agent, opts EnableOptions) error {\\n   172→\\t// Uninstall hooks for agents that were previously active but are no longer selected\\n   173→\\tif err := uninstallDeselectedAgentHooks(ctx, w, agents); err != nil {\\n   174→\\t\\treturn fmt.Errorf(\\\"failed to clean up deselected agents: %w\\\", err)\\n   175→\\t}\\n   176→\\n   177→\\t// Setup agent hooks for all selected agents\\n   178→\\tfor _, ag := range agents {\\n   179→\\t\\tif _, err := setupAgentHooks(ctx, ag, opts.LocalDev, opts.ForceHooks); err != nil {\\n   180→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   181→\\t\\t}\\n   182→\\t}\\n   183→\\n   184→\\t// Setup .entire directory\\n   185→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   186→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   187→\\t}\\n   188→\\n   189→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   190→\\tsettings, err := LoadEntireSettings(ctx)\\n   191→\\tif err != nil {\\n   192→\\t\\t// If we can't load, start with defaults\\n   193→\\t\\tsettings = &EntireSettings{}\\n   194→\\t}\\n   195→\\t// Update the specific fields\\n   196→\\tsettings.Enabled = true\\n   197→\\tif opts.LocalDev {\\n   198→\\t\\tsettings.LocalDev = true\\n   199→\\t}\\n   200→\\tif opts.AbsoluteGitHookPath {\\n   201→\\t\\tsettings.AbsoluteGitHookPath = true\\n   202→\\t}\\n   203→\\n   204→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   205→\\tif opts.SkipPushSessions {\\n   206→\\t\\tif settings.StrategyOptions == nil {\\n   207→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   208→\\t\\t}\\n   209→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   210→\\t}\\n   211→\\n   212→\\t// Determine which settings file to write to\\n   213→\\t// First run always creates settings.json (no prompt)\\n   214→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   215→\\tif err != nil {\\n   216→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   217→\\t}\\n   218→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, opts.UseLocalSettings, opts.UseProjectSettings)\\n   219→\\n   220→\\tif showNotification {\\n   221→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   222→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   223→\\t}\\n   224→\\n   225→\\t// Save settings to the appropriate file.\\n   226→\\tsaveSettings := func() error {\\n   227→\\t\\tif shouldUseLocal {\\n   228→\\t\\t\\treturn SaveEntireSettingsLocal(ctx, settings)\\n   229→\\t\\t}\\n   230→\\t\\treturn SaveEntireSettings(ctx, settings)\\n   231→\\t}\\n   232→\\tif err := saveSettings(); err != nil {\\n   233→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   234→\\t}\\n   235→\\n   236→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   237→\\t// This ensures re-running `entire enable` without flags preserves existing settings\\n   238→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   239→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   240→\\t}\\n   241→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   242→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   243→\\n   244→\\tconfigDisplay := configDisplayProject\\n   245→\\tif shouldUseLocal {\\n   246→\\t\\tconfigDisplay = configDisplayLocal\\n   247→\\t}\\n   248→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   249→\\n   250→\\t// Ask about telemetry consent (only if not already asked)\\n   251→\\tfmt.Fprintln(w)\\n   252→\\tif err := promptTelemetryConsent(settings, opts.Telemetry); err != nil {\\n   253→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   254→\\t}\\n   255→\\t// Save again to persist telemetry choice\\n   256→\\tif err := saveSettings(); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   261→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   262→\\t}\\n   263→\\n   264→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   265→\\n   266→\\treturn nil\\n   267→}\\n   268→\\n   269→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   270→func runEnable(ctx context.Context, w io.Writer) error {\\n   271→\\tsettings, err := LoadEntireSettings(ctx)\\n   272→\\tif err != nil {\\n   273→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   274→\\t}\\n   275→\\n   276→\\tsettings.Enabled = true\\n   277→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   278→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   279→\\t}\\n   280→\\n   281→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   282→\\treturn nil\\n   283→}\\n   284→\\n   285→func runDisable(ctx context.Context, w io.Writer, useProjectSettings bool) error {\\n   286→\\tsettings, err := LoadEntireSettings(ctx)\\n   287→\\tif err != nil {\\n   288→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   289→\\t}\\n   290→\\n   291→\\tsettings.Enabled = false\\n   292→\\n   293→\\t// If --project flag is specified, always write to project settings\\n   294→\\tif useProjectSettings {\\n   295→\\t\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   296→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   297→\\t\\t}\\n   298→\\t} else {\\n   299→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   300→\\t\\tif err := SaveEntireSettingsLocal(ctx, settings); err != nil {\\n   301→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   302→\\t\\t}\\n   303→\\t}\\n   304→\\n   305→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   306→\\treturn nil\\n   307→}\\n   308→\\n   309→// DisabledMessage is the message shown when Entire is disabled\\n   310→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   311→\\n   312→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   313→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   314→// On error reading settings, defaults to enabled (returns false).\\n   315→func checkDisabledGuard(ctx context.Context, w io.Writer) bool {\\n   316→\\tenabled, err := IsEnabled(ctx)\\n   317→\\tif err != nil {\\n   318→\\t\\t// Default to enabled on error\\n   319→\\t\\treturn false\\n   320→\\t}\\n   321→\\tif !enabled {\\n   322→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   323→\\t\\treturn true\\n   324→\\t}\\n   325→\\treturn false\\n   326→}\\n   327→\\n   328→// uninstallDeselectedAgentHooks removes hooks for agents that were previously\\n   329→// installed but are not in the selected list. This handles the case where a user\\n   330→// re-runs `entire enable` and deselects an agent.\\n   331→func uninstallDeselectedAgentHooks(ctx context.Context, w io.Writer, selectedAgents []agent.Agent) error {\\n   332→\\tinstalledNames := GetAgentsWithHooksInstalled(ctx)\\n   333→\\tif len(installedNames) == 0 {\\n   334→\\t\\treturn nil\\n   335→\\t}\\n   336→\\n   337→\\tselectedSet := make(map[types.AgentName]struct{}, len(selectedAgents))\\n   338→\\tfor _, ag := range selectedAgents {\\n   339→\\t\\tselectedSet[ag.Name()] = struct{}{}\\n   340→\\t}\\n   341→\\n   342→\\tvar errs []error\\n   343→\\tfor _, name := range installedNames {\\n   344→\\t\\tif _, selected := selectedSet[name]; selected {\\n   345→\\t\\t\\tcontinue\\n   346→\\t\\t}\\n   347→\\t\\tag, err := agent.Get(name)\\n   348→\\t\\tif err != nil {\\n   349→\\t\\t\\tcontinue\\n   350→\\t\\t}\\n   351→\\t\\thookAgent, ok := agent.AsHookSupport(ag)\\n   352→\\t\\tif !ok {\\n   353→\\t\\t\\tcontinue\\n   354→\\t\\t}\\n   355→\\t\\tif err := hookAgent.UninstallHooks(ctx); err != nil {\\n   356→\\t\\t\\terrs = append(errs, fmt.Errorf(\\\"failed to uninstall %s hooks: %w\\\", ag.Type(), err))\\n   357→\\t\\t} else {\\n   358→\\t\\t\\tfmt.Fprintf(w, \\\"Removed %s hooks\\\\n\\\", ag.Type())\\n   359→\\t\\t}\\n   360→\\t}\\n   361→\\treturn errors.Join(errs...)\\n   362→}\\n   363→\\n   364→// setupAgentHooks sets up hooks for a given agent.\\n   365→// Returns the number of hooks installed (0 if already installed).\\n   366→func setupAgentHooks(ctx context.Context, ag agent.Agent, localDev, forceHooks bool) (int, error) {\\n   367→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   368→\\tif !ok {\\n   369→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   370→\\t}\\n   371→\\n   372→\\tcount, err := hookAgent.InstallHooks(ctx, localDev, forceHooks)\\n   373→\\tif err != nil {\\n   374→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   375→\\t}\\n   376→\\n   377→\\treturn count, nil\\n   378→}\\n   379→\\n   380→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   381→// Returns the detected/selected agents and any error.\\n   382→//\\n   383→// On first run (no hooks installed):\\n   384→//   - Single detected agent: used automatically\\n   385→//   - Multiple/no detected agents: interactive multi-select prompt\\n   386→//\\n   387→// On re-run (hooks already installed):\\n   388→//   - Always shows the interactive multi-select\\n   389→//   - Pre-selects only agents that have hooks installed (respects prior deselection)\\n   390→//\\n   391→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   392→// It receives available agent names and returns the selected names.\\n   393→func detectOrSelectAgent(ctx context.Context, w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   394→\\t// Check for agents with hooks already installed (re-run detection)\\n   395→\\tinstalledAgentNames := GetAgentsWithHooksInstalled(ctx)\\n   396→\\thasInstalledHooks := len(installedAgentNames) > 0\\n   397→\\n   398→\\t// Try auto-detection\\n   399→\\tdetected := agent.DetectAll(ctx)\\n   400→\\n   401→\\t// First run: use existing auto-detect shortcuts\\n   402→\\tif !hasInstalledHooks {\\n   403→\\t\\tswitch {\\n   404→\\t\\tcase len(detected) == 1:\\n   405→\\t\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   406→\\t\\t\\treturn detected, nil\\n   407→\\n   408→\\t\\tcase len(detected) > 1:\\n   409→\\t\\t\\tagentTypes := make([]string, 0, len(detected))\\n   410→\\t\\t\\tfor _, ag := range detected {\\n   411→\\t\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   412→\\t\\t\\t}\\n   413→\\t\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   414→\\t\\t\\tfmt.Fprintln(w)\\n   415→\\t\\t}\\n   416→\\t}\\n   417→\\n   418→\\t// Check if we can prompt interactively\\n   419→\\tif !canPromptInteractively() {\\n   420→\\t\\tif hasInstalledHooks {\\n   421→\\t\\t\\t// Re-run without TTY — keep currently installed agents\\n   422→\\t\\t\\tagents := make([]agent.Agent, 0, len(installedAgentNames))\\n   423→\\t\\t\\tfor _, name := range installedAgentNames {\\n   424→\\t\\t\\t\\tag, err := agent.Get(name)\\n   425→\\t\\t\\t\\tif err != nil {\\n   426→\\t\\t\\t\\t\\tcontinue\\n   427→\\t\\t\\t\\t}\\n   428→\\t\\t\\t\\tagents = append(agents, ag)\\n   429→\\t\\t\\t}\\n   430→\\t\\t\\treturn agents, nil\\n   431→\\t\\t}\\n   432→\\t\\tif len(detected) > 0 {\\n   433→\\t\\t\\treturn detected, nil\\n   434→\\t\\t}\\n   435→\\t\\tdefaultAgent := agent.Default()\\n   436→\\t\\tif defaultAgent == nil {\\n   437→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   438→\\t\\t}\\n   439→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   440→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   441→\\t}\\n   442→\\n   443→\\tif !hasInstalledHooks && len(detected) == 0 {\\n   444→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., \\\"+strings.Join(agent.StringList(), \\\", \\\")+\\\").\\\")\\n   445→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   446→\\t\\tfmt.Fprintln(w)\\n   447→\\t}\\n   448→\\n   449→\\t// Build pre-selection set.\\n   450→\\t// On re-run: only pre-select agents with hooks installed (respect prior deselection).\\n   451→\\t// On first run: pre-select all detected agents.\\n   452→\\tpreSelectedSet := make(map[types.AgentName]struct{})\\n   453→\\tif hasInstalledHooks {\\n   454→\\t\\tfor _, name := range installedAgentNames {\\n   455→\\t\\t\\tpreSelectedSet[name] = struct{}{}\\n   456→\\t\\t}\\n   457→\\t} else {\\n   458→\\t\\tfor _, ag := range detected {\\n   459→\\t\\t\\tpreSelectedSet[ag.Name()] = struct{}{}\\n   460→\\t\\t}\\n   461→\\t}\\n   462→\\n   463→\\t// Build options from registered agents\\n   464→\\tagentNames := agent.List()\\n   465→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   466→\\tfor _, name := range agentNames {\\n   467→\\t\\tag, err := agent.Get(name)\\n   468→\\t\\tif err != nil {\\n   469→\\t\\t\\tcontinue\\n   470→\\t\\t}\\n   471→\\t\\t// Only show agents that support hooks\\n   472→\\t\\tif _, ok := agent.AsHookSupport(ag); !ok {\\n   473→\\t\\t\\tcontinue\\n   474→\\t\\t}\\n   475→\\t\\t// Skip test-only agents (e.g., Vogon canary)\\n   476→\\t\\tif to, ok := ag.(agent.TestOnly); ok && to.IsTestOnly() {\\n   477→\\t\\t\\tcontinue\\n   478→\\t\\t}\\n   479→\\t\\topt := huh.NewOption(string(ag.Type()), string(name))\\n   480→\\t\\tif _, isPreSelected := preSelectedSet[name]; isPreSelected {\\n   481→\\t\\t\\topt = opt.Selected(true)\\n   482→\\t\\t}\\n   483→\\t\\toptions = append(options, opt)\\n   484→\\t}\\n   485→\\n   486→\\tif len(options) == 0 {\\n   487→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   488→\\t}\\n   489→\\n   490→\\t// Collect available agent names for the selector\\n   491→\\tavailableNames := make([]string, 0, len(options))\\n   492→\\tfor _, opt := range options {\\n   493→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   494→\\t}\\n   495→\\n   496→\\tvar selectedAgentNames []string\\n   497→\\tif selectFn != nil {\\n   498→\\t\\tvar err error\\n   499→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   500→\\t\\tif err != nil {\\n   501→\\t\\t\\treturn nil, err\\n   502→\\t\\t}\\n   503→\\t\\tif len(selectedAgentNames) == 0 {\\n   504→\\t\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   505→\\t\\t}\\n   506→\\t} else {\\n   507→\\t\\tform := NewAccessibleForm(\\n   508→\\t\\t\\thuh.NewGroup(\\n   509→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   510→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   511→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   512→\\t\\t\\t\\t\\tOptions(options...).\\n   513→\\t\\t\\t\\t\\tValidate(func(selected []string) error {\\n   514→\\t\\t\\t\\t\\t\\tif len(selected) == 0 {\\n   515→\\t\\t\\t\\t\\t\\t\\treturn errors.New(\\\"please select at least one agent\\\")\\n   516→\\t\\t\\t\\t\\t\\t}\\n   517→\\t\\t\\t\\t\\t\\treturn nil\\n   518→\\t\\t\\t\\t\\t}).\\n   519→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   520→\\t\\t\\t),\\n   521→\\t\\t)\\n   522→\\t\\tif err := form.Run(); err != nil {\\n   523→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   524→\\t\\t}\\n   525→\\t}\\n   526→\\n   527→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   528→\\tfor _, name := range selectedAgentNames {\\n   529→\\t\\tselectedAgent, err := agent.Get(types.AgentName(name))\\n   530→\\t\\tif err != nil {\\n   531→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   532→\\t\\t}\\n   533→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   534→\\t}\\n   535→\\n   536→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   537→\\tfor _, ag := range selectedAgents {\\n   538→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   539→\\t}\\n   540→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   541→\\treturn selectedAgents, nil\\n   542→}\\n   543→\\n   544→// canPromptInteractively checks if we can show interactive prompts.\\n   545→// Returns false when running in CI, tests, or other non-interactive environments.\\n   546→func canPromptInteractively() bool {\\n   547→\\t// Check for test environment\\n   548→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   549→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   550→\\t}\\n   551→\\n   552→\\t// Check if /dev/tty is available\\n   553→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   554→\\tif err != nil {\\n   555→\\t\\treturn false\\n   556→\\t}\\n   557→\\t_ = tty.Close()\\n   558→\\treturn true\\n   559→}\\n   560→\\n   561→// printAgentError writes an error message followed by available agents and usage.\\n   562→func printAgentError(w io.Writer, message string) {\\n   563→\\tagents := agent.List()\\n   564→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   565→\\tfmt.Fprintln(w)\\n   566→\\tfor _, a := range agents {\\n   567→\\t\\tsuffix := \\\"\\\"\\n   568→\\t\\tif a == agent.DefaultAgentName {\\n   569→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   570→\\t\\t}\\n   571→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   572→\\t}\\n   573→\\tfmt.Fprintln(w)\\n   574→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   575→}\\n   576→\\n   577→// printMissingAgentError writes a helpful error listing available agents.\\n   578→func printMissingAgentError(w io.Writer) {\\n   579→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   580→}\\n   581→\\n   582→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   583→func printWrongAgentError(w io.Writer, name string) {\\n   584→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   585→}\\n   586→\\n   587→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   588→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   589→func setupAgentHooksNonInteractive(ctx context.Context, w io.Writer, ag agent.Agent, opts EnableOptions) error {\\n   590→\\tagentName := ag.Name()\\n   591→\\t// Check if agent supports hooks\\n   592→\\thookAgent, ok := agent.AsHookSupport(ag)\\n   593→\\tif !ok {\\n   594→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   595→\\t}\\n   596→\\n   597→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   598→\\n   599→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   600→\\tinstalledHooks, err := hookAgent.InstallHooks(ctx, opts.LocalDev, opts.ForceHooks)\\n   601→\\tif err != nil {\\n   602→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   603→\\t}\\n   604→\\n   605→\\t// Setup .entire directory\\n   606→\\tif _, err := setupEntireDirectory(ctx); err != nil {\\n   607→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   608→\\t}\\n   609→\\n   610→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   611→\\tsettings, err := LoadEntireSettings(ctx)\\n   612→\\tif err != nil {\\n   613→\\t\\t// If we can't load, start with defaults\\n   614→\\t\\tsettings = &EntireSettings{}\\n   615→\\t}\\n   616→\\tsettings.Enabled = true\\n   617→\\tif opts.LocalDev {\\n   618→\\t\\tsettings.LocalDev = true\\n   619→\\t}\\n   620→\\tif opts.AbsoluteGitHookPath {\\n   621→\\t\\tsettings.AbsoluteGitHookPath = true\\n   622→\\t}\\n   623→\\n   624→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   625→\\tif opts.SkipPushSessions {\\n   626→\\t\\tif settings.StrategyOptions == nil {\\n   627→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   628→\\t\\t}\\n   629→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   630→\\t}\\n   631→\\n   632→\\t// Handle telemetry for non-interactive mode\\n   633→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   634→\\tif !opts.Telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   635→\\t\\tf := false\\n   636→\\t\\tsettings.Telemetry = &f\\n   637→\\t}\\n   638→\\n   639→\\tif err := SaveEntireSettings(ctx, settings); err != nil {\\n   640→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   641→\\t}\\n   642→\\n   643→\\t// Use settings values (merged from existing config + flags) for hook installation\\n   644→\\t// This ensures re-running `entire enable --agent X` without flags preserves existing settings\\n   645→\\tif _, err := strategy.InstallGitHook(ctx, true, settings.LocalDev, settings.AbsoluteGitHookPath); err != nil {\\n   646→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   647→\\t}\\n   648→\\tstrategy.CheckAndWarnHookManagers(ctx, w, settings.LocalDev, settings.AbsoluteGitHookPath)\\n   649→\\n   650→\\tif installedHooks == 0 {\\n   651→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   652→\\t\\tif ag.IsPreview() {\\n   653→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   654→\\t\\t}\\n   655→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   656→\\t} else {\\n   657→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   658→\\t\\tif ag.IsPreview() {\\n   659→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   660→\\t\\t}\\n   661→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   662→\\t}\\n   663→\\n   664→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   665→\\n   666→\\tif err := strategy.EnsureSetup(ctx); err != nil {\\n   667→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   668→\\t}\\n   669→\\n   670→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   671→\\n   672→\\treturn nil\\n   673→}\\n   674→\\n   675→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   676→func validateSetupFlags(useLocal, useProject bool) error {\\n   677→\\tif useLocal && useProject {\\n   678→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   679→\\t}\\n   680→\\treturn nil\\n   681→}\\n   682→\\n   683→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   684→// - Whether settings.json already exists\\n   685→// - The --local and --project flags\\n   686→// Returns (useLocal, showNotification).\\n   687→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   688→\\t// Explicit --local flag always uses local settings\\n   689→\\tif useLocal {\\n   690→\\t\\treturn true, false\\n   691→\\t}\\n   692→\\n   693→\\t// Explicit --project flag always uses project settings\\n   694→\\tif useProject {\\n   695→\\t\\treturn false, false\\n   696→\\t}\\n   697→\\n   698→\\t// No flags specified - check if settings file exists\\n   699→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   700→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   701→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   702→\\t\\treturn true, true\\n   703→\\t}\\n   704→\\n   705→\\t// Settings file doesn't exist - create it\\n   706→\\treturn false, false\\n   707→}\\n   708→\\n   709→// setupEntireDirectory creates the .entire directory and gitignore.\\n   710→// Returns true if the directory was created, false if it already existed.\\n   711→func setupEntireDirectory(ctx context.Context) (bool, error) { //nolint:unparam // already present in codebase\\n   712→\\t// Get absolute path for the .entire directory\\n   713→\\tentireDirAbs, err := paths.AbsPath(ctx, paths.EntireDir)\\n   714→\\tif err != nil {\\n   715→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   716→\\t}\\n   717→\\n   718→\\t// Check if directory already exists\\n   719→\\tcreated := false\\n   720→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   721→\\t\\tcreated = true\\n   722→\\t}\\n   723→\\n   724→\\t// Create .entire directory\\n   725→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   726→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   727→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   728→\\t}\\n   729→\\n   730→\\t// Create/update .gitignore with all required entries\\n   731→\\tif err := strategy.EnsureEntireGitignore(ctx); err != nil {\\n   732→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   733→\\t}\\n   734→\\n   735→\\treturn created, nil\\n   736→}\\n   737→\\n   738→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   739→func setupGitHook(ctx context.Context) error {\\n   740→\\ts, err := settings.Load(ctx)\\n   741→\\tlocalDev := err == nil && s.LocalDev\\n   742→\\tabsoluteHookPath := err == nil && s.AbsoluteGitHookPath\\n   743→\\tif _, err := strategy.InstallGitHook(ctx, false, localDev, absoluteHookPath); err != nil {\\n   744→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   745→\\t}\\n   746→\\tstrategy.CheckAndWarnHookManagers(ctx, os.Stderr, localDev, absoluteHookPath)\\n   747→\\treturn nil\\n   748→}\\n   749→\\n   750→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   751→func newSetupGitHookCmd() *cobra.Command {\\n   752→\\tcmd := &cobra.Command{\\n   753→\\t\\tUse:    \\\"git-hook\\\",\\n   754→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   755→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   756→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   757→\\t\\t\\treturn setupGitHook(cmd.Context())\\n   758→\\t\\t},\\n   759→\\t}\\n   760→\\n   761→\\treturn cmd\\n   762→}\\n   763→\\n   764→func newCurlBashPostInstallCmd() *cobra.Command {\\n   765→\\treturn &cobra.Command{\\n   766→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   767→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   768→\\t\\tHidden: true,\\n   769→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   770→\\t\\t\\tw := cmd.OutOrStdout()\\n   771→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   772→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   773→\\t\\t\\t}\\n   774→\\t\\t\\treturn nil\\n   775→\\t\\t},\\n   776→\\t}\\n   777→}\\n   778→\\n   779→// shellCompletionComment is the comment preceding the completion line\\n   780→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   781→\\n   782→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   783→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   784→\\n   785→// shellCompletionTarget returns the rc file path and completion lines for the\\n   786→// user's current shell.\\n   787→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   788→\\thome, err := os.UserHomeDir()\\n   789→\\tif err != nil {\\n   790→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   791→\\t}\\n   792→\\n   793→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   794→\\tswitch {\\n   795→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   796→\\t\\treturn \\\"Zsh\\\",\\n   797→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   798→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   799→\\t\\t\\tnil\\n   800→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   801→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   802→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   803→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   804→\\t\\t}\\n   805→\\t\\treturn \\\"Bash\\\",\\n   806→\\t\\t\\tbashRC,\\n   807→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   808→\\t\\t\\tnil\\n   809→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   810→\\t\\treturn \\\"Fish\\\",\\n   811→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   812→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   813→\\t\\t\\tnil\\n   814→\\tdefault:\\n   815→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   816→\\t}\\n   817→}\\n   818→\\n   819→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   820→// Only prompts if completion is not already configured.\\n   821→func promptShellCompletion(w io.Writer) error {\\n   822→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   823→\\tif err != nil {\\n   824→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   825→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   826→\\t\\t\\treturn nil\\n   827→\\t\\t}\\n   828→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   829→\\t}\\n   830→\\n   831→\\tif isCompletionConfigured(rcFile) {\\n   832→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   833→\\t\\treturn nil\\n   834→\\t}\\n   835→\\n   836→\\tvar selected string\\n   837→\\tform := NewAccessibleForm(\\n   838→\\t\\thuh.NewGroup(\\n   839→\\t\\t\\thuh.NewSelect[string]().\\n   840→\\t\\t\\t\\tTitle(fmt.Sprintf(\\\"Enable shell completion? (detected: %s)\\\", shellName)).\\n   841→\\t\\t\\t\\tOptions(\\n   842→\\t\\t\\t\\t\\thuh.NewOption(\\\"Yes\\\", \\\"yes\\\"),\\n   843→\\t\\t\\t\\t\\thuh.NewOption(\\\"No\\\", \\\"no\\\"),\\n   844→\\t\\t\\t\\t).\\n   845→\\t\\t\\t\\tValue(&selected),\\n   846→\\t\\t),\\n   847→\\t)\\n   848→\\n   849→\\tif err := form.Run(); err != nil {\\n   850→\\t\\t//nolint:nilerr // User cancelled - not a fatal error, just skip\\n   851→\\t\\treturn nil\\n   852→\\t}\\n   853→\\n   854→\\tif selected != \\\"yes\\\" {\\n   855→\\t\\treturn nil\\n   856→\\t}\\n   857→\\n   858→\\tif err := appendShellCompletion(rcFile, completionLine); err != nil {\\n   859→\\t\\treturn fmt.Errorf(\\\"failed to update %s: %w\\\", rcFile, err)\\n   860→\\t}\\n   861→\\n   862→\\tfmt.Fprintf(w, \\\"✓ Shell completion added to %s\\\\n\\\", rcFile)\\n   863→\\tfmt.Fprintln(w, \\\"  Restart your shell to activate\\\")\\n   864→\\n   865→\\treturn nil\\n   866→}\\n   867→\\n   868→// isCompletionConfigured checks if shell completion is already in the rc file.\\n   869→func isCompletionConfigured(rcFile string) bool {\\n   870→\\t//nolint:gosec // G304: rcFile is constructed from home dir + known filename, not user input\\n   871→\\tcontent, err := os.ReadFile(rcFile)\\n   872→\\tif err != nil {\\n   873→\\t\\treturn false // File doesn't exist or can't read, treat as not configured\\n   874→\\t}\\n   875→\\treturn strings.Contains(string(content), \\\"entire completion\\\")\\n   876→}\\n   877→\\n   878→// appendShellCompletion adds the completion line to the rc file.\\n   879→func appendShellCompletion(rcFile, completionLine string) error {\\n   880→\\tif err := os.MkdirAll(filepath.Dir(rcFile), 0o700); err != nil {\\n   881→\\t\\treturn fmt.Errorf(\\\"creating directory: %w\\\", err)\\n   882→\\t}\\n   883→\\t//nolint:gosec // G302: Shell rc files need 0644 for user readability\\n   884→\\tf, err := os.OpenFile(rcFile, os.O_APPEND|os.O_CREATE|os.O_WRONLY, 0o644)\\n   885→\\tif err != nil {\\n   886→\\t\\treturn fmt.Errorf(\\\"opening file: %w\\\", err)\\n   887→\\t}\\n   888→\\tdefer f.Close()\\n   889→\\n   890→\\t_, err = f.WriteString(\\\"\\\\n\\\" + shellCompletionComment + \\\"\\\\n\\\" + completionLine + \\\"\\\\n\\\")\\n   891→\\tif err != nil {\\n   892→\\t\\treturn fmt.Errorf(\\\"writing completion: %w\\\", err)\\n   893→\\t}\\n   894→\\treturn nil\\n   895→}\\n   896→\\n   897→// promptTelemetryConsent asks the user if they want to enable telemetry.\\n   898→// It modifies settings.Telemetry based on the user's choice or flags.\\n   899→// The caller is responsible for saving settings.\\n   900→func promptTelemetryConsent(settings *EntireSettings, telemetryFlag bool) error {\\n   901→\\t// Handle --telemetry=false flag first (always overrides existing setting)\\n   902→\\tif !telemetryFlag {\\n   903→\\t\\tf := false\\n   904→\\t\\tsettings.Telemetry = &f\\n   905→\\t\\treturn nil\\n   906→\\t}\\n   907→\\n   908→\\t// Skip if already asked\\n   909→\\tif settings.Telemetry != nil {\\n   910→\\t\\treturn nil\\n   911→\\t}\\n   912→\\n   913→\\t// Skip if env var disables telemetry (record as disabled)\\n   914→\\tif os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   915→\\t\\tf := false\\n   916→\\t\\tsettings.Telemetry = &f\\n   917→\\t\\treturn nil\\n   918→\\t}\\n   919→\\n   920→\\tconsent := true // Default to Yes\\n   921→\\tform := NewAccessibleForm(\\n   922→\\t\\thuh.NewGroup(\\n   923→\\t\\t\\thuh.NewConfirm().\\n   924→\\t\\t\\t\\tTitle(\\\"Help improve Entire CLI?\\\").\\n   925→\\t\\t\\t\\tDescription(\\\"Share anonymous usage data. No code or personal info collected.\\\").\\n   926→\\t\\t\\t\\tAffirmative(\\\"Yes\\\").\\n   927→\\t\\t\\t\\tNegative(\\\"No\\\").\\n   928→\\t\\t\\t\\tValue(&consent),\\n   929→\\t\\t),\\n   930→\\t)\\n   931→\\n   932→\\tif err := form.Run(); err != nil {\\n   933→\\t\\treturn fmt.Errorf(\\\"telemetry prompt: %w\\\", err)\\n   934→\\t}\\n   935→\\n   936→\\tsettings.Telemetry = &consent\\n   937→\\treturn nil\\n   938→}\\n   939→\\n   940→// runUninstall completely removes Entire from the repository.\\n   941→func runUninstall(ctx context.Context, w, errW io.Writer, force bool) error {\\n   942→\\t// Check if we're in a git repository\\n   943→\\tif _, err := paths.WorktreeRoot(ctx); err != nil {\\n   944→\\t\\tfmt.Fprintln(errW, \\\"Not a git repository. Nothing to uninstall.\\\")\\n   945→\\t\\treturn NewSilentError(errors.New(\\\"not a git repository\\\"))\\n   946→\\t}\\n   947→\\n   948→\\t// Gather counts for display\\n   949→\\tsessionStateCount := countSessionStates(ctx)\\n   950→\\tshadowBranchCount := countShadowBranches(ctx)\\n   951→\\tgitHooksInstalled := strategy.IsGitHookInstalled(ctx)\\n   952→\\tagentsWithInstalledHooks := GetAgentsWithHooksInstalled(ctx)\\n   953→\\tentireDirExists := checkEntireDirExists(ctx)\\n   954→\\n   955→\\t// Check if there's anything to uninstall\\n   956→\\tif !entireDirExists && !gitHooksInstalled && sessionStateCount == 0 &&\\n   957→\\t\\tshadowBranchCount == 0 && len(agentsWithInstalledHooks) == 0 {\\n   958→\\t\\tfmt.Fprintln(w, \\\"Entire is not installed in this repository.\\\")\\n   959→\\t\\treturn nil\\n   960→\\t}\\n   961→\\n   962→\\t// Show