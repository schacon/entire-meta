r if no checkpoint trailer is found in any commit.\\n   682→func (env *TestEnv) GetLatestCheckpointIDFromHistory() (string, error) {\\n   683→\\tenv.T.Helper()\\n   684→\\n   685→\\trepo, err := git.PlainOpen(env.RepoDir)\\n   686→\\tif err != nil {\\n   687→\\t\\tenv.T.Fatalf(\\\"failed to open git repo: %v\\\", err)\\n   688→\\t}\\n   689→\\n   690→\\thead, err := repo.Head()\\n   691→\\tif err != nil {\\n   692→\\t\\tenv.T.Fatalf(\\\"failed to get HEAD: %v\\\", err)\\n   693→\\t}\\n   694→\\n   695→\\tcommitIter, err := repo.Log(&git.LogOptions{From: head.Hash()})\\n   696→\\tif err != nil {\\n   697→\\t\\tenv.T.Fatalf(\\\"failed to iterate commits: %v\\\", err)\\n   698→\\t}\\n   699→\\n   700→\\tvar checkpointID string\\n   701→\\t//nolint:errcheck,gosec // ForEach callback returns error to stop iteration, not a real error\\n   702→\\tcommitIter.ForEach(func(c *object.Commit) error {\\n   703→\\t\\t// Look for Entire-Checkpoint trailer\\n   704→\\t\\tfor _, line := range strings.Split(c.Message, \\\"\\\\n\\\") {\\n   705→\\t\\t\\tline = strings.TrimSpace(line)\\n   706→\\t\\t\\tif strings.HasPrefix(line, \\\"Entire-Checkpoint:\\\") {\\n   707→\\t\\t\\t\\tcheckpointID = strings.TrimSpace(strings.TrimPrefix(line, \\\"Entire-Checkpoint:\\\"))\\n   708→\\t\\t\\t\\treturn errors.New(\\\"stop iteration\\\")\\n   709→\\t\\t\\t}\\n   710→\\t\\t}\\n   711→\\t\\treturn nil\\n   712→\\t})\\n   713→\\n   714→\\tif checkpointID == \\\"\\\" {\\n   715→\\t\\treturn \\\"\\\", errors.New(\\\"no commit with Entire-Checkpoint trailer found in history\\\")\\n   716→\\t}\\n   717→\\n   718→\\treturn checkpointID, nil\\n   719→}\\n   720→\\n   721→// GetLatestCheckpointID returns the checkpoint ID from HEAD commit, or empty string if none.\\n   722→// This is a convenience wrapper that doesn't fail the test on missing checkpoint.\\n   723→func (env *TestEnv) GetLatestCheckpointID() string {\\n   724→\\tenv.T.Helper()\\n   725→\\n   726→\\trepo, err := git.PlainOpen(env.RepoDir)\\n  