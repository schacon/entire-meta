7→\\treturn c.GetHookNames()\\n    18→}\\n    19→\\n    20→// ParseHookEvent translates a Copilot hook into a normalized lifecycle Event.\\n    21→// Returns nil if the hook has no lifecycle significance (e.g., pass-through hooks).\\n    22→//\\n    23→// Note: In Copilot CLI, only agentStop provides sessionId and transcriptPath.\\n    24→// Other hooks (sessionStart, userPromptSubmitted, sessionEnd) do not include\\n    25→// these fields, so the resulting Event will have empty SessionID/SessionRef.\\n    26→func (c *CopilotAgent) ParseHookEvent(hookName string, stdin io.Reader) (*agent.Event, error) {\\n    27→\\tswitch hookName {\\n    28→\\tcase HookNameSessionStart:\\n    29→\\t\\treturn c.parseSessionStart(stdin)\\n    30→\\tcase HookNameUserPromptSubmitted:\\n    31→\\t\\treturn c.parseTurnStart(stdin)\\n    32→\\tcase HookNameAgentStop:\\n    33→\\t\\treturn c.parseTurnEnd(stdin)\\n    34→\\tcase HookNameSessionEnd:\\n    35→\\t\\treturn c.parseSessionEnd(stdin)\\n    36→\\tcase HookNameSubagentStop:\\n    37→\\t\\treturn c.parseSubagentEnd(stdin)\\n    38→\\tcase HookNamePreToolUse, HookNamePostToolUse, HookNameErrorOccurred:\\n    39→\\t\\treturn nil, nil //nolint:nilnil // nil event = no lifecycle action\\n    40→\\tdefault:\\n    41→\\t\\treturn nil, nil //nolint:nilnil // Unknown hooks have no lifecycle action\\n    42→\\t}\\n    43→}\\n    44→\\n    45→// ReadTranscript reads the raw JSONL transcript bytes for a session.\\n    46→func (c *CopilotAgent) ReadTranscript(sessionRef string) ([]byte, error) {\\n    47→\\tdata, err := os.ReadFile(sessionRef) //nolint:gosec // Path comes from agent hook input\\n    48→\\tif err != nil {\\n    49→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    50→\\t}\\n    51→\\treturn data, nil\\n    52→}\\n    53→\\n    54→// ChunkTranscript splits a JSONL transcript into chunks.\\n    55→func (c *CopilotAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n    56→\\tchunks,