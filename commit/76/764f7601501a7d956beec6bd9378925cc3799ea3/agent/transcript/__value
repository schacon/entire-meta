func ParseFromBytes(content []byte) ([]Line, error) {\\n    18→\\tvar lines []Line\\n    19→\\treader := bufio.NewReader(bytes.NewReader(content))\\n    20→\\n    21→\\tfor {\\n    22→\\t\\tlineBytes, err := reader.ReadBytes('\\\\n')\\n    23→\\t\\tif err != nil && err != io.EOF {\\n    24→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n    25→\\t\\t}\\n    26→\\n    27→\\t\\t// Handle empty line or EOF without content\\n    28→\\t\\tif len(lineBytes) == 0 {\\n    29→\\t\\t\\tif err == io.EOF {\\n    30→\\t\\t\\t\\tbreak\\n    31→\\t\\t\\t}\\n    32→\\t\\t\\tcontinue\\n    33→\\t\\t}\\n    34→\\n    35→\\t\\tvar line Line\\n    36→\\t\\tif err := json.Unmarshal(lineBytes, &line); err == nil {\\n    37→\\t\\t\\tlines = append(lines, line)\\n    38→\\t\\t}\\n    39→\\n    40→\\t\\tif err == io.EOF {\\n    41→\\t\\t\\tbreak\\n    42→\\t\\t}\\n    43→\\t}\\n    44→\\n    45→\\treturn lines, nil\\n    46→}\\n    47→\\n    48→// ParseFromFileAtLine reads and parses a transcript file starting from a specific line.\\n    49→// Uses bufio.Reader to handle arbitrarily long lines (no size limit).\\n    50→// Returns:\\n    51→//   - lines: parsed transcript lines from startLine onwards (malformed lines skipped)\\n    52→//   - totalLines: total number of lines in the file (including malformed ones)\\n    53→//   - error: any error encountered during reading\\n    54→//\\n    55→// The startLine parameter is 0-indexed (startLine=0 reads from the beginning).\\n    56→// This is useful for incremental parsing when you've already processed some lines.\\n    57→func ParseFromFileAtLine(path string, startLine int) ([]Line, int, error) {\\n    58→\\tfile, err := os.Open(path) //nolint:gosec // path is a controlled transcript file path\\n    59→\\tif err != nil {\\n    60→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to open transcript: %w\\\", err)\\n    61→\\t}\\n    62→\\tdefer func() { _ = file.Close() }()\\n    63→\\n    64→\\tvar lines []Line\\n    65→