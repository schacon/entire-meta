gs().BoolVar(&useLocalSettings, \\\"local\\\", false, \\\"Write settings to .entire/settings.local.json instead of .entire/settings.json\\\")\\n   135→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Write settings to .entire/settings.json even if it already exists\\\")\\n   136→\\tcmd.Flags().StringVar(&agentName, \\\"agent\\\", \\\"\\\", \\\"Agent to setup hooks for (e.g., claude-code). Enables non-interactive mode.\\\")\\n   137→\\tcmd.Flags().StringVar(&strategyFlag, \\\"strategy\\\", \\\"\\\", \\\"Strategy to use (manual-commit or auto-commit)\\\")\\n   138→\\tcmd.Flags().BoolVarP(&forceHooks, \\\"force\\\", \\\"f\\\", false, \\\"Force reinstall hooks (removes existing Entire hooks first)\\\")\\n   139→\\tcmd.Flags().BoolVar(&skipPushSessions, \\\"skip-push-sessions\\\", false, \\\"Disable automatic pushing of session logs on git push\\\")\\n   140→\\tcmd.Flags().BoolVar(&telemetry, \\\"telemetry\\\", true, \\\"Enable anonymous usage analytics\\\")\\n   141→\\t//nolint:errcheck,gosec // completion is optional, flag is defined above\\n   142→\\tcmd.RegisterFlagCompletionFunc(\\\"strategy\\\", func(_ *cobra.Command, _ []string, _ string) ([]string, cobra.ShellCompDirective) {\\n   143→\\t\\treturn []string{strategyDisplayManualCommit, strategyDisplayAutoCommit}, cobra.ShellCompDirectiveNoFileComp\\n   144→\\t})\\n   145→\\n   146→\\t// Provide a helpful error when --agent is used without a value\\n   147→\\tdefaultFlagErr := cmd.FlagErrorFunc()\\n   148→\\tcmd.SetFlagErrorFunc(func(c *cobra.Command, err error) error {\\n   149→\\t\\tvar valErr *pflag.ValueRequiredError\\n   150→\\t\\tif errors.As(err, &valErr) && valErr.GetSpecifiedName() == \\\"agent\\\" {\\n   151→\\t\\t\\tprintMissingAgentError(c.ErrOrStderr())\\n   152→\\t\\t\\treturn NewSilentError(errors.New(\\\"missing agent name\\\"))\\n   153→\\t\\t}\\n   154→\\t\\treturn defaultFlagErr(c, err)\\n   155→\\t})\\n   156→\\n   157→\\t// Add subcommands for automation/testing\\n   158→\\tcmd.AddCommand(newSetupGitHookCmd())\\n   159→\\n   160→\\treturn cmd\\n   161→}\\n   162→\\n   163→func newDisableCmd() *cobra.Command {\\n   164→\\tvar useProjectSettings bool\\n   165→\\tvar uninstall bool\\n   166→\\tvar force bool\\n   167→\\n   168→\\tcmd := &cobra.Command{\\n   169→\\t\\tUse:   \\\"disable\\\",\\n   170→\\t\\tShort: \\\"Disable Entire in current project\\\",\\n   171→\\t\\tLong: `Disable Entire integrations in the current project.\\n   172→\\n   173→By default, this command will disable Entire. Hooks will exit silently and commands will\\n   174→show a disabled message.\\n   175→\\n   176→To completely remove Entire integrations from this repository, use --uninstall:\\n   177→  - .entire/ directory (settings, logs, metadata)\\n   178→  - Git hooks (prepare-commit-msg, commit-msg, post-commit, pre-push)\\n   179→  - Session state files (.git/entire-sessions/)\\n   180→  - Shadow branches (entire/<hash>)\\n   181→  - Agent hooks (Claude Code, Gemini CLI)`,\\n   182→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   183→\\t\\t\\tif uninstall {\\n   184→\\t\\t\\t\\treturn runUninstall(cmd.OutOrStdout(), cmd.ErrOrStderr(), force)\\n   185→\\t\\t\\t}\\n   186→\\t\\t\\treturn runDisable(cmd.OutOrStdout(), useProjectSettings)\\n   187→\\t\\t},\\n   188→\\t}\\n   189→\\n   190→\\tcmd.Flags().BoolVar(&useProjectSettings, \\\"project\\\", false, \\\"Update .entire/settings.json instead of .entire/settings.local.json\\\")\\n   191→\\tcmd.Flags().BoolVar(&uninstall, \\\"uninstall\\\", false, \\\"Completely remove Entire from this repository\\\")\\n   192→\\tcmd.Flags().BoolVar(&force, \\\"force\\\", false, \\\"Skip confirmation prompt (use with --uninstall)\\\")\\n   193→\\n   194→\\treturn cmd\\n   195→}\\n   196→\\n   197→// isFullyEnabled checks whether Entire is already fully set up.\\n   198→// Returns whether it's fully enabled, and if so, the agent type display name and config file path.\\n   199→func isFullyEnabled() (enabled bool, agentDesc string, configPath string) {\\n   200→\\t// Check settings exist and Enabled == true\\n   201→\\ts, err := LoadEntireSettings()\\n   202→\\tif err != nil || !s.Enabled {\\n   203→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   204→\\t}\\n   205→\\n   206→\\t// Check any agent hooks installed (not just Claude Code — works with Gemini too)\\n   207→\\tinstalledAgents := GetAgentsWithHooksInstalled()\\n   208→\\tif len(installedAgents) == 0 {\\n   209→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   210→\\t}\\n   211→\\n   212→\\t// Check git hooks installed\\n   213→\\tif !strategy.IsGitHookInstalled() {\\n   214→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   215→\\t}\\n   216→\\n   217→\\t// Check .entire directory exists\\n   218→\\tif !checkEntireDirExists() {\\n   219→\\t\\treturn false, \\\"\\\", \\\"\\\"\\n   220→\\t}\\n   221→\\n   222→\\t// Determine agent description from first installed agent\\n   223→\\tdesc := string(installedAgents[0]) // fallback to agent name\\n   224→\\tif ag, err := agent.Get(installedAgents[0]); err == nil {\\n   225→\\t\\tdesc = string(ag.Type())\\n   226→\\t}\\n   227→\\n   228→\\t// Determine config path - check if local settings exists, otherwise show project settings\\n   229→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   230→\\tif err != nil {\\n   231→\\t\\tentireDirAbs = paths.EntireDir\\n   232→\\t}\\n   233→\\tconfigDisplay := configDisplayProject\\n   234→\\tlocalSettingsPath := filepath.Join(entireDirAbs, \\\"settings.local.json\\\")\\n   235→\\tif _, err := os.Stat(localSettingsPath); err == nil {\\n   236→\\t\\tconfigDisplay = configDisplayLocal\\n   237→\\t}\\n   238→\\n   239→\\treturn true, desc, configDisplay\\n   240→}\\n   241→\\n   242→// runEnableWithStrategy enables Entire with a specified strategy (non-interactive).\\n   243→// The selectedStrategy can be either a display name (manual-commit, auto-commit)\\n   244→// or an internal name (manual-commit, auto-commit).\\n   245→// agents must be provided by the caller (via detectOrSelectAgent).\\n   246→func runEnableWithStrategy(w io.Writer, agents []agent.Agent, selectedStrategy string, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   247→\\t// Map the strategy to internal name if it's a display name\\n   248→\\tinternalStrategy := selectedStrategy\\n   249→\\tif mapped, ok := strategyDisplayToInternal[selectedStrategy]; ok {\\n   250→\\t\\tinternalStrategy = mapped\\n   251→\\t}\\n   252→\\n   253→\\t// Validate the strategy exists\\n   254→\\tstrat, err := strategy.Get(internalStrategy)\\n   255→\\tif err != nil {\\n   256→\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", selectedStrategy)\\n   257→\\t}\\n   258→\\n   259→\\t// Setup agent hooks for all selected agents\\n   260→\\tfor _, ag := range agents {\\n   261→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   262→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   263→\\t\\t}\\n   264→\\t}\\n   265→\\n   266→\\t// Setup .entire directory\\n   267→\\tif _, err := setupEntireDirectory(); err != nil {\\n   268→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   269→\\t}\\n   270→\\n   271→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   272→\\tsettings, err := LoadEntireSettings()\\n   273→\\tif err != nil {\\n   274→\\t\\t// If we can't load, start with defaults\\n   275→\\t\\tsettings = &EntireSettings{}\\n   276→\\t}\\n   277→\\t// Update the specific fields\\n   278→\\tsettings.Strategy = internalStrategy\\n   279→\\tsettings.LocalDev = localDev\\n   280→\\tsettings.Enabled = true\\n   281→\\n   282→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   283→\\tif skipPushSessions {\\n   284→\\t\\tif settings.StrategyOptions == nil {\\n   285→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   286→\\t\\t}\\n   287→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   288→\\t}\\n   289→\\n   290→\\t// Handle telemetry for non-interactive mode\\n   291→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   292→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   293→\\t\\tf := false\\n   294→\\t\\tsettings.Telemetry = &f\\n   295→\\t}\\n   296→\\n   297→\\t// Determine which settings file to write to\\n   298→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   299→\\tif err != nil {\\n   300→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   301→\\t}\\n   302→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   303→\\n   304→\\tif showNotification {\\n   305→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   306→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   307→\\t}\\n   308→\\n   309→\\tconfigDisplay := configDisplayProject\\n   310→\\tif shouldUseLocal {\\n   311→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   312→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   313→\\t\\t}\\n   314→\\t\\tconfigDisplay = configDisplayLocal\\n   315→\\t} else {\\n   316→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   317→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   318→\\t\\t}\\n   319→\\t}\\n   320→\\n   321→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   322→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   323→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   324→\\t}\\n   325→\\tstrategy.CheckAndWarnHookManagers(w)\\n   326→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   327→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   328→\\n   329→\\t// Let the strategy handle its own setup requirements\\n   330→\\tif err := strat.EnsureSetup(); err != nil {\\n   331→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   332→\\t}\\n   333→\\n   334→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   335→\\n   336→\\treturn nil\\n   337→}\\n   338→\\n   339→// runEnableInteractive runs the interactive enable flow.\\n   340→// agents must be provided by the caller (via detectOrSelectAgent).\\n   341→// The isFullyEnabled check is handled by the caller before agent detection.\\n   342→func runEnableInteractive(w io.Writer, agents []agent.Agent, localDev, useLocalSettings, useProjectSettings, forceHooks, skipPushSessions, telemetry bool) error {\\n   343→\\t// Setup agent hooks for all selected agents\\n   344→\\tfor _, ag := range agents {\\n   345→\\t\\tif _, err := setupAgentHooks(ag, localDev, forceHooks); err != nil {\\n   346→\\t\\t\\treturn fmt.Errorf(\\\"failed to setup %s hooks: %w\\\", ag.Type(), err)\\n   347→\\t\\t}\\n   348→\\t}\\n   349→\\n   350→\\t// Setup .entire directory\\n   351→\\tif _, err := setupEntireDirectory(); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   353→\\t}\\n   354→\\n   355→\\t// Use the default strategy (manual-commit)\\n   356→\\tinternalStrategy := strategy.DefaultStrategyName\\n   357→\\n   358→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   359→\\tsettings, err := LoadEntireSettings()\\n   360→\\tif err != nil {\\n   361→\\t\\t// If we can't load, start with defaults\\n   362→\\t\\tsettings = &EntireSettings{}\\n   363→\\t}\\n   364→\\t// Update the specific fields\\n   365→\\tsettings.Strategy = internalStrategy\\n   366→\\tsettings.LocalDev = localDev\\n   367→\\tsettings.Enabled = true\\n   368→\\n   369→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   370→\\tif skipPushSessions {\\n   371→\\t\\tif settings.StrategyOptions == nil {\\n   372→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   373→\\t\\t}\\n   374→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   375→\\t}\\n   376→\\n   377→\\t// Determine which settings file to write to\\n   378→\\t// First run always creates settings.json (no prompt)\\n   379→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   380→\\tif err != nil {\\n   381→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   382→\\t}\\n   383→\\tshouldUseLocal, showNotification := determineSettingsTarget(entireDirAbs, useLocalSettings, useProjectSettings)\\n   384→\\n   385→\\tif showNotification {\\n   386→\\t\\tfmt.Fprintln(w, \\\"Info: Project settings exist. Saving to settings.local.json instead.\\\")\\n   387→\\t\\tfmt.Fprintln(w, \\\"  Use --project to update the project settings file.\\\")\\n   388→\\t}\\n   389→\\n   390→\\t// Helper to save settings to the appropriate file\\n   391→\\tsaveSettings := func() error {\\n   392→\\t\\tif shouldUseLocal {\\n   393→\\t\\t\\treturn SaveEntireSettingsLocal(settings)\\n   394→\\t\\t}\\n   395→\\t\\treturn SaveEntireSettings(settings)\\n   396→\\t}\\n   397→\\n   398→\\t// Save settings before telemetry prompt so config is persisted even if the user cancels\\n   399→\\tif err := saveSettings(); err != nil {\\n   400→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   401→\\t}\\n   402→\\n   403→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   404→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   405→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   406→\\t}\\n   407→\\tstrategy.CheckAndWarnHookManagers(w)\\n   408→\\tfmt.Fprintln(w, \\\"✓ Hooks installed\\\")\\n   409→\\n   410→\\tconfigDisplay := configDisplayProject\\n   411→\\tif shouldUseLocal {\\n   412→\\t\\tconfigDisplay = configDisplayLocal\\n   413→\\t}\\n   414→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplay)\\n   415→\\n   416→\\t// Ask about telemetry consent (only if not already asked)\\n   417→\\tfmt.Fprintln(w)\\n   418→\\tif err := promptTelemetryConsent(settings, telemetry); err != nil {\\n   419→\\t\\treturn fmt.Errorf(\\\"telemetry consent: %w\\\", err)\\n   420→\\t}\\n   421→\\t// Save again to persist telemetry choice\\n   422→\\tif err := saveSettings(); err != nil {\\n   423→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   424→\\t}\\n   425→\\n   426→\\t// Let the strategy handle its own setup requirements\\n   427→\\tstrat, err := strategy.Get(internalStrategy)\\n   428→\\tif err != nil {\\n   429→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   430→\\t}\\n   431→\\tif err := strat.EnsureSetup(); err != nil {\\n   432→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   433→\\t}\\n   434→\\n   435→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   436→\\n   437→\\treturn nil\\n   438→}\\n   439→\\n   440→// runEnable is a simple enable that just sets the enabled flag (for programmatic use).\\n   441→func runEnable(w io.Writer) error {\\n   442→\\tsettings, err := LoadEntireSettings()\\n   443→\\tif err != nil {\\n   444→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   445→\\t}\\n   446→\\n   447→\\tsettings.Enabled = true\\n   448→\\tif err := SaveEntireSettings(settings); err != nil {\\n   449→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   450→\\t}\\n   451→\\n   452→\\tfmt.Fprintln(w, \\\"Entire is now enabled.\\\")\\n   453→\\treturn nil\\n   454→}\\n   455→\\n   456→func runDisable(w io.Writer, useProjectSettings bool) error {\\n   457→\\tsettings, err := LoadEntireSettings()\\n   458→\\tif err != nil {\\n   459→\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   460→\\t}\\n   461→\\n   462→\\tsettings.Enabled = false\\n   463→\\n   464→\\t// If --project flag is specified, always write to project settings\\n   465→\\tif useProjectSettings {\\n   466→\\t\\tif err := SaveEntireSettings(settings); err != nil {\\n   467→\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   468→\\t\\t}\\n   469→\\t} else {\\n   470→\\t\\t// Always write to local settings file (create if doesn't exist)\\n   471→\\t\\tif err := SaveEntireSettingsLocal(settings); err != nil {\\n   472→\\t\\t\\treturn fmt.Errorf(\\\"failed to save local settings: %w\\\", err)\\n   473→\\t\\t}\\n   474→\\t}\\n   475→\\n   476→\\tfmt.Fprintln(w, \\\"Entire is now disabled.\\\")\\n   477→\\treturn nil\\n   478→}\\n   479→\\n   480→// DisabledMessage is the message shown when Entire is disabled\\n   481→const DisabledMessage = \\\"Entire is disabled. Run `entire enable` to re-enable.\\\"\\n   482→\\n   483→// checkDisabledGuard checks if Entire is disabled and prints a message if so.\\n   484→// Returns true if the caller should exit (i.e., Entire is disabled).\\n   485→// On error reading settings, defaults to enabled (returns false).\\n   486→func checkDisabledGuard(w io.Writer) bool {\\n   487→\\tenabled, err := IsEnabled()\\n   488→\\tif err != nil {\\n   489→\\t\\t// Default to enabled on error\\n   490→\\t\\treturn false\\n   491→\\t}\\n   492→\\tif !enabled {\\n   493→\\t\\tfmt.Fprintln(w, DisabledMessage)\\n   494→\\t\\treturn true\\n   495→\\t}\\n   496→\\treturn false\\n   497→}\\n   498→\\n   499→// setupAgentHooks sets up hooks for a given agent.\\n   500→// Returns the number of hooks installed (0 if already installed).\\n   501→func setupAgentHooks(ag agent.Agent, localDev, forceHooks bool) (int, error) { //nolint:unparam // return value used by setupAgentHooksNonInteractive\\n   502→\\thookAgent, ok := ag.(agent.HookSupport)\\n   503→\\tif !ok {\\n   504→\\t\\treturn 0, fmt.Errorf(\\\"agent %s does not support hooks\\\", ag.Name())\\n   505→\\t}\\n   506→\\n   507→\\tcount, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   508→\\tif err != nil {\\n   509→\\t\\treturn 0, fmt.Errorf(\\\"failed to install %s hooks: %w\\\", ag.Name(), err)\\n   510→\\t}\\n   511→\\n   512→\\treturn count, nil\\n   513→}\\n   514→\\n   515→// detectOrSelectAgent tries to auto-detect agents, or prompts the user to select.\\n   516→// Returns the detected/selected agents and any error.\\n   517→// When exactly one agent is detected, it is used automatically.\\n   518→// When multiple agents are detected, the user is prompted to confirm.\\n   519→// If no agent is detected and no TTY is available, falls back to the default agent.\\n   520→//\\n   521→// selectFn overrides the interactive prompt for testing. When nil, the real form is used.\\n   522→// It receives available agent names and returns the selected names.\\n   523→func detectOrSelectAgent(w io.Writer, selectFn func(available []string) ([]string, error)) ([]agent.Agent, error) {\\n   524→\\t// Try auto-detection first\\n   525→\\tdetected := agent.DetectAll()\\n   526→\\n   527→\\tswitch {\\n   528→\\tcase len(detected) == 1:\\n   529→\\t\\t// Single agent detected — use it directly\\n   530→\\t\\tfmt.Fprintf(w, \\\"Detected agent: %s\\\\n\\\\n\\\", detected[0].Type())\\n   531→\\t\\treturn detected, nil\\n   532→\\n   533→\\tcase len(detected) > 1:\\n   534→\\t\\t// Multiple agents detected — prompt the user to confirm which to enable\\n   535→\\t\\tagentTypes := make([]string, 0, len(detected))\\n   536→\\t\\tfor _, ag := range detected {\\n   537→\\t\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   538→\\t\\t}\\n   539→\\t\\tfmt.Fprintf(w, \\\"Detected multiple agents: %s\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   540→\\t\\tfmt.Fprintln(w)\\n   541→\\t\\t// Fall through to the interactive multi-select below\\n   542→\\t}\\n   543→\\n   544→\\t// No agent detected (or multiple detected) — check if we can prompt interactively\\n   545→\\tif !canPromptInteractively() {\\n   546→\\t\\tif len(detected) > 0 {\\n   547→\\t\\t\\t// Multiple agents detected but no TTY — use all of them\\n   548→\\t\\t\\treturn detected, nil\\n   549→\\t\\t}\\n   550→\\t\\t// No TTY available (e.g., running in CI or tests) - fall back to default agent\\n   551→\\t\\tdefaultAgent := agent.Default()\\n   552→\\t\\tif defaultAgent == nil {\\n   553→\\t\\t\\treturn nil, errors.New(\\\"no default agent available\\\")\\n   554→\\t\\t}\\n   555→\\t\\tfmt.Fprintf(w, \\\"Agent: %s (use --agent to change)\\\\n\\\\n\\\", defaultAgent.Type())\\n   556→\\t\\treturn []agent.Agent{defaultAgent}, nil\\n   557→\\t}\\n   558→\\n   559→\\tif len(detected) == 0 {\\n   560→\\t\\t// Show message only when nothing was detected\\n   561→\\t\\tfmt.Fprintln(w, \\\"No agent configuration detected (e.g., .claude or .gemini directory).\\\")\\n   562→\\t\\tfmt.Fprintln(w, \\\"This is normal - some agents don't require a config directory.\\\")\\n   563→\\t\\tfmt.Fprintln(w)\\n   564→\\t}\\n   565→\\n   566→\\t// Build a set of detected agent names for pre-selection\\n   567→\\tdetectedSet := make(map[agent.AgentName]struct{}, len(detected))\\n   568→\\tfor _, ag := range detected {\\n   569→\\t\\tdetectedSet[ag.Name()] = struct{}{}\\n   570→\\t}\\n   571→\\n   572→\\t// Build options from registered agents\\n   573→\\tagentNames := agent.List()\\n   574→\\toptions := make([]huh.Option[string], 0, len(agentNames))\\n   575→\\tfor _, name := range agentNames {\\n   576→\\t\\tag, err := agent.Get(name)\\n   577→\\t\\tif err != nil {\\n   578→\\t\\t\\tcontinue\\n   579→\\t\\t}\\n   580→\\t\\t// Only show agents that support hooks\\n   581→\\t\\tif _, ok := ag.(agent.HookSupport); !ok {\\n   582→\\t\\t\\tcontinue\\n   583→\\t\\t}\\n   584→\\t\\tlabel := string(ag.Type())\\n   585→\\t\\tif name == agent.DefaultAgentName {\\n   586→\\t\\t\\tlabel += \\\" (default)\\\"\\n   587→\\t\\t}\\n   588→\\t\\topt := huh.NewOption(label, string(name))\\n   589→\\t\\tif _, isDetected := detectedSet[name]; isDetected {\\n   590→\\t\\t\\topt = opt.Selected(true)\\n   591→\\t\\t}\\n   592→\\t\\toptions = append(options, opt)\\n   593→\\t}\\n   594→\\n   595→\\tif len(options) == 0 {\\n   596→\\t\\treturn nil, errors.New(\\\"no agents with hook support available\\\")\\n   597→\\t}\\n   598→\\n   599→\\t// Collect available agent names for the selector\\n   600→\\tavailableNames := make([]string, 0, len(options))\\n   601→\\tfor _, opt := range options {\\n   602→\\t\\tavailableNames = append(availableNames, opt.Value)\\n   603→\\t}\\n   604→\\n   605→\\tvar selectedAgentNames []string\\n   606→\\tif selectFn != nil {\\n   607→\\t\\tvar err error\\n   608→\\t\\tselectedAgentNames, err = selectFn(availableNames)\\n   609→\\t\\tif err != nil {\\n   610→\\t\\t\\treturn nil, err\\n   611→\\t\\t}\\n   612→\\t} else {\\n   613→\\t\\tform := NewAccessibleForm(\\n   614→\\t\\t\\thuh.NewGroup(\\n   615→\\t\\t\\t\\thuh.NewMultiSelect[string]().\\n   616→\\t\\t\\t\\t\\tTitle(\\\"Which agents are you using?\\\").\\n   617→\\t\\t\\t\\t\\tDescription(\\\"Use space to select, enter to confirm.\\\").\\n   618→\\t\\t\\t\\t\\tOptions(options...).\\n   619→\\t\\t\\t\\t\\tValue(&selectedAgentNames),\\n   620→\\t\\t\\t),\\n   621→\\t\\t)\\n   622→\\t\\tif err := form.Run(); err != nil {\\n   623→\\t\\t\\treturn nil, fmt.Errorf(\\\"agent selection cancelled: %w\\\", err)\\n   624→\\t\\t}\\n   625→\\t}\\n   626→\\n   627→\\tif len(selectedAgentNames) == 0 {\\n   628→\\t\\treturn nil, errors.New(\\\"no agents selected\\\")\\n   629→\\t}\\n   630→\\n   631→\\tselectedAgents := make([]agent.Agent, 0, len(selectedAgentNames))\\n   632→\\tfor _, name := range selectedAgentNames {\\n   633→\\t\\tselectedAgent, err := agent.Get(agent.AgentName(name))\\n   634→\\t\\tif err != nil {\\n   635→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to get selected agent %s: %w\\\", name, err)\\n   636→\\t\\t}\\n   637→\\t\\tselectedAgents = append(selectedAgents, selectedAgent)\\n   638→\\t}\\n   639→\\n   640→\\tagentTypes := make([]string, 0, len(selectedAgents))\\n   641→\\tfor _, ag := range selectedAgents {\\n   642→\\t\\tagentTypes = append(agentTypes, string(ag.Type()))\\n   643→\\t}\\n   644→\\tfmt.Fprintf(w, \\\"\\\\nSelected agents: %s\\\\n\\\\n\\\", strings.Join(agentTypes, \\\", \\\"))\\n   645→\\treturn selectedAgents, nil\\n   646→}\\n   647→\\n   648→// canPromptInteractively checks if we can show interactive prompts.\\n   649→// Returns false when running in CI, tests, or other non-interactive environments.\\n   650→func canPromptInteractively() bool {\\n   651→\\t// Check for test environment\\n   652→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n   653→\\t\\treturn os.Getenv(\\\"ENTIRE_TEST_TTY\\\") == \\\"1\\\"\\n   654→\\t}\\n   655→\\n   656→\\t// Check if /dev/tty is available\\n   657→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   658→\\tif err != nil {\\n   659→\\t\\treturn false\\n   660→\\t}\\n   661→\\t_ = tty.Close()\\n   662→\\treturn true\\n   663→}\\n   664→\\n   665→// printAgentError writes an error message followed by available agents and usage.\\n   666→func printAgentError(w io.Writer, message string) {\\n   667→\\tagents := agent.List()\\n   668→\\tfmt.Fprintf(w, \\\"%s Available agents:\\\\n\\\", message)\\n   669→\\tfmt.Fprintln(w)\\n   670→\\tfor _, a := range agents {\\n   671→\\t\\tsuffix := \\\"\\\"\\n   672→\\t\\tif a == agent.DefaultAgentName {\\n   673→\\t\\t\\tsuffix = \\\"    (default)\\\"\\n   674→\\t\\t}\\n   675→\\t\\tfmt.Fprintf(w, \\\"  %s%s\\\\n\\\", a, suffix)\\n   676→\\t}\\n   677→\\tfmt.Fprintln(w)\\n   678→\\tfmt.Fprintln(w, \\\"Usage: entire enable --agent <agent-name>\\\")\\n   679→}\\n   680→\\n   681→// printMissingAgentError writes a helpful error listing available agents.\\n   682→func printMissingAgentError(w io.Writer) {\\n   683→\\tprintAgentError(w, \\\"Missing agent name.\\\")\\n   684→}\\n   685→\\n   686→// printWrongAgentError writes a helpful error when an unknown agent name is provided.\\n   687→func printWrongAgentError(w io.Writer, name string) {\\n   688→\\tprintAgentError(w, fmt.Sprintf(\\\"Unknown agent %q.\\\", name))\\n   689→}\\n   690→\\n   691→// setupAgentHooksNonInteractive sets up hooks for a specific agent non-interactively.\\n   692→// If strategyName is provided, it sets the strategy; otherwise uses default.\\n   693→func setupAgentHooksNonInteractive(w io.Writer, ag agent.Agent, strategyName string, localDev, forceHooks, skipPushSessions, telemetry bool) error {\\n   694→\\tagentName := ag.Name()\\n   695→\\t// Check if agent supports hooks\\n   696→\\thookAgent, ok := ag.(agent.HookSupport)\\n   697→\\tif !ok {\\n   698→\\t\\treturn fmt.Errorf(\\\"agent %s does not support hooks\\\", agentName)\\n   699→\\t}\\n   700→\\n   701→\\tfmt.Fprintf(w, \\\"Agent: %s\\\\n\\\\n\\\", ag.Type())\\n   702→\\n   703→\\t// Install agent hooks (agent hooks don't depend on settings)\\n   704→\\tinstalledHooks, err := hookAgent.InstallHooks(localDev, forceHooks)\\n   705→\\tif err != nil {\\n   706→\\t\\treturn fmt.Errorf(\\\"failed to install hooks for %s: %w\\\", agentName, err)\\n   707→\\t}\\n   708→\\n   709→\\t// Setup .entire directory\\n   710→\\tif _, err := setupEntireDirectory(); err != nil {\\n   711→\\t\\treturn fmt.Errorf(\\\"failed to setup .entire directory: %w\\\", err)\\n   712→\\t}\\n   713→\\n   714→\\t// Load existing settings to preserve other options (like strategy_options.push)\\n   715→\\tsettings, err := LoadEntireSettings()\\n   716→\\tif err != nil {\\n   717→\\t\\t// If we can't load, start with defaults\\n   718→\\t\\tsettings = &EntireSettings{Strategy: strategy.DefaultStrategyName}\\n   719→\\t}\\n   720→\\tsettings.Enabled = true\\n   721→\\tif localDev {\\n   722→\\t\\tsettings.LocalDev = localDev\\n   723→\\t}\\n   724→\\n   725→\\t// Set push_sessions option if --skip-push-sessions flag was provided\\n   726→\\tif skipPushSessions {\\n   727→\\t\\tif settings.StrategyOptions == nil {\\n   728→\\t\\t\\tsettings.StrategyOptions = make(map[string]interface{})\\n   729→\\t\\t}\\n   730→\\t\\tsettings.StrategyOptions[\\\"push_sessions\\\"] = false\\n   731→\\t}\\n   732→\\n   733→\\t// Set strategy if provided\\n   734→\\tif strategyName != \\\"\\\" {\\n   735→\\t\\t// Map display name to internal name if needed\\n   736→\\t\\tinternalStrategy := strategyName\\n   737→\\t\\tif mapped, ok := strategyDisplayToInternal[strategyName]; ok {\\n   738→\\t\\t\\tinternalStrategy = mapped\\n   739→\\t\\t}\\n   740→\\t\\t// Validate the strategy exists\\n   741→\\t\\tif _, err := strategy.Get(internalStrategy); err != nil {\\n   742→\\t\\t\\treturn fmt.Errorf(\\\"unknown strategy: %s (use manual-commit or auto-commit)\\\", strategyName)\\n   743→\\t\\t}\\n   744→\\t\\tsettings.Strategy = internalStrategy\\n   745→\\t}\\n   746→\\n   747→\\t// Handle telemetry for non-interactive mode\\n   748→\\t// Note: if telemetry is nil (not configured), it defaults to disabled\\n   749→\\tif !telemetry || os.Getenv(\\\"ENTIRE_TELEMETRY_OPTOUT\\\") != \\\"\\\" {\\n   750→\\t\\tf := false\\n   751→\\t\\tsettings.Telemetry = &f\\n   752→\\t}\\n   753→\\n   754→\\tif err := SaveEntireSettings(settings); err != nil {\\n   755→\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   756→\\t}\\n   757→\\n   758→\\t// Install git hooks AFTER saving settings (InstallGitHook reads local_dev from settings)\\n   759→\\tif _, err := strategy.InstallGitHook(true); err != nil {\\n   760→\\t\\treturn fmt.Errorf(\\\"failed to install git hooks: %w\\\", err)\\n   761→\\t}\\n   762→\\tstrategy.CheckAndWarnHookManagers(w)\\n   763→\\n   764→\\tif installedHooks == 0 {\\n   765→\\t\\tmsg := fmt.Sprintf(\\\"Hooks for %s already installed\\\", ag.Description())\\n   766→\\t\\tif ag.IsPreview() {\\n   767→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   768→\\t\\t}\\n   769→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   770→\\t} else {\\n   771→\\t\\tmsg := fmt.Sprintf(\\\"Installed %d hooks for %s\\\", installedHooks, ag.Description())\\n   772→\\t\\tif ag.IsPreview() {\\n   773→\\t\\t\\tmsg += \\\" (Preview)\\\"\\n   774→\\t\\t}\\n   775→\\t\\tfmt.Fprintf(w, \\\"%s\\\\n\\\", msg)\\n   776→\\t}\\n   777→\\n   778→\\tfmt.Fprintf(w, \\\"✓ Project configured (%s)\\\\n\\\", configDisplayProject)\\n   779→\\n   780→\\t// Let the strategy handle its own setup requirements (creates entire/checkpoints/v1 branch, etc.)\\n   781→\\tstrat, err := strategy.Get(settings.Strategy)\\n   782→\\tif err != nil {\\n   783→\\t\\treturn fmt.Errorf(\\\"failed to get strategy: %w\\\", err)\\n   784→\\t}\\n   785→\\tif err := strat.EnsureSetup(); err != nil {\\n   786→\\t\\treturn fmt.Errorf(\\\"failed to setup strategy: %w\\\", err)\\n   787→\\t}\\n   788→\\n   789→\\tfmt.Fprintln(w, \\\"\\\\nReady.\\\")\\n   790→\\n   791→\\treturn nil\\n   792→}\\n   793→\\n   794→// validateSetupFlags checks that --local and --project flags are not both specified.\\n   795→func validateSetupFlags(useLocal, useProject bool) error {\\n   796→\\tif useLocal && useProject {\\n   797→\\t\\treturn errors.New(\\\"cannot specify both --project and --local\\\")\\n   798→\\t}\\n   799→\\treturn nil\\n   800→}\\n   801→\\n   802→// determineSettingsTarget decides whether to write to settings.local.json based on:\\n   803→// - Whether settings.json already exists\\n   804→// - The --local and --project flags\\n   805→// Returns (useLocal, showNotification).\\n   806→func determineSettingsTarget(entireDir string, useLocal, useProject bool) (bool, bool) {\\n   807→\\t// Explicit --local flag always uses local settings\\n   808→\\tif useLocal {\\n   809→\\t\\treturn true, false\\n   810→\\t}\\n   811→\\n   812→\\t// Explicit --project flag always uses project settings\\n   813→\\tif useProject {\\n   814→\\t\\treturn false, false\\n   815→\\t}\\n   816→\\n   817→\\t// No flags specified - check if settings file exists\\n   818→\\tsettingsPath := filepath.Join(entireDir, paths.SettingsFileName)\\n   819→\\tif _, err := os.Stat(settingsPath); err == nil {\\n   820→\\t\\t// Settings file exists - auto-redirect to local with notification\\n   821→\\t\\treturn true, true\\n   822→\\t}\\n   823→\\n   824→\\t// Settings file doesn't exist - create it\\n   825→\\treturn false, false\\n   826→}\\n   827→\\n   828→// setupEntireDirectory creates the .entire directory and gitignore.\\n   829→// Returns true if the directory was created, false if it already existed.\\n   830→func setupEntireDirectory() (bool, error) { //nolint:unparam // already present in codebase\\n   831→\\t// Get absolute path for the .entire directory\\n   832→\\tentireDirAbs, err := paths.AbsPath(paths.EntireDir)\\n   833→\\tif err != nil {\\n   834→\\t\\tentireDirAbs = paths.EntireDir // Fallback to relative\\n   835→\\t}\\n   836→\\n   837→\\t// Check if directory already exists\\n   838→\\tcreated := false\\n   839→\\tif _, err := os.Stat(entireDirAbs); os.IsNotExist(err) {\\n   840→\\t\\tcreated = true\\n   841→\\t}\\n   842→\\n   843→\\t// Create .entire directory\\n   844→\\t//nolint:gosec // G301: Project directory needs standard permissions for git\\n   845→\\tif err := os.MkdirAll(entireDirAbs, 0o755); err != nil {\\n   846→\\t\\treturn false, fmt.Errorf(\\\"failed to create .entire directory: %w\\\", err)\\n   847→\\t}\\n   848→\\n   849→\\t// Create/update .gitignore with all required entries\\n   850→\\tif err := strategy.EnsureEntireGitignore(); err != nil {\\n   851→\\t\\treturn false, fmt.Errorf(\\\"failed to setup .gitignore: %w\\\", err)\\n   852→\\t}\\n   853→\\n   854→\\treturn created, nil\\n   855→}\\n   856→\\n   857→// setupGitHook installs the prepare-commit-msg hook for context trailers.\\n   858→func setupGitHook() error {\\n   859→\\t// Use shared implementation from strategy package\\n   860→\\t// The localDev setting is read from settings.json\\n   861→\\t_, err := strategy.InstallGitHook(false) // not silent - show output during setup\\n   862→\\tif err != nil {\\n   863→\\t\\treturn fmt.Errorf(\\\"failed to install git hook: %w\\\", err)\\n   864→\\t}\\n   865→\\tstrategy.CheckAndWarnHookManagers(os.Stderr)\\n   866→\\treturn nil\\n   867→}\\n   868→\\n   869→// newSetupGitHookCmd creates the standalone git-hook setup command\\n   870→func newSetupGitHookCmd() *cobra.Command {\\n   871→\\tcmd := &cobra.Command{\\n   872→\\t\\tUse:    \\\"git-hook\\\",\\n   873→\\t\\tShort:  \\\"Install git hook for session context trailers\\\",\\n   874→\\t\\tHidden: true, // Hidden as it's mainly for testing\\n   875→\\t\\tRunE: func(_ *cobra.Command, _ []string) error {\\n   876→\\t\\t\\treturn setupGitHook()\\n   877→\\t\\t},\\n   878→\\t}\\n   879→\\n   880→\\treturn cmd\\n   881→}\\n   882→\\n   883→func newCurlBashPostInstallCmd() *cobra.Command {\\n   884→\\treturn &cobra.Command{\\n   885→\\t\\tUse:    \\\"curl-bash-post-install\\\",\\n   886→\\t\\tShort:  \\\"Post-install tasks for curl|bash installer\\\",\\n   887→\\t\\tHidden: true,\\n   888→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   889→\\t\\t\\tw := cmd.OutOrStdout()\\n   890→\\t\\t\\tif err := promptShellCompletion(w); err != nil {\\n   891→\\t\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion setup skipped: %v\\\\n\\\", err)\\n   892→\\t\\t\\t}\\n   893→\\t\\t\\treturn nil\\n   894→\\t\\t},\\n   895→\\t}\\n   896→}\\n   897→\\n   898→// shellCompletionComment is the comment preceding the completion line\\n   899→const shellCompletionComment = \\\"# Entire CLI shell completion\\\"\\n   900→\\n   901→// errUnsupportedShell is returned when the user's shell is not supported for completion.\\n   902→var errUnsupportedShell = errors.New(\\\"unsupported shell\\\")\\n   903→\\n   904→// shellCompletionTarget returns the rc file path and completion lines for the\\n   905→// user's current shell.\\n   906→func shellCompletionTarget() (shellName, rcFile, completionLine string, err error) {\\n   907→\\thome, err := os.UserHomeDir()\\n   908→\\tif err != nil {\\n   909→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot determine home directory: %w\\\", err)\\n   910→\\t}\\n   911→\\n   912→\\tshell := os.Getenv(\\\"SHELL\\\")\\n   913→\\tswitch {\\n   914→\\tcase strings.Contains(shell, \\\"zsh\\\"):\\n   915→\\t\\treturn \\\"Zsh\\\",\\n   916→\\t\\t\\tfilepath.Join(home, \\\".zshrc\\\"),\\n   917→\\t\\t\\t\\\"autoload -Uz compinit && compinit && source <(entire completion zsh)\\\",\\n   918→\\t\\t\\tnil\\n   919→\\tcase strings.Contains(shell, \\\"bash\\\"):\\n   920→\\t\\tbashRC := filepath.Join(home, \\\".bashrc\\\")\\n   921→\\t\\tif _, err := os.Stat(filepath.Join(home, \\\".bash_profile\\\")); err == nil {\\n   922→\\t\\t\\tbashRC = filepath.Join(home, \\\".bash_profile\\\")\\n   923→\\t\\t}\\n   924→\\t\\treturn \\\"Bash\\\",\\n   925→\\t\\t\\tbashRC,\\n   926→\\t\\t\\t\\\"source <(entire completion bash)\\\",\\n   927→\\t\\t\\tnil\\n   928→\\tcase strings.Contains(shell, \\\"fish\\\"):\\n   929→\\t\\treturn \\\"Fish\\\",\\n   930→\\t\\t\\tfilepath.Join(home, \\\".config\\\", \\\"fish\\\", \\\"config.fish\\\"),\\n   931→\\t\\t\\t\\\"entire completion fish | source\\\",\\n   932→\\t\\t\\tnil\\n   933→\\tdefault:\\n   934→\\t\\treturn \\\"\\\", \\\"\\\", \\\"\\\", errUnsupportedShell\\n   935→\\t}\\n   936→}\\n   937→\\n   938→// promptShellCompletion offers to add shell completion to the user's rc file.\\n   939→// Only prompts if completion is not already configured.\\n   940→func promptShellCompletion(w io.Writer) error {\\n   941→\\tshellName, rcFile, completionLine, err := shellCompletionTarget()\\n   942→\\tif err != nil {\\n   943→\\t\\tif errors.Is(err, errUnsupportedShell) {\\n   944→\\t\\t\\tfmt.Fprintf(w, \\\"Note: Shell completion not available for your shell. Supported: zsh, bash, fish.\\\\n\\\")\\n   945→\\t\\t\\treturn nil\\n   946→\\t\\t}\\n   947→\\t\\treturn fmt.Errorf(\\\"shell completion: %w\\\", err)\\n   948→\\t}\\n   949→\\n   950→\\tif isCompletionConfigured(rcFile) {\\n   951→\\t\\tfmt.Fprintf(w, \\\"✓ Shell completion already configured in %s\\\\n\\\", rcFile)\\n   952→\\t\\tret