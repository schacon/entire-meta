\\n    11→\\t\\\"os\\\"\\n    12→\\t\\\"path/filepath\\\"\\n    13→\\t\\\"regexp\\\"\\n    14→\\t\\\"time\\\"\\n    15→\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    19→)\\n    20→\\n    21→//nolint:gochecknoinits // Agent self-registration is the intended pattern\\n    22→func init() {\\n    23→\\tagent.Register(agent.AgentNameGemini, NewGeminiCLIAgent)\\n    24→}\\n    25→\\n    26→// GeminiCLIAgent implements the Agent interface for Gemini CLI.\\n    27→//\\n    28→//nolint:revive // GeminiCLIAgent is clearer than Agent in this context\\n    29→type GeminiCLIAgent struct{}\\n    30→\\n    31→func NewGeminiCLIAgent() agent.Agent {\\n    32→\\treturn &GeminiCLIAgent{}\\n    33→}\\n    34→\\n    35→// Name returns the agent registry key.\\n    36→func (g *GeminiCLIAgent) Name() agent.AgentName {\\n    37→\\treturn agent.AgentNameGemini\\n    38→}\\n    39→\\n    40→// Type returns the agent type identifier.\\n    41→func (g *GeminiCLIAgent) Type() agent.AgentType {\\n    42→\\treturn agent.AgentTypeGemini\\n    43→}\\n    44→\\n    45→// Description returns a human-readable description.\\n    46→func (g *GeminiCLIAgent) Description() string {\\n    47→\\treturn \\\"Gemini CLI - Google's AI coding assistant\\\"\\n    48→}\\n    49→\\n    50→func (g *GeminiCLIAgent) IsPreview() bool { return true }\\n    51→\\n    52→// DetectPresence checks if Gemini CLI is configured in the repository.\\n    53→func (g *GeminiCLIAgent) DetectPresence() (bool, error) {\\n    54→\\t// Get repo root to check for .gemini directory\\n    55→\\t// This is needed because the CLI may be run from a subdirectory\\n    56→\\trepoRoot, err := paths.RepoRoot()\\n    57→\\tif err != nil {\\n    58→\\t\\t// Not in a git repo, fall back to CWD-relative check\\n    59→\\t\\trepoRoot = \\\".\\\"\\n    60→\\t}\\n    61→\\n    62→\\t// Check for .gemini directory\\n    63→\\tgeminiDir := filepath.Join(repoRoot, \\\".gemini\\\")\\n    64→\\tif _, err := os.Stat(geminiDir); err == nil {\\n    65→\\t\\treturn true, nil\\n    66→\\t}\\n    67→\\t// Check for .gemini/settings.json\\n    68→\\tsettingsFile := filepath.Join(repoRoot, \\\".gemini\\\", \\\"settings.json\\\")\\n    69→\\tif _, err := os.Stat(settingsFile); err == nil {\\n    70→\\t\\treturn true, nil\\n    71→\\t}\\n    72→\\treturn false, nil\\n    73→}\\n    74→\\n    75→// GetHookConfigPath returns the path to Gemini's hook config file.\\n    76→func (g *GeminiCLIAgent) GetHookConfigPath() string {\\n    77→\\treturn \\\".gemini/settings.json\\\"\\n    78→}\\n    79→\\n    80→// SupportsHooks returns true as Gemini CLI supports lifecycle hooks.\\n    81→func (g *GeminiCLIAgent) SupportsHooks() bool {\\n    82→\\treturn true\\n    83→}\\n    84→\\n    85→// ParseHookInput parses Gemini CLI hook input from stdin.\\n    86→func (g *GeminiCLIAgent) ParseHookInput(hookType agent.HookType, reader io.Reader) (*agent.HookInput, error) {\\n    87→\\tdata, err := io.ReadAll(reader)\\n    88→\\tif err != nil {\\n    89→\\t\\treturn nil, fmt.Errorf(\\\"failed to read input: %w\\\", err)\\n    90→\\t}\\n    91→\\n    92→\\tif len(data) == 0 {\\n    93→\\t\\treturn nil, errors.New(\\\"empty input\\\")\\n    94→\\t}\\n    95→\\n    96→\\tinput := &agent.HookInput{\\n    97→\\t\\tHookType:  hookType,\\n    98→\\t\\tTimestamp: time.Now(),\\n    99→\\t\\tRawData:   make(map[string]interface{}),\\n   100→\\t}\\n   101→\\n   102→\\t// Parse based on hook type\\n   103→\\tswitch hookType {\\n   104→\\tcase agent.HookSessionStart, agent.HookSessionEnd, agent.HookStop:\\n   105→\\t\\tvar raw sessionInfoRaw\\n   106→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   107→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session info: %w\\\", err)\\n   108→\\t\\t}\\n   109→\\t\\tinput.SessionID = raw.SessionID\\n   110→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   111→\\t\\t// Store Gemini-specific fields in RawData\\n   112→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   113→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   114→\\t\\tif raw.Source != \\\"\\\" {\\n   115→\\t\\t\\tinput.RawData[\\\"source\\\"] = raw.Source\\n   116→\\t\\t}\\n   117→\\t\\tif raw.Reason != \\\"\\\" {\\n   118→\\t\\t\\tinput.RawData[\\\"reason\\\"] = raw.Reason\\n   119→\\t\\t}\\n   120→\\n   121→\\tcase agent.HookUserPromptSubmit:\\n   122→\\t\\t// BeforeAgent is Gemini's equivalent to Claude's UserPromptSubmit\\n   123→\\t\\t// It provides the user's prompt in the \\\"prompt\\\" field\\n   124→\\t\\tvar raw agentHookInputRaw\\n   125→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   126→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse agent hook input: %w\\\", err)\\n   127→\\t\\t}\\n   128→\\t\\tinput.SessionID = raw.SessionID\\n   129→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   130→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   131→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   132→\\t\\tif raw.Prompt != \\\"\\\" {\\n   133→\\t\\t\\tinput.UserPrompt = raw.Prompt\\n   134→\\t\\t\\tinput.RawData[\\\"prompt\\\"] = raw.Prompt\\n   135→\\t\\t}\\n   136→\\n   137→\\tcase agent.HookPreToolUse, agent.HookPostToolUse:\\n   138→\\t\\tvar raw toolHookInputRaw\\n   139→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   140→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse tool hook input: %w\\\", err)\\n   141→\\t\\t}\\n   142→\\t\\tinput.SessionID = raw.SessionID\\n   143→\\t\\tinput.SessionRef = raw.TranscriptPath\\n   144→\\t\\tinput.ToolName = raw.ToolName\\n   145→\\t\\tinput.ToolInput = raw.ToolInput\\n   146→\\t\\tif hookType == agent.HookPostToolUse {\\n   147→\\t\\t\\tinput.ToolResponse = raw.ToolResponse\\n   148→\\t\\t}\\n   149→\\t\\tinput.RawData[\\\"cwd\\\"] = raw.Cwd\\n   150→\\t\\tinput.RawData[\\\"hook_event_name\\\"] = raw.HookEventName\\n   151→\\t}\\n   152→\\n   153→\\treturn input, nil\\n   154→}\\n   155→\\n   156→// GetSessionID extracts the session ID from hook input.\\n   157→func (g *GeminiCLIAgent) GetSessionID(input *agent.HookInput) string {\\n   158→\\treturn input.SessionID\\n   159→}\\n   160→\\n   161→// ProtectedDirs returns directories that Gemini uses for config/state.\\n   162→func (g *GeminiCLIAgent) ProtectedDirs() []string { return []string{\\\".gemini\\\"} }\\n   163→\\n   164→// ResolveSessionFile returns the path to a Gemini session file.\\n   165→// Gemini names files as session-<date>-<shortid>.json where shortid is the first 8 chars\\n   166→// of the session UUID. This searches for an existing file matching the pattern, falling\\n   167→// back to <dir>/<id>.json if no match is found.\\n   168→func (g *GeminiCLIAgent) ResolveSessionFile(sessionDir, agentSessionID string) string {\\n   169→\\t// Try to find existing file matching Gemini's naming convention:\\n   170→\\t// session-*-<first8chars>.json\\n   171→\\tshortID := agentSessionID\\n   172→\\tif len(shortID) > 8 {\\n   173→\\t\\tshortID = shortID[:8]\\n   174→\\t}\\n   175→\\n   176→\\tpattern := filepath.Join(sessionDir, \\\"session-*-\\\"+shortID+\\\".json\\\")\\n   177→\\tmatches, err := filepath.Glob(pattern)\\n   178→\\tif err == nil && len(matches) > 0 {\\n   179→\\t\\t// Return the most recent match (last alphabetically, since date is in the name)\\n   180→\\t\\treturn matches[len(matches)-1]\\n   181→\\t}\\n   182→\\n   183→\\t// Fallback: construct a default path\\n   184→\\treturn filepath.Join(sessionDir, agentSessionID+\\\".json\\\")\\n   185→}\\n   186→\\n   187→// GetSessionDir returns the directory where Gemini stores session transcripts.\\n   188→// Gemini stores sessions in ~/.gemini/tmp/<project-hash>/chats/\\n   189→func (g *GeminiCLIAgent) GetSessionDir(repoPath string) (string, error) {\\n   190→\\t// Check for test environment override\\n   191→\\tif override := os.Getenv(\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR\\\"); override != \\\"\\\" {\\n   192→\\t\\treturn override, nil\\n   193→\\t}\\n   194→\\n   195→\\thomeDir, err := os.UserHomeDir()\\n   196→\\tif err != nil {\\n   197→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get home directory: %w\\\", err)\\n   198→\\t}\\n   199→\\n   200→\\t// Gemini uses a hash of the project path for the directory name\\n   201→\\tprojectDir := SanitizePathForGemini(repoPath)\\n   202→\\treturn filepath.Join(homeDir, \\\".gemini\\\", \\\"tmp\\\", projectDir, \\\"chats\\\"), nil\\n   203→}\\n   204→\\n   205→// ReadSession reads a session from Gemini's storage (JSON transcript file).\\n   206→// The session data is stored in NativeData as raw JSON bytes.\\n   207→func (g *GeminiCLIAgent) ReadSession(input *agent.HookInput) (*agent.AgentSession, error) {\\n   208→\\tif input.SessionRef == \\\"\\\" {\\n   209→\\t\\treturn nil, errors.New(\\\"session reference (transcript path) is required\\\")\\n   210→\\t}\\n   211→\\n   212→\\t// Read the raw JSON file\\n   213→\\tdata, err := os.ReadFile(input.SessionRef)\\n   214→\\tif err != nil {\\n   215→\\t\\treturn nil, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Parse to extract computed fields\\n   219→\\tmodifiedFiles, err := ExtractModifiedFiles(data)\\n   220→\\tif err != nil {\\n   221→\\t\\t// Non-fatal: we can still return the session without modified files\\n   222→\\t\\tmodifiedFiles = nil\\n   223→\\t}\\n   224→\\n   225→\\treturn &agent.AgentSession{\\n   226→\\t\\tSessionID:     input.SessionID,\\n   227→\\t\\tAgentName:     g.Name(),\\n   228→\\t\\tSessionRef:    input.SessionRef,\\n   229→\\t\\tStartTime:     time.Now(),\\n   230→\\t\\tNativeData:    data,\\n   231→\\t\\tModifiedFiles: modifiedFiles,\\n   232→\\t}, nil\\n   233→}\\n   234→\\n   235→// WriteSession writes a session to Gemini's storage (JSON transcript file).\\n   236→// Uses the NativeData field which contains raw JSON bytes.\\n   237→func (g *GeminiCLIAgent) WriteSession(session *agent.AgentSession) error {\\n   238→\\tif session == nil {\\n   239→\\t\\treturn errors.New(\\\"session is nil\\\")\\n   240→\\t}\\n   241→\\n   242→\\t// Verify this session belongs to Gemini CLI\\n   243→\\tif session.AgentName != \\\"\\\" && session.AgentName != g.Name() {\\n   244→\\t\\treturn fmt.Errorf(\\\"session belongs to agent %q, not %q\\\", session.AgentName, g.Name())\\n   245→\\t}\\n   246→\\n   247→\\tif session.SessionRef == \\\"\\\" {\\n   248→\\t\\treturn errors.New(\\\"session reference (transcript path) is required\\\")\\n   249→\\t}\\n   250→\\n   251→\\tif len(session.NativeData) == 0 {\\n   252→\\t\\treturn errors.New(\\\"session has no native data to write\\\")\\n   253→\\t}\\n   254→\\n   255→\\t// Write the raw JSON data\\n   256→\\tif err := os.WriteFile(session.SessionRef, session.NativeData, 0o600); err != nil {\\n   257→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   258→\\t}\\n   259→\\n   260→\\treturn nil\\n   261→}\\n   262→\\n   263→// FormatResumeCommand returns the command to resume a Gemini CLI session.\\n   264→func (g *GeminiCLIAgent) FormatResumeCommand(sessionID string) string {\\n   265→\\treturn \\\"gemini --resume \\\" + sessionID\\n   266→}\\n   267→\\n   268→// SanitizePathForGemini converts a path to Gemini's project directory format.\\n   269→// Gemini uses a hash-like sanitization similar to Claude.\\n   270→var nonAlphanumericRegex = regexp.MustCompile(`[^a-zA-Z0-9]`)\\n   271→\\n   272→func SanitizePathForGemini(path string) string {\\n   273→\\treturn nonAlphanumericRegex.ReplaceAllString(path, \\\"-\\\")\\n   274→}\\n   275→\\n   276→// TranscriptAnalyzer interface implementation\\n   277→\\n   278→// GetTranscriptPosition returns the current message count of a Gemini transcript.\\n   279→// Gemini uses JSON format with a messages array, so position is the message count.\\n   280→// Returns 0 if the file doesn't exist or is empty.\\n   281→func (g *GeminiCLIAgent) GetTranscriptPosition(path string) (int, error) {\\n   282→\\tif path == \\\"\\\" {\\n   283→\\t\\treturn 0, nil\\n   284→\\t}\\n   285→\\n   286→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   287→\\tif err != nil {\\n   288→\\t\\tif os.IsNotExist(err) {\\n   289→\\t\\t\\treturn 0, nil\\n   290→\\t\\t}\\n   291→\\t\\treturn 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\tif len(data) == 0 {\\n   295→\\t\\treturn 0, nil\\n   296→\\t}\\n   297→\\n   298→\\ttranscript, err := ParseTranscript(data)\\n   299→\\tif err != nil {\\n   300→\\t\\treturn 0, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   301→\\t}\\n   302→\\n   303→\\treturn len(transcript.Messages), nil\\n   304→}\\n   305→\\n   306→// ExtractModifiedFilesFromOffset extracts files modified since a given message index.\\n   307→// For Gemini (JSON format), offset is the starting message index.\\n   308→// Returns:\\n   309→//   - files: list of file paths modified by Gemini (from Write/Edit tools)\\n   310→//   - currentPosition: total number of messages in the transcript\\n   311→//   - error: any error encountered during reading\\n   312→func (g *GeminiCLIAgent) ExtractModifiedFilesFromOffset(path string, startOffset int) (files []string, currentPosition int, err error) {\\n   313→\\tif path == \\\"\\\" {\\n   314→\\t\\treturn nil, 0, nil\\n   315→\\t}\\n   316→\\n   317→\\tdata, readErr := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   318→\\tif readErr != nil {\\n   319→\\t\\tif os.IsNotExist(readErr) {\\n   320→\\t\\t\\treturn nil, 0, nil\\n   321→\\t\\t}\\n   322→\\t\\treturn nil, 0, fmt.Errorf(\\\"failed to read transcript: %w\\\", readErr)\\n   323→\\t}\\n   324→\\n   325→\\tif len(data) == 0 {\\n   326→\\t\\treturn nil, 0, nil\\n   327→\\t}\\n   328→\\n   329→\\ttranscript, parseErr := ParseTranscript(data)\\n   330→\\tif parseErr != nil {\\n   331→\\t\\treturn nil, 0, parseErr\\n   332→\\t}\\n   333→\\n   334→\\ttotalMessages := len(transcript.Messages)\\n   335→\\n   336→\\t// Extract files from messages starting at startOffset\\n   337→\\tfileSet := make(map[string]bool)\\n   338→\\tfor i := startOffset; i < len(transcript.Messages); i++ {\\n   339→\\t\\tmsg := transcript.Messages[i]\\n   340→\\t\\t// Only process gemini messages (assistant messages)\\n   341→\\t\\tif msg.Type != MessageTypeGemini {\\n   342→\\t\\t\\tcontinue\\n   343→\\t\\t}\\n   344→\\n   345→\\t\\t// Process tool calls in this message\\n   346→\\t\\tfor _, toolCall := range msg.ToolCalls {\\n   347→\\t\\t\\t// Check if it's a file modification tool\\n   348→\\t\\t\\tisModifyTool := false\\n   349→\\t\\t\\tfor _, name := range FileModificationTools {\\n   350→\\t\\t\\t\\tif toolCall.Name == name {\\n   351→\\t\\t\\t\\t\\tisModifyTool = true\\n   352→\\t\\t\\t\\t\\tbreak\\n   353→\\t\\t\\t\\t}\\n   354→\\t\\t\\t}\\n   355→\\n   356→\\t\\t\\tif !isModifyTool {\\n   357→\\t\\t\\t\\tcontinue\\n   358→\\t\\t\\t}\\n   359→\\n   360→\\t\\t\\t// Extract file path from args map\\n   361→\\t\\t\\tvar file string\\n   362→\\t\\t\\tif fp, ok := toolCall.Args[\\\"file_path\\\"].(string); ok && fp != \\\"\\\" {\\n   363→\\t\\t\\t\\tfile = fp\\n   364→\\t\\t\\t} else if p, ok := toolCall.Args[\\\"path\\\"].(string); ok && p != \\\"\\\" {\\n   365→\\t\\t\\t\\tfile = p\\n   366→\\t\\t\\t} else if fn, ok := toolCall.Args[\\\"filename\\\"].(string); ok && fn != \\\"\\\" {\\n   367→\\t\\t\\t\\tfile = fn\\n   368→\\t\\t\\t}\\n   369→\\n   370→\\t\\t\\tif file != \\\"\\\" && !fileSet[file] {\\n   371→\\t\\t\\t\\tfileSet[file] = true\\n   372→\\t\\t\\t\\tfiles = append(files, file)\\n   373→\\t\\t\\t}\\n   374→\\t\\t}\\n   375→\\t}\\n   376→\\n   377→\\treturn files, totalMessages, nil\\n   378→}\\n   379→\\n   380→// ChunkTranscript splits a Gemini JSON transcript by distributing messages across chunks.\\n   381→// Gemini uses JSON format with a {\\\"messages\\\": [...]} structure, so chunking splits\\n   382→// the messages array while preserving the JSON structure in each chunk.\\n   383→func (g *GeminiCLIAgent) ChunkTranscript(content []byte, maxSize int) ([][]byte, error) {\\n   384→\\tvar transcript GeminiTranscript\\n   385→\\tif err := json.Unmarshal(content, &transcript); err != nil {\\n   386→\\t\\t// Fall back to JSONL chunking if not valid Gemini JSON\\n   387→\\t\\tchunks, chunkErr := agent.ChunkJSONL(content, maxSize)\\n   388→\\t\\tif chunkErr != nil {\\n   389→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to chunk as JSONL: %w\\\", chunkErr)\\n   390→\\t\\t}\\n   391→\\t\\treturn chunks, nil\\n   392→\\t}\\n   393→\\n   394→\\tif len(transcript.Messages) == 0 {\\n   395→\\t\\treturn [][]byte{content}, nil\\n   396→\\t}\\n   397→\\n   398→\\tvar chunks [][]byte\\n   399→\\tvar currentMessages []GeminiMessage\\n   400→\\tcurrentSize := len(`{\\\"messages\\\":[]}`) // Base JSON structure size\\n   401→\\n   402→\\tfor i, msg := range transcript.Messages {\\n   403→\\t\\t// Marshal message to get its size\\n   404→\\t\\tmsgBytes, err := json.Marshal(msg)\\n   405→\\t\\tif err != nil {\\n   406→\\t\\t\\tlogging.Warn(context.Background(), \\\"failed to marshal Gemini message during chunking\\\",\\n   407→\\t\\t\\t\\tslog.Int(\\\"message_index\\\", i),\\n   408→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   409→\\t\\t\\t)\\n   410→\\t\\t\\tcontinue\\n   411→\\t\\t}\\n   412→\\t\\tmsgSize := len(msgBytes) + 1 // +1 for comma separator\\n   413→\\n   414→\\t\\tif currentSize+msgSize > maxSize && len(currentMessages) > 0 {\\n   415→\\t\\t\\t// Save current chunk\\n   416→\\t\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   417→\\t\\t\\tif err != nil {\\n   418→\\t\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal chunk: %w\\\", err)\\n   419→\\t\\t\\t}\\n   420→\\t\\t\\tchunks = append(chunks, chunkData)\\n   421→\\n   422→\\t\\t\\t// Start new chunk\\n   423→\\t\\t\\tcurrentMessages = nil\\n   424→\\t\\t\\tcurrentSize = len(`{\\\"messages\\\":[]}`)\\n   425→\\t\\t}\\n   426→\\n   427→\\t\\tcurrentMessages = append(currentMessages, msg)\\n   428→\\t\\tcurrentSize += msgSize\\n   429→\\t}\\n   430→\\n   431→\\t// Add the last chunk\\n   432→\\tif len(currentMessages) > 0 {\\n   433→\\t\\tchunkData, err := json.Marshal(GeminiTranscript{Messages: currentMessages})\\n   434→\\t\\tif err != nil {\\n   435→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal final chunk: %w\\\", err)\\n   436→\\t\\t}\\n   437→\\t\\tchunks = append(chunks, chunkData)\\n   438→\\t}\\n   439→\\n   440→\\t// Ensure we created at least one chunk (could be empty if all messages failed to marshal)\\n   441→\\tif len(chunks) == 0 {\\n   442→\\t\\treturn nil, errors.New(\\\"failed to create any chunks: all messages failed to marshal\\\")\\n   443→\\t}\\n   444→\\n   445→\\treturn chunks, nil\\n   446→}\\n   447→\\n   448→// ReassembleTranscript merges Gemini JSON chunks by combining their message arrays.\\n   449→func (g *GeminiCLIAgent) ReassembleTranscript(chunks [][]byte) ([]byte, error) {\\n   450→\\tvar allMessages []GeminiMessage\\n   451→\\n   452→\\tfor _, chunk := range chunks {\\n   453→\\t\\tvar transcript GeminiTranscript\\n   454→\\t\\tif err := json.Unmarshal(chunk, &transcript); err != nil {\\n   455→\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal chunk: %w\\\", err)\\n   456→\\t\\t}\\n   457→\\t\\tallMessages = append(allMessages, transcript.Messages...)\\n   458→\\t}\\n   459→\\n   460→\\tresult, err := json.Marshal(GeminiTranscript{Messages: allMessages})\\n   461→\\tif err != nil {\\n   462→\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal reassembled transcript: %w\\\", err)\\n   463→\\t}\\n   464→\\treturn result, nil\\n   465→}\\n   466→\"}]},\"uuid\":\"2de26f93-ebe2-4cc5-91d0-f66a3f2fa73a\",\"timestamp\":\"2026-02-19T02:49:40.615Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Compare the copilot package (cmd/entire/cli/agent