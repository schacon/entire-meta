sult\",\"content\":\"     1→// Package summarize provides AI-powered summarization of development sessions.\\n     2→package summarize\\n     3→\\n     4→import (\\n     5→\\t\\\"context\\\"\\n     6→\\t\\\"encoding/json\\\"\\n     7→\\t\\\"errors\\\"\\n     8→\\t\\\"fmt\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/copilot\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent/geminicli\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    16→)\\n    17→\\n    18→// GenerateFromTranscript generates a summary from raw transcript bytes.\\n    19→// This is the shared implementation used by both explain --generate and auto-summarize.\\n    20→//\\n    21→// Parameters:\\n    22→//   - ctx: context for cancellation\\n    23→//   - transcriptBytes: raw transcript bytes (JSONL or JSON format depending on agent)\\n    24→//   - filesTouched: list of files modified during the session\\n    25→//   - agentType: the agent type to determine transcript format\\n    26→//   - generator: summary generator to use (if nil, uses default ClaudeGenerator)\\n    27→//\\n    28→// Returns nil, error if transcript is empty or cannot be parsed.\\n    29→func GenerateFromTranscript(ctx context.Context, transcriptBytes []byte, filesTouched []string, agentType agent.AgentType, generator Generator) (*checkpoint.Summary, error) {\\n    30→\\tif len(transcriptBytes) == 0 {\\n    31→\\t\\treturn nil, errors.New(\\\"empty transcript\\\")\\n    32→\\t}\\n    33→\\n    34→\\t// Build condensed transcript for summarization\\n    35→\\tcondensed, err := BuildCondensedTranscriptFromBytes(transcriptBytes, agentType)\\n    36→\\tif err != nil {\\n    37→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    38→\\t}\\n    39→\\tif len(condensed) == 0 {\\n    40→\\t\\treturn nil, errors.New(\\\"transcript has no content to summarize\\\")\\n    41→\\t}\\n    42→\\n    43→\\tinput := Input{\\n    44→\\t\\tTranscript:   condensed,\\n    45→\\t\\tFilesTouched: filesTouched,\\n    46→\\t}\\n    47→\\n    48→\\t// Use default generator if none provided\\n    49→\\tif generator == nil {\\n    50→\\t\\tgenerator = &ClaudeGenerator{}\\n    51→\\t}\\n    52→\\n    53→\\tsummary, err := generator.Generate(ctx, input)\\n    54→\\tif err != nil {\\n    55→\\t\\treturn nil, fmt.Errorf(\\\"failed to generate summary: %w\\\", err)\\n    56→\\t}\\n    57→\\n    58→\\treturn summary, nil\\n    59→}\\n    60→\\n    61→// Generator generates checkpoint summaries using an LLM.\\n    62→type Generator interface {\\n    63→\\t// Generate creates a summary from checkpoint data.\\n    64→\\t// Returns the generated summary or an error if generation fails.\\n    65→\\tGenerate(ctx context.Context, input Input) (*checkpoint.Summary, error)\\n    66→}\\n    67→\\n    68→// Input contains condensed checkpoint data for summarization.\\n    69→type Input struct {\\n    70→\\t// Transcript is the condensed transcript entries\\n    71→\\tTranscript []Entry\\n    72→\\n    73→\\t// FilesTouched are the files modified during the session\\n    74→\\tFilesTouched []string\\n    75→}\\n    76→\\n    77→// EntryType represents the type of a transcript entry.\\n    78→type EntryType string\\n    79→\\n    80→const (\\n    81→\\t// EntryTypeUser indicates a user prompt entry.\\n    82→\\tEntryTypeUser EntryType = \\\"user\\\"\\n    83→\\t// EntryTypeAssistant indicates an assistant response entry.\\n    84→\\tEntryTypeAssistant EntryType = \\\"assistant\\\"\\n    85→\\t// EntryTypeTool indicates a tool call entry.\\n    86→\\tEntryTypeTool EntryType = \\\"tool\\\"\\n    87→)\\n    88→\\n    89→// Entry represents one item in the condensed transcript.\\n    90→type Entry struct {\\n    91→\\t// Type is the entry type (user, assistant, tool)\\n    92→\\tType EntryType\\n    93→\\n    94→\\t// Content is the text content for user/assistant entries\\n    95→\\tContent string\\n    96→\\n    97→\\t// ToolName is the name of the tool (for tool entries)\\n    98→\\tToolName string\\n    99→\\n   100→\\t// ToolDetail is a description or file path (for tool entries)\\n   101→\\tToolDetail string\\n   102→}\\n   103→\\n   104→// minimalDetailTools lists tools that should show only essential details in summaries.\\n   105→// These tools often have verbose outputs that don't add value to summarization.\\n   106→// The detail shown is typically just a path, URL, or identifier rather than full content.\\n   107→var minimalDetailTools = map[string]bool{\\n   108→\\t\\\"Skill\\\":    true, // Show skill name only, not loaded content\\n   109→\\t\\\"Read\\\":     true, // Show file path only, not file contents\\n   110→\\t\\\"WebFetch\\\": true, // Show URL only, not fetched content\\n   111→}\\n   112→\\n   113→// BuildCondensedTranscriptFromBytes parses transcript bytes and extracts a condensed view.\\n   114→// This is a convenience function that combines parsing and condensing.\\n   115→// The agentType parameter determines which parser to use (Claude JSONL vs Gemini JSON).\\n   116→func BuildCondensedTranscriptFromBytes(content []byte, agentType agent.AgentType) ([]Entry, error) {\\n   117→\\tswitch agentType {\\n   118→\\tcase agent.AgentTypeGemini:\\n   119→\\t\\treturn buildCondensedTranscriptFromGemini(content)\\n   120→\\tcase agent.AgentTypeCopilot:\\n   121→\\t\\treturn buildCondensedTranscriptFromCopilot(content)\\n   122→\\tcase agent.AgentTypeClaudeCode, agent.AgentTypeUnknown:\\n   123→\\t\\t// JSONL format - fall through to shared logic below\\n   124→\\t}\\n   125→\\t// Claude format (JSONL) - handles Claude Code, Unknown, and any future agent types\\n   126→\\tlines, err := transcript.ParseFromBytes(content)\\n   127→\\tif err != nil {\\n   128→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n   129→\\t}\\n   130→\\treturn BuildCondensedTranscript(lines), nil\\n   131→}\\n   132→\\n   133→// buildCondensedTranscriptFromGemini parses Gemini JSON transcript and extracts a condensed view.\\n   134→func buildCondensedTranscriptFromGemini(content []byte) ([]Entry, error) {\\n   135→\\tgeminiTranscript, err := geminicli.ParseTranscript(content)\\n   136→\\tif err != nil {\\n   137→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse Gemini transcript: %w\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tvar entries []Entry\\n   141→\\tfor _, msg := range geminiTranscript.Messages {\\n   142→\\t\\tswitch msg.Type {\\n   143→\\t\\tcase geminicli.MessageTypeUser:\\n   144→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   145→\\t\\t\\t\\tentries = append(entries, Entry{\\n   146→\\t\\t\\t\\t\\tType:    EntryTypeUser,\\n   147→\\t\\t\\t\\t\\tContent: msg.Content,\\n   148→\\t\\t\\t\\t})\\n   149→\\t\\t\\t}\\n   150→\\t\\tcase geminicli.MessageTypeGemini:\\n   151→\\t\\t\\t// Add assistant content\\n   152→\\t\\t\\tif msg.Content != \\\"\\\" {\\n   153→\\t\\t\\t\\tentries = append(entries, Entry{\\n   154→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   155→\\t\\t\\t\\t\\tContent: msg.Content,\\n   156→\\t\\t\\t\\t})\\n   157→\\t\\t\\t}\\n   158→\\t\\t\\t// Add tool calls\\n   159→\\t\\t\\tfor _, tc := range msg.ToolCalls {\\n   160→\\t\\t\\t\\tentries = append(entries, Entry{\\n   161→\\t\\t\\t\\t\\tType:       EntryTypeTool,\\n   162→\\t\\t\\t\\t\\tToolName:   tc.Name,\\n   163→\\t\\t\\t\\t\\tToolDetail: extractGeminiToolDetail(tc.Args),\\n   164→\\t\\t\\t\\t})\\n   165→\\t\\t\\t}\\n   166→\\t\\t}\\n   167→\\t}\\n   168→\\n   169→\\treturn entries, nil\\n   170→}\\n   171→\\n   172→// buildCondensedTranscriptFromCopilot parses a Copilot events.jsonl transcript\\n   173→// and extracts a condensed view for summarization.\\n   174→func buildCondensedTranscriptFromCopilot(content []byte) ([]Entry, error) {\\n   175→\\tevents, err := copilot.ParseTranscript(content)\\n   176→\\tif err != nil {\\n   177→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse Copilot transcript: %w\\\", err)\\n   178→\\t}\\n   179→\\n   180→\\tvar entries []Entry\\n   181→\\tfor _, event := range events {\\n   182→\\t\\tswitch event.Type {\\n   183→\\t\\tcase copilot.EventUserMessage:\\n   184→\\t\\t\\tvar data struct {\\n   185→\\t\\t\\t\\tContent string `json:\\\"content\\\"`\\n   186→\\t\\t\\t}\\n   187→\\t\\t\\tif err := json.Unmarshal(event.Data, &data); err != nil {\\n   188→\\t\\t\\t\\tcontinue\\n   189→\\t\\t\\t}\\n   190→\\t\\t\\tif data.Content != \\\"\\\" {\\n   191→\\t\\t\\t\\tentries = append(entries, Entry{\\n   192→\\t\\t\\t\\t\\tType:    EntryTypeUser,\\n   193→\\t\\t\\t\\t\\tContent: data.Content,\\n   194→\\t\\t\\t\\t})\\n   195→\\t\\t\\t}\\n   196→\\n   197→\\t\\tcase copilot.EventAssistantMessage:\\n   198→\\t\\t\\tvar data struct {\\n   199→\\t\\t\\t\\tContent      string `json:\\\"content\\\"`\\n   200→\\t\\t\\t\\tToolRequests []struct {\\n   201→\\t\\t\\t\\t\\tName      string         `json:\\\"name\\\"`\\n   202→\\t\\t\\t\\t\\tArguments map[string]any `json:\\\"arguments\\\"`\\n   203→\\t\\t\\t\\t} `json:\\\"toolRequests\\\"`\\n   204→\\t\\t\\t}\\n   205→\\t\\t\\tif err := json.Unmarshal(event.Data, &data); err != nil {\\n   206→\\t\\t\\t\\tcontinue\\n   207→\\t\\t\\t}\\n   208→\\t\\t\\tif data.Content != \\\"\\\" {\\n   209→\\t\\t\\t\\tentries = append(entries, Entry{\\n   210→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   211→\\t\\t\\t\\t\\tContent: data.Content,\\n   212→\\t\\t\\t\\t})\\n   213→\\t\\t\\t}\\n   214→\\t\\t\\tfor _, tc := range data.ToolRequests {\\n   215→\\t\\t\\t\\tentries = append(entries, Entry{\\n   216→\\t\\t\\t\\t\\tType:       EntryTypeTool,\\n   217→\\t\\t\\t\\t\\tToolName:   tc.Name,\\n   218→\\t\\t\\t\\t\\tToolDetail: extractCopilotToolDetail(tc.Arguments),\\n   219→\\t\\t\\t\\t})\\n   220→\\t\\t\\t}\\n   221→\\t\\t}\\n   222→\\t}\\n   223→\\n   224→\\treturn entries, nil\\n   225→}\\n   226→\\n   227→// extractCopilotToolDetail extracts an appropriate detail string from Copilot tool args.\\n   228→func extractCopilotToolDetail(args map[string]any) string {\\n   229→\\tfor _, key := range []string{\\\"path\\\", \\\"command\\\", \\\"file_path\\\", \\\"pattern\\\", \\\"description\\\"} {\\n   230→\\t\\tif v, ok := args[key].(string); ok && v != \\\"\\\" {\\n   231→\\t\\t\\treturn v\\n   232→\\t\\t}\\n   233→\\t}\\n   234→\\treturn \\\"\\\"\\n   235→}\\n   236→\\n   237→// extractGeminiToolDetail extracts an appropriate detail string from Gemini tool args.\\n   238→func extractGeminiToolDetail(args map[string]any) string {\\n   239→\\t// Check common fields in order of preference\\n   240→\\tfor _, key := range []string{\\\"description\\\", \\\"command\\\", \\\"file_path\\\", \\\"path\\\", \\\"pattern\\\"} {\\n   241→\\t\\tif v, ok := args[key].(string); ok && v != \\\"\\\" {\\n   242→\\t\\t\\treturn v\\n   243→\\t\\t}\\n   244→\\t}\\n   245→\\treturn \\\"\\\"\\n   246→}\\n   247→\\n   248→// BuildCondensedTranscript extracts a condensed view of the transcript.\\n   249→// It processes user prompts, assistant responses, and tool calls into\\n   250→// a simplified format suitable for LLM summarization.\\n   251→func BuildCondensedTranscript(lines []transcript.Line) []Entry {\\n   252→\\tvar entries []Entry\\n   253→\\n   254→\\tfor _, line := range lines {\\n   255→\\t\\tswitch line.Type {\\n   256→\\t\\tcase transcript.TypeUser:\\n   257→\\t\\t\\tif entry := extractUserEntry(line); entry != nil {\\n   258→\\t\\t\\t\\tentries = append(entries, *entry)\\n   259→\\t\\t\\t}\\n   260→\\t\\tcase transcript.TypeAssistant:\\n   261→\\t\\t\\tassistantEntries := extractAssistantEntries(line)\\n   262→\\t\\t\\tentries = append(entries, assistantEntries...)\\n   263→\\t\\t}\\n   264→\\t}\\n   265→\\n   266→\\treturn entries\\n   267→}\\n   268→\\n   269→// skillContentPrefix identifies user messages that are skill content injections.\\n   270→// These are injected after a Skill tool call and contain the full skill instructions.\\n   271→const skillContentPrefix = \\\"Base directory for this skill:\\\"\\n   272→\\n   273→// extractUserEntry extracts a user entry from a transcript line.\\n   274→// Returns nil if the line doesn't contain a valid user prompt or is skill content.\\n   275→func extractUserEntry(line transcript.Line) *Entry {\\n   276→\\tcontent := transcript.ExtractUserContent(line.Message)\\n   277→\\tif content == \\\"\\\" {\\n   278→\\t\\treturn nil\\n   279→\\t}\\n   280→\\n   281→\\t// Skip skill content injections - these are verbose skill instructions\\n   282→\\t// injected as user messages after Skill tool invocations in Claude Code.\\n   283→\\t// The prefix \\\"Base directory for this skill:\\\" is added by the superpowers\\n   284→\\t// plugin when loading skill content. This filtering reduces transcript noise\\n   285→\\t// since skill content is documentation, not user intent.\\n   286→\\tif strings.HasPrefix(content, skillContentPrefix) {\\n   287→\\t\\treturn nil\\n   288→\\t}\\n   289→\\n   290→\\treturn &Entry{\\n   291→\\t\\tType:    EntryTypeUser,\\n   292→\\t\\tContent: content,\\n   293→\\t}\\n   294→}\\n   295→\\n   296→// extractAssistantEntries extracts assistant and tool entries from a transcript line.\\n   297→func extractAssistantEntries(line transcript.Line) []Entry {\\n   298→\\tvar msg transcript.AssistantMessage\\n   299→\\tif err := json.Unmarshal(line.Message, &msg); err != nil {\\n   300→\\t\\treturn nil\\n   301→\\t}\\n   302→\\n   303→\\tvar entries []Entry\\n   304→\\n   305→\\tfor _, block := range msg.Content {\\n   306→\\t\\tswitch block.Type {\\n   307→\\t\\tcase transcript.ContentTypeText:\\n   308→\\t\\t\\tif block.Text != \\\"\\\" {\\n   309→\\t\\t\\t\\tentries = append(entries, Entry{\\n   310→\\t\\t\\t\\t\\tType:    EntryTypeAssistant,\\n   311→\\t\\t\\t\\t\\tContent: block.Text,\\n   312→\\t\\t\\t\\t})\\n   313→\\t\\t\\t}\\n   314→\\t\\tcase transcript.ContentTypeToolUse:\\n   315→\\t\\t\\tvar input transcript.ToolInput\\n   316→\\t\\t\\t_ = json.Unmarshal(block.Input, &input) //nolint:errcheck // Best-effort parsing\\n   317→\\n   318→\\t\\t\\tdetail := extractToolDetail(block.Name, input)\\n   319→\\n   320→\\t\\t\\tentries = append(entries, Entry{\\n   321→\\t\\t\\t\\tType:       EntryTypeTool,\\n   322→\\t\\t\\t\\tToolName:   block.Name,\\n   323→\\t\\t\\t\\tToolDetail: detail,\\n   324→\\t\\t\\t})\\n   325→\\t\\t}\\n   326→\\t}\\n   327→\\n   328→\\treturn entries\\n   329→}\\n   330→\\n   331→// extractToolDetail extracts an appropriate detail string for a tool call.\\n   332→// For tools in minimalDetailTools, only essential identifiers are shown.\\n   333→// For other tools, the full detail chain is used.\\n   334→func extractToolDetail(toolName string, input transcript.ToolInput) string {\\n   335→\\t// For minimal detail tools, extract only the essential identifier\\n   336→\\tif minimalDetailTools[toolName] {\\n   337→\\t\\tswitch toolName {\\n   338→\\t\\tcase \\\"Skill\\\":\\n   339→\\t\\t\\treturn input.Skill\\n   340→\\t\\tcase \\\"Read\\\":\\n   341→\\t\\t\\tif input.FilePath != \\\"\\\" {\\n   342→\\t\\t\\t\\treturn input.FilePath\\n   343→\\t\\t\\t}\\n   344→\\t\\t\\treturn input.NotebookPath\\n   345→\\t\\tcase \\\"WebFetch\\\":\\n   346→\\t\\t\\treturn input.URL\\n   347→\\t\\t}\\n   348→\\t}\\n   349→\\n   350→\\t// For other tools, use the full detail chain\\n   351→\\tif input.Description != \\\"\\\" {\\n   352→\\t\\treturn input.Description\\n   353→\\t}\\n   354→\\tif input.Command != \\\"\\\" {\\n   355→\\t\\treturn input.Command\\n   356→\\t}\\n   357→\\tif input.FilePath != \\\"\\\" {\\n   358→\\t\\treturn input.FilePath\\n   359→\\t}\\n   360→\\tif input.NotebookPath != \\\"\\\" {\\n   361→\\t\\treturn input.NotebookPath\\n   362→\\t}\\n   363→\\treturn input.Pattern\\n   364→}\\n   365→\\n   366→// FormatCondensedTranscript formats an Input into a human-readable string for LLM.\\n   367→// The format is:\\n   368→//\\n   369→//\\t[User] user prompt here\\n   370→//\\n   371→//\\t[Assistant] assistant response here\\n   372→//\\n   373→//\\t[Tool] ToolName: description or file path\\n   374→func FormatCondensedTranscript(input Input) string {\\n   375→\\tvar sb strings.Builder\\n   376→\\n   377→\\tfor i, entry := range input.Transcript {\\n   378→\\t\\tif i > 0 {\\n   379→\\t\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   380→\\t\\t}\\n   381→\\n   382→\\t\\tswitch entry.Type {\\n   383→\\t\\tcase EntryTypeUser:\\n   384→\\t\\t\\tsb.WriteString(\\\"[User] \\\")\\n   385→\\t\\t\\tsb.WriteString(entry.Content)\\n   386→\\t\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   387→\\t\\tcase EntryTypeAssistant:\\n   388→\\t\\t\\tsb.WriteString(\\\"[Assistant] \\\")\\n   389→\\t\\t\\tsb.WriteString(entry.Content)\\n   390→\\t\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   391→\\t\\tcase EntryTypeTool:\\n   392→\\t\\t\\tsb.WriteString(\\\"[Tool] \\\")\\n   393→\\t\\t\\tsb.WriteString(entry.ToolName)\\n   394→\\t\\t\\tif entry.ToolDetail != \\\"\\\" {\\n   395→\\t\\t\\t\\tsb.WriteString(\\\": \\\")\\n   396→\\t\\t\\t\\tsb.WriteString(entry.ToolDetail)\\n   397→\\t\\t\\t}\\n   398→\\t\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   399→\\t\\t}\\n   400→\\t}\\n   401→\\n   402→\\tif len(input.FilesTouched) > 0 {\\n   403→\\t\\tsb.WriteString(\\\"\\\\n[Files Modified]\\\\n\\\")\\n   404→\\t\\tfor _, file := range input.FilesTouched {\\n   405→\\t\\t\\tfmt.Fprintf(&sb, \\\"- %s\\\\n\\\", file)\\n   406→\\t\\t}\\n   407→\\t}\\n   408→\\n   409→\\treturn sb.String()\\n   410→}\\n   411→\"}]},\"uuid\":\"b40b63d0-e248-44d5-80af-13e79be11c2c\",\"timestamp\":\"2026-02-19T02:49:38.950Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"Explore the copilot package at cmd/entire/cli/agent/copilot/ and find ALL external references to it across the codebase. I need to know:\\n\\n1. Every function, type, constant, and variable exported from the copilot package\\n2. Which of those exports are actually used outside the 