gger instance\\n    46→\\tlogger *slog.Logger\\n    47→\\n    48→\\t// logFile holds the current log file handle for cleanup\\n    49→\\tlogFile *os.File\\n    50→\\n    51→\\t// logBufWriter wraps logFile with buffered I/O for performance\\n    52→\\tlogBufWriter *bufio.Writer\\n    53→\\n    54→\\t// currentSessionID stores the session ID from Init() to include in all logs\\n    55→\\tcurrentSessionID string\\n    56→\\n    57→\\t// mu protects logger, logFile, logBufWriter, and currentSessionID\\n    58→\\tmu sync.RWMutex\\n    59→\\n    60→\\t// logLevelGetter is an optional callback to get log level from settings.\\n    61→\\t// Set by SetLogLevelGetter before Init is called.\\n    62→\\tlogLevelGetter func() string\\n    63→)\\n    64→\\n    65→// SetLogLevelGetter sets a callback function to get the log level from settings.\\n    66→// This allows the logging package to read settings without a circular dependency.\\n    67→// The callback is only used if ENTIRE_LOG_LEVEL env var is not set.\\n    68→func SetLogLevelGetter(getter func() string) {\\n    69→\\tmu.Lock()\\n    70→\\tdefer mu.Unlock()\\n    71→\\tlogLevelGetter = getter\\n    72→}\\n    73→\\n    74→// Init initializes the logger for a session, writing JSON logs to\\n    75→// .entire/logs/entire.log.\\n    76→//\\n    77→// If sessionID is non-empty, it is stored as an slog attribute on every log line for filtering.\\n    78→// If the log file cannot be created, falls back to stderr.\\n    79→// Log level is controlled by ENTIRE_LOG_LEVEL environment variable.\\n    80→func Init(sessionID string) error {\\n    81→\\t// Validate session ID if provided (used only for the slog attribute, not the filename)\\n    82→\\tif sessionID != \\\"\\\" {\\n    83→\\t\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n    84→\\t\\t\\treturn fmt.Errorf(\\\"invalid session ID for logging: %w\\\", err)\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\tmu.Lock()\\n    89→\\tdefer mu.Unlock()\\n 