ore checkpoints[1].CreatedAt (%v)\\\",\\n   596→\\t\\t\\tcheckpoints[0].CreatedAt, checkpoints[1].CreatedAt)\\n   597→\\t}\\n   598→\\tif !checkpoints[1].CreatedAt.Before(checkpoints[2].CreatedAt) {\\n   599→\\t\\tt.Errorf(\\\"checkpoints[1].CreatedAt (%v) should be before checkpoints[2].CreatedAt (%v)\\\",\\n   600→\\t\\t\\tcheckpoints[1].CreatedAt, checkpoints[2].CreatedAt)\\n   601→\\t}\\n   602→}\\n   603→\\n   604→func TestFindCheckpointInHistory_MultipleCheckpoints(t *testing.T) {\\n   605→\\ttmpDir := t.TempDir()\\n   606→\\tt.Chdir(tmpDir)\\n   607→\\n   608→\\trepo, w, _ := setupResumeTestRepo(t, tmpDir, false)\\n   609→\\n   610→\\t// Create a commit that simulates a squash merge with multiple checkpoint trailers\\n   611→\\ttestFile := filepath.Join(tmpDir, \\\"squash.txt\\\")\\n   612→\\tif err := os.WriteFile(testFile, []byte(\\\"squash content\\\"), 0o644); err != nil {\\n   613→\\t\\tt.Fatalf(\\\"Failed to write file: %v\\\", err)\\n   614→\\t}\\n   615→\\tif _, err := w.Add(\\\"squash.txt\\\"); err != nil {\\n   616→\\t\\tt.Fatalf(\\\"Failed to add file: %v\\\", err)\\n   617→\\t}\\n   618→\\n   619→\\tsquashMsg := \\\"Soph/test branch (#2)\\\\n* random_letter script\\\\n\\\\nEntire-Checkpoint: 0aa0814d9839\\\\n\\\\n* random color\\\\n\\\\nEntire-Checkpoint: 33fb587b6fbb\\\\n\\\"\\n   620→\\t_, err := w.Commit(squashMsg, &git.CommitOptions{\\n   621→\\t\\tAuthor: &object.Signature{\\n   622→\\t\\t\\tName:  \\\"Test User\\\",\\n   623→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   624→\\t\\t},\\n   625→\\t})\\n   626→\\tif err != nil {\\n   627→\\t\\tt.Fatalf(\\\"Failed to create squash commit: %v\\\", err)\\n   628→\\t}\\n   629→\\n   630→\\thead, err := repo.Head()\\n   631→\\tif err != nil {\\n   632→\\t\\tt.Fatalf(\\\"Failed to get HEAD: %v\\\", err)\\n   633→\\t}\\n   634→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   635→\\tif err != nil {\\n   636→\\t\\tt.Fatalf(\\\"Failed to get HEAD commit: %v\\\", err)\\n   637→\\t}\\n   638→\\n  