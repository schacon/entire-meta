ey-value metadata appended to git commit messages following the\\n     3→// git trailer convention (key: value format after a blank line).\\n     4→package trailers\\n     5→\\n     6→import (\\n     7→\\t\\\"fmt\\\"\\n     8→\\t\\\"regexp\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\tcheckpointID \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    12→)\\n    13→\\n    14→// Trailer key constants used in commit messages.\\n    15→const (\\n    16→\\t// MetadataTrailerKey points to the metadata directory within a commit tree.\\n    17→\\tMetadataTrailerKey = \\\"Entire-Metadata\\\"\\n    18→\\n    19→\\t// MetadataTaskTrailerKey points to the task metadata directory for subagent checkpoints.\\n    20→\\tMetadataTaskTrailerKey = \\\"Entire-Metadata-Task\\\"\\n    21→\\n    22→\\t// StrategyTrailerKey indicates which strategy created the commit.\\n    23→\\tStrategyTrailerKey = \\\"Entire-Strategy\\\"\\n    24→\\n    25→\\t// BaseCommitTrailerKey links shadow commits to their base code commit.\\n    26→\\tBaseCommitTrailerKey = \\\"Base-Commit\\\"\\n    27→\\n    28→\\t// SessionTrailerKey identifies which session created a commit.\\n    29→\\tSessionTrailerKey = \\\"Entire-Session\\\"\\n    30→\\n    31→\\t// CondensationTrailerKey identifies the condensation ID for a commit (legacy).\\n    32→\\tCondensationTrailerKey = \\\"Entire-Condensation\\\"\\n    33→\\n    34→\\t// SourceRefTrailerKey links code commits to their metadata on a shadow/metadata branch.\\n    35→\\t// Format: \\\"<branch>@<commit-hash>\\\" e.g. \\\"entire/metadata@abc123def456\\\"\\n    36→\\tSourceRefTrailerKey = \\\"Entire-Source-Ref\\\"\\n    37→\\n    38→\\t// CheckpointTrailerKey links commits to their checkpoint metadata on entire/checkpoints/v1.\\n    39→\\t// Format: 12 hex characters e.g. \\\"a3b2c4d5e6f7\\\"\\n    40→\\t// This trailer survives git amend and rebase operations.\\n    41→\\tCheckpointTrailerKey = \\\"Entire-Checkpoint\\\"\\n    42→\\n    43→\\t// EphemeralBranchTrailerKey identifies the shadow branch that a checkpoint originated from.\\n    44→\\t// Used in manual-commit strategy checkpoint commits on entire/checkpoints/v1 branch.\\n    45→\\t// Format: full branch name e.g. \\\"entire/2b4c177\\\"\\n    46→\\tEphemeralBranchTrailerKey = \\\"Ephemeral-branch\\\"\\n    47→\\n    48→\\t// AgentTrailerKey identifies the agent that created a checkpoint.\\n    49→\\t// Format: human-readable agent name e.g. \\\"Claude Code\\\", \\\"Cursor\\\"\\n    50→\\tAgentTrailerKey = \\\"Entire-Agent\\\"\\n    51→)\\n    52→\\n    53→// Pre-compiled regexes for trailer parsing.\\n    54→var (\\n    55→\\t// Trailer parsing regexes.\\n    56→\\tstrategyTrailerRegex     = regexp.MustCompile(StrategyTrailerKey + `:\\\\s*(.+)`)\\n    57→\\tmetadataTrailerRegex     = regexp.MustCompile(MetadataTrailerKey + `:\\\\s*(.+)`)\\n    58→\\ttaskMetadataTrailerRegex = regexp.MustCompile(MetadataTaskTrailerKey + `:\\\\s*(.+)`)\\n    59→\\tbaseCommitTrailerRegex   = regexp.MustCompile(BaseCommitTrailerKey + `:\\\\s*([a-f0-9]{40})`)\\n    60→\\tcondensationTrailerRegex = regexp.MustCompile(CondensationTrailerKey + `:\\\\s*(.+)`)\\n    61→\\tsessionTrailerRegex      = regexp.MustCompile(SessionTrailerKey + `:\\\\s*(.+)`)\\n    62→\\tcheckpointTrailerRegex   = regexp.MustCompile(CheckpointTrailerKey + `:\\\\s*(` + checkpointID.Pattern + `)(?:\\\\s|$)`)\\n    63→)\\n    64→\\n    65→// ParseStrategy extracts strategy from commit message.\\n    66→// Returns the strategy name and true if found, empty string and false otherwise.\\n    67→func ParseStrategy(commitMessage string) (string, bool) {\\n    68→\\tmatches := strategyTrailerRegex.FindStringSubmatch(commitMessage)\\n    69→\\tif len(matches) > 1 {\\n    70→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    71→\\t}\\n    72→\\treturn \\\"\\\", false\\n    73→}\\n    74→\\n    75→// ParseMetadata extracts metadata dir from commit message.\\n    76→// Returns the metadata directory and true if found, empty string and false otherwise.\\n    77→func ParseMetadata(commitMessage string) (string, bool) {\\n    78→\\tmatches := metadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    79→\\tif len(matches) > 1 {\\n    80→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    81→\\t}\\n    82→\\treturn \\\"\\\", false\\n    83→}\\n    84→\\n    85→// ParseTaskMetadata extracts task metadata dir from commit message.\\n    86→// Returns the task metadata directory and true if found, empty string and false otherwise.\\n    87→func ParseTaskMetadata(commitMessage string) (string, bool) {\\n    88→\\tmatches := taskMetadataTrailerRegex.FindStringSubmatch(commitMessage)\\n    89→\\tif len(matches) > 1 {\\n    90→\\t\\treturn strings.TrimSpace(matches[1]), true\\n    91→\\t}\\n    92→\\treturn \\\"\\\", false\\n    93→}\\n    94→\\n    95→// ParseBaseCommit extracts the base commit SHA from a commit message.\\n    96→// Returns the full SHA and true if found, empty string and false otherwise.\\n    97→func ParseBaseCommit(commitMessage string) (string, bool) {\\n    98→\\tmatches := baseCommitTrailerRegex.FindStringSubmatch(commitMessage)\\n    99→\\tif len(matches) > 1 {\\n   100→\\t\\treturn matches[1], true\\n   101→\\t}\\n   102→\\treturn \\\"\\\", false\\n   103→}\\n   104→\\n   105→// ParseCondensation extracts the condensation ID from a commit message.\\n   106→// Returns the condensation ID and true if found, empty string and false otherwise.\\n   107→func ParseCondensation(commitMessage string) (string, bool) {\\n   108→\\tmatches := condensationTrailerRegex.FindStringSubmatch(commitMessage)\\n   109→\\tif len(matches) > 1 {\\n   110→\\t\\treturn strings.TrimSpace(matches[1]), true\\n   111→\\t}\\n   112→\\treturn \\\"\\\", false\\n   113→}\\n   114→\\n   115→// ParseSession extracts the session ID from a commit message.\\n   116→// Returns the session ID and true if found, empty string and false otherwise.\\n   117→// Note: If multiple Entire-Session trailers exist, this returns only the first one.\\n   118→// Use ParseAllSessions to get all session IDs.\\n   119→func ParseSession(commitMessage string) (string, bool) {\\n   120→\\tmatches := sessionTrailerRegex.FindStringSubmatch(commitMessage)\\n   121→\\tif len(matches) > 1 {\\n   122→\\t\\treturn strings.TrimSpace(matches[1]), true\\n   123→\\t}\\n   124→\\treturn \\\"\\\", false\\n   125→}\\n   126→\\n   127→// ParseCheckpoint extracts the checkpoint ID from a commit message.\\n   128→// Returns the CheckpointID and true if found, empty ID and false otherwise.\\n   129→func ParseCheckpoint(commitMessage string) (checkpointID.CheckpointID, bool) {\\n   130→\\tmatches := checkpointTrailerRegex.FindStringSubmatch(commitMessage)\\n   131→\\tif len(matches) > 1 {\\n   132→\\t\\tidStr := strings.TrimSpace(matches[1])\\n   133→\\t\\t// Validate it's a proper checkpoint ID\\n   134→\\t\\tif cpID, err := checkpointID.NewCheckpointID(idStr); err == nil {\\n   135→\\t\\t\\treturn cpID, true\\n   136→\\t\\t}\\n   137→\\t}\\n   138→\\treturn checkpointID.EmptyCheckpointID, false\\n   139→}\\n   140→\\n   141→// ParseAllCheckpoints extracts all checkpoint IDs from a commit message.\\n   142→// Returns a slice of CheckpointIDs (may be empty if none found).\\n   143→// Duplicate IDs are deduplicated while preserving order.\\n   144→// This is useful for squash merge commits that contain multiple Entire-Checkpoint trailers.\\n   145→func ParseAllCheckpoints(commitMessage string) []checkpointID.CheckpointID {\\n   146→\\tmatches := checkpointTrailerRegex.FindAllStringSubmatch(commitMessage, -1)\\n   147→\\tif len(matches) == 0 {\\n   148→\\t\\treturn nil\\n   149→\\t}\\n   150→\\n   151→\\tseen := make(map[string]bool)\\n   152→\\tids := make([]checkpointID.CheckpointID, 0, len(matches))\\n   153→\\tfor _, match := range matches {\\n   154→\\t\\tif len(match) > 1 {\\n   155→\\t\\t\\tidStr := strings.TrimSpace(match[1])\\n   156→\\t\\t\\tif !seen[idStr] {\\n   157→\\t\\t\\t\\tif 