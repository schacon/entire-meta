n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\tt.Fatalf(\\\"entire %s failed: %v\\\\n%s\\\", strings.Join(args, \\\" \\\"), err, out)\\n\\t}\\n\\treturn strings.TrimSpace(string(out))\\n}\\n\\n// runErr executes an `entire` subcommand in dir and returns any error.\\nfunc runErr(dir string, args ...string) error {\\n\\tcmd := exec.Command(BinPath(), args...)\\n\\tcmd.Dir = dir\\n\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\treturn &ExecError{\\n\\t\\t\\tArgs:   args,\\n\\t\\t\\tErr:    err,\\n\\t\\t\\tOutput: string(out),\\n\\t\\t}\\n\\t}\\n\\treturn nil\\n}\\n\\n// ExecError wraps an entire CLI execution failure with its output.\\ntype ExecError struct {\\n\\tArgs   []string\\n\\tErr    error\\n\\tOutput string\\n}\\n\\nfunc (e *ExecError) Error() string {\\n\\treturn \\\"entire \\\" + strings.Join(e.Args, \\\" \\\") + \\\": \\\" + e.Err.Error() + \\\"\\\\n\\\" + e.Output\\n}\\n\\nfunc (e *ExecError) Unwrap() error {\\n\\treturn e.Err\\n}\\n\\n// Explain runs `entire explain --checkpoint <id>` and returns the output.\\nfunc Explain(t *testing.T, dir, checkpointID string) string {\\n\\tt.Helper()\\n\\treturn run(t, dir, \\\"explain\\\", \\\"--checkpoint\\\", checkpointID)\\n}\\n\\n// ExplainGenerate runs `entire explain --checkpoint <id> --generate`.\\n// Returns (output, error) — doesn't fail test since callers may test failure cases.\\nfunc ExplainGenerate(dir, checkpointID string) (string, error) {\\n\\treturn runOutput(dir, \\\"explain\\\", \\\"--checkpoint\\\", checkpointID, \\\"--generate\\\")\\n}\\n\\n// ExplainCommit runs `entire explain --commit <ref>`.\\n// Returns (output, error) — for testing failure cases.\\nfunc ExplainCommit(dir, ref string) (string, error) {\\n\\treturn runOutput(dir, \\\"explain\\\", \\\"--commit\\\", ref)\\n}\\n\\n// Resume runs `entire resume <branch> --force` and returns the output.\\nfunc Resume(dir, branch string) (string, error) {\\n\\treturn runOutput(dir, \\\"resume\\\", branch, \\\"--force\\\")\\n}\\n\\n// runOutput executes an `entire` subcommand and returns (output, error).\\nfunc runOutput(dir string, args ...string) (string, error) {\\n\\tcmd := exec.Command(BinPath(), args...)\\n\\tcmd.Dir = dir\\n\\tcmd.Env = append(os.Environ(), \\\"ENTIRE_TEST_TTY=0\\\")\\n\\n\\tout, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\treturn string(out), &ExecError{\\n\\t\\t\\tArgs:   args,\\n\\t\\t\\tErr:    err,\\n\\t\\t\\tOutput: string(out),\\n\\t\\t}\\n\\t}\\n\\treturn strings.TrimSpace(string(out)), nil\\n}\\n\",\"numLines\":155,\"startLine\":1,\"totalLines\":155}},\"sourceToolAssistantUUID\":\"bb8d5397-570d-4c2d-a18a-738bcbf6cef3\"}\n{\"parentUuid\":\"31632479-be1e-4c34-96e7-6e0c3798174b\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli\",\"sessionId\":\"79629433-3dbc-4b5e-9c6a-1c729f034186\",\"version\":\"2.1.63\",\"gitBranch\":\"squash-merge-resume-e2e-tests\",\"slug\":\"indexed-sprouting-cascade\",\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01EekKHWPYt4zUarLFejof57\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"text\",\"text\":\"Here's a comprehensive overview of the E2E test suite:\\n\\n## How It Works\\n\\nThe E2E tests exercise the **real end-to-end flow**: they spin up actual AI agents (Claude Code, Gemini CLI, OpenCode), send them prompts, and verify the `entire` CLI's checkpoint/session/rewind behavior against real agent interactions.\\n\\n### Architecture\\n\\n```\\ne2e/\\n├── agents/       # Agent abstraction layer (Agent interface, tmux sessions, concurrency gates)\\n├── bootstrap/    # CI pre-test setup (auth config, warmup)\\n├── entire/       # Wrapper around the `entire` CLI binary (enable, rewind, explain, resume)\\n├── tests/        # The actual test files (run by CI)\\n├── exploratory/  # Experimental tests, NOT run by CI\\n└── testutil/     # Repo setup, assertions, artifact capture\\n```\\n\\n### Core flow of every test\\n\\n1. **`testutil.ForEachAgent`** — the entry point for all tests. It:\\n   - Runs the test as a parallel subtest for each registered agent\\n   - Acquires a concurrency slot (agents have configurable concurrency limits)\\n   - Scales timeouts per agent (e.g., Gemini gets 2.5x longer)\\n   - Handles transient API errors by restarting the entire scenario (up to 3 attempts with a fresh repo each time)\\n\\n2. **`testutil.SetupRepo`** — creates a fresh git repo in a temp dir:\\n   - `git init` + initial empty commit\\n   - Runs `entire enable --agent <name>`\\n   - Configures debug logging\\n   - Sets up artifact capture on cleanup\\n\\n3. **`s.RunPrompt`** — sends a prompt to the real agent CLI and captures stdout/stderr. For Claude Code, this runs `claude -p \\\"<prompt>\\\" --model haiku --dangerously-skip-permissions`.\\n\\n4. **Assertions** — rich helpers in `testutil/assertions.go` verify checkpoint behavior:\\n   - `WaitForCheckpoint` — polls until the checkpoint branch advances (hooks are async)\\n   - `AssertHasCheckpointTrailer` — verifies the commit trailer linking to metadata\\n   - `AssertCheckpointMetadataComplete` — checks all metadata fields\\n   - `AssertNoShadowBranches` — verifies cleanup after condensation\\n   - `ValidateCheckpointDeep` — comprehensive validation including transcript JSONL, content hashes, and prompt content\\n\\n### Two modes of agent interaction\\n\\n- **Non-interactive** (`s.RunPrompt`) — runs the agent CLI with `-p` flag, waits for it to finish. Used by most tests.\\n- **Interactive** (`s.StartSession` + `s.Send` / `s.WaitFor`) — starts a tmux session, sends keystrokes, and pattern-matches output. Used for multi-turn tests.\\n\\n## How to Run\\n\\n```bash\\n# All agents (all tests)\\nmise run test:e2e\\n\\n# Specific agent\\nmise run test:e2e --agent claude-code\\nmise run test:e2e --agent gemini-cli\\nmise run test:e2e --agent opencode\\n\\n# Filter to a specific test\\nmise run test:e2e TestSingleSessionManualCommit\\nmise run test:e2e --agent claude-code TestRewind\\n```\\n\\n### Prerequisites\\n\\n- The agent CLI must be installed (e.g., `claude` binary on PATH)\\n- `tmux` must be installed (used for interactive sessions)\\n- API key set: `ANTHROPIC_API_KEY` for Claude, `GEMINI_API_KEY` for Gemini\\n\\n### Key environment variables\\n\\n| Variable | Description | Default |\\n|---|---|---|\\n| `E2E_AGENT` | Which agent(s) to test | all registered |\\n| `E2E_TIMEOUT` | Per-prompt timeout | `2m` |\\n| `E2E_KEEP_REPOS` | Set to `1` to preserve temp repos for inspection | unset |\\n| `E2E_ARTIFACT_DIR` | Override artifact output dir | `e2e/artifacts/<timestamp>` |\\n| `E2E_ENTIRE_BIN` | Path to pre-built binary | builds from source |\\n\\n## What to Be Aware Of\\n\\n### Cost and API calls\\nTests make **real API calls** that consume tokens and cost money. Claude Code tests default to `haiku` model for cost efficiency. Never run E2E tests proactively — only when explicitly asked.\\n\\n### Build tag\\nAll test files use `//go:build e2e` — they won't compile or run with normal `go test`. The `mise run test:e2e` task handles this.\\n\\n### Flakiness from agent non-determinism\\nThe biggest source of flakiness is agents behaving unpredictably:\\n- **Agent asks for confirmation** instead of acting — fix prompts with \\\"Do not ask for confirmation, just make the change.\\\"\\n- **Agent writes to wrong path** — be more explicit about file paths\\n- **Agent commits when it shouldn't** — add \\\"Do not commit\\\" to prompt\\n- **Checkpoint wait timeout** — increase the timeout argument\\n\\n### Transient error handling\\nIf an agent returns a transient API error (rate limit, 503, overloaded), `RunPrompt` panics with `errScenarioRestart`. `ForEachAgent` catches this, discards the failed repo, and retries with a fresh one — up to 3 total attempts.\\n\\n### Debugging failures\\nArtifacts are automatically captured to `e2e/artifacts/` on every run:\\n- `console.log` — full transcript of all prompts, stdout/stderr, and git commands\\n- `git-log.txt` — commit history at time of failure\\n- `git-tree.txt` — working tree state\\n- `entire-logs/` — internal CLI debug logs\\n\\nSet `E2E_KEEP_REPOS=1` to preserve the temp repo on disk for manual inspection — a symlink in the artifact dir points to it.\\n\\n### Concurrency\\nTests run in parallel, but each agent has a concurrency gate limiting how many tests run simultaneously (to avoid rate-limiting). The default can be overridden with `E2E_CONCURRENT_TEST_LIMIT`.\\n\\n### CI workflows\\n- `.github/workflows/e2e.yml` — full suite on push to main, matrix across agents\\n- `.github/workflows/e2e-isolated.yml` — manual dispatch for debugging a single test\"}],\"stop_reason\":\"end_turn\",\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":11440,\"cache_read_input_tokens\":47119,\"output_tokens\":1512,\"server_tool_use\":{\"web_search_requests\":0,\"web_fetch_requests\":0},\"service_tier\":\"standard\",\"cache_creation\":{\"ephemeral_1h_input_tokens\":11440,\"ephemeral_5m_input_tokens\":0},\"inference_geo\":\"\",\"iterations\":[],\"speed\":\"standard\"}},\"requestId\":\"req_011CYgqTmvGLaZuYj8dJsMGJ\",\"type\":\"assistant\",\"uuid\":\"c75c33f0-3f9d-479c-8f22-dd82d985d24d\",\"timestamp\":\"2026-03-03T21:13:31.413Z\"}\n{\"parentUuid\":\"c75c33f0-3f9d-479c-8f22-dd82d985d24d\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/pfleidi/entire/cli\",\"sessionId\":\"79629433-3dbc-4b5e-9c6a-1c729f034186\",\"version\":\"2.1.63\",\"gitBranch\":\"squash-merge-resume-e2e-tests\",\"slug\":\"indexed-sprouting-cascade\",\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"Stop\",\"hookName\":\"Stop\",\"command\":\"go run ${CLAUDE_PROJECT_DIR}/cmd/entire/main.go hooks claude-code stop\"},\"parentToolUseID\":\"d88c79b6-1c92-440e-88e5-9096d09bc4d3\",\"toolUseID\":\"d88c79b6-1c92-440e-88e5-9096d09bc4d3\",\"timestamp\":\"2026-03-03T21:13:31.44