  46→\\t// creates nested subdirectories (TestName.../001/) whose structure\\n    47→\\t// confuses some agents' (e.g. opencode) working-directory resolution.\\n    48→\\tdir, err := os.MkdirTemp(\\\"\\\", \\\"e2e-repo-*\\\")\\n    49→\\tif err != nil {\\n    50→\\t\\tt.Fatalf(\\\"create temp dir: %v\\\", err)\\n    51→\\t}\\n    52→\\tif keepRepos {\\n    53→\\t\\tt.Logf(\\\"E2E_KEEP_REPOS: repo will be preserved at %s\\\", dir)\\n    54→\\t} else {\\n    55→\\t\\tt.Cleanup(func() { os.RemoveAll(dir) })\\n    56→\\t}\\n    57→\\n    58→\\t// Resolve symlinks (macOS: /var -> /private/var) so paths match\\n    59→\\t// what agent CLIs see when they resolve their own CWD.\\n    60→\\tif resolved, err := filepath.EvalSymlinks(dir); err == nil {\\n    61→\\t\\tdir = resolved\\n    62→\\t}\\n    63→\\n    64→\\tGit(t, dir, \\\"init\\\")\\n    65→\\tGit(t, dir, \\\"config\\\", \\\"user.name\\\", \\\"E2E Test\\\")\\n    66→\\tGit(t, dir, \\\"config\\\", \\\"user.email\\\", \\\"e2e@test.local\\\")\\n    67→\\tGit(t, dir, \\\"commit\\\", \\\"--allow-empty\\\", \\\"-m\\\", \\\"initial commit\\\")\\n    68→\\n    69→\\tentire.Enable(t, dir, agent.EntireAgent())\\n    70→\\tif agent.Name() == \\\"factoryai-droid\\\" {\\n    71→\\t\\tif err := configureDroidRepoSettings(dir); err != nil {\\n    72→\\t\\t\\tt.Fatalf(\\\"configure droid repo settings: %v\\\", err)\\n    73→\\t\\t}\\n    74→\\t}\\n    75→\\tPatchSettings(t, dir, map[string]any{\\\"log_level\\\": \\\"debug\\\"})\\n    76→\\n    77→\\t// OpenCode's non-interactive mode auto-rejects external_directory permission\\n    78→\\t// since there's no user to prompt. Write a config to allow it.\\n    79→\\tif agent.Name() == \\\"opencode\\\" {\\n    80→\\t\\tcfg := `{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}}`\\n    81→\\t\\tif key := os.Getenv(\\\"ANTHROPIC_API_KEY\\\"); key != \\\"\\\" {\\n    82→\\t\\t\\tcfg = fmt.Sprintf(`{\\\"$schema\\\": \\\"https://opencode.ai/config.json\\\", \\\"permission\\\": {\\\"external_directory\\\": \\\"allow\\\"}, \\\"provider\\\": {\\\"anthropic\\\": {\\\"options\\\": {\\\"apiKey\\\": %q}}}}`, key)\\n    83→\\t\\t}\\n    84→\\t\\tif err := os.WriteFile(filepath.Join(dir, \\\"opencode.json\\\"), []byte(cfg+\\\"\\\\n\\\"), 0o644); err != nil {\\n    85→\\t\\t\\tt.Fatalf(\\\"write opencode.json: %v\\\", err)\\n    86→\\t\\t}\\n    87→\\t}\\n    88→\\n    89→\\t// Create artifact dir eagerly so console.log is written to disk\\n    90→\\t// incrementally. Even if the test is killed by a global timeout,\\n    91→\\t// partial output survives.\\n    92→\\tartDir := artifactDir(t)\\n    93→\\tconsoleLog, err := os.Create(filepath.Join(artDir, \\\"console.log\\\"))\\n    94→\\tif err != nil {\\n    95→\\t\\tt.Fatalf(\\\"create console.log: %v\\\", err)\\n    96→\\t}\\n    97→\\n    98→\\tstate := &RepoState{\\n    99→\\t\\tAgent:            agent,\\n   100→\\t\\tDir:              dir,\\n   101→\\t\\tArtifactDir:      artDir,\\n   102→\\t\\tHeadBefore:       GitOutput(t, dir, \\\"rev-parse\\\", \\\"HEAD\\\"),\\n   103→\\t\\tCheckpointBefore: GitOutput(t, dir, \\\"rev-parse\\\", \\\"entire/checkpoints/v1\\\"),\\n   104→\\t\\tConsoleLog:       consoleLog,\\n   105→\\t}\\n   106→\\n   107→\\tt.Cleanup(func() {\\n   108→\\t\\t_ = consoleLog.Close()\\n   109→\\t\\tif !state.skipArtifacts {\\n   110→\\t\\t\\tCaptureArtifacts(t, state)\\n   111→\\t\\t}\\n   112→\\t})\\n   113→\\n   114→\\treturn state\\n   115→}\\n   116→\\n   117→func configureDroidRepoSettings(repoDir string) error {\\n   118→\\thome, err := os.UserHomeDir()\\n   119→\\tif err != nil {\\n   120→\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n   121→\\t}\\n   122→\\n   123→\\tglobalSettingsPath := filepath.Join(home, \\\".factory\\\", \\\"settings.json\\\")\\n   124→\\trepoSettingsPath := filepath.Join(repoDir, droidRepoSettingsPath)\\n   125→\\n   126→\\tif err := mergeDroidCustomModels(globalSettingsPath, repoSettingsPath); err != nil {\\n   127→\\t\\treturn err\\n   128→\\t}\\n   129→\\tif err := ensureGitInfoExcludeContains(repoDir, droidRepoSettingsPath); err != nil {\\n   130→\\t\\treturn fmt.Errorf(\\\"exclude droid settings from git: %w\\\", err)\\n   131→\\t}\\n   132→\\treturn nil\\n   133→}\\n   134→\\n   135→func mergeDroidCustomModels(globalSettingsPath, repoSettingsPath string) error {\\n   136→\\tglobalSettings, err := loadJSONMap(globalSettingsPath, \\\"global droid settings\\\")\\n   137→\\tif err != nil {\\n   138→\\t\\treturn err\\n   139→\\t}\\n   140→\\n   141→\\tcustomModels, ok := globalSettings[\\\"customModels\\\"]\\n   142→\\tif !ok {\\n   143→\\t\\treturn fmt.Errorf(\\n   144→\\t\\t\\t\\\"global droid settings at %s missing customModels; repo-local %s shadows global settings\\\",\\n   145→\\t\\t\\tglobalSettingsPath,\\n   146→\\t\\t\\trepoSettingsPath,\\n   147→\\t\\t)\\n   148→\\t}\\n   149→\\n   150→\\tvar models []json.RawMessage\\n   151→\\tif err := json.Unmarshal(customModels, &models); err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"parse customModels in %s: %w\\\", globalSettingsPath, err)\\n   153→\\t}\\n   154→\\tif len(models) == 0 {\\n   155→\\t\\treturn fmt.Errorf(\\\"global droid settings at %s has empty customModels\\\", globalSettingsPath)\\n   156→\\t}\\n   157→\\n   158→\\trepoSettings, err := loadJSONMap(repoSettingsPath, \\\"repo-local droid settings\\\")\\n   159→\\tif err != nil {\\n   160→\\t\\treturn err\\n   161→\\t}\\n   162→\\trepoSettings[\\\"customModels\\\"] = customModels\\n   163→\\n   164→\\tout, err := json.MarshalIndent(repoSettings, \\\"\\\", \\\"  \\\")\\n   165→\\tif err != nil {\\n   166→\\t\\treturn fmt.Errorf(\\\"marshal repo-local droid settings: %w\\\", err)\\n   167→\\t}\\n   168→\\tout = append(out, '\\\\n')\\n   169→\\n   170→\\tif err := os.WriteFile(repoSettingsPath, out, 0o600); err != nil {\\n   171→\\t\\treturn fmt.Errorf(\\\"write repo-local droid settings %s: %w\\\", repoSettingsPath, err)\\n   172→\\t}\\n   173→\\treturn nil\\n   174→}\\n   175→\\n   176→func loadJSONMap(path, description string) (map[string]json.RawMessage, error) {\\n   177→\\tdata, err := os.ReadFile(path)\\n   178→\\tif err != nil {\\n   179→\\t\\treturn nil, fmt.Errorf(\\\"read %s at %s: %w\\\", description, path, err)\\n   180→\\t}\\n   181→\\n   182→\\tvar parsed map[string]json.RawMessage\\n   183→\\tif err := json.Unmarshal(data, &parsed); err != nil {\\n   184→\\t\\treturn nil, fmt.Errorf(\\\"parse %s at %s: %w\\\", description, path, err)\\n   185→\\t}\\n   186→\\tif parsed == nil {\\n   187→\\t\\tparsed = make(map[string]json.RawMessage)\\n   188→\\t}\\n   189→\\treturn parsed, nil\\n   190→}\\n   191→\\n   192→func ensureGitInfoExcludeContains(repoDir, entry string) error {\\n   193→\\texcludePath := filepath.Join(repoDir, \\\".git\\\", \\\"info\\\", \\\"exclude\\\")\\n   194→\\n   195→\\tdata, err := os.ReadFile(excludePath)\\n   196→\\tif err != nil && !errors.Is(err, os.ErrNotExist) {\\n   197→\\t\\treturn fmt.Errorf(\\\"read %s: %w\\\", excludePath, err)\\n   198→\\t}\\n   199→\\n   200→\\tnormalized := strings.ReplaceAll(string(data), \\\"\\\\r\\\\n\\\", \\\"\\\\n\\\")\\n   201→\\tfor _, line := range strings.Split(normalized, \\\"\\\\n\\\") {\\n   202→\\t\\tif strings.TrimSpace(line) == entry {\\n   203→\\t\\t\\treturn nil\\n   204→\\t\\t}\\n   205→\\t}\\n   206→\\n   207→\\tvar b strings.Builder\\n   208→\\tif len(data) > 0 {\\n   209→\\t\\tb.Write(data)\\n   210→\\t\\tif data[len(data)-1] != '\\\\n' {\\n   211→\\t\\t\\tb.WriteByte('\\\\n')\\n   212→\\t\\t}\\n   213→\\t}\\n   214→\\tb.WriteString(entry)\\n   215→\\tb.WriteByte('\\\\n')\\n   216→\\n   217→\\tif err := os.MkdirAll(filepath.Dir(excludePath), 0o755); err != nil {\\n   218→\\t\\treturn fmt.Errorf(\\\"create %s: %w\\\", filepath.Dir(excludePath), err)\\n   219→\\t}\\n   220→\\tif err := os.WriteFile(excludePath, []byte(b.String()), 0o644); err != nil {\\n   221→\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", excludePath, err)\\n   222→\\t}\\n   223→\\treturn nil\\n   224→}\\n   225→\\n   226→// ForEachAgent runs fn as a parallel subtest for every registered agent.\\n   227→// It handles repo setup, concurrency gating, context timeout, and cleanup.\\n   228→// The timeout is scaled by each agent's TimeoutMultiplier.\\n   229→//\\n   230→// If RunPrompt detects a transient API error (e.g. rate limit, token refresh\\n   231→// failure), it panics with errScenarioRestart. ForEachAgent recovers from the\\n   232→// panic and restarts the entire scenario with a fresh repository, up to\\n   233→// maxScenarioRestarts times. This avoids stale CLI session state from the\\n   234→// failed attempt poisoning the retry.\\n   235→func ForEachAgent(t *testing.T, timeout time.Duration, fn func(t *testing.T, s *RepoState, ctx context.Context)) {\\n   236→\\tt.Helper()\\n   237→\\tt.Parallel()\\n   238→\\tall := agents.All()\\n   239→\\tif len(all) == 0 {\\n   240→\\t\\tt.Skip(\\\"no agents registered (check E2E_AGENT filter)\\\")\\n   241→\\t}\\n   242→\\tfor _, agent := range all {\\n   243→\\t\\tt.Run(agent.Name(), func(t *testing.T) {\\n   244→\\t\\t\\t// Use the global test deadline for slot wait so we don't\\n   245→\\t\\t\\t// skip prematurely — only bail if the whole binary is dying.\\n   246→\\t\\t\\tslotCtx := context.Background()\\n   247→\\t\\t\\tif deadline, ok := t.Deadline(); ok {\\n   248→\\t\\t\\t\\tvar cancel context.CancelFunc\\n   249→\\t\\t\\t\\tslotCtx, cancel = context.WithDeadline(slotCtx, deadline)\\n   250→\\t\\t\\t\\tdefer cancel()\\n   251→\\t\\t\\t}\\n   252→\\t\\t\\tif err := agents.AcquireSlot(slotCtx, agent); err != nil {\\n   253→\\t\\t\\t\\tt.Fatalf(\\\"timed out waiting for agent slot: %v\\\", err)\\n   254→\\t\\t\\t}\\n   255→\\t\\t\\tdefer agents.ReleaseSlot(agent)\\n   256→\\n   257→\\t\\t\\t// Per-test timeout starts after slot is acquired, scaled\\n   258→\\t\\t\\t// by the agent's multiplier (e.g. 2.5× for gemini).\\n   259→\\t\\t\\tscaled := time.Duration(float64(timeout) * agent.TimeoutMultiplier())\\n   260→\\n   261→\\t\\t\\tvar prevState *RepoState\\n   262→\\t\\t\\tfor attempt := range maxScenarioRestarts + 1 {\\n   263→\\t\\t\\t\\ts := SetupRepo(t, agent)\\n   264→\\t\\t\\t\\tctx, cancel := context.WithTimeout(context.Background(), scaled)\\n   265→\\n   266→\\t\\t\\t\\t// On restart, suppress artifact capture from the previous\\n   267→\\t\\t\\t\\t// failed attempt so it doesn't overwrite the final one.\\n   268→\\t\\t\\t\\tif prevState != nil {\\n   269→\\t\\t\\t\\t\\tprevState.skipArtifacts = true\\n   270→\\t\\t\\t\\t}\\n   271→\\n   272→\\t\\t\\t\\trestarted := runScenario(t, s, ctx, fn)\\n   273→\\t\\t\\t\\tcancel()\\n   274→\\n   275→\\t\\t\\t\\tif !restarted {\\n   276→\\t\\t\\t\\t\\treturn\\n   277→\\t\\t\\t\\t}\\n   278→\\t\\t\\t\\tprevState = s\\n   279→\\t\\t\\t\\tif attempt >= maxScenarioRestarts {\\n   280→\\t\\t\\t\\t\\tt.Fatalf(\\\"exhausted %d scenario attempts due to transient API errors\\\", maxScenarioRestarts+1)\\n   281→\\t\\t\\t\\t}\\n   282→\\t\\t\\t\\tt.Logf(\\\"transient error, restarting scenario (attempt %d/%d)\\\", attempt+2, maxScenarioRestarts+1)\\n   283→\\t\\t\\t}\\n   284→\\t\\t})\\n   285→\\t}\\n   286→}\\n   287→\\n   288→// runScenario runs the test function and recovers from errScenarioRestart\\n   289→// panics triggered by transient API errors in RunPrompt. Returns true if\\n   290→// the scenario should be restarted with a fresh repository.\\n   291→func runScenario(t *testing.T, s *RepoState, ctx context.Context, fn func(t *testing.T, s *RepoState, ctx context.Context)) (restarted bool) {\\n   292→\\tt.Helper()\\n   293→\\tdefer func() {\\n   294→\\t\\tif r := recover(); r != nil {\\n   295→\\t\\t\\tif _, ok := r.(errScenarioRestart); ok {\\n   296→\\t\\t\\t\\trestarted = true\\n   297→\\t\\t\\t\\treturn\\n   298→\\t\\t\\t}\\n   299→\\t\\t\\tpanic(r) // re-panic for unexpected panics\\n   300→\\t\\t}\\n   301→\\t}()\\n   302→\\tfn(t, s, ctx)\\n   303→\\treturn false\\n   304→}\\n   305→\\n   306→const maxScenarioRestarts = 2 // restart up to 2 times = 3 total attempts\\n   307→\\n   308→// errScenarioRestart is panicked by RunPrompt when a transient API error is\\n   309→// detected. ForEachAgent recovers from this panic and restarts the test\\n   310→// scenario with a fresh repository, avoiding stale CLI state from the failed\\n   311→// attempt.\\n   312→type errScenarioRestart struct {\\n   313→\\tmsg string\\n   314→}\\n   315→\\n   316→// RunPrompt runs an agent prompt, logs the command and output to ConsoleLog,\\n   317→// and returns the result. If the agent reports a transient API error, it\\n   318→// panics with errScenarioRestart to trigger a full scenario restart in\\n   319→// ForEachAgent (see runScenario).\\n   320→func (s *RepoState) RunPrompt(t *testing.T, ctx context.Context, prompt string, opts ...agents.Option) (agents.Output, error) {\\n   321→\\tt.Helper()\\n   322→\\tout, err := s.Agent.RunPrompt(ctx, s.Dir, prompt, opts...)\\n   323→\\ts.logPromptResult(out)\\n   324→\\n   325→\\tif err != nil && s.Agent.IsTransientError(out, err) {\\n   326→\\t\\terrMsg := fmt.Sprintf(\\\"transient API error (stderr: %s)\\\", strings.TrimSpace(out.Stderr))\\n   327→\\t\\tt.Logf(\\\"%s — restarting scenario\\\", errMsg)\\n   328→\\t\\tfmt.Fprintf(s.ConsoleLog, \\\"> [transient] %s — restarting scenario\\\\n\\\", errMsg)\\n   329→\\t\\tpanic(errScenarioRestart{msg: errMsg})\\n   330→\\t}\\n   331→\\n   332→\\treturn out, err\\n   333→}\\n   334→\\n   335→func (s *RepoState) logPromptResult(out agents.Output) {\\n   336→\\ts.ConsoleLog.WriteString(\\\"> \\\" + out.Command + \\\"\\\\n\\\")\\n   337→\\ts.ConsoleLog.WriteString(\\\"stdout:\\\\n\\\" + out.Stdout + \\\"\\\\n\\\")\\n   338→\\ts.ConsoleLog.WriteString(\\\"stderr:\\\\n\\\" + out.Stderr + \\\"\\\\n\\\")\\n   339→}\\n   340→\\n   341→// Git runs a git command in the repo and logs it to ConsoleLog.\\n   342→func (s *RepoState) Git(t *testing.T, args ...string) {\\n   343→\\tt.Helper()\\n   344→\\ts.ConsoleLog.WriteString(\\\"> git \\\" + strings.Join(args, \\\" \\\") + \\\"\\\\n\\\")\\n   345→\\tGit(t, s.Dir, args...)\\n   346→}\\n   347→\\n   348→// StartSession starts an interactive session and registers it for pane\\n   349→// capture in artifacts. Returns nil if the agent does not support interactive\\n   350→// mode. The session is closed automatically during test cleanup.\\n   351→func (s *RepoState) StartSession(t *testing.T, ctx context.Context) agents.Session {\\n   352→\\tt.Helper()\\n   353→\\tsession, err := s.Agent.StartSession(ctx, s.Dir)\\n   354→\\tif err != nil {\\n   355→\\t\\tt.Fatalf(\\\"start session: %v\\\", err)\\n   356→\\t}\\n   357→\\tif session == nil {\\n   358→\\t\\treturn nil\\n   359→\\t}\\n   360→\\ts.session = session\\n   361→\\treturn session\\n   362→}\\n   363→\\n   364→// WaitFor waits for a pattern in the interactive session's pane and logs the\\n   365→// pane content to ConsoleLog after the wait completes (success or failure).\\n   366→func (s *RepoState) WaitFor(t *testing.T, session agents.Session, pattern string, timeout time.Duration) {\\n   367→\\tt.Helper()\\n   368→\\tcontent, err := session.WaitFor(pattern, timeout)\\n   369→\\tfmt.Fprintf(s.ConsoleLog, \\\"> pane after WaitFor(%q):\\\\n%s\\\\n\\\", pattern, content)\\n   370→\\tif err != nil {\\n   371→\\t\\tt.Fatalf(\\\"WaitFor(%q): %v\\\", pattern, err)\\n   372→\\t}\\n   373→}\\n   374→\\n   375→// Send sends input to an interactive session and logs it to ConsoleLog.\\n   376→// Fails the test on error.\\n   377→func (s *RepoState) Send(t *testing.T, session agents.Session, input string) {\\n   378→\\tt.Helper()\\n   379→\\ts.ConsoleLog.WriteString(\\\"> send: \\\" + input + \\\"\\\\n\\\")\\n   380→\\tif err := session.Send(input); err != nil {\\n   381→\\t\\tt.Fatalf(\\\"send failed: %v\\\", err)\\n   382→\\t}\\n   383→}\\n   384→\\n   385→// PatchSettings merges extra keys into .entire/settings.json.\\n   386→func 