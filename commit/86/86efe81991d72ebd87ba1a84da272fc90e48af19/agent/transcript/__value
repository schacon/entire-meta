lsBranchName)\\n\\tpushTrailsSpan.RecordError(err)\\n\\tpushTrailsSpan.End()\\n\\treturn err\\n}\\n\",\"numLines\":42,\"startLine\":1,\"totalLines\":42}},\"sourceToolAssistantUUID\":\"483fd6f3-7e7e-4d42-8db9-15739bda3643\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"9191cbda-fdd5-41ea-8c6a-d8e7fa6d3b23\",\"version\":\"2.1.74\",\"gitBranch\":\"soph/add-support-for-different-remote-for-checkpoints\",\"slug\":\"woolly-exploring-pond\"}\n{\"parentUuid\":\"ebf0577d-b041-42d6-ada4-961a1b6d3170\",\"isSidechain\":false,\"message\":{\"model\":\"claude-opus-4-6\",\"id\":\"msg_01QxZcNqQgXq1pVufxCKhxTM\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_016WQKCbZR6NtvfnLUXtGDqL\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/strategy/checkpoint_remote.go\"},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":1,\"cache_creation_input_tokens\":4905,\"cache_read_input_tokens\":47473,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":4905},\"output_tokens\":8,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"}},\"requestId\":\"req_011CYyA4yApS2XEeUepBMvS5\",\"type\":\"assistant\",\"uuid\":\"617b8ee8-7d3a-4843-b2ba-b77ce4090556\",\"timestamp\":\"2026-03-12T12:06:39.179Z\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"9191cbda-fdd5-41ea-8c6a-d8e7fa6d3b23\",\"version\":\"2.1.74\",\"gitBranch\":\"soph/add-support-for-different-remote-for-checkpoints\",\"slug\":\"woolly-exploring-pond\"}\n{\"parentUuid\":\"617b8ee8-7d3a-4843-b2ba-b77ce4090556\",\"isSidechain\":false,\"type\":\"progress\",\"data\":{\"type\":\"hook_progress\",\"hookEvent\":\"PostToolUse\",\"hookName\":\"PostToolUse:Read\",\"command\":\"callback\"},\"parentToolUseID\":\"toolu_016WQKCbZR6NtvfnLUXtGDqL\",\"toolUseID\":\"toolu_016WQKCbZR6NtvfnLUXtGDqL\",\"timestamp\":\"2026-03-12T12:06:39.191Z\",\"uuid\":\"ec6217a8-a0c0-4750-9d44-b60e2f7f06ef\",\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"9191cbda-fdd5-41ea-8c6a-d8e7fa6d3b23\",\"version\":\"2.1.74\",\"gitBranch\":\"soph/add-support-for-different-remote-for-checkpoints\",\"slug\":\"woolly-exploring-pond\"}\n{\"parentUuid\":\"617b8ee8-7d3a-4843-b2ba-b77ce4090556\",\"isSidechain\":false,\"promptId\":\"5f019439-b9dc-471b-9605-0e8e663f0013\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_016WQKCbZR6NtvfnLUXtGDqL\",\"type\":\"tool_result\",\"content\":\"     1→package strategy\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"fmt\\\"\\n     6→\\t\\\"log/slog\\\"\\n     7→\\t\\\"net/url\\\"\\n     8→\\t\\\"os\\\"\\n     9→\\t\\\"os/exec\\\"\\n    10→\\t\\\"strings\\\"\\n    11→\\t\\\"time\\\"\\n    12→\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    14→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    15→\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n    16→\\n    17→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    18→)\\n    19→\\n    20→// checkpointRemoteFetchTimeout is the timeout for fetching branches from the checkpoint URL.\\n    21→const checkpointRemoteFetchTimeout = 30 * time.Second\\n    22→\\n    23→// Git remote protocol identifiers.\\n    24→const (\\n    25→\\tprotocolSSH   = \\\"ssh\\\"\\n    26→\\tprotocolHTTPS = \\\"https\\\"\\n    27→)\\n    28→\\n    29→// pushSettings holds the resolved push configuration from a single settings load.\\n    30→type pushSettings struct {\\n    31→\\t// remote is the git remote name to use for pushing (the user's push remote).\\n    32→\\tremote string\\n    33→\\t// checkpointURL is the derived URL for pushing checkpoint branches.\\n    34→\\t// When set, checkpoint/trails branches are pushed directly to this URL\\n    35→\\t// instead of the remote name. Empty means use the remote name.\\n    36→\\tcheckpointURL string\\n    37→\\t// pushDisabled is true if push_sessions is explicitly set to false.\\n    38→\\tpushDisabled bool\\n    39→}\\n    40→\\n    41→// pushTarget returns the target to use for git push/fetch commands for checkpoint branches.\\n    42→// If a checkpoint URL is configured, returns that; otherwise returns the remote name.\\n    43→func (ps *pushSettings) pushTarget() string {\\n    44→\\tif ps.checkpointURL != \\\"\\\" {\\n    45→\\t\\treturn ps.checkpointURL\\n    46→\\t}\\n    47→\\treturn ps.remote\\n    48→}\\n    49→\\n    50→// hasCheckpointURL returns true if a dedicated checkpoint URL is configured.\\n    51→func (ps *pushSettings) hasCheckpointURL() bool {\\n    52→\\treturn ps.checkpointURL != \\\"\\\"\\n    53→}\\n    54→\\n    55→// resolvePushSettings loads settings once and returns the resolved push config.\\n    56→// If a structured checkpoint_remote is configured (e.g., {\\\"provider\\\": \\\"github\\\", \\\"repo\\\": \\\"org/repo\\\"}):\\n    57→//   - Derives the checkpoint URL from the push remote's protocol (SSH vs HTTPS)\\n    58→//   - Skips if the push remote owner differs from the checkpoint repo owner (fork detection)\\n    59→//   - If a checkpoint branch doesn't exist locally, attempts to fetch it from the URL\\n    60→//\\n    61→// The push itself handles failures gracefully (doPushBranch warns and continues),\\n    62→// so no reachability check is needed here.\\n    63→func resolvePushSettings(ctx context.Context, pushRemoteName string) pushSettings {\\n    64→\\ts, err := settings.Load(ctx)\\n    65→\\tif err != nil {\\n    66→\\t\\treturn pushSettings{remote: pushRemoteName}\\n    67→\\t}\\n    68→\\n    69→\\tps := pushSettings{\\n    70→\\t\\tremote:       pushRemoteName,\\n    71→\\t\\tpushDisabled: s.IsPushSessionsDisabled(),\\n    72→\\t}\\n    73→\\n    74→\\tconfig := s.GetCheckpointRemote()\\n    75→\\tif config == nil {\\n    76→\\t\\treturn ps\\n    77→\\t}\\n    78→\\n    79→\\t// Get the push remote URL for protocol detection and fork detection\\n    80→\\tpushRemoteURL, err := getRemoteURL(ctx, pushRemoteName)\\n    81→\\tif err != nil {\\n    82→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: could not get push remote URL, skipping\\\",\\n    83→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n    84→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    85→\\t\\t)\\n    86→\\t\\treturn ps\\n    87→\\t}\\n    88→\\n    89→\\t// Parse the push remote URL once for both fork detection and URL derivation\\n    90→\\tpushInfo, err := parseGitRemoteURL(pushRemoteURL)\\n    91→\\tif err != nil {\\n    92→\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: could not parse push remote URL\\\",\\n    93→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n    94→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n    95→\\t\\t)\\n    96→\\t\\treturn ps\\n    97→\\t}\\n    98→\\n    99→\\t// Fork detection: compare owners\\n   100→\\tcheckpointOwner := config.Owner()\\n   101→\\tif pushInfo.owner != \\\"\\\" && checkpointOwner != \\\"\\\" && !strings.EqualFold(pushInfo.owner, checkpointOwner) {\\n   102→\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: push remote owner differs from checkpoint remote owner, skipping (fork detected)\\\",\\n   103→\\t\\t\\tslog.String(\\\"push_owner\\\", pushInfo.owner),\\n   104→\\t\\t\\tslog.String(\\\"checkpoint_owner\\\", checkpointOwner),\\n   105→\\t\\t)\\n   106→\\t\\treturn ps\\n   107→\\t}\\n   108→\\n   109→\\t// Derive checkpoint URL using same protocol as push remote\\n   110→\\tcheckpointURL, err := deriveCheckpointURLFromInfo(pushInfo, config)\\n   111→\\tif err != nil {\\n   112→\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: could not derive URL from push remote\\\",\\n   113→\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n   114→\\t\\t\\tslog.String(\\\"repo\\\", config.Repo),\\n   115→\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   116→\\t\\t)\\n   117→\\t\\treturn ps\\n   118→\\t}\\n   119→\\n   120→\\tps.checkpointURL = checkpointURL\\n   121→\\n   122→\\t// If checkpoint branches don't exist locally, try to fetch them from the URL.\\n   123→\\t// This is a one-time operation per branch — once the branch exists locally,\\n   124→\\t// subsequent pushes skip the fetch entirely.\\n   125→\\tfor _, branchName := range []string{paths.MetadataBranchName, paths.TrailsBranchName} {\\n   126→\\t\\tif err := fetchBranchIfMissing(ctx, checkpointURL, branchName); err != nil {\\n   127→\\t\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: failed to fetch branch\\\",\\n   128→\\t\\t\\t\\tslog.String(\\\"branch\\\", branchName),\\n   129→\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n   130→\\t\\t\\t)\\n   131→\\t\\t}\\n   132→\\t}\\n   133→\\n   134→\\treturn ps\\n   135→}\\n   136→\\n   137→// gitRemoteInfo holds parsed components of a git remote URL.\\n   138→type gitRemoteInfo struct {\\n   139→\\tprotocol string // \\\"ssh\\\" or \\\"https\\\"\\n   140→\\thost     string // e.g., \\\"github.com\\\"\\n   141→\\towner    string // e.g., \\\"org\\\"\\n   142→\\trepo     string // e.g., \\\"my-repo\\\" (without .git)\\n   143→}\\n   144→\\n   145→// parseGitRemoteURL parses a git remote URL into its components.\\n   146→// Supports:\\n   147→//   - SSH SCP format: git@github.com:org/repo.git\\n   148→//   - HTTPS format: https://github.com/org/repo.git\\n   149→//   - SSH protocol format: ssh://git@github.com/org/repo.git\\n   150→func parseGitRemoteURL(rawURL string) (*gitRemoteInfo, error) {\\n   151→\\trawURL = strings.TrimSpace(rawURL)\\n   152→\\n   153→\\t// SSH SCP format: git@github.com:org/repo.git\\n   154→\\tif strings.Contains(rawURL, \\\":\\\") && !strings.Contains(rawURL, \\\"://\\\") {\\n   155→\\t\\t// Split on the first \\\":\\\"\\n   156→\\t\\tparts := strings.SplitN(rawURL, \\\":\\\", 2)\\n   157→\\t\\tif len(parts) != 2 {\\n   158→\\t\\t\\treturn nil, fmt.Errorf(\\\"invalid SSH URL: %s\\\", redactURL(rawURL))\\n   159→\\t\\t}\\n   160→\\t\\thostPart := parts[0] // e.g., \\\"git@github.com\\\"\\n   161→\\t\\tpathPart := parts[1] // e.g., \\\"org/repo.git\\\"\\n   162→\\n   163→\\t\\thost := hostPart\\n   164→\\t\\tif idx := strings.Index(host, \\\"@\\\"); idx >= 0 {\\n   165→\\t\\t\\thost = host[idx+1:]\\n   166→\\t\\t}\\n   167→\\n   168→\\t\\towner, repo, err := splitOwnerRepo(pathPart)\\n   169→\\t\\tif err != nil {\\n   170→\\t\\t\\treturn nil, err\\n   171→\\t\\t}\\n   172→\\n   173→\\t\\treturn &gitRemoteInfo{protocol: protocolSSH, host: host, owner: owner, repo: repo}, nil\\n   174→\\t}\\n   175→\\n   176→\\t// URL format: https://github.com/org/repo.git or ssh://git@github.com/org/repo.git\\n   177→\\tu, err := url.Parse(rawURL)\\n   178→\\tif err != nil {\\n   179→\\t\\treturn nil, fmt.Errorf(\\\"invalid URL: %s\\\", redactURL(rawURL))\\n   180→\\t}\\n   181→\\n   182→\\tprotocol := u.Scheme\\n   183→\\tif protocol == \\\"\\\" {\\n   184→\\t\\treturn nil, fmt.Errorf(\\\"no protocol in URL: %s\\\", redactURL(rawURL))\\n   185→\\t}\\n   186→\\thost := u.Hostname()\\n   187→\\n   188→\\t// Path is like /org/repo.git — trim leading slash\\n   189→\\tpathPart := strings.TrimPrefix(u.Path, \\\"/\\\")\\n   190→\\towner, repo, err := splitOwnerRepo(pathPart)\\n   191→\\tif err != nil {\\n   192→\\t\\treturn nil, err\\n   193→\\t}\\n   194→\\n   195→\\treturn &gitRemoteInfo{protocol: protocol, host: host, owner: owner, repo: repo}, nil\\n   196→}\\n   197→\\n   198→// splitOwnerRepo splits \\\"org/repo.git\\\" into owner and repo (without .git suffix).\\n   199→func splitOwnerRepo(path string) (string, string, error) {\\n   200→\\tpath = strings.TrimSuffix(path, \\\".git\\\")\\n   201→\\tparts := strings.SplitN(path, \\\"/\\\", 2)\\n   202→\\tif len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n   203→\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot parse owner/repo from path: %s\\\", path)\\n   204→\\t}\\n   205→\\treturn parts[0], parts[1], nil\\n   206→}\\n   207→\\n   208→// deriveCheckpointURL constructs a checkpoint remote URL using the same protocol\\n   209→// as the push remote. For example, if push remote uses SSH, the checkpoint URL\\n   210→// will also use SSH.\\n   211→func deriveCheckpointURL(pushRemoteURL string, config *settings.CheckpointRemoteConfig) (string, error) {\\n   212→\\tinfo, err := parseGitRemoteURL(pushRemoteURL)\\n   213→\\tif err != nil {\\n   214→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"cannot parse push remote URL: %w\\\", err)\\n   215→\\t}\\n   216→\\treturn deriveCheckpointURLFromInfo(info, config)\\n   217→}\\n   218→\\n   219→// deriveCheckpointURLFromInfo constructs a checkpoint URL from already-parsed remote info.\\n   220→func deriveCheckpointURLFromInfo(info *gitRemoteInfo, config *settings.CheckpointRemoteConfig) (string, error) {\\n   221→\\tswitch info.protocol {\\n   222→\\tcase protocolSSH:\\n   223→\\t\\t// SCP format: git@host:owner/repo.git\\n   224→\\t\\treturn fmt.Sprintf(\\\"git@%s:%s.git\\\", info.host, config.Repo), nil\\n   225→\\tcase protocolHTTPS:\\n   226→\\t\\treturn fmt.Sprintf(\\\"https://%s/%s.git\\\", info.host, config.Repo), nil\\n   227→\\tdefault:\\n   228→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unsupported protocol %q in push remote\\\", info.protocol)\\n   229→\\t}\\n   230→}\\n   231→\\n   232→// extractOwnerFromRemoteURL extracts the owner from a git remote URL.\\n   233→// Returns empty string if the URL cannot be parsed.\\n   234→func extractOwnerFromRemoteURL(rawURL string) string {\\n   235→\\tinfo, err := parseGitRemoteURL(rawURL)\\n   236→\\tif err != nil {\\n   237→\\t\\treturn \\\"\\\"\\n   238→\\t}\\n   239→\\treturn info.owner\\n   240→}\\n   241→\\n   242→// getRemoteURL returns the URL configured for a git remote.\\n   243→func getRemoteURL(ctx context.Context, remoteName string) (string, error) {\\n   244→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"get-url\\\", remoteName)\\n   245→\\toutput, err := cmd.Output()\\n   246→\\tif err != nil {\\n   247→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"remote %q not found\\\", remoteName)\\n   248→\\t}\\n   249→\\treturn strings.TrimSpace(string(output)), nil\\n   250→}\\n   251→\\n   252→// redactURL removes credentials from a URL for safe logging.\\n   253→// Handles both HTTPS URLs with embedded credentials and general URLs.\\n   254→func redactURL(rawURL string) string {\\n   255→\\tu, err := url.Parse(rawURL)\\n   256→\\tif err != nil {\\n   257→\\t\\t// For non-URL formats (SSH SCP), just return the host portion\\n   258→\\t\\tif idx := strings.Index(rawURL, \\\"@\\\"); idx >= 0 {\\n   259→\\t\\t\\tif colonIdx := strings.Index(rawURL[idx:], \\\":\\\"); colonIdx >= 0 {\\n   260→\\t\\t\\t\\treturn rawURL[idx+1:idx+colonIdx] + \\\":***\\\"\\n   261→\\t\\t\\t}\\n   262→\\t\\t}\\n   263→\\t\\treturn \\\"<unparseable>\\\"\\n   264→\\t}\\n   265→\\tu.User = nil\\n   266→\\tu.RawQuery = \\\"\\\"\\n   267→\\thost := u.Host\\n   268→\\tpath := u.Path\\n   269→\\treturn u.Scheme + \\\"://\\\" + host + path\\n   270→}\\n   271→\\n   272→// fetchBranchIfMissing fetches a branch from a URL only if it doesn't exist locally.\\n   273→// This avoids network calls on every push — once the branch exists locally, this is a no-op.\\n   274→// Fetch failures are silently swallowed (returns nil): the push will handle creating the\\n   275→// branch on the remote. Only fatal errors (opening repo, creating local branch) are returned.\\n   276→func fetchBranchIfMissing(ctx context.Context, remoteURL, branchName string) error {\\n   277→\\trepo, err := OpenRepository(ctx)\\n   278→\\tif err != nil {\\n   279→\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   280→\\t}\\n   281→\\n   282→\\t// Check if branch already exists locally - if so, nothing to do\\n   283→\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n   284→\\tif _, err := repo.Reference(branchRef, true); err == nil {\\n   285→\\t\\treturn nil // Branch exists locally, skip fetch\\n   286→\\t}\\n   287→\\n   288→\\t// Branch doesn't exist locally - try to fetch it from the URL.\\n   289→\\t// Fetch to a temp ref to avoid polluting the remote-tracking namespace.\\n   290→\\tfetchCtx, cancel := context.WithTimeout(ctx, checkpointRemoteFetchTimeout)\\n   291→\\tdefer cancel()\\n   292→\\n   293→\\ttmpRef := \\\"refs/entire-fetch-tmp/\\\" + branchName\\n   294→\\trefSpec := fmt.Sprintf(\\\"+refs/heads/%s:%s\\\", branchName, tmpRef)\\n   295→\\tfetchCmd := exec.CommandContext(fetchCtx, \\\"git\\\", \\\"fetch\\\", \\\"--no-tags\\\", remoteURL, refSpec)\\n   296→\\tfetchCmd.Stdin = nil\\n   297→\\tfetchCmd.Env = append(os.Environ(),\\n   298→\\t\\t\\\"GIT_TERMINAL_PROMPT=0\\\", // Prevent interactive auth prompts\\n   299→\\t)\\n   300→\\tif err := fetchCmd.Run(); err != nil {\\n   301→\\t\\t// Fetch failed - remote may be unreachable or branch doesn't exist there yet.\\n   302→\\t\\t// Not fatal: push will create it on the remote when it succeeds.\\n   303→\\t\\treturn nil\\n   304→\\t}\\n   305→\\n   306→\\t// Fetch succeeded - create local branch from the fetched ref\\n   307→\\tfetchedRef, err := repo.Reference(plumbing.ReferenceName(tmpRef), true)\\n   308→\\tif err != nil {\\n   309→\\t\\t// Fetch succeeded but ref not found - branch may not exist on remote\\n   310→\\t\\treturn nil\\n   311→\\t}\\n   312→\\n   313→\\tnewRef := plumbing.NewHashReference(branchRef, fetchedRef.Hash())\\n   314→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   315→\\t\\treturn fmt.Errorf(\\\"failed to create local branch from fetched ref: %w\\\", err)\\n   316→\\t}\\n   317→\\n   318→\\t// Clean up the temp ref (best-effort, not critical if it fails)\\n   319→\\t_ = repo.Storer.RemoveReference(plumbing.ReferenceName(tmpRef)) //nolint:errcheck // cleanup is best-effort\\n   320→\\n   321→\\tlogging.Info(ctx, \\\"checkpoint-remote: fetched branch from URL\\\",\\n   322→\\t\\tslog.String(\\\"branch\\\", branchName),\\n   323→\\t)\\n   324→\\treturn nil\\n   325→}\\n   326→\"}]},\"uuid\":\"ffb00fc1-75f9-4d89-a65d-391d0ab5c53e\",\"timestamp\":\"2026-03-12T12:06:39.191Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/strategy/checkpoint_remote.go\",\"content\":\"package strategy\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"net/url\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/settings\\\"\\n\\n\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n)\\n\\n// checkpointRemoteFetchTimeout is the timeout for fetching branches from the checkpoint URL.\\nconst checkpointRemoteFetchTimeout = 30 * time.Second\\n\\n// Git remote protocol identifiers.\\nconst (\\n\\tprotocolSSH   = \\\"ssh\\\"\\n\\tprotocolHTTPS = \\\"https\\\"\\n)\\n\\n// pushSettings holds the resolved push configuration from a single settings load.\\ntype pushSettings struct {\\n\\t// remote is the git remote name to use for pushing (the user's push remote).\\n\\tremote string\\n\\t// checkpointURL is the derived URL for pushing checkpoint branches.\\n\\t// When set, checkpoint/trails branches are pushed directly to this URL\\n\\t// instead of the remote name. Empty means use the remote name.\\n\\tcheckpointURL string\\n\\t// pushDisabled is true if push_sessions is explicitly set to false.\\n\\tpushDisabled bool\\n}\\n\\n// pushTarget returns the target to use for git push/fetch commands for checkpoint branches.\\n// If a checkpoint URL is configured, returns that; otherwise returns the remote name.\\nfunc (ps *pushSettings) pushTarget() string {\\n\\tif ps.checkpointURL != \\\"\\\" {\\n\\t\\treturn ps.checkpointURL\\n\\t}\\n\\treturn ps.remote\\n}\\n\\n// hasCheckpointURL returns true if a dedicated checkpoint URL is configured.\\nfunc (ps *pushSettings) hasCheckpointURL() bool {\\n\\treturn ps.checkpointURL != \\\"\\\"\\n}\\n\\n// resolvePushSettings loads settings once and returns the resolved push config.\\n// If a structured checkpoint_remote is configured (e.g., {\\\"provider\\\": \\\"github\\\", \\\"repo\\\": \\\"org/repo\\\"}):\\n//   - Derives the checkpoint URL from the push remote's protocol (SSH vs HTTPS)\\n//   - Skips if the push remote owner differs from the checkpoint repo owner (fork detection)\\n//   - If a checkpoint branch doesn't exist locally, attempts to fetch it from the URL\\n//\\n// The push itself handles failures gracefully (doPushBranch warns and continues),\\n// so no reachability check is needed here.\\nfunc resolvePushSettings(ctx context.Context, pushRemoteName string) pushSettings {\\n\\ts, err := settings.Load(ctx)\\n\\tif err != nil {\\n\\t\\treturn pushSettings{remote: pushRemoteName}\\n\\t}\\n\\n\\tps := pushSettings{\\n\\t\\tremote:       pushRemoteName,\\n\\t\\tpushDisabled: s.IsPushSessionsDisabled(),\\n\\t}\\n\\n\\tconfig := s.GetCheckpointRemote()\\n\\tif config == nil {\\n\\t\\treturn ps\\n\\t}\\n\\n\\t// Get the push remote URL for protocol detection and fork detection\\n\\tpushRemoteURL, err := getRemoteURL(ctx, pushRemoteName)\\n\\tif err != nil {\\n\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: could not get push remote URL, skipping\\\",\\n\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\treturn ps\\n\\t}\\n\\n\\t// Parse the push remote URL once for both fork detection and URL derivation\\n\\tpushInfo, err := parseGitRemoteURL(pushRemoteURL)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: could not parse push remote URL\\\",\\n\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\treturn ps\\n\\t}\\n\\n\\t// Fork detection: compare owners\\n\\tcheckpointOwner := config.Owner()\\n\\tif pushInfo.owner != \\\"\\\" && checkpointOwner != \\\"\\\" && !strings.EqualFold(pushInfo.owner, checkpointOwner) {\\n\\t\\tlogging.Debug(ctx, \\\"checkpoint-remote: push remote owner differs from checkpoint remote owner, skipping (fork detected)\\\",\\n\\t\\t\\tslog.String(\\\"push_owner\\\", pushInfo.owner),\\n\\t\\t\\tslog.String(\\\"checkpoint_owner\\\", checkpointOwner),\\n\\t\\t)\\n\\t\\treturn ps\\n\\t}\\n\\n\\t// Derive checkpoint URL using same protocol as push remote\\n\\tcheckpointURL, err := deriveCheckpointURLFromInfo(pushInfo, config)\\n\\tif err != nil {\\n\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: could not derive URL from push remote\\\",\\n\\t\\t\\tslog.String(\\\"remote\\\", pushRemoteName),\\n\\t\\t\\tslog.String(\\\"repo\\\", config.Repo),\\n\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t)\\n\\t\\treturn ps\\n\\t}\\n\\n\\tps.checkpointURL = checkpointURL\\n\\n\\t// If checkpoint branches don't exist locally, try to fetch them from the URL.\\n\\t// This is a one-time operation per branch — once the branch exists locally,\\n\\t// subsequent pushes skip the fetch entirely.\\n\\tfor _, branchName := range []string{paths.MetadataBranchName, paths.TrailsBranchName} {\\n\\t\\tif err := fetchBranchIfMissing(ctx, checkpointURL, branchName); err != nil {\\n\\t\\t\\tlogging.Warn(ctx, \\\"checkpoint-remote: failed to fetch branch\\\",\\n\\t\\t\\t\\tslog.String(\\\"branch\\\", branchName),\\n\\t\\t\\t\\tslog.String(\\\"error\\\", err.Error()),\\n\\t\\t\\t)\\n\\t\\t}\\n\\t}\\n\\n\\treturn ps\\n}\\n\\n// gitRemoteInfo holds parsed components of a git remote URL.\\ntype gitRemoteInfo struct {\\n\\tprotocol string // \\\"ssh\\\" or \\\"https\\\"\\n\\thost     string // e.g., \\\"github.com\\\"\\n\\towner    string // e.g., \\\"org\\\"\\n\\trepo     string // e.g., \\\"my-repo\\\" (without .git)\\n}\\n\\n// parseGitRemoteURL parses a git remote URL into its components.\\n// Supports:\\n//   - SSH SCP format: git@github.com:org/repo.git\\n//   - HTTPS format: https://github.com/org/repo.git\\n//   - SSH protocol format: ssh://git@github.com/org/repo.git\\nfunc parseGitRemoteURL(rawURL string) (*gitRemoteInfo, error) {\\n\\trawURL = strings.TrimSpace(rawURL)\\n\\n\\t// SSH SCP format: git@github.com:org/repo.git\\n\\tif strings.Contains(rawURL, \\\":\\\") && !strings.Contains(rawURL, \\\"://\\\") {\\n\\t\\t// Split on the first \\\":\\\"\\n\\t\\tparts := strings.SplitN(rawURL, \\\":\\\", 2)\\n\\t\\tif len(parts) != 2 {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"invalid SSH URL: %s\\\", redactURL(rawURL))\\n\\t\\t}\\n\\t\\thostPart := parts[0] // e.g., \\\"git@github.com\\\"\\n\\t\\tpathPart := parts[1] // e.g., \\\"org/repo.git\\\"\\n\\n\\t\\thost := hostPart\\n\\t\\tif idx := strings.Index(host, \\\"@\\\"); idx >= 0 {\\n\\t\\t\\thost = host[idx+1:]\\n\\t\\t}\\n\\n\\t\\towner, repo, err := splitOwnerRepo(pathPart)\\n\\t\\tif err != nil {\\n\\t\\t\\treturn nil, err\\n\\t\\t}\\n\\n\\t\\treturn &gitRemoteInfo{protocol: protocolSSH, host: host, owner: owner, repo: repo}, nil\\n\\t}\\n\\n\\t// URL format: https://github.com/org/repo.git or ssh://git@github.com/org/repo.git\\n\\tu, err := url.Parse(rawURL)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"invalid URL: %s\\\", redactURL(rawURL))\\n\\t}\\n\\n\\tprotocol := u.Scheme\\n\\tif protocol == \\\"\\\" {\\n\\t\\treturn nil, fmt.Errorf(\\\"no protocol in URL: %s\\\", redactURL(rawURL))\\n\\t}\\n\\thost := u.Hostname()\\n\\n\\t// Path is like /org/repo.git — trim leading slash\\n\\tpathPart := strings.TrimPrefix(u.Path, \\\"/\\\")\\n\\towner, repo, err := splitOwnerRepo(pathPart)\\n\\tif err != nil {\\n\\t\\treturn nil, err\\n\\t}\\n\\n\\treturn &gitRemoteInfo{protocol: protocol, host: host, owner: owner, repo: repo}, nil\\n}\\n\\n// splitOwnerRepo splits \\\"org/repo.git\\\" into owner and repo (without .git suffix).\\nfunc splitOwnerRepo(path string) (string, string, error) {\\n\\tpath = strings.TrimSuffix(path, \\\".git\\\")\\n\\tparts := strings.SplitN(path, \\\"/\\\", 2)\\n\\tif len(parts) != 2 || parts[0] == \\\"\\\" || parts[1] == \\\"\\\" {\\n\\t\\treturn \\\"\\\", \\\"\\\", fmt.Errorf(\\\"cannot parse owner/repo from path: %s\\\", path)\\n\\t}\\n\\treturn parts[0], parts[1], nil\\n}\\n\\n// deriveCheckpointURL constructs a checkpoint remote URL using the same protocol\\n// as the push remote. For example, if push remote uses SSH, the checkpoint URL\\n// will also use SSH.\\nfunc deriveCheckpointURL(pushRemoteURL string, config *settings.CheckpointRemoteConfig) (string, error) {\\n\\tinfo, err := parseGitRemoteURL(pushRemoteURL)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"cannot parse push remote URL: %w\\\", err)\\n\\t}\\n\\treturn deriveCheckpointURLFromInfo(info, config)\\n}\\n\\n// deriveCheckpointURLFromInfo constructs a checkpoint URL from already-parsed remote info.\\nfunc deriveCheckpointURLFromInfo(info *gitRemoteInfo, config *settings.CheckpointRemoteConfig) (string, error) {\\n\\tswitch info.protocol {\\n\\tcase protocolSSH:\\n\\t\\t// SCP format: git@host:owner/repo.git\\n\\t\\treturn fmt.Sprintf(\\\"git@%s:%s.git\\\", info.host, config.Repo), nil\\n\\tcase protocolHTTPS:\\n\\t\\treturn fmt.Sprintf(\\\"https://%s/%s.git\\\", info.host, config.Repo), nil\\n\\tdefault:\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"unsupported protocol %q in push remote\\\", info.protocol)\\n\\t}\\n}\\n\\n// extractOwnerFromRemoteURL extracts the owner from a git remote URL.\\n// Returns empty string if the URL cannot be parsed.\\nfunc extractOwnerFromRemoteURL(rawURL string) string {\\n\\tinfo, err := parseGitRemoteURL(rawURL)\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\"\\n\\t}\\n\\treturn info.owner\\n}\\n\\n// getRemoteURL returns the URL configured for a git remote.\\nfunc getRemoteURL(ctx context.Context, remoteName string) (string, error) {\\n\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"remote\\\", \\\"get-url\\\", remoteName)\\n\\toutput, err := cmd.Output()\\n\\tif err != nil {\\n\\t\\treturn \\\"\\\", fmt.Errorf(\\\"remote %q not found\\\", remoteName)\\n\\t}\\n\\treturn strings.TrimSpace(string(output)), nil\\n}\\n\\n// redactURL removes credentials from a URL for safe logging.\\n// Handles both HTTPS URLs with embedded credentials and general URLs.\\nfunc redactURL(rawURL string) string {\\n\\tu, err := url.Parse(rawURL)\\n\\tif err != nil {\\n\\t\\t// For non-URL formats (SSH SCP), just return the host portion\\n\\t\\tif idx := strings.Index(rawURL, \\\"@\\\"); idx >= 0 {\\n\\t\\t\\tif colonIdx := strings.Index(rawURL[idx:], \\\":\\\"); colonIdx >= 0 {\\n\\t\\t\\t\\treturn rawURL[idx+1:idx+colonIdx] + \\\":***\\\"\\n\\t\\t\\t}\\n\\t\\t}\\n\\t\\treturn \\\"<unparseable>\\\"\\n\\t}\\n\\tu.User = nil\\n\\tu.RawQuery = \\\"\\\"\\n\\thost := u.Host\\n\\tpath := u.Path\\n\\treturn u.Scheme + \\\"://\\\" + host + path\\n}\\n\\n// fetchBranchIfMissing fetches a branch from a URL only if it doesn't exist locally.\\n// This avoids network calls on every push — once the branch exists locally, this is a no-op.\\n// Fetch failures are silently swallowed (returns nil): the push will handle creating the\\n// branch on the remote. Only fatal errors (opening repo, creating local branch) are returned.\\nfunc fetchBranchIfMissing(ctx context.Context, remoteURL, branchName string) error {\\n\\trepo, err := OpenRepository(ctx)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n\\t}\\n\\n\\t// Check if branch already exists locally - if so, nothing to do\\n\\tbranchRef := plumbing.NewBranchReferenceName(branchName)\\n\\tif _, err := repo.Reference(branchRef, true); err == nil {\\n\\t\\treturn nil // Branch exists locally, skip fetch\\n\\t}\\n\\n\\t// Branch doesn't exist locally - try to fetch it from the URL.\\n\\t// Fetch to a temp ref to avoid polluting the remote-tracking namespace.\\n\\tfetchCtx, cancel := context.WithTimeout(ctx, checkpointRemoteFetchTimeout)\\n\\tdefer cancel()\\n\\n\\ttmpRef := \\\"refs/entire-fetch-t