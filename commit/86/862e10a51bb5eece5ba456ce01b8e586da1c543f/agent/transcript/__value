→func parseCopilotHookType(rawHooks map[string]json.RawMessage, hookType string, target *[]CopilotHookEntry) {\\n   256→\\tif data, ok := rawHooks[hookType]; ok {\\n   257→\\t\\t//nolint:errcheck,gosec // Intentionally ignoring parse errors - leave target as nil/empty\\n   258→\\t\\tjson.Unmarshal(data, target)\\n   259→\\t}\\n   260→}\\n   261→\\n   262→// marshalCopilotHookType marshals a hook type back into rawHooks.\\n   263→// If the slice is empty, removes the key from rawHooks.\\n   264→func marshalCopilotHookType(rawHooks map[string]json.RawMessage, hookType string, entries []CopilotHookEntry) {\\n   265→\\tif len(entries) == 0 {\\n   266→\\t\\tdelete(rawHooks, hookType)\\n   267→\\t\\treturn\\n   268→\\t}\\n   269→\\tdata, err := json.Marshal(entries)\\n   270→\\tif err != nil {\\n   271→\\t\\treturn // Silently ignore marshal errors (shouldn't happen)\\n   272→\\t}\\n   273→\\trawHooks[hookType] = data\\n   274→}\\n   275→\\n   276→// hookBashExists checks if a hook with the given bash command already exists.\\n   277→func hookBashExists(entries []CopilotHookEntry, bash string) bool {\\n   278→\\tfor _, entry := range entries {\\n   279→\\t\\tif entry.Bash == bash {\\n   280→\\t\\t\\treturn true\\n   281→\\t\\t}\\n   282→\\t}\\n   283→\\treturn false\\n   284→}\\n   285→\\n   286→// isEntireHook checks if a hook entry's bash command belongs to Entire.\\n   287→func isEntireHook(bash string) bool {\\n   288→\\tfor _, prefix := range entireHookPrefixes {\\n   289→\\t\\tif strings.HasPrefix(bash, prefix) {\\n   290→\\t\\t\\treturn true\\n   291→\\t\\t}\\n   292→\\t}\\n   293→\\treturn false\\n   294→}\\n   295→\\n   296→// hasEntireHook checks if any entry in the slice is an Entire hook.\\n   297→func hasEntireHook(entries []CopilotHookEntry) bool {\\n   298→\\tfor _, entry := range entries {\\n   299→\\t\\tif isEntireHook(entry.Bash) {\\n   300→\\t\\t\\treturn true\\n   301→\\t\\t}\\n   302→\\t}\\n   303→\\treturn false\\n   304→}\\n   305→\\n   306→// remov