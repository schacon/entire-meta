"slug\":\"shiny-herding-gosling\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01P7tQiRmJZB5b7SnQDyEh5m\",\"type\":\"tool_result\",\"content\":\"     1→package copilotcli\\n     2→\\n     3→import (\\n     4→\\t\\\"context\\\"\\n     5→\\t\\\"encoding/json\\\"\\n     6→\\t\\\"fmt\\\"\\n     7→\\t\\\"os\\\"\\n     8→\\t\\\"path/filepath\\\"\\n     9→\\t\\\"strings\\\"\\n    10→\\n    11→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    12→\\t\\\"github.com/entireio/cli/cmd/entire/cli/jsonutil\\\"\\n    13→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    14→)\\n    15→\\n    16→// HooksFileName is the hooks file managed by Entire for Copilot CLI.\\n    17→const HooksFileName = \\\"entire.json\\\"\\n    18→\\n    19→// hooksDir is the directory within the repo where Copilot CLI looks for hook configs.\\n    20→const hooksDir = \\\".github/hooks\\\"\\n    21→\\n    22→// entireHookPrefixes are command prefixes that identify Entire hooks in the bash field.\\n    23→var entireHookPrefixes = []string{\\n    24→\\t\\\"entire \\\",\\n    25→\\t\\\"go run ${COPILOT_PROJECT_DIR}/cmd/entire/main.go \\\",\\n    26→}\\n    27→\\n    28→// hookConfigKey maps our kebab-case hook names to camelCase JSON keys.\\n    29→var hookConfigKey = map[string]string{\\n    30→\\tHookNameUserPromptSubmitted: \\\"userPromptSubmitted\\\",\\n    31→\\tHookNameSessionStart:        \\\"sessionStart\\\",\\n    32→\\tHookNameAgentStop:           \\\"agentStop\\\",\\n    33→\\tHookNameSessionEnd:          \\\"sessionEnd\\\",\\n    34→\\tHookNameSubagentStop:        \\\"subagentStop\\\",\\n    35→\\tHookNamePreToolUse:          \\\"preToolUse\\\",\\n    36→\\tHookNamePostToolUse:         \\\"postToolUse\\\",\\n    37→\\tHookNameErrorOccurred:       \\\"errorOccurred\\\",\\n    38→}\\n    39→\\n    40→// InstallHooks installs Copilot CLI hooks in .github/hooks/entire.json.\\n    41→// If force is true, removes existing Entire hooks before installing.\\n    42→// Returns the number of hooks installed.\\n    43→// Unknown top-level fields and hook types are preserved on round-trip.\\n    44→func (c *CopilotCLIAgent) InstallHooks(ctx context.Context, localDev bool, force bool) (int, error) {\\n    45→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n    46→\\tif err != nil {\\n    47→\\t\\tworktreeRoot = \\\".\\\"\\n    48→\\t}\\n    49→\\n    50→\\thooksPath := filepath.Join(worktreeRoot, hooksDir, HooksFileName)\\n    51→\\n    52→\\t// Use raw maps to preserve unknown fields on round-trip\\n    53→\\tvar rawFile map[string]json.RawMessage\\n    54→\\tvar rawHooks map[string]json.RawMessage\\n    55→\\n    56→\\texistingData, readErr := os.ReadFile(hooksPath) //nolint:gosec // path is constructed from repo root + fixed path\\n    57→\\tif readErr == nil {\\n    58→\\t\\tif err := json.Unmarshal(existingData, &rawFile); err != nil {\\n    59→\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse existing %s: %w\\\", HooksFileName, err)\\n    60→\\t\\t}\\n    61→\\t\\tif hooksRaw, ok := rawFile[\\\"hooks\\\"]; ok {\\n    62→\\t\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n    63→\\t\\t\\t\\treturn 0, fmt.Errorf(\\\"failed to parse hooks in %s: %w\\\", HooksFileName, err)\\n    64→\\t\\t\\t}\\n    65→\\t\\t}\\n    66→\\t\\tif _, ok := rawFile[\\\"version\\\"]; !ok {\\n    67→\\t\\t\\trawFile[\\\"version\\\"] = json.RawMessage(`1`)\\n    68→\\t\\t}\\n    69→\\t} else {\\n    70→\\t\\trawFile = map[string]json.RawMessage{\\n    71→\\t\\t\\t\\\"version\\\": json.RawMessage(`1`),\\n    72→\\t\\t}\\n    73→\\t}\\n    74→\\n    75→\\tif rawHooks == nil {\\n    76→\\t\\trawHooks = make(map[string]json.RawMessage)\\n    77→\\t}\\n    78→\\n    79→\\t// Parse existing entries for each hook type we manage\\n    80→\\thookEntries := make(map[string][]CopilotHookEntry)\\n    81→\\tfor _, hookName := range c.HookNames() {\\n    82→\\t\\tkey := hookConfigKey[hookName]\\n    83→\\t\\tvar entries []CopilotHookEntry\\n    84→\\t\\tparseCopilotHookType(rawHooks, key, &entries)\\n    85→\\t\\thookEntries[hookName] = entries\\n    86→\\t}\\n    87→\\n    88→\\t// If force, remove existing Entire hooks first\\n    89→\\tif force {\\n    90→\\t\\tfor hookName, entries := range hookEntries {\\n    91→\\t\\t\\thookEntries[hookName] = removeEntireHooks(entries)\\n    92→\\t\\t}\\n    93→\\t}\\n    94→\\n    95→\\t// Define command prefix\\n    96→\\tvar cmdPrefix string\\n    97→\\tif localDev {\\n    98→\\t\\tcmdPrefix = \\\"go run ${COPILOT_PROJECT_DIR}/cmd/entire/main.go hooks copilot-cli \\\"\\n    99→\\t} else {\\n   100→\\t\\tcmdPrefix = \\\"entire hooks copilot-cli \\\"\\n   101→\\t}\\n   102→\\n   103→\\tcount := 0\\n   104→\\n   105→\\t// Add hooks that don't already exist\\n   106→\\tfor _, hookName := range c.HookNames() {\\n   107→\\t\\tcmd := cmdPrefix + hookName\\n   108→\\t\\tentries := hookEntries[hookName]\\n   109→\\t\\tif !hookBashExists(entries, cmd) {\\n   110→\\t\\t\\tentries = append(entries, CopilotHookEntry{\\n   111→\\t\\t\\t\\tType:    \\\"command\\\",\\n   112→\\t\\t\\t\\tBash:    cmd,\\n   113→\\t\\t\\t\\tComment: \\\"Entire CLI\\\",\\n   114→\\t\\t\\t})\\n   115→\\t\\t\\thookEntries[hookName] = entries\\n   116→\\t\\t\\tcount++\\n   117→\\t\\t}\\n   118→\\t}\\n   119→\\n   120→\\tif count == 0 {\\n   121→\\t\\treturn 0, nil\\n   122→\\t}\\n   123→\\n   124→\\t// Marshal modified hook types back into rawHooks\\n   125→\\tfor _, hookName := range c.HookNames() {\\n   126→\\t\\tkey := hookConfigKey[hookName]\\n   127→\\t\\tmarshalCopilotHookType(rawHooks, key, hookEntries[hookName])\\n   128→\\t}\\n   129→\\n   130→\\t// Marshal hooks and update raw file\\n   131→\\thooksJSON, err := json.Marshal(rawHooks)\\n   132→\\tif err != nil {\\n   133→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   134→\\t}\\n   135→\\trawFile[\\\"hooks\\\"] = hooksJSON\\n   136→\\n   137→\\t// Write to file\\n   138→\\tif err := os.MkdirAll(filepath.Dir(hooksPath), 0o750); err != nil {\\n   139→\\t\\treturn 0, fmt.Errorf(\\\"failed to create %s directory: %w\\\", hooksDir, err)\\n   140→\\t}\\n   141→\\n   142→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawFile, \\\"\\\", \\\"  \\\")\\n   143→\\tif err != nil {\\n   144→\\t\\treturn 0, fmt.Errorf(\\\"failed to marshal %s: %w\\\", HooksFileName, err)\\n   145→\\t}\\n   146→\\n   147→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   148→\\t\\treturn 0, fmt.Errorf(\\\"failed to write %s: %w\\\", HooksFileName, err)\\n   149→\\t}\\n   150→\\n   151→\\treturn count, nil\\n   152→}\\n   153→\\n   154→// UninstallHooks removes Entire hooks from Copilot CLI's entire.json.\\n   155→// Unknown top-level fields and hook types are preserved on round-trip.\\n   156→func (c *CopilotCLIAgent) UninstallHooks(ctx context.Context) error {\\n   157→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   158→\\tif err != nil {\\n   159→\\t\\tworktreeRoot = \\\".\\\"\\n   160→\\t}\\n   161→\\thooksPath := filepath.Join(worktreeRoot, hooksDir, HooksFileName)\\n   162→\\tdata, err := os.ReadFile(hooksPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   163→\\tif err != nil {\\n   164→\\t\\treturn nil //nolint:nilerr // No hooks file means nothing to uninstall\\n   165→\\t}\\n   166→\\n   167→\\tvar rawFile map[string]json.RawMessage\\n   168→\\tif err := json.Unmarshal(data, &rawFile); err != nil {\\n   169→\\t\\treturn fmt.Errorf(\\\"failed to parse %s: %w\\\", HooksFileName, err)\\n   170→\\t}\\n   171→\\n   172→\\tvar rawHooks map[string]json.RawMessage\\n   173→\\tif hooksRaw, ok := rawFile[\\\"hooks\\\"]; ok {\\n   174→\\t\\tif err := json.Unmarshal(hooksRaw, &rawHooks); err != nil {\\n   175→\\t\\t\\treturn fmt.Errorf(\\\"failed to parse hooks in %s: %w\\\", HooksFileName, err)\\n   176→\\t\\t}\\n   177→\\t}\\n   178→\\tif rawHooks == nil {\\n   179→\\t\\trawHooks = make(map[string]json.RawMessage)\\n   180→\\t}\\n   181→\\n   182→\\t// Parse and remove Entire hooks from each hook type we manage\\n   183→\\tfor _, hookName := range c.HookNames() {\\n   184→\\t\\tkey := hookConfigKey[hookName]\\n   185→\\t\\tvar entries []CopilotHookEntry\\n   186→\\t\\tparseCopilotHookType(rawHooks, key, &entries)\\n   187→\\t\\tentries = removeEntireHooks(entries)\\n   188→\\t\\tmarshalCopilotHookType(rawHooks, key, entries)\\n   189→\\t}\\n   190→\\n   191→\\t// Marshal hooks back (preserving unknown hook types)\\n   192→\\tif len(rawHooks) > 0 {\\n   193→\\t\\thooksJSON, err := json.Marshal(rawHooks)\\n   194→\\t\\tif err != nil {\\n   195→\\t\\t\\treturn fmt.Errorf(\\\"failed to marshal hooks: %w\\\", err)\\n   196→\\t\\t}\\n   197→\\t\\trawFile[\\\"hooks\\\"] = hooksJSON\\n   198→\\t} else {\\n   199→\\t\\tdelete(rawFile, \\\"hooks\\\")\\n   200→\\t}\\n   201→\\n   202→\\t// Write back\\n   203→\\toutput, err := jsonutil.MarshalIndentWithNewline(rawFile, \\\"\\\", \\\"  \\\")\\n   204→\\tif err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to marshal %s: %w\\\", HooksFileName, err)\\n   206→\\t}\\n   207→\\n   208→\\tif err := os.WriteFile(hooksPath, output, 0o600); err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to write %s: %w\\\", HooksFileName, err)\\n   210→\\t}\\n   211→\\treturn nil\\n   212→}\\n   213→\\n   214→// AreHooksInstalled checks if Entire hooks are installed in the Copilot CLI config.\\n   215→func (c *CopilotCLIAgent) AreHooksInstalled(ctx context.Context) bool {\\n   216→\\tworktreeRoot, err := paths.WorktreeRoot(ctx)\\n   217→\\tif err != nil {\\n   218→\\t\\tworktreeRoot = \\\".\\\"\\n   219→\\t}\\n   220→\\thooksPath := filepath.Join(worktreeRoot, hooksDir, HooksFileName)\\n   221→\\tdata, err := os.ReadFile(hooksPath) //nolint:gosec // path is constructed from repo root + fixed path\\n   222→\\tif err != nil {\\n   223→\\t\\treturn false\\n   224→\\t}\\n   225→\\n   226→\\tvar hooksFile CopilotHooksFile\\n   227