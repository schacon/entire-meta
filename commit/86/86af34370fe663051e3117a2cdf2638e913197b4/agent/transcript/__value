FLOW_RUN_ID\\\"\\n    47→\\n    48→      # - name: Notify Slack - triage started\\n    49→      #   if: ${{ env.SLACK_WEBHOOK_URL != '' }}\\n    50→      #   uses: slackapi/slack-github-action@91efab103c0de0a537f72a35f6b8cda0ee76bf0a\\n    51→      #   env:\\n    52→      #     RUN_URL: ${{ github.event.workflow_run.html_url || format('https://github.com/{0}/actions/runs/{1}', github.repository, inputs.run_id) }}\\n    53→      #     RUN_ID: ${{ github.event.workflow_run.id || inputs.run_id }}\\n    54→      #   with:\\n    55→      #     webhook: ${{ env.SLACK_WEBHOOK_URL }}\\n    56→      #     webhook-type: incoming-webhook\\n    57→      #     payload: |\\n    58→      #       {\\n    59→      #         \\\"blocks\\\": [\\n    60→      #           {\\n    61→      #             \\\"type\\\": \\\"section\\\",\\n    62→      #             \\\"text\\\": {\\n    63→      #               \\\"type\\\": \\\"mrkdwn\\\",\\n    64→      #               \\\"text\\\": \\\":mag: *Claude is triaging E2E failures* from <${{ env.RUN_URL }}|run #${{ env.RUN_ID }}>...\\\"\\n    65→      #             }\\n    66→      #           }\\n    67→      #         ]\\n    68→      #       }\\n    69→\\n    70→      - name: Run triage\\n    71→        env:\\n    72→          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}\\n    73→          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}\\n    74→          WORKFLOW_RUN_ID: ${{ inputs.run_id }}\\n    75→          WORKFLOW_RUN_URL: ${{ format('https://github.com/{0}/actions/runs/{1}', github.repository, inputs.run_id) }}\\n    76→        run: |\\n    77→          ARTIFACT_DIR=\\\"e2e/artifacts/ci-${WORKFLOW_RUN_ID}\\\"\\n    78→          cat <<PROMPT | claude -p \\\\\\n    79→            --model claude-opus-4-6 \\\\\\n    80→            --allowedTools \\\"Read,Glob,Grep,Write,Edit,Bash(mise run test:e2e*),Bash(mise run fmt*),Bash(mise run lint*),Bash(gh workflow run *),Bash(gh run list *),Bash(gh run view *),Bash(gh run download *),Bash(gh pr crea