\\n   346→\\t\\treturn\\n   347→\\t}\\n   348→\\n   349→\\trepoRoot, err := paths.RepoRoot()\\n   350→\\tif err != nil {\\n   351→\\t\\treturn\\n   352→\\t}\\n   353→\\n   354→\\thead := resolveHEAD(repoRoot)\\n   355→\\tif head == \\\"\\\" {\\n   356→\\t\\treturn\\n   357→\\t}\\n   358→\\n   359→\\t// Get changed files from the commit\\n   360→\\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\\n   361→\\tdefer cancel()\\n   362→\\t//nolint:gosec // G204: head is from git rev-parse, not user input\\n   363→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"diff-tree\\\", \\\"--no-commit-id\\\", \\\"--name-status\\\", \\\"-r\\\", head)\\n   364→\\tcmd.Dir = repoRoot\\n   365→\\tout, err := cmd.Output()\\n   366→\\tif err != nil || len(out) == 0 {\\n   367→\\t\\treturn\\n   368→\\t}\\n   369→\\n   370→\\tvar modified, newFiles, deleted []string\\n   371→\\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \\\"\\\\n\\\") {\\n   372→\\t\\tif len(line) < 3 {\\n   373→\\t\\t\\tcontinue\\n   374→\\t\\t}\\n   375→\\t\\tstatus := line[0]\\n   376→\\t\\tfile := strings.TrimSpace(line[1:])\\n   377→\\t\\tswitch status {\\n   378→\\t\\tcase 'M':\\n   379→\\t\\t\\tmodified = append(modified, file)\\n   380→\\t\\tcase 'A':\\n   381→\\t\\t\\tnewFiles = append(newFiles, file)\\n   382→\\t\\tcase 'D':\\n   383→\\t\\t\\tdeleted = append(deleted, file)\\n   384→\\t\\t}\\n   385→\\t}\\n   386→\\n   387→\\tif len(modified)+len(newFiles)+len(deleted) == 0 {\\n   388→\\t\\treturn\\n   389→\\t}\\n   390→\\n   391→\\t// Get commit message\\n   392→\\t//nolint:gosec // G204: head is from git rev-parse, not user input\\n   393→\\tmsgCmd := exec.CommandContext(ctx, \\\"git\\\", \\\"log\\\", \\\"-1\\\", \\\"--format=%B\\\", head)\\n   394→\\tmsgCmd.Dir = repoRoot\\n   395→\\tmsgOut, _ := msgCmd.Output() //nolint:errcheck // best-effort commit message\\n   396→\\tcommitMessage := strings.TrimSpace(string(msgOut))\\n   397→\\n   398→\\tsessionID := strategy.FindMostRecentSession()\\n   399→\\n   400→\\ttriggerWingmanReview(WingmanPayload{\\n   401→\\t\\tSessionID:     sessionID,\\n   402→\\t\\tRepoRoot:      repoRoot,\\n   403→\\t\\tModifiedFiles: modified,\\n   404→\\t\\tNewFiles:      newFiles,\\n   405→\\t\\tDeletedFiles:  deleted,\\n   406→\\t\\tCommitMessage: commitMessage,\\n   407→\\t})\\n   408→}\\n   409→\\n   410→// staleLockThreshold is how old a lock file can be before we consider it stale\\n   411→// (e.g., the detached process was SIGKILLed and the defer never ran).\\n   412→const staleLockThreshold = 30 * time.Minute\\n   413→\\n   414→// acquireWingmanLock atomically creates the lock file. Returns true if acquired.\\n   415→// If the lock already exists but is older than staleLockThreshold, it is removed\\n   416→// and re-acquired (handles crashed detached processes).\\n   417→func acquireWingmanLock(lockPath, sessionID string) bool {\\n   418→\\t//nolint:gosec // G304: lockPath is constructed from repoRoot + constant\\n   419→\\tf, err := os.OpenFile(lockPath, os.O_WRONLY|os.O_CREATE|os.O_EXCL, 0o644)\\n   420→\\tif err != nil {\\n   421→\\t\\tif !errors.Is(err, os.ErrExist) {\\n   422→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Failed to create lock: %v\\\\n\\\", err)\\n   423→\\t\\t\\treturn false\\n   424→\\t\\t}\\n   425→\\t\\t// Lock exists — check if it's stale\\n   426→\\t\\tinfo, statErr := os.Stat(lockPath)\\n   427→\\t\\tif statErr != nil || time.Since(info.ModTime()) <= staleLockThreshold {\\n   428→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Review already in progress, skipping\\\\n\\\")\\n   429→\\t\\t\\treturn false\\n   430→\\t\\t}\\n   431→\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Removing stale lock (age: %s)\\\\n\\\",\\n   432→\\t\\t\\ttime.Since(info.ModTime()).Round(time.Second))\\n   433→\\t\\t_ = os.Remove(lockPath)\\n   434→\\t\\t// Retry the atomic create\\n   435→\\t\\t//nolint:gosec // G304: lockPath is constructed from repoRoot + constant\\n   436→\\t\\tf, err = os.OpenFile(lockPath, os.O_WRONLY|os.O_CREATE|os.O_EXCL, 0o644)\\n   437→\\t\\tif err != nil {\\n   438→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Failed to create lock after stale removal: %v\\\\n\\\", err)\\n   439→\\t\\t\\treturn false\\n   440→\\t\\t}\\n   441→\\t}\\n   442→\\t_, _ = f.WriteString(sessionID) //nolint:errcheck // best-effort session ID write\\n   443→\\t_ = f.Close()\\n   444→\\treturn true\\n   445→}\\n   446→\\n   447→// resolveHEAD returns the current HEAD commit hash, or empty string on error.\\n   448→func resolveHEAD(repoRoot string) string {\\n   449→\\tctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)\\n   450→\\tdefer cancel()\\n   451→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"HEAD\\\")\\n   452→\\tcmd.Dir = repoRoot\\n   453→\\tout, err := cmd.Output()\\n   454→\\tif err != nil {\\n   455→\\t\\treturn \\\"\\\"\\n   456→\\t}\\n   457→\\treturn strings.TrimSpace(string(out))\\n   458→}\\n   459→\\n   460→// computeFilesHash returns a SHA256 hex digest of the sorted file paths.\\n   461→// Uses null byte separator (impossible in filenames) to avoid ambiguity.\\n   462→func computeFilesHash(files []string) string {\\n   463→\\tsorted := make([]string, len(files))\\n   464→\\tcopy(sorted, files)\\n   465→\\tsort.Strings(sorted)\\n   466→\\th := sha256.Sum256([]byte(strings.Join(sorted, \\\"\\\\x00\\\")))\\n   467→\\treturn hex.EncodeToString(h[:])\\n   468→}\\n   469→\\n   470→// loadWingmanState loads the wingman state from .entire/wingman-state.json.\\n   471→func loadWingmanState() (*WingmanState, error) {\\n   472→\\tstatePath, err := paths.AbsPath(wingmanStateFile)\\n   473→\\tif err != nil {\\n   474→\\t\\treturn nil, fmt.Errorf(\\\"resolving wingman state path: %w\\\", err)\\n   475→\\t}\\n   476→\\n   477→\\tdata, err := os.ReadFile(statePath) //nolint:gosec // path is repo-relative\\n   478→\\tif err != nil {\\n   479→\\t\\treturn nil, fmt.Errorf(\\\"reading wingman state: %w\\\", err)\\n   480→\\t}\\n   481→\\n   482→\\tvar state WingmanState\\n   483→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   484→\\t\\treturn nil, fmt.Errorf(\\\"parsing wingman state: %w\\\", err)\\n   485→\\t}\\n   486→\\treturn &state, nil\\n   487→}\\n   488→\\n   489→// saveWingmanState saves the wingman state to .entire/wingman-state.json.\\n   490→func saveWingmanState(state *WingmanState) error {\\n   491→\\tstatePath, err := paths.AbsPath(wingmanStateFile)\\n   492→\\tif err != nil {\\n   493→\\t\\treturn fmt.Errorf(\\\"resolving wingman state path: %w\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\tdir := filepath.Dir(statePath)\\n   497→\\tif err := os.MkdirAll(dir, 0o750); err != nil {\\n   498→\\t\\treturn fmt.Errorf(\\\"creating wingman state directory: %w\\\", err)\\n   499→\\t}\\n   500→\\n   501→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   502→\\tif err != nil {\\n   503→\\t\\treturn fmt.Errorf(\\\"marshaling wingman state: %w\\\", err)\\n   504→\\t}\\n   505→\\n   506→\\t//nolint:gosec // G306: state file is config, not secrets\\n   507→\\tif err := os.WriteFile(statePath, data, 0o644); err != nil {\\n   508→\\t\\treturn fmt.Errorf(\\\"writing wingman state: %w\\\", err)\\n   509→\\t}\\n   510→\\treturn nil\\n   511→}\\n   512→\\n   513→// loadWingmanStateDirect reads the wingman state file directly from a known\\n   514→// path under repoRoot. Returns nil if the file doesn't exist or can't be parsed.\\n   515→func loadWingmanStateDirect(repoRoot string) *WingmanState {\\n   516→\\tstatePath := filepath.Join(repoRoot, wingmanStateFile)\\n   517→\\tdata, err := os.ReadFile(statePath) //nolint:gosec // path is repo-relative constant\\n   518→\\tif err != nil {\\n   519→\\t\\treturn nil\\n   520→\\t}\\n   521→\\tvar state WingmanState\\n   522→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   523→\\t\\treturn nil\\n   524→\\t}\\n   525→\\treturn &state\\n   526→}\\n   527→\\n   528→// newWingmanApplyCmd returns a hidden subcommand used by the stop hook to\\n   529→// apply a pending REVIEW.md via claude --continue in a detached subprocess.\\n   530→func newWingmanApplyCmd() *cobra.Command {\\n   531→\\treturn &cobra.Command{\\n   532→\\t\\tUse:    \\\"__apply\\\",\\n   533→\\t\\tHidden: true,\\n   534→\\t\\tArgs:   cobra.ExactArgs(1),\\n   535→\\t\\tRunE: func(_ *cobra.Command, args []string) error {\\n   536→\\t\\t\\treturn runWingmanApply(args[0])\\n   537→\\t\\t},\\n   538→\\t}\\n   539→}\\n   540→\\n   541→// shouldSkipPendingReview checks whether a pending REVIEW.md should prevent\\n   542→// a new review from being triggered. It cleans up stale/orphaned reviews.\\n   543→//\\n   544→// Returns true only when REVIEW.md exists AND belongs to the current session\\n   545→// AND is younger than wingmanStaleReviewTTL.\\n   546→func shouldSkipPendingReview(repoRoot, currentSessionID string) bool {\\n   547→\\treviewPath := filepath.Join(repoRoot, wingmanReviewFile)\\n   548→\\tif _, err := os.Stat(reviewPath); err != nil {\\n   549→\\t\\treturn false // No REVIEW.md, don't skip\\n   550→\\t}\\n   551→\\n   552→\\t// REVIEW.md exists — check state to determine if it's current or stale\\n   553→\\tstate := loadWingmanStateDirect(repoRoot)\\n   554→\\tif state == nil {\\n   555→\\t\\t// Orphan: REVIEW.md without state file — clean up\\n   556→\\t\\t_ = os.Remove(reviewPath)\\n   557→\\t\\treturn false\\n   558→\\t}\\n   559→\\n   560→\\tif state.SessionID != currentSessionID {\\n   561→\\t\\t// Different session — stale review, clean up\\n   562→\\t\\t_ = os.Remove(reviewPath)\\n   563→\\t\\treturn false\\n   564→\\t}\\n   565→\\n   566→\\tif time.Since(state.ReviewedAt) > wingmanStaleReviewTTL {\\n   567→\\t\\t// Same session but too old — clean up\\n   568→\\t\\t_ = os.Remove(reviewPath)\\n   569→\\t\\treturn false\\n   570→\\t}\\n   571→\\n   572→\\treturn true // Current session, fresh review — skip\\n   573→}\\n   574→\"}]},\"uuid\":\"ae3b5621-692c-4594-85ff-ddfe5f577f