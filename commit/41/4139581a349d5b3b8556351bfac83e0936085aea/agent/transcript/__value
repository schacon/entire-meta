ub.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy()\\n    81→\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n    82→\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n    83→\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    84→\\t\\t}\\n    85→\\t}\\n    86→\\n    87→\\t// Output informational message\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif err := outputHookResponse(message); err != nil {\\n    92→\\t\\treturn err\\n    93→\\t}\\n    94→\\n    95→\\t// Fire EventSessionStart for the current session (if state exists).\\n    96→\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n    97→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n    98→\\t} else if state != nil {\\n    99→\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   100→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n   101→\\t\\t}\\n   102→\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n   103→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\n   107→\\treturn nil\\n   108→}\\n   109→\\n   110→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   111→// ensures strategy setup, initializes session.\\n   112→func handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n   113→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   114→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   115→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   116→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   117→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   118→\\t)\\n   119→\\n   120→\\tsessionID := event.SessionID\\n   121→\\tif sessionID == \\\"\\\" {\\n   122→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   123→\\t}\\n   124→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   125→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   126→\\t}\\n   127→\\n   128→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   129→\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n   130→\\t\\treturn err\\n   131→\\t}\\n   132→\\n   133→\\t// Ensure strategy setup and initialize session\\n   134→\\tstrat := GetStrategy()\\n   135→\\n   136→\\tif err := strat.EnsureSetup(); err != nil {\\n   137→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n   141→\\t\\tagentType := ag.Type()\\n   142→\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n   143→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\treturn nil\\n   148→}\\n   149→\\n   150→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   151→// detects file changes, saves step + checkpoint, transitions phase.\\n   152→//\\n   153→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   154→func handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   155→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   156→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   157→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   158→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   159→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   160→\\t)\\n   161→\\n   162→\\tsessionID := event.SessionID\\n   163→\\tif sessionID == \\\"\\\" {\\n   164→\\t\\tsessionID = unknownSessionID\\n   165→\\t}\\n   166→\\n   167→\\ttranscriptRef := event.SessionRef\\n   168→\\tif transcriptRef == \\\"\\\" {\\n   169→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   170→\\t}\\n   171→\\tif !fileExists(transcriptRef) {\\n   172→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   173→\\t}\\n   174→\\n   175→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   176→\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   177→\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   178→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   179→\\t}\\n   180→\\n   181→\\t// Create session metadata directory\\n   182→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   183→\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n   184→\\tif err != nil {\\n   185→\\t\\tsessionDirAbs = sessionDir\\n   186→\\t}\\n   187→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   188→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   189→\\t}\\n   190→\\n   191→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   192→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   193→\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n   194→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Copy transcript to session directory\\n   199→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   202→\\t}\\n   203→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   204→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n   208→\\n   209→\\t// Load pre-prompt state (captured on TurnStart)\\n   210→\\tpreState, err := LoadPrePromptState(sessionID)\\n   211→\\tif err != nil {\\n   212→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n   213→\\t}\\n   214→\\n   215→\\t// Determine transcript offset\\n   216→\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n   217→\\n   218→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   219→\\tvar allPrompts []string\\n   220→\\tvar summary string\\n   221→\\tvar modifiedFiles []string\\n   222→\\tvar newTranscriptPosition int\\n   223→\\n   224→\\t// Compute subagents directory for agents that support subagent extraction.\\n   225→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   226→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   227→\\n   228→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   229→\\t\\t// Extract prompts\\n   230→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   231→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n   232→\\t\\t} else {\\n   233→\\t\\t\\tallPrompts = prompts\\n   234→\\t\\t}\\n   235→\\n   236→\\t\\t// Extract summary\\n   237→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   238→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   239→\\t\\t} else {\\n   240→\\t\\t\\tsummary = s\\n   241→\\t\\t}\\n   242→\\n   243→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   244→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   245→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n   246→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   247→\\t\\t\\t} else {\\n   248→\\t\\t\\t\\tmodifiedFiles = files\\n   249→\\t\\t\\t}\\n   250→\\t\\t\\t// Get position from basic analyzer\\n   251→\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n   252→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   253→\\t\\t\\t}\\n   254→\\t\\t} else {\\n   255→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   256→\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   257→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   258→\\t\\t\\t} else {\\n   259→\\t\\t\\t\\tmodifiedFiles = files\\n   260→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   261→\\t\\t\\t}\\n   262→\\t\\t}\\n   263→\\t}\\n   264→\\n   265→\\t// Write prompts file\\n   266→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   267→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   268→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   269→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   270→\\t}\\n   271→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   272→\\n   273→\\t// Write summary file\\n   274→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   275→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   276→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   277→\\t}\\n   278→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   279→\\n   280→\\t// Generate commit message from last prompt\\n   281→\\tlastPrompt := \\\"\\\"\\n   282→\\tif len(allPrompts) > 0 {\\n   283→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   284→\\t}\\n   285→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   286→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   287→\\n   288→\\t// Get repo root for path normalization\\n   289→\\trepoRoot, err := paths.RepoRoot()\\n   290→\\tif err != nil {\\n   291→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\tvar preUntrackedFiles []string\\n   295→\\tif preState != nil {\\n   296→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   297→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   298→\\t}\\n   299→\\n   300→\\t// Detect file changes via git status\\n   301→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   302→\\tif err != nil {\\n   303→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   304→\\t}\\n   305→\\n   306→\\t// Filter and normalize all paths\\n   307→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   308→\\tvar relNewFiles, relDeletedFiles []string\\n   309→\\tif changes != nil {\\n   310→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   311→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   312→\\t}\\n   313→\\n   314→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   315→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   316→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   317→\\t// if it exists in HEAD with the same content as the working tree.\\n   318→\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   319→\\n   320→\\t// Check if there are any changes\\n   321→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   322→\\tif totalChanges == 0 {\\n   323→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   324→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   325→\\t\\ttransitionSessionTurnEnd(sessionID)\\n   326→\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   327→\\t\\t\\tfmt.Fprintf(os.Stderr, 