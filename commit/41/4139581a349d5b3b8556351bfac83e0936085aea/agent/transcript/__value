o:embed wingman_instruction.md\\n    48→var wingmanApplyInstruction string\\n    49→\\n    50→const (\\n    51→\\twingmanStateFile  = \\\".entire/wingman-state.json\\\"\\n    52→\\twingmanReviewFile = \\\".entire/REVIEW.md\\\"\\n    53→\\twingmanLockFile   = \\\".entire/wingman.lock\\\"\\n    54→\\n    55→\\t// wingmanStaleReviewTTL is the maximum age of a pending REVIEW.md before\\n    56→\\t// it's considered stale and automatically cleaned up.\\n    57→\\twingmanStaleReviewTTL = 1 * time.Hour\\n    58→)\\n    59→\\n    60→func newWingmanCmd() *cobra.Command {\\n    61→\\tcmd := &cobra.Command{\\n    62→\\t\\tUse:   \\\"wingman\\\",\\n    63→\\t\\tShort: \\\"Automated code review for agent sessions\\\",\\n    64→\\t\\tLong: `Wingman provides automated code review after agent turns.\\n    65→\\n    66→When enabled, wingman automatically reviews code changes made by agents,\\n    67→writes suggestions to .entire/REVIEW.md, and optionally triggers the agent\\n    68→to apply them.`,\\n    69→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    70→\\t\\t\\treturn cmd.Help()\\n    71→\\t\\t},\\n    72→\\t}\\n    73→\\n    74→\\tcmd.AddCommand(newWingmanEnableCmd())\\n    75→\\tcmd.AddCommand(newWingmanDisableCmd())\\n    76→\\tcmd.AddCommand(newWingmanStatusCmd())\\n    77→\\tcmd.AddCommand(newWingmanReviewCmd())\\n    78→\\tcmd.AddCommand(newWingmanApplyCmd())\\n    79→\\n    80→\\treturn cmd\\n    81→}\\n    82→\\n    83→func newWingmanEnableCmd() *cobra.Command {\\n    84→\\tvar useLocal bool\\n    85→\\n    86→\\tcmd := &cobra.Command{\\n    87→\\t\\tUse:   \\\"enable\\\",\\n    88→\\t\\tShort: \\\"Enable wingman auto-review\\\",\\n    89→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n    90→\\t\\t\\tif _, err := paths.RepoRoot(); err != nil {\\n    91→\\t\\t\\t\\tfmt.Fprintln(cmd.ErrOrStderr(), \\\"Not a git repository. Please run from within a git repository.\\\")\\n    92→\\t\\t\\t\\treturn NewSilentError(errors.New(\\\"not a git repository