hort: \\\"Disable wingman auto-review\\\",\\n   141→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   142→\\t\\t\\ts, err := loadSettingsTarget(useLocal)\\n   143→\\t\\t\\tif err != nil {\\n   144→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   145→\\t\\t\\t}\\n   146→\\n   147→\\t\\t\\tif s.StrategyOptions == nil {\\n   148→\\t\\t\\t\\ts.StrategyOptions = make(map[string]any)\\n   149→\\t\\t\\t}\\n   150→\\t\\t\\ts.StrategyOptions[\\\"wingman\\\"] = map[string]any{\\\"enabled\\\": false}\\n   151→\\n   152→\\t\\t\\tif err := saveSettingsTarget(s, useLocal); err != nil {\\n   153→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to save settings: %w\\\", err)\\n   154→\\t\\t\\t}\\n   155→\\n   156→\\t\\t\\t// Clean up pending review file if it exists\\n   157→\\t\\t\\treviewPath, err := paths.AbsPath(wingmanReviewFile)\\n   158→\\t\\t\\tif err == nil {\\n   159→\\t\\t\\t\\t_ = os.Remove(reviewPath)\\n   160→\\t\\t\\t}\\n   161→\\n   162→\\t\\t\\tmsg := \\\"Wingman disabled.\\\"\\n   163→\\t\\t\\tif useLocal {\\n   164→\\t\\t\\t\\tmsg += \\\" (saved to settings.local.json)\\\"\\n   165→\\t\\t\\t}\\n   166→\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), msg)\\n   167→\\t\\t\\treturn nil\\n   168→\\t\\t},\\n   169→\\t}\\n   170→\\n   171→\\tcmd.Flags().BoolVar(&useLocal, \\\"local\\\", false, \\\"Write to settings.local.json instead of settings.json\\\")\\n   172→\\n   173→\\treturn cmd\\n   174→}\\n   175→\\n   176→// loadSettingsTarget loads settings from the appropriate file based on the --local flag.\\n   177→// When local is true, loads from settings.local.json only (without merging).\\n   178→// When local is false, loads the merged settings (project + local).\\n   179→func loadSettingsTarget(local bool) (*settings.EntireSettings, error) {\\n   180→\\tif !local {\\n   181→\\t\\ts, err := settings.Load()\\n   182→\\t\\tif err != nil {\\n   183→\\t\\t\\treturn nil, fmt.Errorf(\\\"loading settings: %w\\\", err)\\n   184→\\t\\t}\\n   185→\\t\\treturn s, nil\\n   186→\\t}\\n   187→\\tabsPath, err := paths.AbsPath(settings.EntireSettingsLocalFile)\\n   188→\\tif err != nil {\\n   189→\\t\\tabsPath = settings.EntireSettingsLocalFile\\n   190→\\t}\\n   191→\\ts, err := settings.LoadFromFile(absPath)\\n   192→\\tif err != nil {\\n   193→\\t\\treturn nil, fmt.Errorf(\\\"loading local settings: %w\\\", err)\\n   194→\\t}\\n   195→\\treturn s, nil\\n   196→}\\n   197→\\n   198→// saveSettingsTarget saves settings to the appropriate file based on the --local flag.\\n   199→func saveSettingsTarget(s *settings.EntireSettings, local bool) error {\\n   200→\\tif local {\\n   201→\\t\\tif err := settings.SaveLocal(s); err != nil {\\n   202→\\t\\t\\treturn fmt.Errorf(\\\"saving local settings: %w\\\", err)\\n   203→\\t\\t}\\n   204→\\t\\treturn nil\\n   205→\\t}\\n   206→\\tif err := settings.Save(s); err != nil {\\n   207→\\t\\treturn fmt.Errorf(\\\"saving settings: %w\\\", err)\\n   208→\\t}\\n   209→\\treturn nil\\n   210→}\\n   211→\\n   212→func newWingmanStatusCmd() *cobra.Command {\\n   213→\\treturn &cobra.Command{\\n   214→\\t\\tUse:   \\\"status\\\",\\n   215→\\t\\tShort: \\\"Show wingman status\\\",\\n   216→\\t\\tRunE: func(cmd *cobra.Command, _ []string) error {\\n   217→\\t\\t\\ts, err := settings.Load()\\n   218→\\t\\t\\tif err != nil {\\n   219→\\t\\t\\t\\treturn fmt.Errorf(\\\"failed to load settings: %w\\\", err)\\n   220→\\t\\t\\t}\\n   221→\\n   222→\\t\\t\\tif s.IsWingmanEnabled() {\\n   223→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Wingman: enabled\\\")\\n   224→\\t\\t\\t} else {\\n   225→\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Wingman: disabled\\\")\\n   226→\\t\\t\\t}\\n   227→\\n   228→\\t\\t\\t// Show last review info if available\\n   229→\\t\\t\\tstate, err := loadWingmanState()\\n   230→\\t\\t\\tif err == nil && state != nil {\\n   231→\\t\\t\\t\\tfmt.Fprintf(cmd.OutOrStdout(), \\\"Last review: %s\\\\n\\\", state.ReviewedAt.Format(time.RFC3339))\\n   232→\\t\\t\\t\\tif state.ReviewApplied {\\n   233→\\t\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Status: applied\\\")\\n   234→\\t\\t\\t\\t} else {\\n   235→\\t\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Status: pending\\\")\\n   236→\\t\\t\\t\\t}\\n   237→\\t\\t\\t}\\n   238→\\n   239→\\t\\t\\t// Check for pending REVIEW.md\\n   240→\\t\\t\\treviewPath, err := paths.AbsPath(wingmanReviewFile)\\n   241→\\t\\t\\tif err == nil {\\n   242→\\t\\t\\t\\tif _, statErr := os.Stat(reviewPath); statErr == nil {\\n   243→\\t\\t\\t\\t\\tfmt.Fprintln(cmd.OutOrStdout(), \\\"Pending review: .entire/REVIEW.md\\\")\\n   244→\\t\\t\\t\\t}\\n   245→\\t\\t\\t}\\n   246→\\n   247→\\t\\t\\treturn nil\\n   248→\\t\\t},\\n   249→\\t}\\n   250→}\\n   251→\\n   252→// triggerWingmanReview checks preconditions and spawns the detached review process.\\n   253→func triggerWingmanReview(payload WingmanPayload) {\\n   254→\\t// Prevent infinite recursion: if we're inside a wingman auto-apply,\\n   255→\\t// don't trigger another review. The env var is set by triggerAutoApply.\\n   256→\\tif os.Getenv(\\\"ENTIRE_WINGMAN_APPLY\\\") != \\\"\\\" {\\n   257→\\t\\treturn\\n   258→\\t}\\n   259→\\n   260→\\tlogCtx := logging.WithComponent(context.Background(), \\\"wingman\\\")\\n   261→\\trepoRoot := payload.RepoRoot\\n   262→\\n   263→\\ttotalFiles := len(payload.ModifiedFiles) + len(payload.NewFiles) + len(payload.DeletedFiles)\\n   264→\\tlogging.Info(logCtx, \\\"wingman trigger evaluating\\\",\\n   265→\\t\\tslog.String(\\\"session_id\\\", payload.SessionID),\\n   266→\\t\\tslog.Int(\\\"file_count\\\", totalFiles),\\n   267→\\t)\\n   268→\\n   269→\\t// Check if a pending REVIEW.md already exists for the current session\\n   270→\\tif shouldSkipPendingReview(repoRoot, payload.SessionID) {\\n   271→\\t\\tlogging.Info(logCtx, \\\"wingman skipped: pending review exists for current session\\\")\\n   272→\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Pending review exists, skipping\\\\n\\\")\\n   273→\\t\\treturn\\n   274→\\t}\\n   275→\\n   276→\\t// Atomic lock file prevents concurrent review spawns. O_CREATE|O_EXCL\\n   277→\\t// is atomic on all platforms, avoiding the TOCTOU race of Stat+WriteFile.\\n   278→\\tlockPath := filepath.Join(repoRoot, wingmanLockFile)\\n   279→\\tif !acquireWingmanLock(lockPath, payload.SessionID) {\\n   280→\\t\\tlogging.Info(logCtx, \\\"wingman skipped: review already in progress\\\")\\n   281→\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Review in progress, skipping\\\\n\\\")\\n   282→\\t\\treturn\\n   283→\\t}\\n   284→\\n   285→\\t// Dedup check: compute hash of sorted file paths\\n   286→\\tallFiles := make([]string, 0, len(payload.ModifiedFiles)+len(payload.NewFiles)+len(payload.DeletedFiles))\\n   287→\\tallFiles = append(allFiles, payload.ModifiedFiles...)\\n   288→\\tallFiles = append(allFiles, payload.NewFiles...)\\n   289→\\tallFiles = append(allFiles, payload.DeletedFiles...)\\n   290→\\tfilesHash := computeFilesHash(allFiles)\\n   291→\\n   292→\\tstate, _ := loadWingmanState() //nolint:errcheck // best-effort dedup\\n   293→\\tif state != nil && state.FilesHash == filesHash && state.SessionID == payload.SessionID {\\n   294→\\t\\tlogging.Info(logCtx, \\\"wingman skipped: dedup hash match\\\",\\n   295→\\t\\t\\tslog.String(\\\"files_hash\\\", filesHash[:12]),\\n   296→\\t\\t)\\n   297→\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Already reviewed these changes, skipping\\\\n\\\")\\n   298→\\t\\treturn\\n   299→\\t}\\n   300→\\n   301→\\t// Capture HEAD at trigger time so the detached review diffs against\\n   302→\\t// the correct commit even if HEAD moves during the initial delay.\\n   303→\\tpayload.BaseCommit = resolveHEAD(repoRoot)\\n   304→\\tlogging.Debug(logCtx, \\\"wingman captured base commit\\\",\\n   305→\\t\\tslog.String(\\\"base_commit\\\", payload.BaseCommit),\\n   306→\\t)\\n   307→\\n   308→\\t// Write payload to a temp file instead of passing as a CLI argument,\\n   309→\\t// which can exceed OS argv limits (~128KB Linux, ~256KB