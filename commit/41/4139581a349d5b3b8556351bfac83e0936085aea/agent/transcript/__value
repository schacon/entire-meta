→\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   370→\\t\\t// Fall back to basic token calculation (main transcript only)\\n   371→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   372→\\t\\tif tokenErr != nil {\\n   373→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   374→\\t\\t} else {\\n   375→\\t\\t\\ttokenUsage = usage\\n   376→\\t\\t}\\n   377→\\t}\\n   378→\\n   379→\\t// Build fully-populated step context and delegate to strategy\\n   380→\\tctx := strategy.StepContext{\\n   381→\\t\\tSessionID:                sessionID,\\n   382→\\t\\tModifiedFiles:            relModifiedFiles,\\n   383→\\t\\tNewFiles:                 relNewFiles,\\n   384→\\t\\tDeletedFiles:             relDeletedFiles,\\n   385→\\t\\tMetadataDir:              sessionDir,\\n   386→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   387→\\t\\tCommitMessage:            commitMessage,\\n   388→\\t\\tTranscriptPath:           transcriptRef,\\n   389→\\t\\tAuthorName:               author.Name,\\n   390→\\t\\tAuthorEmail:              author.Email,\\n   391→\\t\\tAgentType:                agentType,\\n   392→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   393→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   394→\\t\\tTokenUsage:               tokenUsage,\\n   395→\\t}\\n   396→\\n   397→\\tif err := strat.SaveStep(ctx); err != nil {\\n   398→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   399→\\t}\\n   400→\\n   401→\\t// Update session state transcript position for auto-commit strategy\\n   402→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   403→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   404→\\t}\\n   405→\\n   406→\\t// Transition session phase and cleanup\\n   407→\\ttransitionSessionTurnEnd(sessionID)\\n   408→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   409→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   410→\\t}\\n   411→\\n   412→\\treturn nil\\n   413→}\\n   414→\\n   415→// handleLifecycleCompaction handles context compaction: saves current progress\\n   416→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   417→// Also resets the transcript offset since the transcript may be truncated.\\n   418→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   419→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   420→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   421→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   422→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   423→\\t)\\n   424→\\n   425→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   426→\\tsessionID := event.SessionID\\n   427→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   428→\\tif loadErr != nil {\\n   429→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   430→\\t}\\n   431→\\tif sessionState != nil {\\n   432→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   433→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   434→\\t\\t}\\n   435→\\n   436→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   437→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   438→\\n   439→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   440→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   441→\\t\\t}\\n   442→\\t}\\n   443→\\n   444→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   445→\\treturn nil\\n   446→}\\n   447→\\n   448→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   449→func handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   450→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   451→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   452→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   453→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   454→\\t)\\n   455→\\n   456→\\tif event.SessionID == \\\"\\\" {\\n   457→\\t\\treturn nil // No session to update\\n   458→\\t}\\n   459→\\n   460→\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   461→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   462→\\t}\\n   463→\\treturn nil\\n   464→}\\n   465→\\n   466→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   467→func handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   468→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   469→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   470→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   471→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   472→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   473→\\t)\\n   474→\\n   475→\\t// Log context\\n   476→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   477→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   478→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   479→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   480→\\n   481→\\t// Capture pre-task state\\n   482→\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   483→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   484→\\t}\\n   485→\\n   486→\\treturn nil\\n   487→}\\n   488→\\n   489→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   490→func handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   491→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   492→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   493→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   494→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   495→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   496→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   497→\\t)\\n   498→\\n   499→\\t// Extract subagent type and description from tool input\\n   500→\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   501→\\n   502→\\t// Determine subagent transcript path\\n   503→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   504→\\tvar subagentTranscriptPath string\\n   505→\\tif event.SubagentID != \\\"\\\" {\\n   506→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   507→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   508→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   509→\\t\\t}\\n   510→\\t}\\n   511→\\n   512→\\t// Log context\\n   513→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   514→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   515→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   516→\\tif event.SubagentID != \\\"\\\" {\\n   517→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   518→\\t}\\n   519→\\tif subagentTranscriptPath != \\\"\\\" {\\n   520→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   521→\\t}\\n   522→\\n   523→\\t// Extract modified files from subagent transcript\\n   524→\\tvar modifiedFiles []string\\n   525→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   526→\\t\\ttranscriptToScan := event.SessionRef\\n   527→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   528→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   529→\\t\\t}\\n   530→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   531→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   532→\\t\\t} else {\\n   533→\\t\\t\\tmodifiedFiles = files\\n   534→\\t\\t}\\n   535→\\t}\\n   536→\\n   537→\\t// Load pre-task state and detect file changes\\n   538→\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   539→\\tif err != nil {\\n   540→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   541→\\t}\\n   542→\\tvar preUntrackedFiles []string\\n   543→\\tif preState != nil {\\n   544→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   545→\\t}\\n   546→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   547→\\tif err != nil {\\n   548→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   549→\\t}\\n   550→\\n   551→\\t// Get repo root and normalize paths\\n   552→\\trepoRoot, err := paths.RepoRoot()\\n   553→\\tif err != nil {\\n   554→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   555→\\t}\\n   556→\\n   557→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   558→\\tvar relNewFiles, relDeletedFiles []string\\n   559→\\tif changes != nil {\\n   560→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   561→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   562→\\t}\\n   563→\\n   564→\\t// If no changes, skip\\n   565→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   566→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   567→\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   568→\\t\\treturn nil\\n   569→\\t}\\n   570→\\n   571→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   572→\\tvar checkpointUUID string\\n   573→\\t// Use the existing CLI-level checkpoint UUID finder\\n   574→\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   575→\\tif mainLines != nil {\\n   576→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   577→\\t}\\n   578→\\n   579→\\t// Get git author\\n   580→\\tauthor, err := GetGitAuthor()\\n   581→\\tif err != nil {\\n   582→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   583→\\t}\\n   584→\\n   585→\\t// Build task checkpoint context\\n   586→\\tstrat := GetStrategy()\\n   587→\\tagentType := ag.Type()\\n   588→\\n   589→\\tctx := strategy.TaskStepContext{\\n   590→\\t\\tSessionID:              event.SessionID,\\n   591→\\t\\tToolUseID:              event.ToolUseID,\\n   592→\\t\\tAgentID:                event.SubagentID,\\n   593→\\t\\tModifiedFiles:          relModifiedFiles,\\n   594→\\t\\tNewFiles:               relNewFiles,\\n   595→\\t\\tDeletedFiles:           relDeletedFiles,\\n   596→\\t\\tTranscriptPath:         event.SessionRef,\\n   597→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   598→\\t\\tCheckpointUUID:         checkpointUUID,\\n   599→\\t\\tAuthorName:             author.Name,\\n   600→\\t\\tAuthorEmail:            author.Email,\\n   601→\\t\\tSubagentType:           subagentType,\\n   602→\\t\\tTaskDescription:        taskDescription,\\n   603→\\t\\tAgentType:              agentType,\\n   604→\\t}\\n   605→\\n   606→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   607→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   608→\\t}\\n   609→\\n   610→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   611→\\treturn nil\\n   612→}\\n   613→\\n   614→// --- Helper functions ---\\n   615→\\n   616→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   617→// Prefers pre-prompt state, falls back to session state.\\n   618→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   619→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   620→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   621→\\t\\treturn preState.TranscriptOffset\\n   622→\\t}\\n   623→\\n   624→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   625→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   626→\\tif loadErr != nil {\\n   627→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   628→\\t\\treturn 0\\n   629→\\t}\\n   630→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   631→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   632→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   633→\\t}\\n   634→\\n   635→\\treturn 0\\n   636→}\\n   637→\\n   638→// updateAutoCommitTranscriptPosition updates the session state with the new transcript position\\n   639→// for the auto-commit strategy.\\n   640→func updateAutoCommitTranscriptPosition(sessionID string, newPosition int) {\\n   641→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   642→\\tif loadErr != nil {\\n   643→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   644→\\t\\treturn\\n   645→\\t}\\n   646→\\tif sessionState == nil {\\n   647→\\t\\tsessionState = &strategy.SessionState{\\n   648→\\t\\t\\tSessionID: sessionID,\\n   649→\\t\\t}\\n   650→\\t}\\n   651→\\tsessionState.CheckpointTranscriptStart = newPosition\\n   652→\\tsessionState.StepCount++\\n   653→\\tif updateErr := strategy.SaveSessionState(sessionState); updateErr != nil {\\n   654→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state: %v\\\\n\\\", updateErr)\\n   655→\\t} else {\\n   656→\\t\\tfmt.Fprintf(os.Stderr, \\\"Updated session state: transcript position=%d, checkpoint=%d\\\\n\\\",\\n   657→\\t\\t\\tnewPosition, sessionState.StepCount)\\n   658→\\t}\\n   659→}\\n   660→\\n   661→// createContextFile creates a context.md file for the session checkpoint.\\n   662→// This is a unified version that works for all agents.\\n   663→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   664→\\tvar sb strings.Builder\\n   665→\\n   666→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   667→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   668→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   669→\\n   670→\\tif len(prompts) > 0 {\\n   671→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   672→\\t\\tfor i, p := range prompts {\\n   673→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   674→\\t\\t}\\n   675→\\t}\\n   676→\\n   677→\\tif summary != \\\"\\\" {\\n   678→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   679→\\t\\tsb.WriteString(summary)\\n   680→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   681→\\t}\\n   682→\\n   683→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   684→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   685→\\t}\\n   686→\\treturn nil\\n   687→}\\n   688→\\n   689→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   690→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   691→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, int, error) {\\n   692→\\tlines, total, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   693→\\tif err != nil {\\n   694→\\t\\treturn nil, 0, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   695→\\t}\\n   696→\\treturn lines, total, nil\\n   697→}\\n   698→\\n   699→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   700→func transitionSessionTurnEnd(sessionID string) {\\n   701→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   702→\\tif loadErr != nil {\\n   703→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   704→\\t\\treturn\\n   705→\\t}\\n   706→\\tif turnState == nil {\\n   707→\\t\\treturn\\n   708→\\t}\\n   709→\\tif err := strategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   710→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   711→\\t}\\n   712→\\n   713→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   714→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   715→\\tstrat := GetStrategy()\\n   716→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   717→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   718→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   719→\\t\\t}\\n   720→\\t}\\n   721→\\n   722→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   723→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   724→\\t}\\n   725→}\\n   726→\\n   727→// markSessionEnded