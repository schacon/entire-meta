tPath, 0) //nolint:errcheck // best-effort extraction\\n   720→\\tcheckpointUUID, _ := FindCheckpointUUID(mainLines, input.ToolUseID)\\n   721→\\n   722→\\t// Get git author\\n   723→\\tauthor, err := GetGitAuthor()\\n   724→\\tif err != nil {\\n   725→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   726→\\t}\\n   727→\\n   728→\\t// Get the configured strategy\\n   729→\\tstrat := GetStrategy()\\n   730→\\n   731→\\t// Get agent type from the currently executing hook agent (authoritative source)\\n   732→\\tvar agentType agent.AgentType\\n   733→\\tif hookAgent, agentErr := GetCurrentHookAgent(); agentErr == nil {\\n   734→\\t\\tagentType = hookAgent.Type()\\n   735→\\t}\\n   736→\\n   737→\\t// Build task checkpoint context - strategy handles metadata creation\\n   738→\\t// Note: Incremental checkpoints are now created during task execution via handleClaudeCodePostTodo,\\n   739→\\t// so we don't need to collect/cleanup staging area here.\\n   740→\\tctx := strategy.TaskCheckpointContext{\\n   741→\\t\\tSessionID:              input.SessionID,\\n   742→\\t\\tToolUseID:              input.ToolUseID,\\n   743→\\t\\tAgentID:                input.AgentID,\\n   744→\\t\\tModifiedFiles:          relModifiedFiles,\\n   745→\\t\\tNewFiles:               relNewFiles,\\n   746→\\t\\tDeletedFiles:           relDeletedFiles,\\n   747→\\t\\tTranscriptPath:         input.TranscriptPath,\\n   748→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   749→\\t\\tCheckpointUUID:         checkpointUUID,\\n   750→\\t\\tAuthorName:             author.Name,\\n   751→\\t\\tAuthorEmail:            author.Email,\\n   752→\\t\\tSubagentType:           subagentType,\\n   753→\\t\\tTaskDescription:        taskDescription,\\n   754→\\t\\tAgentType:              agentType,\\n   755→\\t}\\n   756→\\n   757→\\t// Call strategy to save task checkpoint - strategy handles all metadata creation\\n   758→\\tif err := strat.SaveTaskCheckpoint(ctx); err != nil {\\n   759→\\t\\treturn fmt.Errorf(\\\"failed to save task checkpoint: %w\\\", err)\\n   760→\\t}\\n   761→\\n   762→\\t// Cleanup pre-task state (ignore error - cleanup is best-effort)\\n   763→\\t_ = CleanupPreTaskState(input.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   764→\\n   765→\\treturn nil\\n   766→}\\n   767→\\n   768→// handleClaudeCodeSessionStart handles the SessionStart hook for Claude Code.\\n   769→func handleClaudeCodeSessionStart() error {\\n   770→\\treturn handleSessionStartCommon()\\n   771→}\\n   772→\\n   773→// handleClaudeCodeSessionEnd handles the SessionEnd hook for Claude Code.\\n   774→// This fires when the user explicitly closes the session.\\n   775→// Updates the session state with EndedAt timestamp.\\n   776→func handleClaudeCodeSessionEnd() error {\\n   777→\\tag, err := GetCurrentHookAgent()\\n   778→\\tif err != nil {\\n   779→\\t\\treturn fmt.Errorf(\\\"failed to get agent: %w\\\", err)\\n   780→\\t}\\n   781→\\n   782→\\tinput, err := ag.ParseHookInput(agent.HookSessionEnd, os.Stdin)\\n   783→\\tif err != nil {\\n   784→\\t\\treturn fmt.Errorf(\\\"failed to parse hook input: %w\\\", err)\\n   785→\\t}\\n   786→\\n   787→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"hooks\\\"), ag.Name())\\n   788→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   789→\\t\\tslog.String(\\\"hook\\\", \\\"session-end\\\"),\\n   790→\\t\\tslog.String(\\\"hook_type\\\", \\\"agent\\\"),\\n   791→\\t\\tslog.String(\\\"model_session_id\\\", input.SessionID),\\n   792→\\t)\\n   793→\\n   794→\\tif input.SessionID == \\\"\\\" {\\n   795→\\t\\treturn nil // No session to update\\n   796→\\t}\\n   797→\\n   798→\\t// Best-effort cleanup - don't block session closure on failure\\n   799→\\tif err := markSessionEnded(input.SessionID); err != nil {\\n   800→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   801→\\t}\\n   802→\\n   803→\\treturn nil\\n   804→}\\n   805→\\n   806→// wingmanNotificationLockThreshold is the maximum lock file age for showing\\n   807→// \\\"Reviewing your changes...\\\" notifications. Much tighter than staleLockThreshold\\n   808→// (used for lock acquisition) because a real review takes at most\\n   809→// wingmanInitialDelay (10s) + wingmanReviewTimeout (5m) ≈ 6 minutes.\\n   810→// A lock older than this is almost certainly stale for notification purposes.\\n   811→const wingmanNotificationLockThreshold = 10 * time.Minute\\n   812→\\n   813→// outputWingmanStopNotification outputs a systemMessage notification about\\n   814→// wingman status at the end of a stop hook. This makes wingman activity visible\\n   815→// in the agent terminal without injecting context into the agent's conversation.\\n   816→// Best-effort: status may be stale due to concurrent wingman processes.\\n   817→func outputWingmanStopNotification(repoRoot string) {\\n   818→\\tif !settings.IsWingmanEnabled() {\\n   819→\\t\\treturn\\n   820→\\t}\\n   821→\\tif os.Getenv(\\\"ENTIRE_WINGMAN_APPLY\\\") != \\\"\\\" {\\n   822→\\t\\treturn\\n   823→\\t}\\n   824→\\n   825→\\tlockPath := filepath.Join(repoRoot, wingmanLockFile)\\n   826→\\tif info, err := os.Stat(lockPath); err == nil && time.Since(info.ModTime()) <= wingmanNotificationLockThreshold {\\n   827→\\t\\t_ = outputHookMessage(\\\"[Wingman] Reviewing your changes...\\\") //nolint:errcheck // best-effort notification\\n   828→\\t\\treturn\\n   829→\\t}\\n   830→\\n   831→\\treviewPath := filepath.Join(repoRoot, wingmanReviewFile)\\n   832→\\tif _, err := os.Stat(reviewPath); err == nil {\\n   833→\\t\\t_ = outputHookMessage(\\\"[Wingman] Review pending \\\\u2014 will be addressed on your next prompt\\\") //nolint:errcheck // best-effort notification\\n   834→\\t\\treturn\\n   835→\\t}\\n   836→}\\n   837→\\n   838→// transitionSessionTurnEnd fires EventTurnEnd to move the session from\\n   839→// ACTIVE → IDLE. Best-effort: logs warnings on failure rather than\\n   840→// returning errors.\\n   841→func transitionSessionTurnEnd(sessionID string) {\\n   842→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   843→\\tif loadErr != nil {\\n   844→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   845→\\t\\treturn\\n   846→\\t}\\n   847→\\tif turnState == nil {\\n   848→\\t\\treturn\\n   849→\\t}\\n   850→\\tif err := strategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   851→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   852→\\t}\\n   853→\\n   854→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   855→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   856→\\tstrat := GetStrategy()\\n   857→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   858→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   859→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   860→\\t\\t}\\n   861→\\t}\\n   862→\\n   863→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   864→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   865→\\t}\\n   866→}\\n   867→\\n   868→// triggerWingmanAutoApplyIfPending checks for a pending REVIEW.md and spawns\\n   869→// the auto-apply subprocess if conditions are met. Called from the stop hook\\n   870→// on every turn end (both with-changes and no-changes paths).\\n   871→//\\n   872→// When a live session exists, this is a no-op: the prompt-submit injection\\n   873→// will deliver the review visibly in the user's terminal instead. Background\\n   874→// auto-apply is only used when no sessions are alive (all ended).\\n   875→func triggerWingmanAutoApplyIfPending(repoRoot string) {\\n   876→\\tlogCtx := logging.WithComponent(context.Background(), \\\"wingman\\\")\\n   877→\\tif !settings.IsWingmanEnabled() {\\n   878→\\t\\tlogging.Debug(logCtx, \\\"wingman auto-apply skip: wingman not enabled\\\")\\n   879→\\t\\treturn\\n   880→\\t}\\n   881→\\tif os.Getenv(\\\"ENTIRE_WINGMAN_APPLY\\\") != \\\"\\\" {\\n   882→\\t\\tlogging.Debug(logCtx, \\\"wingman auto-apply skip: already in apply subprocess\\\")\\n   883→\\t\\treturn\\n   884→\\t}\\n   885→\\treviewPath := filepath.Join(repoRoot, wingmanReviewFile)\\n   886→\\tif _, statErr := os.Stat(reviewPath); statErr != nil {\\n   887→\\t\\tlogging.Debug(logCtx, \\\"wingman auto-apply skip: no REVIEW.md pending\\\")\\n   888→\\t\\treturn\\n   889→\\t}\\n   890→\\twingmanState := loadWingmanStateDirect(repoRoot)\\n   891→\\tif wingmanState != nil && wingmanState.ApplyAttemptedAt != nil {\\n   892→\\t\\tlogging.Debug(logCtx, \\\"wingman auto-apply already attempted, skipping\\\",\\n   893→\\t\\t\\tslog.Time(\\\"attempted_at\\\", *wingmanState.ApplyAttemptedAt),\\n   894→\\t\\t)\\n   895→\\t\\treturn\\n   896→\\t}\\n   897→\\t// Don't spawn background auto-apply if a live session exists.\\n   898→\\t// The prompt-submit hook will inject REVIEW.md as additionalContext,\\n   899→\\t// which is visible to the user in their terminal.\\n   900→\\tif hasAnyLiveSession(repoRoot) {\\n   901→\\t\\tlogging.Debug(logCtx, \\\"wingman auto-apply deferred: live session will handle via injection\\\")\\n   902→\\t\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Review pending — will be injected on next prompt\\\\n\\\")\\n   903→\\t\\treturn\\n   904→\\t}\\n   905→\\tfmt.Fprintf(os.Stderr, \\\"[wingman] Pending review found, spawning auto-apply (no live sessions)\\\\n\\\")\\n   906→\\tlogging.Info(logCtx, \\\"wingman auto-apply spawning (no live sessions)\\\",\\n   907→\\t\\tslog.String(\\\"review_path\\\", reviewPath),\\n   908→\\t)\\n   909→\\tspawnDetachedWingmanApply(repoRoot)\\n   910→}\\n   911→\\n   912→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   913→func markSessionEnded(sessionID string) error {\\n   914→\\tstate, err := strategy.LoadSessionState(sessionID)\\n   915→\\tif err != nil {\\n   916→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   917→\\t}\\n   918→\\tif state == nil {\\n   919→\\t\\treturn nil // No state file, nothing to update\\n   920→\\t}\\n   921→\\n   922→\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   923→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session stop transition failed: %v\\\\n\\\", transErr)\\n   924→\\t}\\n   925→\\n   926→\\tnow := time.Now()\\n   927→\\tstate.EndedAt = &now\\n   928→\\n   929→\\tif err := strategy.SaveSessionState(state); err != nil {\\n   930→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   931→\\t}\\n   932→\\treturn nil\\n   933→}\\n   934→\\n   935→// stopHookSentinel is the string that appears in Claude Code's hook_progress\\n   936→// transcript entry when it launches our stop hook. Used to detect that the\\n   937→// transcript file has been fully flushed before we copy it.\\n   938→const stopHookSentinel = \\\"hooks claude-code stop\\\"\\n   939→\\n   940→// waitForTranscriptFlush polls the transcript file tail for the hook_progress\\n   941→// sentinel entry that Claude Code writes when launching the stop hook.\\n   942→// Once this entry appears in the file, all prior entries (assistant replies,\\n   943→// tool results) are guaranteed to have been flushed.\\n   944→//\\n   945→// hookStartTime is the approximate time our process started, used to avoid\\n   946→// matching stale sentinel entries from previous stop hook invocations.\\n   947→//\\n   948→// Falls back silently after a timeout — the transcript copy will proceed\\n   949→// with whatever data is available.\\n   950→func waitForTranscriptFlush(transcriptPath string, hookStartTime time.Time) {\\n   951→\\tconst (\\n   952→\\t\\tmaxWait      = 3 * time.Second\\n   953→\\t\\tpollInterval = 50 * time.Millisecond\\n   954→\\t\\ttailBytes    = 4096 // Read last 4KB — sentinel is near the end\\n   955→\\t\\tmaxSkew      = 2 * time.Second\\n   956→\\t)\\n   957→\\n   958→\\tlogCtx := logging.WithComponent(context.Background(), \\\"hooks\\\")\\n   959→\\tdeadline := time.Now().Add(maxWait)\\n   960→\\tfor time.Now().Before(deadline) {\\n   961→\\t\\tif checkStopSentinel(transcriptPath, tailBytes, hookStartTime, maxSkew) {\\n   962→\\t\\t\\tlogging.Debug(logCtx, \\\"transcript flush sentinel found\\\",\\n   963→\\t\\t\\t\\tslog.Duration(\\\"wait\\\", time.Since(hookStartTime)),\\n   964→\\t\\t\\t)\\n   965→\\t\\t\\treturn\\n   966→\\t\\t}\\n   967→\\t\\ttime.Sleep(pollInterval)\\n   968→\\t}\\n   969→\\t// Timeout — proceed with whatever is on disk.\\n   970→\\tlogging.Warn(logCtx, \\\"transcript flush sentinel not found within timeout, proceeding\\\",\\n   971→\\t\\tslog.Duration(\\\"timeout\\\", maxWait),\\n   972→\\t)\\n   973→}\\n   974→\\n   975→// checkStopSentinel reads the tail of the transcript file and looks for a\\n   976→// hook_progress entry containing the stop hook sentinel, with a timestamp\\n   977→// close to hookStartTime.\\n   978→func checkStopSentinel(path string, tailBytes int64, hookStartTime time.Time, maxSkew time.Duration) bool {\\n   979→\\tf, err := os.Open(path) //nolint:gosec // path comes from agent hook input\\n   980→\\tif err != nil {\\n   981→\\t\\treturn false\\n   982→\\t}\\n   983→\\tdefer f.Close()\\n   984→\\n   985→\\t// Seek to tail\\n   986→\\tinfo, err := f.Stat()\\n   987→\\tif err != nil {\\n   988→\\t\\treturn false\\n   989→\\t}\\n   990→\\toffset := info.Size() - tailBytes\\n   991→\\tif offset < 0 {\\n   992→\\t\\toffset = 0\\n   993→\\t}\\n   994→\\tbuf := make([]byte, info.Size()-offset)\\n   995→\\tif _, err := f.ReadAt(buf, offset); err != nil {\\n   996→\\t\\treturn false\\n   997→\\t}\\n   998→\\n   999→\\t// Scan li