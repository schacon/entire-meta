_lines_added\\\"`\\n   176→\\n   177→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   178→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   179→\\n   180→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   181→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   182→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   183→\\n   184→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   185→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   186→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   187→\\n   188→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   189→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   190→\\t// See docs/architecture/attribution.md for details.\\n   191→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   192→}\\n   193→\\n   194→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   195→// Call this after deserializing a State from JSON.\\n   196→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   197→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   198→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   199→\\t// during ACTIVE phase with immediate condensation.\\n   200→\\tif s.Phase == \\\"active_committed\\\" {\\n   201→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   202→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   203→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   204→\\t\\t)\\n   205→\\t\\ts.Phase = PhaseActive\\n   206→\\t}\\n   207→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n 