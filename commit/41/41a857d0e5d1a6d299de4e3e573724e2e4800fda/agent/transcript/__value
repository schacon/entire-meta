oot, fileName)\\n   189→\\tif err != nil {\\n   190→\\t\\tif os.IsNotExist(err) {\\n   191→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   192→\\t\\t}\\n   193→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   194→\\t}\\n   195→\\n   196→\\tvar state PrePromptState\\n   197→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   198→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   199→\\t}\\n   200→\\n   201→\\tstate.normalizePrePromptState()\\n   202→\\n   203→\\treturn &state, nil\\n   204→}\\n   205→\\n   206→// CleanupPrePromptState removes the state file after use\\n   207→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   208→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   209→\\t\\treturn fmt.Errorf(\\\"invalid session ID for pre-prompt state cleanup: %w\\\", err)\\n   210→\\t}\\n   211→\\n   212→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   213→\\tif err != nil {\\n   214→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   215→\\t}\\n   216→\\n   217→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   218→\\tif err != nil {\\n   219→\\t\\tif os.IsNotExist(err) {\\n   220→\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n   221→\\t\\t}\\n   222→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   223→\\t}\\n   224→\\tdefer root.Close()\\n   225→\\n   226→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   227→\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // best-effort cleanup, caller adds context via wrapping function name\\n   228→}\\n   229→\\n   230→// FileChanges holds categorized file changes from git status.\\n   231→type FileChanges struct {\\n   232→\\tModified []string // Modified or staged files\\n   233→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   234→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   235→}\\n   236→\\n   237→// DetectFileChanges returns categorized file changes from the current git status.\\n   238→//\\n   239→// previouslyUntracked controls new-file detection:\\n   240→//   - nil: all untracked files go into New\\n   241→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   242→//\\n   243→// Modified includes both worktree and staging modified/added files.\\n   244→// Deleted includes both staged and unstaged deletions.\\n   245→// All results exclude .entire/ directory.\\n   246→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   247→\\trepo, err := openRepository(ctx)\\n   248→\\tif err != nil {\\n   249→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   250→\\t}\\n   251→\\n   252→\\tworktree, err := repo.Worktree()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\tstatus, err := worktree.Status()\\n   258→\\tif err != nil {\\n   259→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\t// Build set of pre-existing untracked files for quick lookup\\n   263→\\tvar preExisting map[string]bool\\n   264→\\tif previouslyUntracked != nil {\\n   265→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   266→\\t\\tfor _, f := range previouslyUntracked {\\n   267→\\t\\t\\tpreExisting[f] = true\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\tvar changes FileChanges\\n   272→\\tfor file, st := range status {\\n   273→\\t\\tif paths.IsInfrastructurePath(file) {\\n   274→\\t\\t\\tcontinue\\n   275→\\t\\t}\\n   276→\\n   277→\\t\\tswitch {\\n   278→\\t\\tcase st.Worktree == git.Untracked:\\n   279→\\t\\t\\tif preExisting != nil {\\n   280→\\t\\t\\t\\tif !preExisting[file] {\\n   281→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   282→\\t\\t\\t\\t}\\n   283→\\t\\t\\t} else {\\n   284→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   285→\\t\\t\\t}\\n   286→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   287→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   288→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   289→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   290→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   291→\\t\\t}\\n   292→\\t}\\n   293→\\n   294→\\treturn &changes, nil\\n   295→}\\n   296→\\n   297→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   298→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   299→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   300→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   301→// operation errors, returns the original list unchanged.\\n   302→func filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n   303→\\tif len(files) == 0 {\\n   304→\\t\\treturn files\\n   305→\\t}\\n   306→\\n   307→\\trepo, err := openRepository(ctx)\\n   308→\\tif err != nil {\\n   309→\\t\\treturn files // fail open\\n   310→\\t}\\n   311→\\n   312→\\thead, err := repo.Head()\\n   313→\\tif err != nil {\\n   314→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   315→\\t}\\n   316→\\n   317→\\tcommit, err := repo.CommitObject(head.Hash())\\n   318→\\tif err != nil {\\n   319→\\t\\treturn files // fail open\\n   320→\\t}\\n   321→\\n   322→\\theadTree, err := commit.Tree()\\n   323→\\tif err != nil {\\n   324→\\t\\treturn files // fail open\\n   325→\\t}\\n   326→\\n   327→\\tvar result []string\\n   328→\\tfor _, relPath := range files {\\n   329→\\t\\theadFile, err := headTree.File(relPath)\\n   330→\\t\\tif err != nil {\\n   331→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   332→\\t\\t\\tresult = append(result, relPath)\\n   333→\\t\\t\\tcontinue\\n   334→\\t\\t}\\n   335→\\n   336→\\t\\t// File is in HEAD — compare content with working tree\\n   337→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   338→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   339→\\t\\tif err != nil {\\n   340→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   341→\\t\\t\\tresult = append(result, relPath)\\n   342→\\t\\t\\tcontinue\\n   343→\\t\\t}\\n   344→\\n   345→\\t\\theadContent, err := headFile.Contents()\\n   346→\\t\\tif err != nil {\\n   347→\\t\\t\\tresult = append(result, relPath)\\n   348→\\t\\t\\tcontinue\\n   349→\\t\\t}\\n   350→\\n   351→\\t\\tif string(workingContent) != headContent {\\n   352→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   353→\\t\\t\\tresult = append(result, relPath)\\n   354→\\t\\t}\\n   355→\\t\\t// else: content matches HEAD — already committed, skip\\n   356→\\t}\\n   357→\\n   358→\\treturn result\\n   359→}\\n   360→\\n   361→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   362→// infrastructure paths and paths outside the repo.\\n   363→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   364→\\tvar result []string\\n   365→\\tfor _, file := range files {\\n   366→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   367→\\t\\tif relPath == \\\"\\\" {\\n   368→\\t\\t\\tcontinue // outside repo\\n   369→\\t\\t}\\n   370→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   371→\\t\\t\\tcontinue // skip .entire directory\\n   372→\\t\\t}\\n   373→\\t\\tresult = append(result, relPath)\\n   374→\\t}\\n   375→\\treturn result\\n   376→}\\n   377→\\n   378→// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\n   379→func mergeUnique(base, extra []string) []string {\\n   380→\\tif len(extra) == 0 {\\n   381→\\t\\treturn base\\n   382→\\t}\\n   383→\\tseen := make(map[string]bool, len(base))\\n   384→\\tfor _, s := range base {\\n   385→\\t\\tseen[s] = true\\n   386→\\t}\\n   387→\\tfor _, s := range extra {\\n   388→\\t\\tif !seen[s] {\\n   389→\\t\\t\\tseen[s] = true\\n   390→\\t\\t\\tbase = append(base, s)\\n   391→\\t\\t}\\n   392→\\t}\\n   393→\\treturn base\\n   394→}\\n   395→\\n   396→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   397→// Excludes .entire directory\\n   398→func getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n   399→\\trepo, err := openRepository(ctx)\\n   400→\\tif err != nil {\\n   401→\\t\\treturn nil, err\\n   402→\\t}\\n   403→\\n   404→\\tworktree, err := repo.Worktree()\\n   405→\\tif err != nil {\\n   406→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   407→\\t}\\n   408→\\n   409→\\tstatus, err := worktree.Status()\\n   410→\\tif err != nil {\\n   411→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   412→\\t}\\n   413→\\n   414→\\tuntrackedFiles := []string{}\\n   415→\\tfor file, st := range status {\\n   416→\\t\\tif st.Worktree == git.Untracked {\\n   417→\\t\\t\\t// Exclude .entire directory\\n   418→\\t\\t\\tif !paths.IsInfrastructurePath(file) {\\n   419→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   420→\\t\\t\\t}\\n   421→\\t\\t}\\n   422→\\t}\\n   423→\\n   424→\\treturn untrackedFiles, nil\\n   425→}\\n   426→\\n   427→// PreTaskState stores the state captured before a task execution\\n   428→type PreTaskState struct {\\n   429→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   430→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   431→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   432→}\\n   433→\\n   434→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   435→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   436→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   437→\\tif s == nil {\\n   438→\\t\\treturn nil\\n   439→\\t}\\n   440→\\tif s.UntrackedFiles == nil {\\n   441→\\t\\treturn []string{}\\n   442→\\t}\\n   443→\\treturn s.UntrackedFiles\\n   444→}\\n   445→\\n   446→// CapturePreTaskState captures current untracked files before a Task execution\\n   447→// and saves them to a state file.\\n   448→// Works correctly from any subdirectory within the repository.\\n   449→func CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n   450→\\tif toolUseID == \\\"\\\" {\\n   451→\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n   452→\\t}\\n   453→\\n   454→\\tif err := validation.ValidateToolUseID(toolUseID); err != nil {\\n   455→\\t\\treturn fmt.Errorf(\\\"invalid tool use ID for pre-task state: %w\\\", err)\\n   456→\\t}\\n   457→\\n   458→\\t// Get absolute path for tmp directory\\n   459→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   460→\\tif err != nil {\\n   461→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   462→\\t}\\n   463→\\n   464→\\t// Create tmp directory if it doesn't exist\\n   465→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   466→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   467→\\t}\\n   468→\\n   469→\\t// Get list of untracked files (excluding .entire directory itself)\\n   470→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   471→\\tif err != nil {\\n   472→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   473→\\t}\\n   474→\\n   475→\\t// Create state file using os.Root for traversal-resistant write\\n   476→\\tstate := PreTaskState{\\n   477→\\t\\tToolUseID:      toolUseID,\\n   478→\\t\\tTimestamp:      time.Now().UTC().Format(time.RFC3339),\\n   479→\\t\\tUntrackedFiles: untrackedFiles,\\n   480→\\t}\\n   481→\\n   482→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   483→\\tif err != nil {\\n   484→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   485→\\t}\\n   486→\\n   487→\\tfileName := fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID)\\n   488→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   489→\\tif err != nil {\\n   490→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   491→\\t}\\n   492→\\tdefer root.Close()\\n   493→\\n   494→\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n   495→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   496→\\t}\\n   497→\\n   498→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before task\\\",\\n   499→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)))\\n   500→\\treturn nil\\n   501→}\\n   502→\\n   503→// LoadPreTaskState loads previously captured task state.\\n   504→// Returns nil if no state file exists.\\n   505→func LoadPreTaskState(ctx context.Context, toolUseID string) (*PreTaskState, error) {\\n   506→\\tif err := validation.ValidateToolUseID(toolUseID); err != nil {\\n   507→\\t\\treturn nil, fmt.Errorf(\\\"invalid tool use ID for pre-task state: %w\\\", err)\\n   508→\\t}\\n   509→\\n   510→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   511→\\tif err != nil {\\n   512→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   513→\\t}\\n   514→\\n   515→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   516→\\tif err != nil {\\n   517→\\t\\tif os.IsNotExist(err) {\\n   518→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   519→\\t\\t}\\n   520→\\t\\treturn nil, fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   521→\\t}\\n   522→\\tdefer root.Close()\\n   523→\\n   524→\\tfileName := fmt.Sprintf(\\\"pre-task-%s.json\\\", toolUseID)\\n   525→\\tdata, err := osroot.ReadFile(root, fileName)\\n   526→\\tif err != nil {\\n   527→\\t\\tif os.IsNotExist(err) {\\n   528