"\\n    15→\\tcpkg \\\"github.com/entireio/cli/cmd/entire/cli/checkpoint\\\"\\n    16→\\t\\\"github.com/entireio/cli/cmd/entire/cli/checkpoint/id\\\"\\n    17→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    18→\\t\\\"github.com/entireio/cli/cmd/entire/cli/trailers\\\"\\n    19→\\n    20→\\t\\\"github.com/charmbracelet/huh\\\"\\n    21→\\t\\\"github.com/go-git/go-git/v6\\\"\\n    22→\\t\\\"github.com/go-git/go-git/v6/plumbing\\\"\\n    23→\\t\\\"github.com/go-git/go-git/v6/plumbing/filemode\\\"\\n    24→\\t\\\"github.com/go-git/go-git/v6/plumbing/object\\\"\\n    25→)\\n    26→\\n    27→// GetRewindPoints returns available rewind points.\\n    28→// Uses checkpoint.GitStore.ListTemporaryCheckpoints for reading from shadow branches.\\n    29→func (s *ManualCommitStrategy) GetRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n    30→\\trepo, err := OpenRepository(ctx)\\n    31→\\tif err != nil {\\n    32→\\t\\treturn nil, fmt.Errorf(\\\"failed to open git repository: %w\\\", err)\\n    33→\\t}\\n    34→\\n    35→\\t// Get checkpoint store\\n    36→\\tstore, err := s.getCheckpointStore()\\n    37→\\tif err != nil {\\n    38→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n    39→\\t}\\n    40→\\n    41→\\t// Get current HEAD to find matching shadow branch\\n    42→\\thead, err := repo.Head()\\n    43→\\tif err != nil {\\n    44→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n    45→\\t}\\n    46→\\n    47→\\t// Find sessions for current HEAD\\n    48→\\tsessions, err := s.findSessionsForCommit(ctx, head.Hash().String())\\n    49→\\tif err != nil {\\n    50→\\t\\t// Log error but continue to check for logs-only points\\n    51→\\t\\tsessions = nil\\n    52→\\t}\\n    53→\\n    54→\\tvar allPoints []RewindPoint\\n    55→\\n    56→\\t// Collect checkpoint points from active sessions using checkpoint.GitStore\\n    57→\\t// Cache session prompts by session ID to avoid re-reading the same prompt file\\n    58→\\tsessionPrompts := make(map[string]string)\\n    59→\\n    60→\\tfor _, state := range sessions {\\n    61→\\t\\tcheckpoints, err := store.ListTemporaryCheckpoints(ctx, state.BaseCommit, state.WorktreeID, state.SessionID, limit)\\n    62→\\t\\tif err != nil {\\n    63→\\t\\t\\tcontinue // Error reading checkpoints, skip this session\\n    64→\\t\\t}\\n    65→\\n    66→\\t\\tfor _, cp := range checkpoints {\\n    67→\\t\\t\\t// Get session prompt (cached by session ID)\\n    68→\\t\\t\\tsessionPrompt, ok := sessionPrompts[cp.SessionID]\\n    69→\\t\\t\\tif !ok {\\n    70→\\t\\t\\t\\tsessionPrompt = readSessionPrompt(repo, cp.CommitHash, cp.MetadataDir)\\n    71→\\t\\t\\t\\tsessionPrompts[cp.SessionID] = sessionPrompt\\n    72→\\t\\t\\t}\\n    73→\\n    74→\\t\\t\\tallPoints = append(allPoints, RewindPoint{\\n    75→\\t\\t\\t\\tID:               cp.CommitHash.String(),\\n    76→\\t\\t\\t\\tMessage:          cp.Message,\\n    77→\\t\\t\\t\\tMetadataDir:      cp.MetadataDir,\\n    78→\\t\\t\\t\\tDate:             cp.Timestamp,\\n    79→\\t\\t\\t\\tIsTaskCheckpoint: cp.IsTaskCheckpoint,\\n    80→\\t\\t\\t\\tToolUseID:        cp.ToolUseID,\\n    81→\\t\\t\\t\\tSessionID:        cp.SessionID,\\n    82→\\t\\t\\t\\tSessionPrompt:    sessionPrompt,\\n    83→\\t\\t\\t\\tAgent:            state.AgentType,\\n    84→\\t\\t\\t})\\n    85→\\t\\t}\\n    86→\\t}\\n    87→\\n    88→\\t// Sort by date, most recent first\\n    89→\\tsort.Slice(allPoints, func(i, j int) bool {\\n    90→\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n    91→\\t})\\n    92→\\n    93→\\tif len(allPoints) > limit {\\n    94→\\t\\tallPoints = allPoints[:limit]\\n    95→\\t}\\n    96→\\n    97→\\t// Also include logs-only points from commit history\\n    98→\\tlogsOnlyPoints, err := s.GetLogsOnlyRewindPoints(ctx, limit)\\n    99→\\tif err == nil && len(logsOnlyPoints) > 0 {\\n   100→\\t\\t// Build set of existing point IDs for deduplication\\n   101→\\t\\texistingIDs := make(map[string]bool)\\n   102→\\t\\tfor _, p := range allPoints {\\n   103→\\t\\t\\texistingIDs[p.ID] = true\\n   104→\\t\\t}\\n   105→\\n   106→\\t\\t// Add logs-only points that aren't already in the list\\n   107→\\t\\tfor _, p := range logsOnlyPoints {\\n   108→\\t\\t\\tif !existingIDs[p.ID] {\\n   109→\\t\\t\\t\\tallPoints = append(allPoints, p)\\n   110→\\t\\t\\t}\\n   111→\\t\\t}\\n   112→\\n   113→\\t\\t// Re-sort by date\\n   114→\\t\\tsort.Slice(allPoints, func(i, j int) bool {\\n   115→\\t\\t\\treturn allPoints[i].Date.After(allPoints[j].Date)\\n   116→\\t\\t})\\n   117→\\n   118→\\t\\t// Re-trim to limit\\n   119→\\t\\tif len(allPoints) > limit {\\n   120→\\t\\t\\tallPoints = allPoints[:limit]\\n   121→\\t\\t}\\n   122→\\t}\\n   123→\\n   124→\\treturn allPoints, nil\\n   125→}\\n   126→\\n   127→// GetLogsOnlyRewindPoints finds commits in the current branch's history that have\\n   128→// condensed session logs on the entire/checkpoints/v1 branch. These are commits that\\n   129→// were created with session data but the shadow branch has been condensed.\\n   130→//\\n   131→// The function works by:\\n   132→// 1. Getting all checkpoints from the entire/checkpoints/v1 branch\\n   133→// 2. Building a map of checkpoint ID -> checkpoint info\\n   134→// 3. Scanning the current branch history for commits with Entire-Checkpoint trailers\\n   135→// 4. Matching by checkpoint ID (stable across amend/rebase)\\n   136→func (s *ManualCommitStrategy) GetLogsOnlyRewindPoints(ctx context.Context, limit int) ([]RewindPoint, error) {\\n   137→\\trepo, err := OpenRepository(ctx)\\n   138→\\tif err != nil {\\n   139→\\t\\treturn nil, err\\n   140→\\t}\\n   141→\\n   142→\\t// Get all checkpoints from entire/checkpoints/v1 branch\\n   143→\\tcheckpoints, err := s.listCheckpoints(ctx)\\n   144→\\tif err != nil {\\n   145→\\t\\t// No checkpoints yet is fine\\n   146→\\t\\treturn nil, nil //nolint:nilerr // Expected when no checkpoints exist\\n   147→\\t}\\n   148→\\n   149→\\tif