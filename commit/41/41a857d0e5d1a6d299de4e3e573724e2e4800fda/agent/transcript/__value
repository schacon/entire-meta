ked_files\\\"`\\n    29→\\n    30→\\t// TranscriptOffset is the unified transcript position when this state was captured.\\n    31→\\t// For Claude Code (JSONL), this is the line count.\\n    32→\\t// For Gemini CLI (JSON), this is the message count.\\n    33→\\t// Zero means not set or session just started.\\n    34→\\tTranscriptOffset int `json:\\\"transcript_offset,omitempty\\\"`\\n    35→\\n    36→\\t// LastTranscriptIdentifier is the agent-specific identifier at the transcript position.\\n    37→\\t// UUID for Claude Code, message ID for Gemini CLI. Optional metadata.\\n    38→\\tLastTranscriptIdentifier string `json:\\\"last_transcript_identifier,omitempty\\\"`\\n    39→\\n    40→\\t// Deprecated: StartMessageIndex is the old Gemini-specific field.\\n    41→\\t// Migrated to TranscriptOffset on load.\\n    42→\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n    43→\\n    44→\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n    45→\\t// Migrated to TranscriptOffset on load.\\n    46→\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n    47→\\n    48→\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n    49→\\t// Migrated to TranscriptOffset on load.\\n    50→\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n    51→}\\n    52→\\n    53→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n    54→// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n    55→// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n    56→// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n    57→// are correctly treated as new.\\n    58→func (s *PrePromptState) PreUntrackedFiles() []string {\\n    59→\\tif s == nil {\\n    60→\\t\\treturn nil\\n    61→\\t}\\n    62→\\tif s.UntrackedFiles == nil {\\n    63→\\t\\treturn []string{}\\n    64→\\t}\\n    65→\\treturn s.UntrackedFiles\\n    66→}\\n    67→\\n    68→// normalizePrePromptState migrates deprecated fields after loading from JSON.\\n    69→func (s *PrePromptState) normalizePrePromptState() {\\n    70→\\t// Migrate the oldest field to the intermediate field first\\n    71→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    72→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    73→\\t}\\n    74→\\ts.LastTranscriptLineCount = 0\\n    75→\\n    76→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    77→\\tif s.TranscriptOffset == 0 {\\n    78→\\t\\tif s.StepTranscriptStart > 0 {\\n    79→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    80→\\t\\t} else if s.StartMessageIndex > 0 {\\n    81→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    82→\\t\\t}\\n    83→\\t}\\n    84→\\ts.StepTranscriptStart = 0\\n    85→\\ts.StartMessageIndex = 0\\n    86→}\\n    87→\\n    88→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    89→// and saves them to a state file.\\n    90→//\\n    91→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    92→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    93→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    94→//\\n    95→// Works correctly from any subdirectory within the repository.\\n    96→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    97→\\tif sessionID == \\\"\\\" {\\n    98→\\t\\tsessionID = unknownSessionID\\n    99→\\t}\\n   100→\\n   101→\\t// Get absolute path for tmp directory\\n   102→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   103→\\tif err != nil {\\n   104→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   105→\\t}\\n   106→\\n   107→\\t// Create tmp directory if it doesn't exist\\n   108→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   109→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   110→\\t}\\n   111→\\n   112→\\t// Get list of untracked files (excluding .entire directory itself)\\n   113→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   114→\\tif err != nil {\\n   115→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   116→\\t}\\n   117→\\n   118→\\t// Get transcript position using TranscriptAnalyzer if available\\n   119→\\tvar transcriptOffset int\\n   120→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok && sessionRef != \\\"\\\" {\\n   121→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   122→\\t\\tif posErr != nil {\\n   123→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"state\\\"), \\\"failed to get transcript position\\\",\\n   124→\\t\\t\\t\\tslog.String(\\\"error\\\", posErr.Error()))\\n   125→\\t\\t} else {\\n   126→\\t\\t\\ttranscriptOffset = pos\\n   127→\\t\\t}\\n   128→\\t}\\n   129→\\n   130→\\t// Create state file using os.Root for traversal-resistant write\\n   131→\\tstate := PrePromptState{\\n   132→\\t\\tSessionID:        sessionID,\\n   133→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   134→\\t\\tUntrackedFiles:   untrackedFiles,\\n   135→\\t\\tTranscriptOffset: transcriptOffset,\\n   136→\\t}\\n   137→\\n   138→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   144→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   145→\\tif err != nil {\\n   146→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   147→\\t}\\n   148→\\tdefer root.Close()\\n   149→\\n   150→\\tif err := osroot.WriteFile(root, fileName, data, 0o600); err != nil {\\n   151→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   152→\\t}\\n   153→\\n   154→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before prompt\\\",\\n   155→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)),\\n   156→\\t\\tslog.Int(\\\"transcript_offset\\\", transcriptOffset))\\n   157→\\treturn nil\\n   158→}\\n   159→\\n   160→// LoadPrePromptState loads previously captured state.\\n   161→// Returns nil if no state file exists.\\n   162→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   163→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   164→\\tif err != nil {\\n   165→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   166→\\t}\\n   167→\\n   168→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   169→\\tif err != nil {\\n   170→\\t\\t// Directory doesn't exist yet — no state file\\n   171→\\t\\tif os.IsNotExist(err) {\\n   172→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   173→\\t\\t}\\n   174→\\t\\treturn nil, fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   175→\\t}\\n   176→\\tdefer root.Close()\\n   177→\\n   178→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   179→\\tdata, err := osroot.ReadFile(root, fileName)\\n   180→\\tif err != nil {\\n   181→\\t\\tif os.IsNotExist(err) {\\n   182→\\t\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   183→\\t\\t}\\n   184→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   185→\\t}\\n   186→\\n   187→\\tvar state PrePromptState\\n   188→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   189→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   190→\\t}\\n   191→\\n   192→\\tstate.normalizePrePromptState()\\n   193→\\n   194→\\treturn &state, nil\\n   195→}\\n   196→\\n   197→// CleanupPrePromptState removes the state file after use\\n   198→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   199→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   200→\\tif err != nil {\\n   201→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   202→\\t}\\n   203→\\n   204→\\troot, err := os.OpenRoot(tmpDirAbs)\\n   205→\\tif err != nil {\\n   206→\\t\\tif os.IsNotExist(err) {\\n   207→\\t\\t\\treturn nil // Directory doesn't exist, nothing to clean up\\n   208→\\t\\t}\\n   209→\\t\\treturn fmt.Errorf(\\\"failed to open tmp directory root: %w\\\", err)\\n   210→\\t}\\n   211→\\tdefer root.Close()\\n   212→\\n   213→\\tfileName := fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID)\\n   214→\\treturn osroot.Remove(root, fileName) //nolint:wrapcheck // error context in osroot.Remove\\n   215→}\\n   216→\\n   217→// FileChanges holds categorized file changes from git status.\\n   218→type FileChanges struct {\\n   219→\\tModified []string // Modified or staged files\\n   220→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   221→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   222→}\\n   223→\\n   224→// DetectFileChanges returns categorized file changes from the current git status.\\n   225→//\\n   226→// previouslyUntracked controls new-file detection:\\n   227→//   - nil: all untracked files go into New\\n   228→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   229→//\\n   230→// Modified includes both worktree and staging modified/added files.\\n   231→// Deleted includes both staged and unstaged deletions.\\n   232→// All results exclude .entire/ directory.\\n   233→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   234→\\trepo, err := openRepository(ctx)\\n   235→\\tif err != nil {\\n   236→\\t\\treturn nil, fmt.Errorf(\\\"failed to open re