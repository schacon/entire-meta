r home, system temp dir.\\n    86→// dst is resolved through symlinks before matching to handle macOS /var → /private/var.\\n    87→func openAllowedRoot(dst string) (*os.Root, string, error) {\\n    88→\\tallowed := allowedRootDirs()\\n    89→\\n    90→\\t// Resolve dst through symlinks so that e.g. /var/folders/... matches\\n    91→\\t// /private/var/folders/... on macOS.\\n    92→\\tresolvedDst := dst\\n    93→\\tif r, err := filepath.EvalSymlinks(filepath.Dir(dst)); err == nil {\\n    94→\\t\\tresolvedDst = filepath.Join(r, filepath.Base(dst))\\n    95→\\t}\\n    96→\\n    97→\\tfor _, dir := range allowed {\\n    98→\\t\\trel, err := filepath.Rel(dir, resolvedDst)\\n    99→\\t\\tif err != nil {\\n   100→\\t\\t\\tcontinue\\n   101→\\t\\t}\\n   102→\\t\\t// Check that rel doesn't escape dir (traversal-resistant).\\n   103→\\t\\t// This is the same logic as paths.IsSubpath but avoids a redundant\\n   104→\\t\\t// filepath.Rel call since we already have rel.\\n   105→\\t\\tif rel == \\\"..\\\" || strings.HasPrefix(rel, \\\"..\\\"+string(filepath.Separator)) {\\n   106→\\t\\t\\tcontinue\\n   107→\\t\\t}\\n   108→\\t\\troot, err := os.OpenRoot(dir)\\n   109→\\t\\tif err != nil {\\n   110→\\t\\t\\treturn nil, \\\"\\\", fmt.Errorf(\\\"copyFile: failed to open root %q: %w\\\", dir, err)\\n   111→\\t\\t}\\n   112→\\t\\treturn root, rel, nil\\n   113→\\t}\\n   114→\\n   115→\\treturn nil, \\\"\\\", fmt.Errorf(\\\"copyFile: dst %q is outside allowed directories\\\", dst)\\n   116→}\\n   117→\\n   118→// allowedRootDirs returns the list of directories that copyFile may write to.\\n   119→// Directories are resolved through symlinks so they match resolved dst paths.\\n   120→func allowedRootDirs() []string {\\n   121→\\tallowed := make([]string, 0, 3)\\n   122→\\n   123→\\tif repoRoot, err := paths.WorktreeRoot(context.Background()); err == nil {\\n   124→\\t\\tallowed = appendResolved(allowed, repoRoot)\\n   125→\\t}\\n   126→\\tif home, err := os.UserHomeDir(); err == nil {