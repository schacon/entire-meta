all untracked files go into New\\n   241→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   242→//\\n   243→// Modified includes both worktree and staging modified/added files.\\n   244→// Deleted includes both staged and unstaged deletions.\\n   245→// All results exclude .entire/ directory.\\n   246→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   247→\\trepo, err := openRepository(ctx)\\n   248→\\tif err != nil {\\n   249→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   250→\\t}\\n   251→\\n   252→\\tworktree, err := repo.Worktree()\\n   253→\\tif err != nil {\\n   254→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   255→\\t}\\n   256→\\n   257→\\tstatus, err := worktree.Status()\\n   258→\\tif err != nil {\\n   259→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   260→\\t}\\n   261→\\n   262→\\t// Build set of pre-existing untracked files for quick lookup\\n   263→\\tvar preExisting map[string]bool\\n   264→\\tif previouslyUntracked != nil {\\n   265→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   266→\\t\\tfor _, f := range previouslyUntracked {\\n   267→\\t\\t\\tpreExisting[f] = true\\n   268→\\t\\t}\\n   269→\\t}\\n   270→\\n   271→\\tvar changes FileChanges\\n   272→\\tfor file, st := range status {\\n   273→\\t\\tif paths.IsInfrastructurePath(file) {\\n   274→\\t\\t\\tcontinue\\n   275→\\t\\t}\\n   276→\\n   277→\\t\\tswitch {\\n   278→\\t\\tcase st.Worktree == git.Untracked:\\n   279→\\t\\t\\tif preExisting != nil {\\n   280→\\t\\t\\t\\tif !preExisting[file] {\\n   281→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   282→\\t\\t\\t\\t}\\n   283→\\t\\t\\t} else {\\n   284→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   285→\\t\\t\\t}\\n   286→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   287→\\t\\t\\tchanges.Deleted = append(ch