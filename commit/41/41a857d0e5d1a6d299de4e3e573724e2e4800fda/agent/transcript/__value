HEAD commit: %w\\\", err)\\n   550→\\t}\\n   551→\\theadTree, err := headCommit.Tree()\\n   552→\\tif err != nil {\\n   553→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD tree: %w\\\", err)\\n   554→\\t}\\n   555→\\n   556→\\t// Build set of files tracked in HEAD\\n   557→\\ttrackedFiles := make(map[string]bool)\\n   558→\\t//nolint:errcheck // Error is not critical for preview\\n   559→\\t_ = headTree.Files().ForEach(func(f *object.File) error {\\n   560→\\t\\tif err := ctx.Err(); err != nil {\\n   561→\\t\\t\\treturn err //nolint:wrapcheck // Propagating context cancellation\\n   562→\\t\\t}\\n   563→\\t\\ttrackedFiles[f.Name] = true\\n   564→\\t\\treturn nil\\n   565→\\t})\\n   566→\\n   567→\\t// Find untracked files that would be deleted.\\n   568→\\t// Uses git ls-files to only consider non-ignored files.\\n   569→\\tvar filesToDelete []string\\n   570→\\tuntrackedNow, untrackedErr := collectUntrackedFiles(ctx)\\n   571→\\tif untrackedErr != nil {\\n   572→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: could not list untracked files for preview: %v\\\\n\\\", untrackedErr)\\n   573→\\t\\treturn &RewindPreview{\\n   574→\\t\\t\\tFilesToRestore: filesToRestore,\\n   575→\\t\\t\\tFilesToDelete:  filesToDelete,\\n   576→\\t\\t}, nil\\n   577→\\t}\\n   578→\\tfor _, relPath := range untrackedNow {\\n   579→\\t\\tif checkpointFiles[relPath] {\\n   580→\\t\\t\\tcontinue\\n   581→\\t\\t}\\n   582→\\t\\tif trackedFiles[relPath] {\\n   583→\\t\\t\\tcontinue\\n   584→\\t\\t}\\n   585→\\t\\tif preservedUntrackedFiles[relPath] {\\n   586→\\t\\t\\tcontinue\\n   587→\\t\\t}\\n   588→\\t\\tfilesToDelete = append(filesToDelete, relPath)\\n   589→\\t}\\n   590→\\n   591→\\t// Sort for consistent output\\n   592→\\tsort.Strings(filesToRestore)\\n   593→\\tsort.Strings(filesToDelete)\\n   594→\\n   595→\\treturn &RewindPreview{\\n   596→\\t\\tFilesToRestore: filesToRestore,\\n   597→\\t\\tFilesToDelete:  filesToDelete,\\n   598→\\t}, nil\\n   599→}\\n   600→\\n   601→// RestoreLogsOnly restores session logs from a logs-only rewind point.\\n   602→// This fetches the transcript from entire/checkpoints/v1 and writes it to the agent's session directory.\\n   603→// Does not modify the working directory.\\n   604→// When multiple sessions were condensed to the same checkpoint, ALL sessions are restored.\\n   605→// If force is false, prompts for confirmation when local logs have newer timestamps.\\n   606→// Returns info about each restored session so callers can print correct per-session resume commands.\\n   607→func (s *ManualCommitStrategy) RestoreLogsOnly(ctx context.Context, point RewindPoint, force bool) ([]RestoredSession, error) {\\n   608→\\tif !point.IsLogsOnly {\\n   609→\\t\\treturn nil, errors.New(\\\"not a logs-only rewind point\\\")\\n   610→\\t}\\n   611→\\n   612→\\tif point.CheckpointID.IsEmpty() {\\n   613→\\t\\treturn nil, errors.New(\\\"missing checkpoint ID\\\")\\n   614→\\t}\\n   615→\\n   616→\\t// Get checkpoint store\\n   617→\\tstore, err := s.getCheckpointStore()\\n   618→\\tif err != nil {\\n   619→\\t\\treturn nil, fmt.Errorf(\\\"failed to get checkpoint store: %w\\\", err)\\n   620→\\t}\\n   621→\\n   622→\\t// Read checkpoint summary to get session count\\n   623→\\tsummary, err := store.ReadCommitted(ctx, point.CheckpointID)\\n   624→\\tif err != nil {\\n   625→\\t\\treturn nil, fmt.Errorf(\\\"failed to read checkpoint: %w\\\", err)\\n   626→\\t}\\n   627→\\tif summary == nil {\\n   628→\\t\\treturn nil, fmt.Errorf(\\\"checkpoint not found: %s\\\", point.CheckpointID)\\n   629→\\t}\\n   630→\\n   631→\\t// Get worktree root for agent session directory lookup\\n   632→\\trepoRoot, err := paths.WorktreeRoot(ctx)\\n   633→\\tif err != nil {\\n   634→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree root: %w\\\", err)\\n   635→\\t}\\n   636→\\n   637→\\t// Check for newer local logs if not forcing\\n   638→\\tif !force {\\n   639→\\t\\tsessions := s.classifySessionsForRestore(ctx, repoRoot, store, point.CheckpointID, summary)\\n   640→\\t\\thasConflicts := false\\n   641→\\t\\tfor _, sess := range sessions {\\n   642→\\t\\t\\tif sess.Status == StatusLocalNewer {\\n   643→\\t\\t\\t\\thasConflicts = true\\n   644→\\t\\t\\t\\tbreak\\n   645→\\t\\t\\t}\\n   646→\\t\\t}\\n   647→\\t\\tif hasConflicts {\\n   648→\\t\\t\\tshouldOverwrite, promptErr := PromptOverwriteNewerLogs(sessions)\\n   649→\\t\\t\\tif promptErr != nil {\\n   650→\\t\\t\\t\\treturn nil, promptErr\\n   651→\\t\\t\\t}\\n   652→\\t\\t\\tif !shouldOverwrite {\\n   653→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled. Local session logs preserved.\\\\n\\\")\\n   654→\\t\\t\\t\\treturn nil, nil\\n   655→\\t\\t\\t}\\n   656→\\t\\t}\\n   657→\\t}\\n   658→\\n   659→\\t// Count sessions to restore\\n   660→\\ttotalSessions := len(summary.Sessions)\\n   661→\\tif totalSessions > 1 {\\n   662→\\t\\tfmt.Fprintf(os.Stderr, \\\"Restoring %d sessions from checkpoint:\\\\n\\\", totalSessions)\\n   663→\\t}\\n   664→\\n   665→\\t// Restore all sessions (oldest to newest, using 0-based indexing)\\n   666→\\tvar restored []RestoredSession\\n   667→\\tfor i := range totalSessions {\\n   668→\\t\\tcontent, readErr := store.ReadSessionContent(ctx, point.CheckpointID, i)\\n   669→\\t\\tif readErr != nil {\\n   670→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: failed to read session %d: %v\\\\n\\\", i, readErr)\\n   671→\\t\\t\\tcontinue\\n   672→\\t\\t}\\n   673→\\t\\tif content == nil || len(content.Transcript) == 0 {\\n   674→\\t\\t\\tcontinue\\n   675→\\t\\t}\\n   676→\\n   677→\\t\\tsessionID := content.Metadata.SessionID\\n   678→\\t\\tif sessionID == \\\"\\\" {\\n   679→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: session %d has no session ID, skipping\\\\n\\\", i)\\n   680→\\t\\t\\tcontinue\\n   681→\\t\\t}\\n   682→\\n   683→\\t\\t// Resolve per-session agent from metadata — skip if agent is unknown\\n   684→\\t\\tif content.Metadata.Agent == \\\"\\\" {\\n   685→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  Warning: ses