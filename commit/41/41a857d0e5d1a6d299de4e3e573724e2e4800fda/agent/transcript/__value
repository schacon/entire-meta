ni-specific field.\\n    40→\\t// Migrated to TranscriptOffset on load.\\n    41→\\tStartMessageIndex int `json:\\\"start_message_index,omitempty\\\"`\\n    42→\\n    43→\\t// Deprecated: StepTranscriptStart is the old Claude-specific field.\\n    44→\\t// Migrated to TranscriptOffset on load.\\n    45→\\tStepTranscriptStart int `json:\\\"step_transcript_start,omitempty\\\"`\\n    46→\\n    47→\\t// Deprecated: LastTranscriptLineCount is the oldest name for transcript position.\\n    48→\\t// Migrated to TranscriptOffset on load.\\n    49→\\tLastTranscriptLineCount int `json:\\\"last_transcript_line_count,omitempty\\\"`\\n    50→}\\n    51→\\n    52→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n    53→// This nil-vs-empty distinction lets DetectFileChanges know whether to skip new-file detection.\\n    54→// When the receiver is non-nil but UntrackedFiles is nil (e.g., old state files deserialized with\\n    55→// \\\"untracked_files\\\": null), returns an empty non-nil slice so that all current untracked files\\n    56→// are correctly treated as new.\\n    57→func (s *PrePromptState) PreUntrackedFiles() []string {\\n    58→\\tif s == nil {\\n    59→\\t\\treturn nil\\n    60→\\t}\\n    61→\\tif s.UntrackedFiles == nil {\\n    62→\\t\\treturn []string{}\\n    63→\\t}\\n    64→\\treturn s.UntrackedFiles\\n    65→}\\n    66→\\n    67→// normalizePrePromptState migrates deprecated fields after loading from JSON.\\n    68→func (s *PrePromptState) normalizePrePromptState() {\\n    69→\\t// Migrate the oldest field to the intermediate field first\\n    70→\\tif s.StepTranscriptStart == 0 && s.LastTranscriptLineCount > 0 {\\n    71→\\t\\ts.StepTranscriptStart = s.LastTranscriptLineCount\\n    72→\\t}\\n    73→\\ts.LastTranscriptLineCount = 0\\n    74→\\n    75→\\t// Migrate all deprecated fields to the unified TranscriptOffset\\n    76→\\tif s.TranscriptOffset == 0 {\\n    77→\\t\\tif s.StepTranscriptStart > 0 {\\n    78→\\t\\t\\ts.TranscriptOffset = s.StepTranscriptStart\\n    79→\\t\\t} else if s.StartMessageIndex > 0 {\\n    80→\\t\\t\\ts.TranscriptOffset = s.StartMessageIndex\\n    81→\\t\\t}\\n    82→\\t}\\n    83→\\ts.StepTranscriptStart = 0\\n    84→\\ts.StartMessageIndex = 0\\n    85→}\\n    86→\\n    87→// CapturePrePromptState captures current untracked files and transcript position before a prompt\\n    88→// and saves them to a state file.\\n    89→//\\n    90→// The agent parameter is used to determine the transcript position via TranscriptAnalyzer.\\n    91→// If the agent does not implement TranscriptAnalyzer, the transcript offset will be 0.\\n    92→// The sessionRef parameter is optional — if empty, transcript position won't be captured.\\n    93→//\\n    94→// Works correctly from any subdirectory within the repository.\\n    95→func CapturePrePromptState(ctx context.Context, ag agent.Agent, sessionID, sessionRef string) error {\\n    96→\\tif sessionID == \\\"\\\" {\\n    97→\\t\\tsessionID = unknownSessionID\\n    98→\\t}\\n    99→\\n   100→\\t// Get absolute path for tmp directory\\n   101→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   102→\\tif err != nil {\\n   103→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   104→\\t}\\n   105→\\n   106→\\t// Create tmp directory if it doesn't exist\\n   107→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   108→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   109→\\t}\\n   110→\\n   111→\\t// Get list of untracked files (excluding .entire directory itself)\\n   112→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   113→\\tif err != nil {\\n   114→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   115→\\t}\\n   116→\\n   117→\\t// Get transcript position using TranscriptAnalyzer if available\\n   118→\\tvar transcriptOffset int\\n   119→\\tif analyzer, ok := agent.AsTranscriptAnalyzer(ag); ok && sessionRef != \\\"\\\" {\\n   120→\\t\\tpos, posErr := analyzer.GetTranscriptPosition(sessionRef)\\n   121→\\t\\tif posErr != nil {\\n   122→\\t\\t\\tlogging.Warn(logging.WithComponent(ctx, \\\"state\\\"), \\\"failed to get transcript position\\\",\\n   123→\\t\\t\\t\\tslog.String(\\\"error\\\", posErr.Error()))\\n   124→\\t\\t} else {\\n   125→\\t\\t\\ttranscriptOffset = pos\\n   126→\\t\\t}\\n   127→\\t}\\n   128→\\n   129→\\t// Create state file\\n   130→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   131→\\tstate := PrePromptState{\\n   132→\\t\\tSessionID:        sessionID,\\n   133→\\t\\tTimestamp:        time.Now().UTC().Format(time.RFC3339),\\n   134→\\t\\tUntrackedFiles:   untrackedFiles,\\n   135→\\t\\tTranscriptOffset: transcriptOffset,\\n   136→\\t}\\n   137→\\n   138→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   139→\\tif err != nil {\\n   140→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   141→\\t}\\n   142→\\n   143→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   144→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   145→\\t}\\n   146→\\n   147→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before prompt\\\",\\n   148→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)),\\n   149→\\t\\tslog.Int(\\\"transcript_offset\\\", transcriptOffset))\\n   150→\\treturn nil\\n   151→}\\n   152→\\n   153→// LoadPrePromptState loads previously captured state.\\n   154→// Returns nil if no state file exists.\\n   155→func LoadPrePromptState(ctx context.Context, sessionID string) (*PrePromptState, error) {\\n   156→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   157→\\n   158→\\tif !fileExists(stateFile) {\\n   159→\\t\\treturn nil, nil //nolint:nilnil // already present in codebase\\n   160→\\t}\\n   161→\\n   162→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // Reading from controlled git metadata path\\n   163→\\tif err != nil {\\n   164→\\t\\treturn nil, fmt.Errorf(\\\"failed to read state file: %w\\\", err)\\n   165→\\t}\\n   166→\\n   167→\\tvar state PrePromptState\\n   168→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   169→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal state: %w\\\", err)\\n   170→\\t}\\n   171→\\n   172→\\tstate.normalizePrePromptState()\\n   173→\\n   174→\\treturn &state, nil\\n   175→}\\n   176→\\n   177→// CleanupPrePromptState removes the state file after use\\n   178→func CleanupPrePromptState(ctx context.Context, sessionID string) error {\\n   179→\\tstateFile := prePromptStateFile(ctx, sessionID)\\n   180→\\tif fileExists(stateFile) {\\n   181→\\t\\treturn os.Remove(stateFile) //nolint:wrapcheck // already present in codebase\\n   182→\\t}\\n   183→\\treturn nil\\n   184→}\\n   185→\\n   186→// FileChanges holds categorized file changes from git status.\\n   187→type FileChanges struct {\\n   188→\\tModified []string // Modified or staged files\\n   189→\\tNew      []string // Untracked files (filtered if previouslyUntracked provided)\\n   190→\\tDeleted  []string // Deleted files (staged or unstaged)\\n   191→}\\n   192→\\n   193→// DetectFileChanges returns categorized file changes from the current git status.\\n   194→//\\n   195→// previouslyUntracked controls new-file detection:\\n   196→//   - nil: all untracked files go into New\\n   197→//   - non-nil: only untracked files NOT in the pre-existing set go into New\\n   198→//\\n   199→// Modified includes both worktree and staging modified/added files.\\n   200→// Deleted includes both staged and unstaged deletions.\\n   201→// All results exclude .entire/ directory.\\n   202→func DetectFileChanges(ctx context.Context, previouslyUntracked []string) (*FileChanges, error) {\\n   203→\\trepo, err := openRepository(ctx)\\n   204→\\tif err != nil {\\n   205→\\t\\treturn nil, fmt.Errorf(\\\"failed to open repository: %w\\\", err)\\n   206→\\t}\\n   207→\\n   208→\\tworktree, err := repo.Worktree()\\n   209→\\tif err != nil {\\n   210→\\t\\treturn nil, fmt.Errorf(\\\"failed to get worktree: %w\\\", err)\\n   211→\\t}\\n   212→\\n   213→\\tstatus, err := worktree.Status()\\n   214→\\tif err != nil {\\n   215→\\t\\treturn nil, fmt.Errorf(\\\"failed to get status: %w\\\", err)\\n   216→\\t}\\n   217→\\n   218→\\t// Build set of pre-existing untracked files for quick lookup\\n   219→\\tvar preExisting map[string]bool\\n   220→\\tif previouslyUntracked != nil {\\n   221→\\t\\tpreExisting = make(map[string]bool, len(previouslyUntracked))\\n   222→\\t\\tfor _, f := range previouslyUntracked {\\n   223→\\t\\t\\tpreExisting[f] = true\\n   224→\\t\\t}\\n   225→\\t}\\n   226→\\n   227→\\tvar changes FileChanges\\n   228→\\tfor file, st := range status {\\n   229→\\t\\tif paths.IsInfrastructurePath(file) {\\n   230→\\t\\t\\tcontinue\\n   231→\\t\\t}\\n   232→\\n   233→\\t\\tswitch {\\n   234→\\t\\tcase st.Worktree == git.Untracked:\\n   235→\\t\\t\\tif preExisting != nil {\\n   236→\\t\\t\\t\\tif !preExisting[file] {\\n   237→\\t\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   238→\\t\\t\\t\\t}\\n   239→\\t\\t\\t} else {\\n   240→\\t\\t\\t\\tchanges.New = append(changes.New, file)\\n   241→\\t\\t\\t}\\n   242→\\t\\tcase st.Worktree == git.Deleted || st.Staging == git.Deleted:\\n   243→\\t\\t\\tchanges.Deleted = append(changes.Deleted, file)\\n   244→\\t\\tcase st.Worktree == git.Modified || st.Staging == git.Modified ||\\n   245→\\t\\t\\tst.Worktree == git.Added || st.Staging == git.Added:\\n   246→\\t\\t\\tchanges.Modified = append(changes.Modified, file)\\n   247→\\t\\t}\\n   248→\\t}\\n   249→\\n   250→\\treturn &changes, nil\\n   251→}\\n   252→\\n   253→// filterToUncommittedFiles removes files from the list that are already committed to HEAD\\n   254→// with matching content. This prevents re-adding files that an agent committed mid-turn\\n   255→// (already condensed by PostCommit) back to FilesTouched via SaveStep. Files not in\\n   256→// HEAD or with different content in the working tree are kept. Fails open: if any git\\n   257→// operation errors, returns the original list unchanged.\\n   258→func filterToUncommittedFiles(ctx context.Context, files []string, repoRoot string) []string {\\n   259→\\tif len(files) == 0 {\\n   260→\\t\\treturn files\\n   261→\\t}\\n   262→\\n   263→\\trepo, err := openRepository(ctx)\\n   264→\\tif err != nil {\\n   265→\\t\\treturn files // fail open\\n   266→\\t}\\n   267→\\n   268→\\thead, err := repo.Head()\\n   269→\\tif err != nil {\\n   270→\\t\\treturn files // fail open (empty repo, detached HEAD, etc.)\\n   271→\\t}\\n   272→\\n   273→\\tcommit, err := repo.CommitObject(head.Hash())\\n   274→\\tif err != nil {\\n   275→\\t\\treturn files // fail open\\n   276→\\t}\\n   277→\\n   278→\\theadTree, err := commit.Tree()\\n   279→\\tif err != nil {\\n   280→\\t\\treturn files // fail open\\n   281→\\t}\\n   282→\\n   283→\\tvar result []string\\n   284→\\tfor _, relPath := range files {\\n   285→\\t\\theadFile, err := headTree.File(relPath)\\n   286→\\t\\tif err != nil {\\n   287→\\t\\t\\t// File not in HEAD — it's uncommitted\\n   288→\\t\\t\\tresult = append(result, relPath)\\n   289→\\t\\t\\tcontinue\\n   290→\\t\\t}\\n   291→\\n   292→\\t\\t// File is in HEAD — compare content with working tree\\n   293→\\t\\tabsPath := filepath.Join(repoRoot, relPath)\\n   294→\\t\\tworkingContent, err := os.ReadFile(absPath) //nolint:gosec // path from controlled source\\n   295→\\t\\tif err != nil {\\n   296→\\t\\t\\t// Can't read working tree file (deleted?) — keep it\\n   297→\\t\\t\\tresult = append(result, relPath)\\n   298→\\t\\t\\tcontinue\\n   299→\\t\\t}\\n   300→\\n   301→\\t\\theadContent, err := headFile.Contents()\\n   302→\\t\\tif err != nil {\\n   303→\\t\\t\\tresult = append(result, relPath)\\n   304→\\t\\t\\tcontinue\\n   305→\\t\\t}\\n   306→\\n   307→\\t\\tif string(workingContent) != headContent {\\n   308→\\t\\t\\t// Working tree differs from HEAD — uncommitted changes\\n   309→\\t\\t\\tresult = append(result, relPath)\\n   310→\\t\\t}\\n   311→\\t\\t// else: content matches HEAD — already committed, skip\\n   312→\\t}\\n   313→\\n   314→\\treturn result\\n   315→}\\n   316→\\n   317→// FilterAndNormalizePaths converts absolute paths to relative and filters out\\n   318→// infrastructure paths and paths outside the repo.\\n   319→func FilterAndNormalizePaths(files []string, cwd string) []string {\\n   320→\\tvar result []string\\n   321→\\tfor _, file := range files {\\n   322→\\t\\trelPath := paths.ToRelativePath(file, cwd)\\n   323→\\t\\tif relPath == \\\"\\\" {\\n   324→\\t\\t\\tcontinue // outside repo\\n   325→\\t\\t}\\n   326→\\t\\tif paths.IsInfrastructurePath(relPath) {\\n   327→\\t\\t\\tcontinue // skip .entire directory\\n   328→\\t\\t}\\n   329→\\t\\tresult = append(result, relPath)\\n   330→\\t}\\n   331→\\treturn result\\n   332→}\\n   333→\\n   334→// mergeUnique appends elements from extra into base, skipping duplicates already in base.\\n   335→func mergeUnique(base, extra []string) []string {\\n   336→\\tif len(extra) == 0 {\\n   337→\\t\\treturn base\\n   338→\\t}\\n   339→\\tseen := make(map[string]bool, len(base))\\n   340→\\tfor _, s := range base {\\n   341→\\t\\tseen[s] = true\\n   342→\\t}\\n   343→\\tfor _, s := range extra {\\n   344→\\t\\tif !seen[s] {\\n   345→\\t\\t\\tseen[s] = true\\n   346→\\t\\t\\tbase = append(base, s)\\n   347→\\t\\t}\\n   348→\\t}\\n   349→\\treturn base\\n   350→}\\n   351→\\n   352→// prePromptStateFile returns the absolute path to the pre-prompt state file for a session.\\n   353→// Works correctly from any subdirectory within the repository.\\n   354→func prePromptStateFile(ctx context.Context, sessionID string) string {\\n   355→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   356→\\tif err != nil {\\n   357→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   358→\\t}\\n   359→\\treturn filepath.Join(tmpDirAbs, fmt.Sprintf(\\\"pre-prompt-%s.json\\\", sessionID))\\n   360→}\\n   361→\\n   362→// getUntrackedFilesForState returns a list of untracked files using go-git\\n   363→// Excludes .entire directory\\n   364→func getUntrackedFilesForState(ctx context.Context) ([]string, error) {\\n   365→\\trepo, err := openRepository(ctx)\\n   366→\\tif err != nil {\\n   367→\\t\\treturn nil, err\\n   368→\\t}\\n   369→\\n   370→\\tworktree, err := repo.Worktree()\\n   371→\\tif err != nil {\\n   372→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   373→\\t}\\n   374→\\n   375→\\tstatus, err := worktree.Status()\\n   376→\\tif err != nil {\\n   377→\\t\\treturn nil, err //nolint:wrapcheck // already present in codebase\\n   378→\\t}\\n   379→\\n   380→\\tuntrackedFiles := []string{}\\n   381→\\tfor file, st := range status {\\n   382→\\t\\tif st.Worktree == git.Untracked {\\n   383→\\t\\t\\t// Exclude .entire directory\\n   384→\\t\\t\\tif !paths.IsInfrastructurePath(file) {\\n   385→\\t\\t\\t\\tuntrackedFiles = append(untrackedFiles, file)\\n   386→\\t\\t\\t}\\n   387→\\t\\t}\\n   388→\\t}\\n   389→\\n   390→\\treturn untrackedFiles, nil\\n   391→}\\n   392→\\n   393→// PreTaskState stores the state captured before a task execution\\n   394→type PreTaskState struct {\\n   395→\\tToolUseID      string   `json:\\\"tool_use_id\\\"`\\n   396→\\tTimestamp      string   `json:\\\"timestamp\\\"`\\n   397→\\tUntrackedFiles []string `json:\\\"untracked_files\\\"`\\n   398→}\\n   399→\\n   400→// PreUntrackedFiles returns the untracked files list, or nil if the receiver is nil.\\n   401→// See PrePromptState.PreUntrackedFiles for nil-vs-empty semantics.\\n   402→func (s *PreTaskState) PreUntrackedFiles() []string {\\n   403→\\tif s == nil {\\n   404→\\t\\treturn nil\\n   405→\\t}\\n   406→\\tif s.UntrackedFiles == nil {\\n   407→\\t\\treturn []string{}\\n   408→\\t}\\n   409→\\treturn s.UntrackedFiles\\n   410→}\\n   411→\\n   412→// CapturePreTaskState captures current untracked files before a Task execution\\n   413→// and saves them to a state file.\\n   414→// Works correctly from any subdirectory within the repository.\\n   415→func CapturePreTaskState(ctx context.Context, toolUseID string) error {\\n   416→\\tif toolUseID == \\\"\\\" {\\n   417→\\t\\treturn errors.New(\\\"tool_use_id is required\\\")\\n   418→\\t}\\n   419→\\n   420→\\t// Get absolute path for tmp directory\\n   421→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   422→\\tif err != nil {\\n   423→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   424→\\t}\\n   425→\\n   426→\\t// Create tmp directory if it doesn't exist\\n   427→\\tif err := os.MkdirAll(tmpDirAbs, 0o750); err != nil {\\n   428→\\t\\treturn fmt.Errorf(\\\"failed to create tmp directory: %w\\\", err)\\n   429→\\t}\\n   430→\\n   431→\\t// Get list of untracked files (excluding .entire directory itself)\\n   432→\\tuntrackedFiles, err := getUntrackedFilesForState(ctx)\\n   433→\\tif err != nil {\\n   434→\\t\\treturn fmt.Errorf(\\\"failed to get untracked files: %w\\\", err)\\n   435→\\t}\\n   436→\\n   437→\\t// Create state file\\n   438→\\tstateFile := preTaskStateFile(ctx, toolUseID)\\n   439→\\tstate := PreTaskState{\\n   440→\\t\\tToolUseID:      toolUseID,\\n   441→\\t\\tTimestamp:      time.Now().UTC().Format(time.RFC3339),\\n   442→\\t\\tUntrackedFiles: untrackedFiles,\\n   443→\\t}\\n   444→\\n   445→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   446→\\tif err != nil {\\n   447→\\t\\treturn fmt.Errorf(\\\"failed to marshal state: %w\\\", err)\\n   448→\\t}\\n   449→\\n   450→\\tif err := os.WriteFile(stateFile, data, 0o600); err != nil {\\n   451→\\t\\treturn fmt.Errorf(\\\"failed to write state file: %w\\\", err)\\n   452→\\t}\\n   453→\\n   454→\\tlogging.Debug(logging.WithComponent(ctx, \\\"state\\\"), \\\"captured state before task\\\",\\n   455→\\t\\tslog.Int(\\\"untracked_files\\\", len(untrackedFiles)))\\n   456→\\treturn nil\