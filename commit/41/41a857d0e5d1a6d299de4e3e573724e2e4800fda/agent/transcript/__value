/ modified one.\\n   572→// Works correctly from any subdirectory within the repository.\\n   573→func FindActivePreTaskFile(ctx context.Context) (taskToolUseID string, found bool) {\\n   574→\\ttmpDirAbs, err := paths.AbsPath(ctx, paths.EntireTmpDir)\\n   575→\\tif err != nil {\\n   576→\\t\\ttmpDirAbs = paths.EntireTmpDir // Fallback to relative\\n   577→\\t}\\n   578→\\tentries, err := os.ReadDir(tmpDirAbs)\\n   579→\\tif err != nil {\\n   580→\\t\\treturn \\\"\\\", false\\n   581→\\t}\\n   582→\\n   583→\\tvar latestFile string\\n   584→\\tvar latestTime time.Time\\n   585→\\n   586→\\tfor _, entry := range entries {\\n   587→\\t\\tif entry.IsDir() {\\n   588→\\t\\t\\tcontinue\\n   589→\\t\\t}\\n   590→\\t\\tname := entry.Name()\\n   591→\\t\\tif !strings.HasPrefix(name, preTaskFilePrefix) || !strings.HasSuffix(name, \\\".json\\\") {\\n   592→\\t\\t\\tcontinue\\n   593→\\t\\t}\\n   594→\\n   595→\\t\\t// Check modification time for nested subagent handling\\n   596→\\t\\tinfo, err := entry.Info()\\n   597→\\t\\tif err != nil {\\n   598→\\t\\t\\tcontinue\\n   599→\\t\\t}\\n   600→\\t\\tif latestFile == \\\"\\\" || info.ModTime().After(latestTime) {\\n   601→\\t\\t\\tlatestFile = name\\n   602→\\t\\t\\tlatestTime = info.ModTime()\\n   603→\\t\\t}\\n   604→\\t}\\n   605→\\n   606→\\tif latestFile == \\\"\\\" {\\n   607→\\t\\treturn \\\"\\\", false\\n   608→\\t}\\n   609→\\n   610→\\t// Extract tool_use_id from filename: pre-task-<tool_use_id>.json\\n   611→\\ttoolUseID := strings.TrimPrefix(latestFile, preTaskFilePrefix)\\n   612→\\ttoolUseID = strings.TrimSuffix(toolUseID, \\\".json\\\")\\n   613→\\treturn toolUseID, true\\n   614→}\\n   615→\\n   616→// GetNextCheckpointSequence returns the next sequence number for incremental checkpoints.\\n   617→// It counts existing checkpoint files in the task metadata checkpoints directory.\\n   618→// Returns 1 if no checkpoints exist yet.\\n   619→func GetNextCheckpointSequence(sessionID, taskToolUseID string) int {\\n   