ty\\\"`\\n   148→\\n   149→\\t// TranscriptPath is the path to the live transcript file (for mid-session commit detection)\\n   150→\\tTranscriptPath string `json:\\\"transcript_path,omitempty\\\"`\\n   151→\\n   152→\\t// LastPrompt is the most recent user prompt for this session (truncated for display).\\n   153→\\t// Updated on every turn start (UserPromptSubmit). JSON tag kept as \\\"first_prompt\\\"\\n   154→\\t// for backward compatibility with existing state files.\\n   155→\\tLastPrompt string `json:\\\"last_prompt,omitempty\\\"`\\n   156→\\n   157→\\t// PromptAttributions tracks user and agent line changes at each prompt start.\\n   158→\\t// This enables accurate attribution by capturing user edits between checkpoints.\\n   159→\\tPromptAttributions []PromptAttribution `json:\\\"prompt_attributions,omitempty\\\"`\\n   160→\\n   161→\\t// PendingPromptAttribution holds attribution calculated at prompt start (before agent runs).\\n   162→\\t// This is moved to PromptAttributions when SaveStep is called.\\n   163→\\tPendingPromptAttribution *PromptAttribution `json:\\\"pending_prompt_attribution,omitempty\\\"`\\n   164→}\\n   165→\\n   166→// PromptAttribution captures line-level attribution data at the start of each prompt.\\n   167→// By recording what changed since the last checkpoint BEFORE the agent works,\\n   168→// we can accurately separate user edits from agent contributions.\\n   169→type PromptAttribution struct {\\n   170→\\t// CheckpointNumber is which checkpoint this was recorded before (1-indexed)\\n   171→\\tCheckpointNumber int `json:\\\"checkpoint_number\\\"`\\n   172→\\n   173→\\t// UserLinesAdded is lines added by user since the last checkpoint\\n   174→\\tUserLinesAdded int `json:\\\"user_lines_added\\\"`\\n   175→\\n   176→\\t// UserLinesRemoved is lines removed by user since the last checkpoint\\n   177→\\tUserLinesRemoved int `json:\\\"user_lines_removed\\\"`\\n   178→\\n   179→\\t// AgentLinesAdded is total agent lines added so far (base → last checkpoint).\\n   180→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   181→\\tAgentLinesAdded int `json:\\\"agent_lines_added\\\"`\\n   182→\\n   183→\\t// AgentLinesRemoved is total agent lines removed so far (base → last checkpoint).\\n   184→\\t// Always 0 for checkpoint 1 since there's no previous checkpoint to measure against.\\n   185→\\tAgentLinesRemoved int `json:\\\"agent_lines_removed\\\"`\\n   186→\\n   187→\\t// UserAddedPerFile tracks per-file user additions for accurate modification tracking.\\n   188→\\t// This enables distinguishing user self-modifications from agent modifications.\\n   189→\\t// See docs/architecture/attribution.md for details.\\n   190→\\tUserAddedPerFile map[string]int `json:\\\"user_added_per_file,omitempty\\\"`\\n   191→}\\n   192→\\n   193→// NormalizeAfterLoad applies backward-compatible migrations to state loaded from disk.\\n   194→// Call this after deserializing a State from JSON.\\n   195→func (s *State) NormalizeAfterLoad(ctx context.Context) {\\n   196→\\t// Normalize legacy phase values. \\\"active_committed\\\" was removed with the\\n   197→\\t// 1:1 checkpoint model in favor of the state machine handling commits\\n   198→\\t// during ACTIVE phase with immediate condensation.\\n   199→\\tif s.Phase == \\\"active_committed\\\" {\\n   200→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   201→\\t\\tlogging.Info(logCtx, \\\"migrating legacy active_committed phase to active\\\",\\n   202→\\t\\t\\tslog.String(\\\"session_id\\\", s.SessionID),\\n   203→\\t\\t)\\n   204→\\t\\ts.Phase = PhaseActive\\n   205→\\t}\\n   206→\\t// Also normalize via PhaseFromString to handle any other legacy/unknown values.\\n   207→\\ts.Phase = PhaseFromString(string(s.Phase))\\n   208→\\n   209→\\t// Migrate transcript fields: CheckpointTranscriptStart replaces both\\n   210→\\t// CondensedTranscriptLines and TranscriptLinesAtStart from older state files.\\n   211→\\tif s.CheckpointTranscriptStart == 0 {\\n   212→\\t\\tif s.CondensedTranscriptLines > 0 {\\n   213→\\t\\t\\ts.CheckpointTranscriptStart = s.CondensedTranscriptLines\\n   214→\\t\\t} else if s.TranscriptLinesAtStart > 0 {\\n   215→\\t\\t\\ts.CheckpointTranscriptStart = s.TranscriptLinesAtStart\\n   216→\\t\\t}\\n   217→\\t}\\n   218→\\t// Clear deprecated fields so they aren't re-persisted.\\n   219→\\t// Note: this is a one-way migration. If the state is re-saved, older CLI versions\\n   220→\\t// will see 0 for these fields and fall back to scoping from the transcript start.\\n   221→\\t// This is acceptable since CLI upgrades are monotonic and the worst case is\\n   222→\\t// redundant transcript content in a condensation, not data loss.\\n   223→\\ts.CondensedTranscriptLines = 0\\n   224→\\ts.TranscriptLinesAtStart = 0\\n   225→\\n   226→\\t// Backfill AttributionBaseCommit for sessions created before this field existed.\\n   227→\\t// Without this, a mid-turn commit would migrate BaseCommit and the fallback in\\n   228→\\t// calculateSessionAttributions would use the migrated value, producing zero attribution.\\n   229→\\tif s.AttributionBaseCommit == \\\"\\\" && s.BaseCommit != \\\"\\\" {\\n   230→\\t\\ts.AttributionBaseCommit = s.BaseCommit\\n   231→\\t}\\n   232→}\\n   233→\\n   234→// IsStale returns true when a session hasn't seen interaction for longer than\\n   235→// StaleSessionThreshold. Falls back to StartedAt when LastInteractionTime is\\n   236→// nil (sessions created before interaction tracking was added).\\n   237→func (s *State) IsStale() bool {\\n   238→\\tvar since time.Duration\\n   239→\\tif s.LastInteractionTime != nil {\\n   240→\\t\\tsince = time.Since(*s.LastInteractionTime)\\n   241→\\t} else {\\n   242→\\t\\tsince = time.Since(s.StartedAt)\\n   243→\\t}\\n   244→\\treturn since > StaleSessionThreshold\\n   245→}\\n   246→\\n   247→// StateStore provides low-level operations for managing session state files.\\n   248→//\\n   249→// StateStore is a primitive for session state persistence. It is NOT the same as\\n   250→// the Sessions interface - it only handles state files in .git/entire-sessions/,\\n   251→// not the full session data which includes checkpoint content.\\n   252→//\\n   253→// Use StateStore directly in strategies for performance-critical state operations.\\n   254→// Use the Sessions interface (when implemented) for high-level session management.\\n   255→type StateStore struct {\\n   256→\\t// stateDir is the directory where session state files are stored\\n   257→\\tstateDir string\\n   258→}\\n   259→\\n   260→// NewStateStore creates a new state store.\\n   261→// Uses the git common dir to store session state (shared across worktrees).\\n   262→func NewStateStore(ctx context.Context) (*StateStore, error) {\\n   263→\\tcommonDir, err := getGitCommonDir(ctx)\\n   264→\\tif err != nil {\\n   265→\\t\\treturn nil, fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   266→\\t}\\n   267→\\treturn &StateStore{\\n   268→\\t\\tstateDir: filepath.Join(commonDir, SessionStateDirName),\\n   269→\\t}, nil\\n   270→}\\n   271→\\n   272→// NewStateStoreWithDir creates a new state store with a custom directory.\\n   273→// This is useful for testing.\\n   274→func NewStateStoreWithDir(stateDir string) *StateStore {\\n   275→\\treturn &StateStore{stateDir: stateDir}\\n   276→}\\n   277→\\n   278→// Load loads the session state for the given session ID.\\n   279→// Returns (nil, nil) when session file doesn't exist or session is stale (not an error condition).\\n   280→// Stale sessions (ended longer than StaleSessionThreshold ago) are automatically deleted.\\n   281→func (s *StateStore) Load(ctx context.Context, sessionID string) (*State, error) {\\n   282→\\t// Validate session ID to prevent path traversal\\n   283→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   284→\\t\\treturn nil, fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   285→\\t}\\n   286→\\n   287→\\tstateFile := s.stateFilePath(sessionID)\\n   288→\\n   289→\\tdata, err := os.ReadFile(stateFile) //nolint:gosec // stateFile is derived from sessionID\\n   290→\\tif os.IsNotExist(err) {\\n   291→\\t\\treturn nil, nil //nolint:nilnil // nil,nil indicates session not found (expected case)\\n   292→\\t}\\n   293→\\tif err != nil {\\n   294→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   295→\\t}\\n   296→\\n   297→\\tvar state State\\n   298→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   299→\\t\\treturn nil, fmt.Errorf(\\\"failed to unmarshal session state: %w\\\", err)\\n   300→\\t}\\n   301→\\tstate.NormalizeAfterLoad(ctx)\\n   302→\\n   303→\\tif state.IsStale() {\\n   304→\\t\\tlogCtx := logging.WithComponent(ctx, \\\"session\\\")\\n   305→\\t\\tlogging.Debug(logCtx, \\\"deleting stale session state\\\",\\n   306→\\t\\t\\tslog.String(\\\"session_id\\\", sessionID),\\n   307→\\t\\t)\\n   308→\\t\\t_ = s.Clear(ctx, sessionID) //nolint:errcheck // best-effort cleanup of stale session\\n   309→\\t\\treturn nil, nil             //nolint:nilnil // stale session treated as not found\\n   310→\\t}\\n   311→\\n   312→\\treturn &state, nil\\n   313→}\\n   314→\\n   315→// Save saves the session state atomically.\\n   316→func (s *StateStore) Save(ctx context.Context, state *State) error {\\n   317→\\t_ = ctx // Reserved for future use\\n   318→\\n   319→\\t// Validate session ID to prevent path traversal\\n   320→\\tif err := validation.ValidateSessionID(state.SessionID); err != nil {\\n   321→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\tif err := os.MkdirAll(s.stateDir, 0o750); err != nil {\\n   325→\\t\\treturn fmt.Errorf(\\\"failed to create session state directory: %w\\\", err)\\n   326→\\t}\\n   327→\\n   328→\\tdata, err := jsonutil.MarshalIndentWithNewline(state, \\\"\\\", \\\"  \\\")\\n   329→\\tif err != nil {\\n   330→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   331→\\t}\\n   332→\\n   333→\\tstateFile := s.stateFilePath(state.SessionID)\\n   334→\\n   335→\\t// Atomic write: write to temp file, then rename\\n   336→\\ttmpFile := stateFile + \\\".tmp\\\"\\n   337→\\tif err := os.WriteFile(tmpFile, data, 0o600); err != nil {\\n   338→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   339→\\t}\\n   340→\\tif err := os.Rename(tmpFile, stateFile); err != nil {\\n   341→\\t\\treturn fmt.Errorf(\\\"failed to rename session state file: %w\\\", err)\\n   342→\\t}\\n   343→\\treturn nil\\n   344→}\\n   345→\\n   346→// Clear removes the session state file for the given session ID.\\n   347→func (s *StateStore) Clear(ctx context.Context, sessionID string) error {\\n   348→\\t_ = ctx // Reserved for future use\\n   349→\\n   350→\\t// Validate session ID to prevent path traversal\\n   351→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   352→\\t\\treturn fmt.Errorf(\\\"invalid session ID: %w\\\", err)\\n   353→\\t}\\n   354→\\n   355→\\t// Remove all files for this session (state .json, .model hint, any future hint files).\\n   356→\\tmatches, _ := filepath.Glob(filepath.Join(s.stateDir, sessionID+\\\".*\\\")) //nolint:errcheck // pattern is always valid\\n   357→\\tfor _, f := range matches {\\n   358→\\t\\t_ = os.Remove(f)\\n   359→\\t}\\n   360→\\n   361→\\treturn nil\\n   362→}\\n   363→\\n   364→// RemoveAll removes the entire session state directory.\\n   365→// This is used during uninstall to completely remove all session state.\\n   366→func (s *StateStore) RemoveAll() error {\\n   367→\\tif err := os.RemoveAll(s.stateDir); err != nil {\\n   368→\\t\\treturn fmt.Errorf(\\\"failed to remove session state directory: %w\\\", err)\\n   369→\\t}\\n   370→\\treturn nil\\n   371→}\\n   372→\\n   373→// List returns all session states.\\n   374→func (s *StateStore) List(ctx context.Context) ([]*State, error) {\\n   375→\\tentries, err := os.ReadDir(s.stateDir)\\n   376→\\tif os.IsNotExist(err) {\\n   377→\\t\\treturn nil, nil\\n   378→\\t}\\n   379→\\tif err != nil {\\n   380→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state directory: %w\\\", err)\\n   381→\\t}\\n   382→\\n   383→\\tvar states []*State\\n   384→\\tfor _, entry := range entries {\\n   385→\\t\\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \\\".json\\\") {\\n   386→\\t\\t\\tcontinue\\n   387→\\t\\t}\\n   388→\\t\\tif strings.HasSuffix(entry.Name(), \\\".tmp\\\") {\\n   389→\\t\\t\\tcontinue // Skip temp files\\n   390→\\t\\t}\\n   391→\\n   392→\\t\\tsessionID := strings.TrimSuffix(entry.Name(), \\\".json\\\")\\n   393→\\t\\tstate, err := s.Load(ctx, sessionID)\\n   394→\\t\\tif err != nil {\\n   395→\\t\\t\\tcontinue // Skip corrupted state files\\n   396→\\t\\t}\\n   397→\\t\\tif state == nil {\\n   398→\\t\\t\\tcontinue // Not found or stale (Load handles cleanup)\\n   399→\\t\\t}\\n   400→\\n   401→\\t\\tstates = append(states, state)\\n   402→\\t}\\n   403→\\treturn states, nil\\n   404→}\\n   405→\\n   406→// stateFilePath returns the path to a session state file.\\n   407→func (s *StateStore) stateFilePath(sessionID string) string {\\n   408→\\treturn filepath.Join(s.stateDir, sessionID+\\\".json\\\")\\n   409→}\\n   410→\\n   411→// gitCommonDirCache caches the git common dir to avoid repeated subprocess calls.\\n   412→// Keyed by working directory to handle directory changes (same pattern as paths.WorktreeRoot).\\n   413→var (\\n   414→\\tgitCommonDirMu       sync.RWMutex\\n   415→\\tgitCommonDirCache    string\\n   416→\\tgitCommonDirCacheDir string\\n   417→)\\n   418→\\n   419→// ClearGitCommonDirCache clears the cached git common dir.\\n   420→// Useful for testing when changing directories.\\n   421→func ClearGitCommonDirCache() {\\n   422→\\tgitCommonDirMu.Lock()\\n   423→\\tgitCommonDirCache = \\\"\\\"\\n   424→\\tgitCommonDirCacheDir = \\\"\\\"\\n   425→\\tgitCommonDirMu.Unlock()\\n   426→}\\n   427→\\n   428→// getGitCommonDir returns the path to the shared git directory.\\n   429→// In a regular checkout, this is .git/\\n   430→// In a worktree, this is the main repo's .git/ (not .git/worktrees/<name>/)\\n   431→// The result is cached per working directory.\\n   432→func getGitCommonDir(ctx context.Context) (string, error) {\\n   433→\\tcwd, err := os.Getwd() //nolint:forbidigo // used for cache key, not git-relative paths\\n   434→\\tif err != nil {\\n   435→\\t\\tcwd = \\\"\\\"\\n   436→\\t}\\n   437→\\n   438→\\t// Check cache with read lock first\\n   439→\\tgitCommonDirMu.RLock()\\n   440→\\tif gitCommonDirCache != \\\"\\\" && gitCommonDirCacheDir == cwd {\\n   441→\\t\\tcached := gitCommonDirCache\\n   442→\\t\\tgitCommonDirMu.RUnlock()\\n   443→\\t\\treturn cached, nil\\n   444→\\t}\\n   445→\\tgitCommonDirMu.RUnlock()\\n   446→\\n   447→\\t// Cache miss — resolve via git subprocess\\n   448→\\tcmd := exec.CommandContext(ctx, \\\"git\\\", \\\"rev-parse\\\", \\\"--git-common-dir\\\")\\n   449→\\tcmd.Dir = \\\".\\\"\\n   450→\\toutput, err := cmd.Output()\\n   451→\\tif err != nil {\\n   452→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to get git common dir: %w\\\", err)\\n   453→\\t}\\n   454→\\n   455→\\tcommonDir := strings.TrimSpace(string(output))\\n   456→\\n   457→\\t// git rev-parse --git-common-dir returns relative paths from the working directory,\\n   458→\\t// so we need to make it absolute if it isn't already\\n   459→\\tif !filepath.IsAbs(commonDir) {\\n   460→\\t\\tcommonDir = filepath.Join(\\\".\\\", commonDir)\\n   461→\\t}\\n   462→\\tcommonDir = filepath.Clean(commonDir)\\n   463→\\n   464→\\tgitCommonDirMu.Lock()\\n   465→\\tgitCommonDirCache = commonDir\\n   466→\\tgitCommonDirCacheDir = cwd\\n   467→\\tgitCommonDirMu.Unlock()\\n   468→\\n   469→\\treturn commonDir, nil\\n   470→}\\n   471→\"}]},\"uuid\":\"c113bae0-5140-4004-8f62-9c3b1f677b0f\",\"timestamp\":\"2026-03-16T13:39:12.319Z\"},\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\