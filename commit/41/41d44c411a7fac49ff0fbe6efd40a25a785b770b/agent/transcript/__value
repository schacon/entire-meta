ng terminal).\\n    40→//\\n    41→// In test environments, ENTIRE_TEST_TTY overrides the real check:\\n    42→//   - ENTIRE_TEST_TTY=1 → simulate human (TTY available)\\n    43→//   - ENTIRE_TEST_TTY=0 → simulate agent (no TTY)\\n    44→func hasTTY() bool {\\n    45→\\tif v := os.Getenv(\\\"ENTIRE_TEST_TTY\\\"); v != \\\"\\\" {\\n    46→\\t\\treturn v == \\\"1\\\"\\n    47→\\t}\\n    48→\\n    49→\\t// Gemini CLI sets GEMINI_CLI=1 when running shell commands.\\n    50→\\t// Gemini subprocesses may have access to the user's TTY, but they can't\\n    51→\\t// actually respond to interactive prompts. Treat them as non-TTY.\\n    52→\\t// See: https://geminicli.com/docs/tools/shell/\\n    53→\\tif os.Getenv(\\\"GEMINI_CLI\\\") != \\\"\\\" {\\n    54→\\t\\treturn false\\n    55→\\t}\\n    56→\\n    57→\\t// GIT_TERMINAL_PROMPT=0 disables git's own terminal prompts.\\n    58→\\t// Factory AI Droid (and other non-interactive environments like CI) set this.\\n    59→\\t// Since we run as a git hook, respect it — if the environment doesn't want\\n    60→\\t// git prompting, our hook shouldn't prompt either.\\n    61→\\tif os.Getenv(\\\"GIT_TERMINAL_PROMPT\\\") == \\\"0\\\" {\\n    62→\\t\\treturn false\\n    63→\\t}\\n    64→\\n    65→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n    66→\\tif err != nil {\\n    67→\\t\\treturn false\\n    68→\\t}\\n    69→\\t_ = tty.Close()\\n    70→\\treturn true\\n    71→}\\n    72→\\n    73→// ttyResult represents the outcome of a TTY confirmation prompt.\\n    74→type ttyResult int\\n    75→\\n    76→const (\\n    77→\\tttyResultLink       ttyResult = iota // Link: add the checkpoint trailer\\n    78→\\tttyResultSkip                        // Skip: don't add the trailer\\n    79→\\tttyResultLinkAlways                  // Link and remember: add trailer + save \\\"always\\\" preference\\n    80→)\\n    81→\\n    82→// askConfirmTTY prompts the user via /dev/tty whether to link a commit to session context.\\n    83→// This requires a controlling terminal — callers must check hasTTY() first and handle\\n    84→// the no-TTY case (agent subprocesses, CI) themselves.\\n    85→//\\n    86→// header is displayed as the first line (e.g., \\\"Entire: Active Claude Code session\\\").\\n    87→// detail lines are displayed indented below the header.\\n    88→func askConfirmTTY(header string, details []string, prompt string, defaultYes bool) ttyResult {\\n    89→\\tdefaultResult := ttyResultSkip\\n    90→\\tif defaultYes {\\n    91→\\t\\tdefaultResult = ttyResultLink\\n    92→\\t}\\n    93→\\n    94→\\t// In test mode, don't try to interact with the real TTY — just use the default.\\n    95→\\t// ENTIRE_TEST_TTY=1 simulates \\\"a human is present\\\" for the hasTTY() check\\n    96→\\t// but we can't actually read from the TTY in tests.\\n    97→\\tif os.Getenv(\\\"ENTIRE_TEST_TTY\\\") != \\\"\\\" {\\n    98→\\t\\treturn defaultResult\\n    99→\\t}\\n   100→\\n   101→\\t// Open /dev/tty for both reading and writing.\\n   102→\\t// This is the controlling terminal, which works even when stdin/stderr are redirected\\n   103→\\t// (e.g., human runs git commit -m where stdin is not a pipe).\\n   104→\\ttty, err := os.OpenFile(\\\"/dev/tty\\\", os.O_RDWR, 0)\\n   105→\\tif err != nil {\\n   106→\\t\\treturn defaultResult\\n   107→\\t}\\n   108→\\tdefer tty.Close()\\n   109→\\n   110→\\t// Write to tty directly, not stderr, since git hooks may redirect stderr to /dev/null\\n   111→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", header)\\n   112→\\tfor _, line := range details {\\n   113→\\t\\tfmt.Fprintf(tty, \\\"  %s\\\\n\\\", line)\\n   114→\\t}\\n   115→\\n   116→\\t// Show prompt with option descriptions\\n   117→\\tfmt.Fprintf(tty, \\\"\\\\n%s\\\\n\\\", prompt)\\n   118→\\tif defaultYes {\\n   119→\\t\\tfmt.Fprint(tty, \\\"  [Y]es / [n]o / [a]lways (remember my choice): \\\")\\n   120→\\t} else {\\n   121→\\t\\tfmt.Fprint(tty, \\\"  [y]es / [N]o / [a]lways (remember my choice): \\\")\\n   122→\\t}\\n   123→\\n   124→\\t// Read response\\n   125→\\treader := bufio.NewReader(tty)\\n   126→\\tresponse, err := reader.ReadString('\\\\n')\\n   127→\\tif err != nil {\\n   128→\\t\\treturn defaultResult\\n   129→\\t}\\n   130→\\n   131→\\tresponse = strings.TrimSpace(strings.ToLower(response))\\n   132→\\tswitch response {\\n   133→\\tcase \\\"y\\\", \\\"yes\\\":\\n   134→\\t\\treturn ttyResultLink\\n   135→\\tcase \\\"n\\\", \\\"no\\\":\\n   136→\\t\\treturn ttyResultSkip\\n   137→\\tcase \\\"a\\\", \\\"always\\\":\\n   138→\\t\\treturn ttyResultLinkAlways\\n   139→\\tdefault:\\n   140→\\t\\t// Empty or invalid input - use default\\n   141→\\t\\treturn defaultResult\\n   142→\\t}\\n   143→}\\n   144→\\n   145→// saveCommitLinkingAlways persists commit_linking = \\\"always\\\" to settings.local.json.\\n   146→// Uses raw JSON merge to set only the commit_linking field without affecting other\\n   147→// fields. This avoids writing unintended defaults (e.g., enabled: true) when the\\n   148→// local settings file doesn't exist yet.\\n   149→func saveCommitLinkingAlways(ctx context.Context) error {\\n   150→\\tlocalPath, err := paths.AbsPath(ctx, settings.EntireSettingsLocalFile)\\n   151→\\tif err != nil {\\n   152→\\t\\treturn fmt.Errorf(\\\"resolving local settings path: %w\\\", err)\\n   153→\\t}\\n   154→\\n   155→\\t// Read existing file as raw JSON map to preserve all existing fields.\\n   156→\\t// If the file doesn't exist, start with an empty map so we only write commit_linking.\\n   157→\\tvar raw map[string]json.RawMessage\\n   158→\\tdata, readErr := os.ReadFile(localPath) //nolint:gosec // path is from AbsPath\\n   159→\\tif readErr == nil {\\n   160→\\t\\tif err := json.Unmarshal(data, &raw); err != nil {\\n   161→\\t\\t\\treturn fmt.Errorf(\\\"parsing local settings: %w\\\", err)\\n   162→\\t\\t}\\n   163→\\t} else if !os.IsNotExist(readErr) {\\n   164→\\t\\treturn fmt.Errorf(\\\"reading local settings: %w\\\", readErr)\\n   165→\\t}\\n   166→\\tif raw == nil {\\n   167→\\t\\traw = make(map[string]json.RawMessage)\\n   168→\\t}\\n   169→\\n   170→\\traw[\\\"commit_linking\\\"] = json.RawMessage(`\\\"` + settings.CommitLinkingAlways + `\\\"`)\\n   171→\\n   172→\\tout, err := json.MarshalIndent(raw, \\\"\\\", \\\"  \\\")\\n   173→\\tif err != nil {\\n   174→\\t\\treturn fmt.Errorf(\\\"marshaling local settings: %w\\\", err)\\n   175→\\t}\\n   176→\\tout = append(out, '\\\\n')\\n   177→\\n   178→\\tif err := os.MkdirAll(filepath.Dir(localPath), 0o750); err != nil {\\n   179→\\t\\treturn fmt.Errorf(\\\"creating settings directory: %w\\\", err)\\n   180→\\t}\\n   181→\\t//nolint:gosec // G306: settings file is config, not secrets; 0o644 is appropriate\\n   182→\\tif err := os.WriteFile(localPath, out, 0o644); err != nil {\\n   183→\\t\\treturn fmt.Errorf(\\\"writing local settings: %w\\\", err)\\n   184→\\t}\\n   185→\\treturn nil\\n   186→}\\n   187→\\n   188→// CommitMsg is called by the git commit-msg hook after the user edits the message.\\n   189→// If the message contains only our trailer (no actual user content), strip it\\n   190→// so git will abort the commit due to empty message.\\n   191→\\n   192→func (s *ManualCommitStrategy) CommitMsg(_ context.Context, commitMsgFile string) error { //nolint:unparam // error return is part of the hook contract; callers check it\\n   193→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // Path comes from git hook\\n   194→\\tif err != nil {\\n   195→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   196→\\t}\\n   197→\\n   198→\\tmessage := string(content)\\n   199→\\n   200→\\t// Check if our trailer is present (ParseCheckpoint validates format, so found==true means valid)\\n   201→\\tif _, found := trailers.ParseCheckpoint(message); !found {\\n   202→\\t\\t// No trailer, nothing to do\\n   203→\\t\\treturn nil\\n   204→\\t}\\n   205→\\n   206→\\t// Check if there's any user content (non-comment, non-trailer lines)\\n   207→\\tif !hasUserContent(message) {\\n   208→\\t\\t// No user content - strip the trailer so git aborts\\n   209→\\t\\tmessage = stripCheckpointTrailer(message)\\n   210→\\t\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   211→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   212→\\t\\t}\\n   213→\\t}\\n   214→\\n   215→\\treturn nil\\n   216→}\\n   217→\\n   218→// hasUserContent checks if the message has any content besides comments and our trailer.\\n   219→func hasUserContent(message string) bool {\\n   220→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   221→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   222→\\t\\ttrimmed := strings.TrimSpace(line)\\n   223→\\t\\t// Skip empty lines\\n   224→\\t\\tif trimmed == \\\"\\\" {\\n   225→\\t\\t\\tcontinue\\n   226→\\t\\t}\\n   227→\\t\\t// Skip comment lines\\n   228→\\t\\tif strings.HasPrefix(trimmed, \\\"#\\\") {\\n   229→\\t\\t\\tcontinue\\n   230→\\t\\t}\\n   231→\\t\\t// Skip our trailer line\\n   232→\\t\\tif strings.HasPrefix(trimmed, trailerPrefix) {\\n   233→\\t\\t\\tcontinue\\n   234→\\t\\t}\\n   235→\\t\\t// Found user content\\n   236→\\t\\treturn true\\n   237→\\t}\\n   238→\\treturn false\\n   239→}\\n   240→\\n   241→// stripCheckpointTrailer removes the Entire-Checkpoint trailer line from the message.\\n   242→func stripCheckpointTrailer(message string) string {\\n   243→\\ttrailerPrefix := trailers.CheckpointTrailerKey + \\\":\\\"\\n   244→\\tvar result []string\\n   245→\\tfor _, line := range strings.Split(message, \\\"\\\\n\\\") {\\n   246→\\t\\tif !strings.HasPrefix(strings.TrimSpace(line), trailerPrefix) {\\n   247→\\t\\t\\tresult = append(result, line)\\n   248→\\t\\t}\\n   249→\\t}\\n   250→\\treturn strings.Join(result, \\\"\\\\n\\\")\\n   251→}\\n   252→\\n   253→// isGitSequenceOperation checks if git is currently in the middle of a rebase,\\n   254→// cherry-pick, or revert operation. During these operations, commits are being\\n   255→// replayed and should not be linked to agent sessions.\\n   256→//\\n   257→// Detects:\\n   258→//   - rebase: .git/rebase-merge/ or .git/rebase-apply/ directories\\n   259→//   - cherry-pick: .git/CHERRY_PICK_HEAD file\\n   260→//   - revert: .git/REVERT_HEAD file\\n   261→func isGitSequenceOperation(ctx context.Context) bool {\\n   262→\\t// Get git directory (handles worktrees and relative paths correctly)\\n   263→\\tgitDir, err := GetGitDir(ctx)\\n   264→\\tif err != nil {\\n   265→\\t\\treturn false // Can't determine, assume not in sequence operation\\n   266→\\t}\\n   267→\\n   268→\\t// Check for rebase state directories\\n   269→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-merge\\\")); err == nil {\\n   270→\\t\\treturn true\\n   271→\\t}\\n   272→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"rebase-apply\\\")); err == nil {\\n   273→\\t\\treturn true\\n   274→\\t}\\n   275→\\n   276→\\t// Check for cherry-pick and revert state files\\n   277→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"CHERRY_PICK_HEAD\\\")); err == nil {\\n   278→\\t\\treturn true\\n   279→\\t}\\n   280→\\tif _, err := os.Stat(filepath.Join(gitDir, \\\"REVERT_HEAD\\\")); err == nil {\\n   281→\\t\\treturn true\\n   282→\\t}\\n   283→\\n   284→\\treturn false\\n   285→}\\n   286→\\n   287→// PrepareCommitMsg is called by the git prepare-commit-msg hook.\\n   288→// Adds an Entire-Checkpoint trailer to the commit message with a stable checkpoint ID.\\n   289→// Only adds a trailer if there's actually new session content to condense.\\n   290→// The actual condensation happens in PostCommit - if the user removes the trailer,\\n   291→// the commit will not be linked to the session (useful for \\\"manual\\\" commits).\\n   292→// For amended commits, preserves the existing checkpoint ID.\\n   293→//\\n   294→// The source parameter indicates how the commit was initiated:\\n   295→//   - \\\"\\\" or \\\"template\\\": normal editor flow - adds trailer with explanatory comment\\n   296→//   - \\\"message\\\": using -m or -F flag - prompts user interactively via /dev/tty\\n   297→//   - \\\"merge\\\", \\\"squash\\\": skip trailer entirely (auto-generated messages)\\n   298→//   - \\\"commit\\\": amend operation - preserves existing trailer or restores from LastCheckpointID\\n   299→//\\n   300→\"}]},\"uuid\":\"d6d3974a-6553-4d3e-821c-4903989c7914\",\"timestamp\":\"2026-03-04T10:35:56.718Z\"},\"normalizedMessages\":[],\"type\":\"agent_progress\",\"prompt\":\"\",\"agentId\":\"a45b4adfd51515e68\"},\"toolUseID\":\"agent_msg_01NmeP5FrVv4shvU7y5wsrmN\",\"parentToolUseID\":\"toolu_01LZeR9dwQ2aapEENabDidvp\",\"uuid\":\"8662bbe3-0729-4810-9c95-8bd048688b5a\",\"timestamp\":\"2026-03-04T10:35:56.720Z\"}\n{\"parentUuid\":\"8662bbe3-0729-4810-9c95-8bd048688b5a\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"cf32cb7d-e69d-4fde-838f-a801d52d6b92\",\"version\":\"2.1.66\",\"gitBranch\":\"soph/latest-squash-resume\",\"slug\":\"purrfect-toasting-stream\",\"type\":\"progress\",\"data\":{\"message\":{\"type\":\"assistant\",\"timestamp\":\"2026-03-04T10:35:58.740Z\",\"message\":{\"model\":\"claude-haiku-4-5-20251001\",\"id\":\"msg_01CUx5Ebxf2RwJAnPuUZqG42\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":\"tool_use\",\"id\":\"toolu_01RHK8N36GeWyLmcm6nRGhfo\",\"name\":\"Read\",\"input\":{\"file_path\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/strategy/manual_commit_hooks.go\",\"offset\":300,\"limit\":500},\"caller\":{\"type\":\"direct\"}}],\"stop_reason\":null,\"stop_sequence\":null,\"usage\":{\"input_tokens\":5,\"cache_creation_input_tokens\":6393,\"cache_read_input_tokens\":58396,\"cache_creation\":{\"ephemeral_5m_input_tokens\":0,\"ephemeral_1h_input_tokens\":6393},\"output_tokens\":1,\"service_tier\":\"standard\",\"inference_geo\":\"not_available\"},\"context_management\":null},\"requestId\":\"req_011CYhthcsnvCfdM3ur57H4p\",\"uuid\":\"6