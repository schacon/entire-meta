t()\\n   355→\\tif err := checkpointTree.Encode(checkpointTreeObj); err != nil {\\n   356→\\t\\tt.Fatalf(\\\"Failed to encode checkpoint tree: %v\\\", err)\\n   357→\\t}\\n   358→\\tcheckpointTreeHash, err := repo.Storer.SetEncodedObject(checkpointTreeObj)\\n   359→\\tif err != nil {\\n   360→\\t\\tt.Fatalf(\\\"Failed to store checkpoint tree: %v\\\", err)\\n   361→\\t}\\n   362→\\n   363→\\t// Create inner shard tree (id[2:])\\n   364→\\tinnerTree := object.Tree{\\n   365→\\t\\tEntries: []object.TreeEntry{\\n   366→\\t\\t\\t{Name: checkpointIDStr[2:], Mode: filemode.Dir, Hash: checkpointTreeHash},\\n   367→\\t\\t},\\n   368→\\t}\\n   369→\\tinnerTreeObj := repo.Storer.NewEncodedObject()\\n   370→\\tif err := innerTree.Encode(innerTreeObj); err != nil {\\n   371→\\t\\tt.Fatalf(\\\"Failed to encode inner tree: %v\\\", err)\\n   372→\\t}\\n   373→\\tinnerTreeHash, err := repo.Storer.SetEncodedObject(innerTreeObj)\\n   374→\\tif err != nil {\\n   375→\\t\\tt.Fatalf(\\\"Failed to store inner tree: %v\\\", err)\\n   376→\\t}\\n   377→\\n   378→\\t// Get existing tree entries from parent\\n   379→\\tparentTree, err := parentCommit.Tree()\\n   380→\\tif err != nil {\\n   381→\\t\\tt.Fatalf(\\\"Failed to get parent tree: %v\\\", err)\\n   382→\\t}\\n   383→\\n   384→\\t// Build new root tree with shard bucket\\n   385→\\tvar rootEntries []object.TreeEntry\\n   386→\\tfor _, entry := range parentTree.Entries {\\n   387→\\t\\tif entry.Name != shardedPath[:2] {\\n   388→\\t\\t\\trootEntries = append(rootEntries, entry)\\n   389→\\t\\t}\\n   390→\\t}\\n   391→\\trootEntries = append(rootEntries, object.TreeEntry{\\n   392→\\t\\tName: checkpointIDStr[:2],\\n   393→\\t\\tMode: filemode.Dir,\\n   394→\\t\\tHash: innerTreeHash,\\n   395→\\t})\\n   396→\\n   397→\\trootTree := object.Tree{Entries: rootEntries}\\n   398→\\trootTreeObj := repo.Storer.NewEncodedObject()\\n   399→\\tif err := rootTree.Encode(rootTreeObj); err != nil {\\n   400→\\t\\tt.Fatalf(\\\"Failed to encode root tree: %v\\\", err)\\n   401→\\t}\\n   402→\\trootTreeHash, err := repo.Storer.SetEncodedObject(rootTreeObj)\\n   403→\\tif err != nil {\\n   404→\\t\\tt.Fatalf(\\\"Failed to store root tree: %v\\\", err)\\n   405→\\t}\\n   406→\\n   407→\\t// Create commit on metadata branch\\n   408→\\tcommit := &object.Commit{\\n   409→\\t\\tAuthor: object.Signature{\\n   410→\\t\\t\\tName:  \\\"Test\\\",\\n   411→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   412→\\t\\t\\tWhen:  parentCommit.Author.When,\\n   413→\\t\\t},\\n   414→\\t\\tCommitter: object.Signature{\\n   415→\\t\\t\\tName:  \\\"Test\\\",\\n   416→\\t\\t\\tEmail: \\\"test@example.com\\\",\\n   417→\\t\\t\\tWhen:  parentCommit.Author.When,\\n   418→\\t\\t},\\n   419→\\t\\tMessage:      \\\"Add checkpoint metadata\\\",\\n   420→\\t\\tTreeHash:     rootTreeHash,\\n   421→\\t\\tParentHashes: []plumbing.Hash{parentCommit.Hash},\\n   422→\\t}\\n   423→\\tcommitObj := repo.Storer.NewEncodedObject()\\n   424→\\tif err := commit.Encode(commitObj); err != nil {\\n   425→\\t\\tt.Fatalf(\\\"Failed to encode commit: %v\\\", err)\\n   426→\\t}\\n   427→\\tcommitHash, err := repo.Storer.SetEncodedObject(commitObj)\\n   428→\\tif err != nil {\\n   429→\\t\\tt.Fatalf(\\\"Failed to store commit: %v\\\", err)\\n   430→\\t}\\n   431→\\n   432→\\t// Update metadata branch ref\\n   433→\\tnewRef := plumbing.NewHashReference(refName, commitHash)\\n   434→\\tif err := repo.Storer.SetReference(newRef); err != nil {\\n   435→\\t\\tt.Fatalf(\\\"Failed to update metadata branch: %v\\\", err)\\n   436→\\t}\\n   437→\\n   438→\\treturn checkpointID\\n   439→}\\n   440→\\n   441→// TestResolveLatestCheckpoint verifies that resolveLatestCheckpoint returns the\\n   442→// checkpoint with the newest CreatedAt, regardless of trailer order.\\n   443→func TestResolveLatestCheckpoint(t *testing.T) {\\n   444→\\ttmpDir := t.TempDir()\\n   445→\\tt.Chdir(tmpDir)\\n   446→\\n   447→\\trepo, _, _ := setupResumeTestRepo(t, tmpDir, false)\\n   448→\\n   449→\\