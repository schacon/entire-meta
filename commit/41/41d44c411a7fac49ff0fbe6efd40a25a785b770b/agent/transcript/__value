\t)\\n   322→\\t\\treturn nil\\n   323→\\t}\\n   324→\\n   325→\\t// Handle amend (source=\\\"commit\\\") separately: preserve or restore trailer\\n   326→\\tif source == \\\"commit\\\" {\\n   327→\\t\\treturn s.handleAmendCommitMsg(ctx, commitMsgFile)\\n   328→\\t}\\n   329→\\n   330→\\trepo, err := OpenRepository(ctx)\\n   331→\\tif err != nil {\\n   332→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   333→\\t}\\n   334→\\n   335→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   336→\\tif err != nil {\\n   337→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   338→\\t}\\n   339→\\n   340→\\t// Find all active sessions for this worktree\\n   341→\\t// We match by worktree (not BaseCommit) because the user may have made\\n   342→\\t// intermediate commits without entering new prompts, causing HEAD to diverge\\n   343→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   344→\\tif err != nil || len(sessions) == 0 {\\n   345→\\t\\t// No active sessions or error listing - silently skip (hooks must be resilient)\\n   346→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no active sessions\\\",\\n   347→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   348→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   349→\\t\\t)\\n   350→\\t\\treturn nil //nolint:nilerr // Intentional: hooks must be silent on failure\\n   351→\\t}\\n   352→\\n   353→\\t// Fast path: when an agent is committing (ACTIVE session + no TTY), skip\\n   354→\\t// content detection and interactive prompts. The agent can't respond to TTY\\n   355→\\t// prompts and the content detection can miss mid-session work (no shadow\\n   356→\\t// branch yet, transcript analysis may fail). Generate a checkpoint ID and\\n   357→\\t// add the trailer directly.\\n   358→\\tif !hasTTY() {\\n   359→\\t\\tfor _, state := range sessions {\\n   360→\\t\\t\\tif state.Phase.IsActive() {\\n   361→\\t\\t\\t\\treturn s.addTrailerForAgentCommit(logCtx, commitMsgFile, state, source)\\n   362→\\t\\t\\t}\\n   363→\\t\\t}\\n   364→\\t}\\n   365→\\n   366→\\t// Check if any session has new content to condense\\n   367→\\tsessionsWithContent := s.filterSessionsWithNewContent(ctx, repo, sessions)\\n   368→\\n   369→\\tif len(sessionsWithContent) == 0 {\\n   370→\\t\\t// No new content — no trailer needed\\n   371→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: no content to link\\\",\\n   372→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   373→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   374→\\t\\t\\tslog.Int(\\\"sessions_found\\\", len(sessions)),\\n   375→\\t\\t)\\n   376→\\t\\treturn nil\\n   377→\\t}\\n   378→\\n   379→\\t// Read current commit message\\n   380→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   381→\\tif err != nil {\\n   382→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   383→\\t}\\n   384→\\n   385→\\tmessage := string(content)\\n   386→\\n   387→\\t// Check if trailer already exists (ParseCheckpoint validates format, so found==true means valid)\\n   388→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   389→\\t\\t// Trailer already exists (e.g., amend) - keep it\\n   390→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: trailer already exists\\\",\\n   391→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   392→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   393→\\t\\t\\tslog.String(\\\"existing_checkpoint_id\\\", existingCpID.String()),\\n   394→\\t\\t)\\n   395→\\t\\treturn nil\\n   396→\\t}\\n   397→\\n   398→\\t// Generate a fresh checkpoint ID\\n   399→\\tcheckpointID, err := id.Generate()\\n   400→\\tif err != nil {\\n   401→\\t\\treturn fmt.Errorf(\\\"failed to generate checkpoint ID: %w\\\", err)\\n   402→\\t}\\n   403→\\n   404→\\t// Determine agent type and last prompt from session\\n   405→\\tvar agentType types.AgentType\\n   406→\\tvar lastPrompt string\\n   407→\\tif len(sessionsWithContent) > 0 {\\n   408→\\t\\tfirstSession := sessionsWithContent[0]\\n   409→\\t\\tif firstSession.AgentType != \\\"\\\" {\\n   410→\\t\\t\\tagentType = firstSession.AgentType\\n   411→\\t\\t}\\n   412→\\t\\tlastPrompt = s.getLastPrompt(ctx, repo, firstSession)\\n   413→\\t}\\n   414→\\n   415→\\t// Prepare prompt for display: collapse newlines/whitespace, then truncate (rune-safe)\\n   416→\\tdisplayPrompt := stringutil.TruncateRunes(stringutil.CollapseWhitespace(lastPrompt), 80, \\\"...\\\")\\n   417→\\n   418→\\t// Load commit_linking setting to decide whether to prompt\\n   419→\\tcommitLinking := settings.CommitLinkingPrompt // safe default\\n   420→\\tif stngs, loadErr := settings.Load(ctx); loadErr == nil {\\n   421→\\t\\tcommitLinking = stngs.GetCommitLinking()\\n   422→\\t}\\n   423→\\n   424→\\t// Add trailer differently based on commit source\\n   425→\\tswitch source {\\n   426→\\tcase \\\"message\\\":\\n   427→\\t\\t// Using -m or -F: behavior depends on TTY availability and commit_linking setting\\n   428→\\t\\tswitch {\\n   429→\\t\\tcase !hasTTY():\\n   430→\\t\\t\\t// No TTY (agent subprocess, CI) — auto-link without prompting\\n   431→\\t\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   432→\\t\\tcase commitLinking == settings.CommitLinkingAlways:\\n   433→\\t\\t\\t// User previously chose \\\"always\\\" — auto-link without prompting\\n   434→\\t\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   435→\\t\\tdefault:\\n   436→\\t\\t\\t// Human at terminal — prompt interactively\\n   437→\\t\\t\\theader := \\\"Entire: Active \\\" + string(agentType) + \\\" session detected\\\"\\n   438→\\t\\t\\tvar details []string\\n   439→\\t\\t\\tif displayPrompt != \\\"\\\" {\\n   440→\\t\\t\\t\\tdetails = append(details, \\\"Last prompt: \\\"+displayPrompt)\\n   441→\\t\\t\\t}\\n   442→\\n   443→\\t\\t\\tresult := askConfirmTTY(header, details, \\\"Link this commit to session context?\\\", true)\\n   444→\\t\\t\\tif result == ttyResultSkip {\\n   445→\\t\\t\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: user declined trailer\\\",\\n   446→\\t\\t\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   447→\\t\\t\\t\\t\\tslog.String(\\\"source\\\", source),\\n   448→\\t\\t\\t\\t)\\n   449→\\t\\t\\t\\treturn nil\\n   450→\\t\\t\\t}\\n   451→\\t\\t\\tif result == ttyResultLinkAlways {\\n   452→\\t\\t\\t\\t// Persist preference so future commits auto-link (non-fatal if it fails)\\n   453→\\t\\t\\t\\tif saveErr := saveCommitLinkingAlways(ctx); saveErr != nil {\\n   454→\\t\\t\\t\\t\\tlogging.Warn(logCtx, \\\"prepare-commit-msg: failed to save commit_linking=always\\\",\\n   455→\\t\\t\\t\\t\\t\\tslog.String(\\\"error\\\", saveErr.Error()),\\n   456→\\t\\t\\t\\t\\t)\\n   457→\\t\\t\\t\\t}\\n   458→\\t\\t\\t}\\n   459→\\t\\t\\tmessage = addCheckpointTrailer(message, checkpointID)\\n   460→\\t\\t}\\n   461→\\tdefault:\\n   462→\\t\\t// Normal editor flow: add trailer with explanatory comment (will be stripped by git)\\n   463→\\t\\tmessage = addCheckpointTrailerWithComment(message, checkpointID, string(agentType), displayPrompt)\\n   464→\\t}\\n   465→\\n   466→\\tlogging.Info(logCtx, \\\"prepare-commit-msg: trailer added\\\",\\n   467→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   468→\\t\\tslog.String(\\\"source\\\", source),\\n   469→\\t\\tslog.String(\\\"checkpoint_id\\\", checkpointID.String()),\\n   470→\\t)\\n   471→\\n   472→\\t// Write updated message back\\n   473→\\tif err := os.WriteFile(commitMsgFile, []byte(message), 0o600); err != nil {\\n   474→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   475→\\t}\\n   476→\\n   477→\\treturn nil\\n   478→}\\n   479→\\n   480→// handleAmendCommitMsg handles the prepare-commit-msg hook for amend operations\\n   481→// (source=\\\"commit\\\"). It preserves existing trailers or restores from LastCheckpointID.\\n   482→func (s *ManualCommitStrategy) handleAmendCommitMsg(ctx context.Context, commitMsgFile string) error {\\n   483→\\tlogCtx := logging.WithComponent(ctx, \\\"checkpoint\\\")\\n   484→\\t// Read current commit message\\n   485→\\tcontent, err := os.ReadFile(commitMsgFile) //nolint:gosec // commitMsgFile is provided by git hook\\n   486→\\tif err != nil {\\n   487→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   488→\\t}\\n   489→\\n   490→\\tmessage := string(content)\\n   491→\\n   492→\\t// If message already has a trailer, keep it unchanged\\n   493→\\tif existingCpID, found := trailers.ParseCheckpoint(message); found {\\n   494→\\t\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend preserves existing trailer\\\",\\n   495→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   496→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", existingCpID.String()),\\n   497→\\t\\t)\\n   498→\\t\\treturn nil\\n   499→\\t}\\n   500→\\n   501→\\t// No trailer in message — check if any session has LastCheckpointID to restore\\n   502→\\tworktreePath, err := paths.WorktreeRoot(ctx)\\n   503→\\tif err != nil {\\n   504→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   505→\\t}\\n   506→\\n   507→\\tsessions, err := s.findSessionsForWorktree(ctx, worktreePath)\\n   508→\\tif err != nil || len(sessions) == 0 {\\n   509→\\t\\treturn nil //nolint:nilerr // No sessions - nothing to restore\\n   510→\\t}\\n   511→\\n   512→\\t// For amend, HEAD^ is the commit being amended, and HEAD is where we are now.\\n   513→\\t// We need to match sessions whose BaseCommit equals HEAD (the commit being amended\\n   514→\\t// was created from this base). This prevents stale sessions from injecting\\n   515→\\t// unrelated checkpoint IDs.\\n   516→\\trepo, repoErr := OpenRepository(ctx)\\n   517→\\tif repoErr != nil {\\n   518→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   519→\\t}\\n   520→\\thead, headErr := repo.Head()\\n   521→\\tif headErr != nil {\\n   522→\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   523→\\t}\\n   524→\\tcurrentHead := head.Hash().String()\\n   525→\\n   526→\\t// Find first matching session with LastCheckpointID to restore.\\n   527→\\t// LastCheckpointID is set after condensation completes.\\n   528→\\tfor _, state := range sessions {\\n   529→\\t\\tif state.BaseCommit != currentHead {\\n   530→\\t\\t\\tcontinue\\n   531→\\t\\t}\\n   532→\\t\\tif state.LastCheckpointID.IsEmpty() {\\n   533→\\t\\t\\tcontinue\\n   534→\\t\\t}\\n   535→\\t\\tcpID := state.LastCheckpointID\\n   536→\\t\\tsource := \\\"LastCheckpointID\\\"\\n   537→\\n   538→\\t\\t// Restore the trailer\\n   539→\\t\\tmessage = addCheckpointTrailer(message, cpID)\\n   540→\\t\\tif writeErr := os.WriteFile(commitMsgFile, []byte(message), 0o600); writeErr != nil {\\n   541→\\t\\t\\treturn nil //nolint:nilerr // Hook must be silent on failure\\n   542→\\t\\t}\\n   543→\\n   544→\\t\\tlogging.Info(logCtx, \\\"prepare-commit-msg: restored trailer on amend\\\",\\n   545→\\t\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   546→\\t\\t\\tslog.String(\\\"checkpoint_id\\\", cpID.String()),\\n   547→\\t\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   548→\\t\\t\\tslog.String(\\\"source\\\", source),\\n   549→\\t\\t)\\n   550→\\t\\treturn nil\\n   551→\\t}\\n   552→\\n   553→\\t// No checkpoint ID found - leave message unchanged\\n   554→\\tlogging.Debug(logCtx, \\\"prepare-commit-msg: amend with no checkpoint to restore\\\",\\n   555→\\t\\tslog.String(\\\"strategy\\\", \\\"manual-commit\\\"),\\n   556→\\t)\\n   557→\\treturn nil\\n   558→}\\n   559→\\n   560→// PostCommit is called by the git post-commit hook after a commit is created.\\n   561→// Uses the session state machine to determine what action to take per session:\\n   562→//   - ACTIVE → condense immediately (each commit gets its own checkpoint)\\n   563→//   - IDLE → condense immediately\\n   564→//   - ENDED → condense if files touched, discard if empty\\n   565→//\\n   566→// After condensation for ACTIVE sessions, remaining uncommitted files are\\n   567→// carried forward to a new shadow branch so the next commit gets its own checkpoint.\\n   568→//\\n   569→// Shadow branches are only deleted when ALL sessions sharing the branch are non-active\\n   570→// and were condensed during this PostCommit.\\n   571→\\n   572→// postCommitActionHandler implements session.ActionHandler for PostCommit.\\n   573→// Each session in the loop gets its own handler with per-session context.\\n   574→// Handler methods use the *State parameter from ApplyTransition (same pointer\\n   575→// as the state being transitioned) rather than capturing state separately.\\n   576→type postCommitActionHandler struct {\\n   577→\\ts                      *ManualCommitStrategy\\n   578→\\tctx                    context.Context\\n   579→\\trepo                   *git.Repository\\n   580→\\tcheckpointID           id.CheckpointID\\n   581→\\thead                   *plumbing.Reference\\n   582→\\tcommit                 *object.Commit\\n   583→\\tnewHead                string\\n   584→\\trepoDir                string\\n   585→\\tshadowBranchName       string\\n   586→\\tshadowBranchesToDelete map[string]struct{}\\n   587→\\tcommittedFileSet       map[string]struct{}\\n   588→\\thasNew                 bool\\n   589→\\tfilesTouchedBefore     []string\\n   590→\\n   591→\\t// Cached git objects — resolved once per PostCommit invocation to avoid\\n   592→\\t// redundant reads across filesOverlapWithContent, filesWithRemainingAgentChanges,\\n   593→\\t// CondenseSession, and calculateSessionAttributions.\\n   594→\\theadTree   *object.Tree        // HEAD commit tree (shared across all sessions)\\n   595→\\tparentTree *object.Tree        // HEAD's first parent tree (shared, nil for initial commits)\\n   596→\\tshadowRef  *plumbing.Reference // Per-session shadow branch ref (nil if branch doesn't exist)\\n   597→\\tshadowTree *object.Tree        // Per-session shadow commit tree (nil if branch doesn't exist)\\n   598→\\n   599→\\t// Output: set by handler methods, read by caller after TransitionAndLog.\\n   600→\\tcondensed bool\\n   601→}\\n   602→\\n   603→func (h *postCommitActionHandler) HandleCondense(state *session.State) error {\\n   604→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   605→\\tshouldCondense := h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   606→\\n   607→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondense decision\\\",\\n   608→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   609→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   610→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   611→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   612→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   613→\\t)\\n   614→\\n   615→\\tif shouldCondense {\\n   616→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   617→\\t\\t\\tshadowRef:      h.shadowRef,\\n   618→\\t\\t\\theadTree:       h.headTree,\\n   619→\\t\\t\\trepoDir:        h.repoDir,\\n   620→\\t\\t\\theadCommitHash: h.newHead,\\n   621→\\t\\t})\\n   622→\\t} else {\\n   623→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   624→\\t}\\n   625→\\treturn nil\\n   626→}\\n   627→\\n   628→func (h *postCommitActionHandler) HandleCondenseIfFilesTouched(state *session.State) error {\\n   629→\\tlogCtx := logging.WithComponent(h.ctx, \\\"checkpoint\\\")\\n   630→\\tshouldCondense := len(state.FilesTouched) > 0 && h.shouldCondenseWithOverlapCheck(state.Phase.IsActive(), state.LastInteractionTime)\\n   631→\\n   632→\\tlogging.Debug(logCtx, \\\"post-commit: HandleCondenseIfFilesTouched decision\\\",\\n   633→\\t\\tslog.String(\\\"session_id\\\", state.SessionID),\\n   634→\\t\\tslog.String(\\\"phase\\\", string(state.Phase)),\\n   635→\\t\\tslog.Bool(\\\"has_new\\\", h.hasNew),\\n   636→\\t\\tslog.Int(\\\"files_touched\\\", len(state.FilesTouched)),\\n   637→\\t\\tslog.Bool(\\\"should_condense\\\", shouldCondense),\\n   638→\\t\\tslog.String(\\\"shadow_branch\\\", h.shadowBranchName),\\n   639→\\t)\\n   640→\\n   641→\\tif shouldCondense {\\n   642→\\t\\th.condensed = h.s.condenseAndUpdateState(h.ctx, h.repo, h.checkpointID, state, h.head, h.shadowBranchName, h.shadowBranchesToDelete, h.committedFileSet, condenseOpts{\\n   643→\\t\\t\\tshadowRef:      h.shadowRef,\\n   644→\\t\\t\\theadTree:       h.headTree,\\n   645→\\t\\t\\trepoDir:        h.repoDir,\\n   646→\\t\\t\\theadCommitHash: h.newHead,\\n   647→\\t\\t})\\n   648→\\t} else {\\n   649→\\t\\th.s.updateBaseCommitIfChanged(h.ctx, state, h.newHead)\\n   650→\\t}\\n   651→\\treturn nil\\n   652→}\\n   653→\\n   654→// shouldCondenseWithOverlapCheck returns true if the session should be condensed\\n   655→// into this commit. Active sessions with recent interaction always condense\\n   656→// (bypasses overlap check). Stale ACTIVE and IDLE/ENDED sessions require\\n   657→// file overlap evidence between tracked files and committed files.\\n   658→func (h *postCommitActionHandler) shouldCondenseWithOverlapCheck(isActive bool, lastInteraction *time.Time) bool {\\n   659→\\tif !h.hasNew {\\n   660→\\t\\treturn false\\n   661→\\t}\\n   662→\\t// ACTIVE sessions with recent interaction: skip the overlap check.\\n   663→\\t// PrepareCommitMsg already validated this commit is session-related\\n   664→\\t// (added trailer). The overlap check is only meaningful when we need\\n   665→\\t// heuristic evidence that a commit was related to the session.\\n   666→\\t//\\n   667→\\t// We check LastInteractionTime to avoid condensing stale ACTIVE sessions\\n   668→\\t// (agent killed without Stop hook) into every subsequent commit. A stale\\n   669→\\t// session has no recent interaction and fall