ch\\\")\\n   137→\\t\\t}\\n   138→\\t})\\n   139→}\\n   140→\\n   141→func TestCheckoutBranch(t *testing.T) {\\n   142→\\ttmpDir := t.TempDir()\\n   143→\\tt.Chdir(tmpDir)\\n   144→\\n   145→\\tsetupResumeTestRepo(t, tmpDir, true)\\n   146→\\n   147→\\tt.Run(\\\"successfully checks out existing branch\\\", func(t *testing.T) {\\n   148→\\t\\terr := CheckoutBranch(context.Background(), \\\"feature\\\")\\n   149→\\t\\tif err != nil {\\n   150→\\t\\t\\tt.Fatalf(\\\"CheckoutBranch() error = %v\\\", err)\\n   151→\\t\\t}\\n   152→\\n   153→\\t\\t// Verify we're on the feature branch\\n   154→\\t\\tbranch, err := GetCurrentBranch(context.Background())\\n   155→\\t\\tif err != nil {\\n   156→\\t\\t\\tt.Fatalf(\\\"GetCurrentBranch() error = %v\\\", err)\\n   157→\\t\\t}\\n   158→\\t\\tif branch != \\\"feature\\\" {\\n   159→\\t\\t\\tt.Errorf(\\\"After CheckoutBranch(), current branch = %q, want %q\\\", branch, \\\"feature\\\")\\n   160→\\t\\t}\\n   161→\\t})\\n   162→\\n   163→\\tt.Run(\\\"returns error for nonexistent branch\\\", func(t *testing.T) {\\n   164→\\t\\terr := CheckoutBranch(context.Background(), \\\"nonexistent\\\")\\n   165→\\t\\tif err == nil {\\n   166→\\t\\t\\tt.Error(\\\"CheckoutBranch() expected error for nonexistent branch, got nil\\\")\\n   167→\\t\\t}\\n   168→\\t})\\n   169→\\n   170→\\tt.Run(\\\"rejects ref starting with dash to prevent argument injection\\\", func(t *testing.T) {\\n   171→\\t\\t// \\\"git checkout -b evil\\\" would create a new branch named \\\"evil\\\" instead\\n   172→\\t\\t// of failing, because git interprets \\\"-b\\\" as a flag.\\n   173→\\t\\terr := CheckoutBranch(context.Background(), \\\"-b evil\\\")\\n   174→\\t\\tif err == nil {\\n   175→\\t\\t\\tt.Fatal(\\\"CheckoutBranch() should reject refs starting with '-', got nil\\\")\\n   176→\\t\\t}\\n   177→\\t\\tif !strings.Contains(err.Error(), \\\"invalid ref\\\") {\\n   178→\\t\\t\\tt.Errorf(\\\"CheckoutBranch() error = %q, want error containing 'invalid ref'\\\", err.Error())\\n   179→\\t\\t}\\n   180→\\t})\\n   181→}\\n   182→\\n   183→func TestPerformGitResetHard_RejectsArgumentInjection(t *testing.T) {\\n   184→\\ttmpDir := t.TempDir()\\n   185→\\tt.Chdir(tmpDir)\\n   186→\\n   187→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   188→\\n   189→\\t// \\\"git reset --hard -q\\\" would silently reset to HEAD in quiet mode instead\\n   190→\\t// of failing, because git interprets \\\"-q\\\" as the --quiet flag.\\n   191→\\terr := performGitResetHard(context.Background(), \\\"-q\\\")\\n   192→\\tif err == nil {\\n   193→\\t\\tt.Fatal(\\\"performGitResetHard() should reject hashes starting with '-', got nil\\\")\\n   194→\\t}\\n   195→\\tif !strings.Contains(err.Error(), \\\"invalid commit hash\\\") {\\n   196→\\t\\tt.Errorf(\\\"performGitResetHard() error = %q, want error containing 'invalid commit hash'\\\", err.Error())\\n   197→\\t}\\n   198→}\\n   199→\\n   200→func TestResumeFromCurrentBranch_NoCheckpoint(t *testing.T) {\\n   201→\\ttmpDir := t.TempDir()\\n   202→\\tt.Chdir(tmpDir)\\n   203→\\n   204→\\t// Initialize repo with initial commit (no checkpoint trailer)\\n   205→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   206→\\n   207→\\t// Run resumeFromCurrentBranch - should not error, just report no checkpoint found\\n   208→\\terr := resumeFromCurrentBranch(context.Background(), \\\"master\\\", false)\\n   209→\\tif err != nil {\\n   210→\\t\\tt.Errorf(\\\"resumeFromCurrentBranch() returned error for commit without checkpoint: %v\\\", err)\\n   211→\\t}\\n   212→}\\n   213→\\n   214→func TestRunResume_AlreadyOnBranch(t *testing.T) {\\n   215→\\ttmpDir := t.TempDir()\\n   216→\\tt.Chdir(tmpDir)\\n   217→\\n   218→\\t// Set up a fake Claude project directory for testing\\n   219→\\tclaudeDir := filepath.Join(tmpDir, \\\"claude-projects\\\")\\n   220→\\tt.Setenv(\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR\\\", claudeDir)\\n   221→\\n   222→\\t_, w, _ := setupResumeTestRepo(t, tmpDir, true)\\n   223→\\n   224→\\t// Checkout feature branch\\n   225→\\tif err := w.Checkout(&git.CheckoutOptions{\\n   226→\\t\\tBranch: plumbing.NewBranchReferenceName(\\\"feature\\\"),\\n   227→\\t}); err != nil {\\n   228→\\t\\tt.Fatalf(\\\"Failed to checkout feature branch: %v\\\", err)\\n   229→\\t}\\n   230→\\n   231→\\t// Run resume on the branch we're already on - should skip checkout\\n   232→\\terr := runResume(context.Background(), \\\"feature\\\", false)\\n   233→\\t// Should not error (no session, but shouldn't error)\\n   234→\\tif err != nil {\\n   235→\\t\\tt.Errorf(\\\"runResume() returned error when already on branch: %v\\\", err)\\n   236→\\t}\\n   237→}\\n   238→\\n   239→func TestRunResume_BranchDoesNotExist(t *testing.T) {\\n   240→\\ttmpDir := t.TempDir()\\n   241→\\tt.Chdir(tmpDir)\\n   242→\\n   243→\\tsetupResumeTestRepo(t, tmpDir, false)\\n   244→\\n   245→\\t// Run resume on a branch that doesn't exist\\n   246→\\terr := runResume(context.Background(), \\\"nonexistent\\\", false)\\n   247→\\tif err == nil {\\n   248→\\t\\tt.Error(\\\"runResume() expected error for nonexistent branch, got nil\\\")\\n   249→\\t}\\n   250→}\\n   251→\\n   252→func TestRunResume_UncommittedChanges(t *testing.T) {\\n   253→\\ttmpDir := t.TempDir()\\n   254→\\tt.Chdir(tmpDir)\\n   255→\\n   256→\\tsetupResumeTestRepo(t, tmpDir, true)\\n   257→\\n   258→\\t// Make uncommitted changes\\n   259→\\ttestFile := filepath.Join(tmpDir, \\\"test.txt\\\")\\n   260→\\tif err := os.WriteFile(testFile, []byte(\\\"uncommitted modification\\\"), 0o644); err != nil {\\n   261→\\t\\tt.Fatalf(\\\"Failed to modify test file: %v\\\", err)\\n   262→\\t}\\n   263→\\n   264→\\t// Run resume - should fail due to uncommitted changes\\n   265→\\terr := runResume(context.Background(), \\\"feature\\\", false)\\n   266→\\tif err == nil {\\n   267→\\t\\tt.Error(\\\"runResume() expected error for uncommitted changes, got nil\\\")\\n   268→\\t}\\n   269→}\\n   270→\\n   271→// createCheckpointOnMetadataBranch creates a checkpoint on the entire/checkpoints/v1 branch\\n   272→// with a default checkpoint ID (\\\"abc123def456\\\") and default timestamp.\\n   273→func createCheckpointOnMetadataBranch(t *testing.T, repo *git.Repository, sessionID string) id.CheckpointID {\\n   274→\\tt.Helper()\\n   275→\\treturn createCheckpointOnMetadataBranchFull(t, repo, sessionID, id.MustCheckpointID(\\\"abc123def456\\\"), time.Date(2025, 1, 1, 0, 0, 0, 0, time.UTC))\\n   276→}\\n   277→\\n   278→// createCheckpointOnMetadataBranchFull creates a checkpoint on the entire/checkpoints/v1 branch\\n   279→// with a caller-specified checkpoint ID and timestamp.\\n   280→func createCheckpointOnMetadataBranchFull(t *testing.T, repo *git.Repository, sessionID string, checkpointID id.CheckpointID, createdAt time.Time) id.CheckpointID {\\n   281→\\tt.Helper()\\n   282→\\n   283→\\t// Get existing metadata branch or create it\\n   284→\\tif err := strategy.EnsureMetadataBranch(repo); err != nil {\\n   285→\\t\\tt.Fatalf(\\\"Failed to ensure metadata branch: %v\\\", err)\\n   286→\\t}\\n   287→\\n   288→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   289→\\tref, err := repo.Reference(refName, true)\\n   290→\\tif err != nil {\\n   291→\\t\\tt.Fatalf(\\\"Failed to get metadata branch ref: %v\\\", err)\\n   292→\\t}\\n   293→\\n   294→\\tparentCommit, err := repo.CommitObject(ref.Hash())\\n   295→\\tif err != nil {\\n   296→\\t\\tt.Fatalf(\\\"Failed to get parent commit: %v\\\", err)\\n   297→\\t}\\n   298→\\n   299→\\t// Create metadata content\\n   300→\\tmetadataJSON := fmt.Sprintf(`{\\n   301→  \\\"checkpoint_id\\\": %q,\\n   302→  \\\"session_id\\\": %q,\\n   303→  \\\"created_at\\\": %q\\n   304→}`, checkpointID.String(), sessionID, createdAt.Format(time.RFC3339))\\n   305→\\n   306→\\t// Create blob for metadata\\n   307→\\tblob := repo.Storer.NewEncodedObject()\\n   308→\\tblob.SetType(plumbing.BlobObject)\\n   309→\\twriter, err := blob.Writer()\\n   310→\\tif err != nil {\\n   311→\\t\\tt.Fatalf(\\\"Failed to