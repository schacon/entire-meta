rst (new format)\\n   376→\\tvar summary checkpoint.CheckpointSummary\\n   377→\\tif err := json.Unmarshal([]byte(content), &summary); err == nil {\\n   378→\\t\\t// If we have sessions array, this is the new format\\n   379→\\t\\tif len(summary.Sessions) > 0 {\\n   380→\\t\\t\\tinfo := &CheckpointInfo{\\n   381→\\t\\t\\t\\tCheckpointID:     summary.CheckpointID,\\n   382→\\t\\t\\t\\tCheckpointsCount: summary.CheckpointsCount,\\n   383→\\t\\t\\t\\tFilesTouched:     summary.FilesTouched,\\n   384→\\t\\t\\t\\tSessionCount:     len(summary.Sessions),\\n   385→\\t\\t\\t}\\n   386→\\n   387→\\t\\t\\t// Read all sessions' metadata to populate SessionIDs and get other fields from first session\\n   388→\\t\\t\\tvar sessionIDs []string\\n   389→\\t\\t\\tfor i, sessionPaths := range summary.Sessions {\\n   390→\\t\\t\\t\\tif sessionPaths.Metadata != \\\"\\\" {\\n   391→\\t\\t\\t\\t\\t// SessionFilePaths now contains absolute paths with leading \\\"/\\\"\\n   392→\\t\\t\\t\\t\\t// Strip the leading \\\"/\\\" for tree.File() which expects paths without leading slash\\n   393→\\t\\t\\t\\t\\tsessionMetadataPath := strings.TrimPrefix(sessionPaths.Metadata, \\\"/\\\")\\n   394→\\t\\t\\t\\t\\tif sessionFile, err := tree.File(sessionMetadataPath); err == nil {\\n   395→\\t\\t\\t\\t\\t\\tif sessionContent, err := sessionFile.Contents(); err == nil {\\n   396→\\t\\t\\t\\t\\t\\t\\tvar sessionMetadata checkpoint.CommittedMetadata\\n   397→\\t\\t\\t\\t\\t\\t\\tif json.Unmarshal([]byte(sessionContent), &sessionMetadata) == nil {\\n   398→\\t\\t\\t\\t\\t\\t\\t\\tsessionIDs = append(sessionIDs, sessionMetadata.SessionID)\\n   399→\\t\\t\\t\\t\\t\\t\\t\\t// Use first session for Agent, SessionID, CreatedAt, IsTask, ToolUseID\\n   400→\\t\\t\\t\\t\\t\\t\\t\\tif i == 0 {\\n   401→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.Agent = sessionMetadata.Agent\\n   402→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.SessionID = sessionMetadata.SessionID\\n   403→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.CreatedAt = sessionMetadata.CreatedAt\\n   404→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.IsTask = sessionMetadata.IsTask\\n   405→\\t\\t\\t\\t\\t\\t\\t\\t\\tinfo.ToolUseID = sessionMetadata.ToolUseID\\n   406→\\t\\t\\t\\t\\t\\t\\t\\t}\\n   407→\\t\\t\\t\\t\\t\\t\\t}\\n   408→\\t\\t\\t\\t\\t\\t}\\n   409→\\t\\t\\t\\t\\t}\\n   410→\\t\\t\\t\\t}\\n   411→\\t\\t\\t}\\n   412→\\t\\t\\tinfo.SessionIDs = sessionIDs\\n   413→\\n   414→\\t\\t\\treturn info, nil\\n   415→\\t\\t}\\n   416→\\t}\\n   417→\\n   418→\\t// Fall back to parsing as CheckpointInfo (old format or direct info)\\n   419→\\tvar metadata CheckpointInfo\\n   420→\\tif err := json.Unmarshal([]byte(content), &metadata); err != nil {\\n   421→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse metadata: %w\\\", err)\\n   422→\\t}\\n   423→\\n   424→\\treturn &metadata, nil\\n   425→}\\n   426→\\n   427→// GetMetadataBranchTree returns the tree object for the entire/checkpoints/v1 branch.\\n   428→func GetMetadataBranchTree(repo *git.Repository) (*object.Tree, error) {\\n   429→\\trefName := plumbing.NewBranchReferenceName(paths.MetadataBranchName)\\n   430→\\tref, err := repo.Reference(refName, true)\\n   431→\\tif err != nil {\\n   432→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch reference: %w\\\", err)\\n   433→\\t}\\n   434→\\n   435→\\tcommit, err := repo.CommitObject(ref.Hash())\\n   436→\\tif err != nil {\\n   437→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch commit: %w\\\", err)\\n   438→\\t}\\n   439→\\n   440→\\ttree, err := commit.Tree()\\n   441→\\tif err != nil {\\n   442→\\t\\treturn nil, fmt.Errorf(\\\"failed to get metadata branch tree: %w\\\", err)\\n   443→\\t}\\n   444→\\treturn tree, nil\\n   445→}\\n   446→\\n   447→// ExtractFirstPrompt extracts and truncates the first meaningful prompt from prompt content.\\n   448→// Prompts are separated by \\\"\\\\n\\\\n---\\\\n\\\\n\\\". Skips empty prompts and separator-only content.\\n   449→// Returns empty string if no valid prompt is found.\\n   450→func Extr