ly, check if it exists on remote\\n    77→\\t\\tremoteExists, err := BranchExistsOnRemote(ctx, branchName)\\n    78→\\t\\tif err != nil {\\n    79→\\t\\t\\treturn fmt.Errorf(\\\"failed to check remote branch: %w\\\", err)\\n    80→\\t\\t}\\n    81→\\n    82→\\t\\tif !remoteExists {\\n    83→\\t\\t\\treturn fmt.Errorf(\\\"branch '%s' not found locally or on origin\\\", branchName)\\n    84→\\t\\t}\\n    85→\\n    86→\\t\\t// Ask user if they want to fetch from remote\\n    87→\\t\\tshouldFetch, err := promptFetchFromRemote(branchName)\\n    88→\\t\\tif err != nil {\\n    89→\\t\\t\\treturn err\\n    90→\\t\\t}\\n    91→\\t\\tif !shouldFetch {\\n    92→\\t\\t\\treturn nil\\n    93→\\t\\t}\\n    94→\\n    95→\\t\\t// Fetch and checkout the remote branch\\n    96→\\t\\tfmt.Fprintf(os.Stderr, \\\"Fetching branch '%s' from origin...\\\\n\\\", branchName)\\n    97→\\t\\tif err := FetchAndCheckoutRemoteBranch(ctx, branchName); err != nil {\\n    98→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n    99→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   100→\\t\\t}\\n   101→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   102→\\t} else {\\n   103→\\t\\t// Branch exists locally, check for uncommitted changes before checkout\\n   104→\\t\\thasChanges, err := HasUncommittedChanges(ctx)\\n   105→\\t\\tif err != nil {\\n   106→\\t\\t\\treturn fmt.Errorf(\\\"failed to check for uncommitted changes: %w\\\", err)\\n   107→\\t\\t}\\n   108→\\t\\tif hasChanges {\\n   109→\\t\\t\\treturn errors.New(\\\"you have uncommitted changes. Please commit or stash them first\\\")\\n   110→\\t\\t}\\n   111→\\n   112→\\t\\t// Checkout the branch\\n   113→\\t\\tif err := CheckoutBranch(ctx, branchName); err != nil {\\n   114→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Failed to checkout branch: %v\\\\n\\\", err)\\n   115→\\t\\t\\treturn NewSilentError(errors.New(\\\"failed to checkout branch\\\"))\\n   116→\\t\\t}\\n   117→\\t\\tfmt.Fprintf(os.Stderr, \\\"Switched to branch '%s'\\\\n\\\", branchName)\\n   118→\\t}\\n   119→\\n   120→\\treturn resumeFromCurrentBranch(ctx, branchName, force)\\n   121→}\\n   122→\\n   123→func resumeFromCurrentBranch(ctx context.Context, branchName string, force bool) error {\\n   124→\\trepo, err := openRepository(ctx)\\n   125→\\tif err != nil {\\n   126→\\t\\treturn fmt.Errorf(\\\"not a git repository: %w\\\", err)\\n   127→\\t}\\n   128→\\n   129→\\t// Find a commit with an Entire-Checkpoint trailer, looking at branch-only commits\\n   130→\\tresult, err := findBranchCheckpoints(repo, branchName)\\n   131→\\tif err != nil {\\n   132→\\t\\treturn err\\n   133→\\t}\\n   134→\\tif len(result.checkpointIDs) == 0 {\\n   135→\\t\\tfmt.Fprintf(os.Stderr, \\\"No Entire checkpoint found on branch '%s'\\\\n\\\", branchName)\\n   136→\\t\\treturn nil\\n   137→\\t}\\n   138→\\n   139→\\t// If there are newer commits without checkpoints, ask for confirmation.\\n   140→\\t// Merge commits (e.g., from merging main) don't count as \\\"work\\\" and are skipped silently.\\n   141→\\tif result.newerCommitsExist && !force {\\n   142→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found checkpoint in an older commit.\\\\n\\\")\\n   143→\\t\\tfmt.Fprintf(os.Stderr, \\\"There are %d newer commit(s) on this branch without checkpoints.\\\\n\\\", result.newerCommitCount)\\n   144→\\t\\tfmt.Fprintf(os.Stderr, \\\"Checkpoint from: %s %s\\\\n\\\\n\\\", result.commitHash[:7], firstLine(result.commitMessage))\\n   145→\\n   146→\\t\\tshouldResume, err := promptResumeFromOlderCheckpoint()\\n   147→\\t\\tif err != nil {\\n   148→\\t\\t\\treturn err\\n   149→\\t\\t}\\n   150→\\t\\tif !shouldResume {\\n   151→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Resume cancelled.\\\\n\\\")\\n   152→\\t\\t\\treturn nil\\n   153→\\t\\t}\\n   154→\\t}\\n   155→\\n   156→\\tcheckpointID := result.checkpointIDs[0]\\n   157→\\n   158→\\t// Multiple checkpoints (squash merge): resolve latest and resume from it\\n   159→\\tif len(result.checkpointIDs) > 1 {\\n   160→\\t\\tlatest, err := resolveLatestCheckpoint(repo, result.checkpointIDs)\\n   161→\\t\\tif err != nil {\\n   162→\\t\\t\\t// Fallback: use last trailer\\n   163→\\t\\t\\tlatest = result.checkpointIDs[len(result.checkpointIDs)-1]\\n   164→\\t\\t}\\n   165→\\t\\tskipped := len(result.checkpointIDs) - 1\\n   166→\\t\\tfmt.Fprintf(os.Stderr, \\\"Found %d checkpoints on the latest commit in this branch, resuming from the latest (%d older checkpoints skipped)\\\\n\\\",\\n   167→\\t\\t\\tlen(result.checkpointIDs), skipped)\\n   168→\\t\\tcheckpointID = latest\\n   169→\\t}\\n   170→\\n   171→\\t// Get metadata branch tree for lookups\\n   172→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   173→\\tif err != nil {\\n   174→\\t\\t// No local metadata branch, check if remote has it\\n   175→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   176→\\t}\\n   177→\\n   178→\\t// Look up metadata from sharded path\\n   179→\\tmetadata, err := strategy.ReadCheckpointMetadata(metadataTree, checkpointID.Path())\\n   180→\\tif err != nil {\\n   181→\\t\\t// Checkpoint exists in commit but no local metadata - check remote\\n   182→\\t\\treturn checkRemoteMetadata(ctx, repo, checkpointID)\\n   183→\\t}\\n   184→\\n   185→\\treturn resumeSession(ctx, metadata.SessionID, checkpointID, force)\\n   186→}\\n   187→\\n   188→// resolveLatestCheckpoint reads metadata for each checkpoint ID and returns\\n   189→// the one with the latest CreatedAt. It tries the local metadata branch first,\\n   190→// then fetches from remote, then falls back to the remote tree directly.\\n   191→func resolveLatestCheckpoint(repo *git.Repository, checkpointIDs []id.CheckpointID) (id.CheckpointID, error) {\\n   192→\\tmetadataTree, err := getMetadataTree(repo)\\n   193→\\tif err != nil {\\n   194→\\t\\treturn id.EmptyCheckpointID, err\\n   195→\\t}\\n   196→\\tsorted := collectCheckpointsByAge(metadataTree, checkpointIDs)\\n   197→\\tif len(sorted) == 0 {\\n   198→\\t\\treturn id.EmptyCheckpointID, errors.New(\\\"no checkpoint metadata found\\\")\\n   199→\\t}\\n   200→\\treturn sorted[len(sorted)-1].CheckpointID, nil\\n   201→}\\n   202→\\n   203→// getMetadataTree returns the metadata branch tree, trying local first,\\n   204→// then fetching from remote, then falling back to the remote tree directly.\\n   205→func getMetadataTree(repo *git.Repository) (*object.Tree, error) {\\n   206→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   207→\\tif err == nil {\\n   208→\\t\\treturn metadataTree, nil\\n   209→\\t}\\n   210→\\n   211→\\t// Try fetching from remote\\n   212→\\tif fetchErr := FetchMetadataBranch(context.Background()); fetchErr == nil {\\n   213→\\t\\tmetadataTree, err = strategy.GetMetadataBranchTree(repo)\\n   214→\\t\\tif err == nil {\\n   215→\\t\\t\\treturn metadataTree, nil\\n   216→\\t\\t}\\n   217→\\t}\\n   218→\\n   219→\\t// Try remote tree directly\\n   220→\\tremoteTree, remoteErr := strategy.GetRemoteMetadataBranchTree(repo)\\n   221→\\tif remoteErr != nil {\\n   222→\\t\\treturn nil, fmt.Errorf(\\\"metadata branch not available: %w\\\", remoteErr)\\n   223→\\t}\\n   224→\\treturn remoteTree, nil\\n   225→}\\n   226→\\n   227→// collectCheckpointsByAge reads metadata for each checkpoint ID from the tree,\\n   228→// skips any that can't be read, and returns them sorted by CreatedAt ascending.\\n   229→// Sorting ensures the newest checkpoint is restored last and wins on disk,\\n   230→// regardless of trailer order in the commit message.\\n   231→func collectCheckpointsByAge(tree *object.Tree, checkpointIDs []id.CheckpointID) []*strategy.CheckpointInfo {\\n   232→\\tvar checkpoints []*strategy.CheckpointInfo\\n   233→\\tfor _, cpID := range checkpointIDs {\\n   234→\\t\\tmetadata, err := strategy.ReadCheckpointMetadata(tree, cpID.Path())\\n   235→\\t\\tif err != nil {\\n   236→\\t\\t\\tcontinue\\n   237→\\t\\t}\\n   238→\\t\\tcheckpoints = append(checkpoints, metadata)\\n   239→\\t}\\n   240→\\tsort.Slice(checkpoints, func(i, j int) bool {\\n   241→\\t\\treturn checkpoints[i].CreatedAt.Before(checkpoints[j].CreatedAt)\\n   242→\\t})\\n   243→\\treturn checkpoints\\n   244→}\\n   245→\\n   246→// branchCheckpointsResult contains the result of searching for checkpoints on a branch.\\n   247→type branchCheckpointsResult struct {\\n   248→\\tcheckpointIDs     []id.CheckpointID\\n   249→\\tcommitHash        string\\n   250→\\tcommitMessage     string\\n   251→\\tnewerCommitsExist bool // true if there are branch-only commits (not merge commits) without checkpoints\\n   252→\\tnewerCommitCount  int  // count of branch-only commits without checkpoints\\n   253→}\\n   254→\\n   255→// findBranchCheckpoints finds the most recent commit with an Entire-Checkpoint trailer\\n   256→// among commits that are unique to this branch (not reachable from the default branch).\\n   257→// This handles the case where main has been merged into the feature branch.\\n   258→func findBranchCheckpoints(repo *git.Repository, branchName string) (*branchCheckpointsResult, error) {\\n   259→\\tresult := &branchCheckpointsResult{}\\n   260→\\n   261→\\t// Get HEAD commit\\n   262→\\thead, err := repo.Head()\\n   263→\\tif err != nil {\\n   264→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD: %w\\\", err)\\n   265→\\t}\\n   266→\\n   267→\\theadCommit, err := repo.CommitObject(head.Hash())\\n   268→\\tif err != nil {\\n   269→\\t\\treturn nil, fmt.Errorf(\\\"failed to get HEAD commit: %w\\\", err)\\n   270→\\t}\\n   271→\\n   272→\\t// First, check if HEAD itself has a checkpoint (most common case)\\n   273→\\tif cpIDs := trailers.ParseAllCheckpoints(headCommit.Message); len(cpIDs) > 0 {\\n   274→\\t\\tresult.checkpointIDs = cpIDs\\n   275→\\t\\tresult.commitHash = head.Hash().String()\\n   276→\\t\\tresult.commitMessage = headCommit.Message\\n   277→\\t\\tresult.newerCommitsExist = false\\n   278→\\t\\treturn result, nil\\n   279→\\t}\\n   280→\\n   281→\\t// HEAD doesn't have a checkpoint - find branch-only commits\\n   282→\\t// Get the default branch name\\n   283→\\tdefaultBranch := getDefaultBranchFromRemote(repo)\\n   284→\\tif defaultBranch == \\\"\\\" {\\n   285→\\t\\t// Fallback: try common names\\n   286→\\t\\tfor _, name := range []string{\\\"main\\\", \\\"master\\\"} {\\n   287→\\t\\t\\tif _, err := repo.Reference(plumbing.NewBranchReferenceName(name), true); err == nil {\\n   288→\\t\\t\\t\\tdefaultBranch = name\\n   289→\\t\\t\\t\\tbreak\\n   290→\\t\\t\\t}\\n   291→\\t\\t}\\n   292→\\t}\\n   293→\\n   294→\\t// If we can't find a default branch, or we're on it, just walk all commits\\n   295→\\tif defaultBranch == \\\"\\\" || defaultBranch == branchName {\\n   296→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil\\n   297→\\t}\\n   298→\\n   299→\\t// Get the default branch reference\\n   300→\\tdefaultRef, err := repo.Reference(plumbing.NewBranchReferenceName(defaultBranch), true)\\n   301→\\tif err != nil {\\n   302→\\t\\t// Default branch doesn't exist locally, fall back to walking all commits\\n   303→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   304→\\t}\\n   305→\\n   306→\\tdefaultCommit, err := repo.CommitObject(defaultRef.Hash())\\n   307→\\tif err != nil {\\n   308→\\t\\t// Can't get default commit, fall back to walking all commits\\n   309→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   310→\\t}\\n   311→\\n   312→\\t// Find merge base\\n   313→\\tmergeBase, err := headCommit.MergeBase(defaultCommit)\\n   314→\\tif err != nil || len(mergeBase) == 0 {\\n   315→\\t\\t// No common ancestor, fall back to walking all commits\\n   316→\\t\\treturn findCheckpointInHistory(headCommit, nil), nil //nolint:nilerr // Intentional fallback\\n   317→\\t}\\n   318→\\n   319→\\t// Walk from HEAD to merge base, looking for checkpoint\\n   320→\\treturn findCheckpointInHistory(headCommit, &mergeBase[0].Hash), nil\\n   321→}\\n   322→\\n   323→// findCheckpointInHistory walks commit history from start looking for a checkpoint trailer.\\n   324→// If stopAt is provided, stops when reaching that commit (exclusive).\\n   325→// Returns the first checkpoint found and info about commits between HEAD and the checkpoint.\\n   326→// It distinguishes between merge commits (bringing in other branches) and regular commits\\n   327→// (actual branch work) to avoid false warnings after merging main.\\n   328→func findCheckpointInHistory(start *object.Commit, stopAt *plumbing.Hash) *branchCheckpointsResult {\\n   329→\\tresult := &branchCheckpointsResult{}\\n   330→\\tbranchWorkCommits := 0 // Regular commits without checkpoints (actual work)\\n   331→\\tconst maxCommits = 100 // Limit search depth\\n   332→\\ttotalChecked := 0\\n   333→\\n   334→\\tcurrent := start\\n   335→\\tfor current != nil && totalChecked < maxCommits {\\n   336→\\t\\t// Stop if we've reached the boundary\\n   337→\\t\\tif stopAt != nil && current.Hash == *stopAt {\\n   338→\\t\\t\\tbreak\\n   339→\\t\\t}\\n   340→\\n   341→\\t\\t// Check for checkpoint trailer\\n   342→\\t\\tif cpIDs := trailers.ParseAllCheckpoints(current.Message); len(cpIDs) > 0 {\\n   343→\\t\\t\\tresult.checkpointIDs = cpIDs\\n   344→\\t\\t\\tresult.commitHash = current.Hash.String()\\n   345→\\t\\t\\tresult.commitMessage = current.Message\\n   346→\\t\\t\\t// Only warn about branch work commits, not merge commits\\n   347→\\t\\t\\tresult.newerCommitsExist = branchWorkCommits > 0\\n   348→\\t\\t\\tresult.newerCommitCount = branchWorkCommits\\n   349→\\t\\t\\treturn result\\n   350→\\t\\t}\\n   351→\\n   352→\\t\\t// Only count regular commits (not merge commits) as \\\"branch work\\\"\\n   353→\\t\\tif current.NumParents() <= 1 {\\n   354→\\t\\t\\tbranchWorkCommits++\\n   355→\\t\\t}\\n   356→\\n   357→\\t\\ttotalChecked++\\n   358→\\n   359→\\t\\t// Move to parent (first parent for merge commits -