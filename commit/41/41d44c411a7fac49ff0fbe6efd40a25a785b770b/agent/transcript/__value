 = %v\\\", err)\\n  1005→\\t}\\n  1006→\\n  1007→\\tif loaded.SessionID != original.SessionID {\\n  1008→\\t\\tt.Errorf(\\\"SessionID = %q, want %q\\\", loaded.SessionID, original.SessionID)\\n  1009→\\t}\\n  1010→\\tif loaded.BaseCommit != original.BaseCommit {\\n  1011→\\t\\tt.Errorf(\\\"BaseCommit = %q, want %q\\\", loaded.BaseCommit, original.BaseCommit)\\n  1012→\\t}\\n  1013→\\tif loaded.StepCount != original.StepCount {\\n  1014→\\t\\tt.Errorf(\\\"StepCount = %d, want %d\\\", loaded.StepCount, original.StepCount)\\n  1015→\\t}\\n  1016→}\\n  1017→\\n  1018→func TestShadowStrategy_GetCheckpointLog_WithCheckpointID(t *testing.T) {\\n  1019→\\t// This test verifies that GetCheckpointLog correctly uses the checkpoint ID\\n  1020→\\t// to look up the log. Since getCheckpointLog requires a full git setup\\n  1021→\\t// with entire/checkpoints/v1 branch, we test the lookup logic by checking error behavior.\\n  1022→\\n  1023→\\tdir := t.TempDir()\\n  1024→\\t_, err := git.PlainInit(dir, false)\\n  1025→\\tif err != nil {\\n  1026→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n  1027→\\t}\\n  1028→\\n  1029→\\tt.Chdir(dir)\\n  1030→\\n  1031→\\ts := NewManualCommitStrategy()\\n  1032→\\n  1033→\\t// Checkpoint with checkpoint ID (12 hex chars)\\n  1034→\\tcheckpoint := Checkpoint{\\n  1035→\\t\\tCheckpointID: \\\"a1b2c3d4e5f6\\\",\\n  1036→\\t\\tMessage:      \\\"Checkpoint: a1b2c3d4e5f6\\\",\\n  1037→\\t\\tTimestamp:    time.Now(),\\n  1038→\\t}\\n  1039→\\n  1040→\\t// This should attempt to call getCheckpointLog (which will fail because\\n  1041→\\t// there's no entire/checkpoints/v1 branch), but the important thing is it uses\\n  1042→\\t// the checkpoint ID to look up metadata\\n  1043→\\t_, err = s.GetCheckpointLog(context.Background(), checkpoint)\\n  1044→\\tif err == nil {\\n  1045→\\t\\tt.Error(\\\"GetCheckpointLog() expected error (no sessions branch), got nil\\\")\\n  1046→\\t}\\n  1047→\\t// The error should be about sessions branch, not about parsing\\n  1048→\\tif err != nil && err.Error() != \\\"sessions branch not found\\\" {\\n  1049→\\t\\tt.Logf(\\\"GetCheckpointLog() error = %v (expected sessions branch error)\\\", err)\\n  1050→\\t}\\n  1051→}\\n  1052→\\n  1053→func TestShadowStrategy_GetCheckpointLog_NoCheckpointID(t *testing.T) {\\n  1054→\\t// Test that checkpoints without checkpoint ID return ErrNoMetadata\\n  1055→\\tdir := t.TempDir()\\n  1056→\\t_, err := git.PlainInit(dir, false)\\n  1057→\\tif err != nil {\\n  1058→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n  1059→\\t}\\n  1060→\\n  1061→\\tt.Chdir(dir)\\n  1062→\\n  1063→\\ts := NewManualCommitStrategy()\\n  1064→\\n  1065→\\t// Checkpoint without checkpoint ID\\n  1066→\\tcheckpoint := Checkpoint{\\n  1067→\\t\\tCheckpointID: \\\"\\\",\\n  1068→\\t\\tMessage:      \\\"Some other message\\\",\\n  1069→\\t\\tTimestamp:    time.Now(),\\n  1070→\\t}\\n  1071→\\n  1072→\\t// This should return ErrNoMetadata since there's no checkpoint ID\\n  1073→\\t_, err = s.GetCheckpointLog(context.Background(), checkpoint)\\n  1074→\\tif err == nil {\\n  1075→\\t\\tt.Error(\\\"GetCheckpointLog() expected error for missing checkpoint ID, got nil\\\")\\n  1076→\\t}\\n  1077→\\tif !errors.Is(err, ErrNoMetadata) {\\n  1078→\\t\\tt.Errorf(\\\"GetCheckpointLog() expected ErrNoMetadata, got %v\\\", err)\\n  1079→\\t}\\n  1080→}\\n  1081→\\n  1082→func TestShadowStrategy_FilesTouched_OnlyModifiedFiles(t *testing.T) {\\n  1083→\\t// This test verifies that files_touched only contains files that were actually\\n  1084→\\t// modified during the session, not ALL files in the repository.\\n  1085→\\t//\\n  1086→\\t// The fix tracks files in SessionState.FilesTouched as they are modified,\\n  1087→\\t// rather than collecting all files from the shadow branch tree.\\n  1088→\\n  1089→\\tdir := t.TempDir()\\n  1090→\\trepo, err := git.PlainInit(dir, false)\\n  1091→\\tif err != nil {\\n  1092→\\t\\tt.Fatalf(\\\"failed to init git repo: %v\\\", err)\\n  1093→\\t}\\n  1094→\\n  1095→\\t// Create initial commit with multiple pre-existing files\\n  1096→\\tworktree, err := repo.Worktree()\\n  1097→\\tif err != nil {\\n  1098→\\t\\tt.Fatalf(\\\"failed to get worktree: %v\\\", err)\\n  1099→\\t}\\n  1100→\\n  1101→\\t// Create 3 pre-existing files that should NOT be in files_touched\\n  1102→\\tpreExistingFiles := []string{\\\"existing1.txt\\\", \\\"existing2.txt\\\", \\\"existing3.txt\\\"}\\n  1103→\\tfor _, f := range preExistingFiles {\\n  1104→\\t\\tfilePath := filepath.Join(dir, f)\\n  1105→\\t\\tif err := os.WriteFile(filePath, []byte(\\\"original content of \\\"+f), 0o644); err != nil {\\n  1106→\\t\\t\\tt.Fatalf(\\\"failed to write file %s: %v\\\", f, err)\\n  1107→\\t\\t}\\n  1108→\\t\\tif _, err := worktree.Add(f); err != nil {\\n  1109→\\t\\t\\tt.Fatalf(\\\"failed to add file %s: %v\\\", f, err)\\n  1110→\\t\\t}\\n  1111→\\t}\\n  1112→\\n  1113→\\t_, err = worktree.Commit(\\\"Initial commit with pre-existing files\\\", &git.CommitOptions{\\n  1114→\\t\\tAuthor: &object.Signature{Name: \\\"Test\\\", Email: \\\"test@test.com\\\", When: time.Now()},\\n  1115→\\t})\\n  1116→\\tif err != nil {\\n  1117→\\t\\tt.Fatalf(\\\"failed to commit: %v\\\", err)\\n  1118→\\t}\\n  1119→\\n  1120→\\tt.Chdir(dir)\\n  1121→\\n  1122→\\ts := &ManualCommitStrategy{}\\n  1123→\\tsessionID := \\\"2025-01-15-test-session-123\\\"\\n  1124→\\n  1125→\\t// Create metadata directory with a transcript\\n  1126→\\tmetadataDir := \\\".entire/metadata/\\\" + sessionID\\n  1127→\\tmetadataDirAbs := filepath.Join(dir, metadataDir)\\n  1128→\\tif err := os.MkdirAll(metadataDirAbs, 0o755); err != nil {\\n  1129→\\t\\tt.Fatalf(\\\"failed to create metadata dir: %v\\\", err)\\n  1130→\\t}\\n  1131→\\n  1132→\\t// Write transcript file (minimal valid JSONL)\\n  1133→\\ttranscript := `{\\\"type\\\":\\\"human\\\",\\\"message\\\":{\\\"content\\\":\\\"modify existing1.txt\\\"}}\\n  1134→{\\\"type\\\":\\\"assistant\\\",\\\"message\\\":{\\\"content\\\":\\\"I'll modify existing1.txt for you.\\\"}}\\n  1135→`\\n  1136→\\tif err := os.WriteFile(filepath.Join(metadataDirAbs, paths.TranscriptFileName), []byte(transcript), 0o644); err != nil {\\n  1137→\\t\\tt.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n  1138→\\t}\\n  1139→\\n  1140→\\t// First checkpoint using SaveStep - captures ALL working directory files\\n  1141→\\t// (for rewind purposes), but tracks only modified files in FilesTouched\\n  1142→\\terr = s.SaveStep(context.Background(), StepContext{\\n  1143→\\t\\tSessionID:      sessionID,\\n  1144→\\t\\tModifiedFiles:  []string{}, // No files modified yet\\n  1145→\\t\\tNewFiles:       []string{},\\n  1146→\\t\\tDeletedFiles:   []string{},\\n  1147→\\t\\tMetadataDir:    metadataDir,\\n  1148→\\t\\tMetadataDirAbs: metadataDirAbs,\\n  1149→\\t\\tCommitMessage:  \\\"Checkpoint 1\\\",\\n  1150→\\t\\tAuthorName:     \\\"Test\\\",\\n  1151→\\t\\tAuthorEmail:    \\\"test@test.com\\\",\\n  1152→\\t})\\n  1153→\\tif err != nil {\\n  1154→\\t\\tt.Fatalf(\\\"SaveStep() error = %v\\\", err)\\n  1155→\\t}\\n  1156→\\n  1157→\\t// Now simulate a second checkpoint where ONLY existing1.txt is modified\\n  1158→\\t// (but NOT existing2.txt or existing3.txt)\\n  1159→\\tmodifiedContent := []byte(\\\"MODIFIED content of existing1.txt\\\")\\n  1160→\\tif err := os.WriteFile(filepath.Join(dir, \\\"existing1.txt\\\"), modifiedContent, 0o644); err != nil {\\n  1161→\\t\\tt.Fatalf(\\\"failed to modify existing1.txt: %v\\\", err)\\n  1162→\\t}\\n  1163→\\n  1164→\\t// Second checkpoint using SaveStep - only modified file should be tracked\\n  1165→\\terr = s.SaveStep(context.Background(), StepContext{\\n  1166→\\t\\tSessionID:      sessionID,\\n  1167→\\t\\tModifiedFiles:  []string{\\\"existing1.txt\\\"}, // Only this file was modified\\n  1168→\\t\\tNewFiles:       []string{},\\n  1169→\\t\\tDeletedFiles:   []string{},\\n  1170→\\t\\tMetadataDir:    metadataDir,\\n  1171→\\t\\tMetadataDirAbs: metadataDirAbs,\\n  1172→\\t\\tCommitMessage:  \\\"Checkpoint 2\\\",\\n  1173→\\t\\tAuthorName:     \\\"Test\\\",\\n  1174→\\t\\tAuthorEmail:    \\\"test@test.com\\\",\\n  1175→\\t})\\n  1176→\\tif err != nil {\\n  1177→\\t\\tt.Fatalf(\\\"SaveStep() error = %v\\\", err)\\n  1178→\\t}\\n  1179→\\n  1180→\\t// Load session state to verify FilesTouched\\n  1181→\\tstate, err := s.loadSessionState(context.Background(), sessionID)\\n  1182→\\tif err != nil {\\n  1183→\\t\\tt.Fatalf(\\\"loadSessionState() error = %v\\\", err)\\n  1184→\\t}\\n  1185→\\n  1186→\\t// Now condense the session\\n  1187→\\tcheckpointID := id.MustCheckpointID(\\\"a1b2c3d4e5f6\\\")\\n  1188→\\tresult, err := s.CondenseSession(context.Background(), repo, checkpointID, state, nil)\\n  1189→\\tif err != nil {\\n  1190→\\t\\tt.Fatalf(\\\"CondenseSession() error = %v\\\", err)\\n  1191→\\t}\\n  1192→\\n  1193→\\t// Verify that files_touched only contains the file that was actually modified\\n  1194→\\texpectedFilesTouched := []string{\\\"existing1.txt\\\"}\\n  1195→\\n  1196→\\t// Check what we actually got\\n  1197→\\tif len(result.FilesTouched) != len(expectedFilesTouched) {\\n  1198→\\t\\tt.Errorf(\\\"FilesTouched contains %d files, want %d.\\\\nGot: %v\\\\nWant: %v\\\",\\n  1199→\\t\\t\\tlen(result.FilesTouched), len(expectedFilesTouched),\\n  1200→\\t\\t\\tresult.FilesTouched, expectedFilesTouched)\\n  1201→\\t}\\n  1202→\\n  1203→\\t// Verify the exact content\\n  1204→\\tfilesTouchedMap := make(map[string]bool)\\n  1205→\\tfor _, f := range result.FilesTouched {\\n  1206→\\t\\tfilesTouchedMap[f] = true\\n  1207→\\t}\\n  1208→\\n  1209→\\t// Check that ONLY the modified file is in files_touched\\n  1210→\\tfor _, expected := range expectedFilesTouched {\\n  1211→\\t\\tif !filesTouchedMap[expected] {\\n  1212→\\t\\t\\tt.Errorf(\\\"Expected file %q to be in files_touched, but it was not. Got: %v\\\", expected, result.FilesTouched)\\n  1213→\\t\\t}\\n  1214→\\t}\\n  1215→\\n  1216→\\t// Check that pre-existing unmodified files are NOT in files_touched\\n  1217→\\tunmodifiedFiles := []string{\\\"existing2.txt\\\", \\\"existing3.txt\\\"}\\n  1218→\\tfor _, unmodified := range unmodifiedFiles {\\n  1219→\\t\\tif filesTouchedMap[unmodified] {\\n  1220→\\t\\t\\tt.Errorf(\\\"File %q should NOT be in files_touched (it was not modified during the session), but it was included. Got: %v\\\",\\n  1221→\\t\\t\\t\\tunmodified, result.FilesTouched)\\n  1222→\\t\\t}\\n  1223→\\t}\\n  1224→}\\n  1225→\\n  1226→// TestDeleteShadowBranch verifies that deleteShadowBranch correctly deletes a shadow branch.\\n  1227→func TestDeleteShadowBranch(t *testing.T) {\\n  1228→\\tdir := t.TempDir()\\n  1229→\\trepo, err := git.PlainInit(dir, false)\\n  1230→\\tif err != nil {\\n  1231→\\t\\tt.Fatalf(\\\"failed to init repo: %v\\\", err)\\n  1232→\\t}\\n  1233→\\n  1234→\\tt.Chdir(dir)\\n  1235→\\n  1236→\\t// Create a dummy commit to use as branch target\\n  1237→\\temptyTreeHash := plumbing.NewHash(\\\"4b825dc642cb6eb9a060e54bf8d69288fbee4904\\\")\\n  1238→\\tdummyCommitHash, err := createCommit(repo, emptyTreeHash, plumbing.ZeroHash, \\\"dummy commit\\\", \\\"test\\\", \\\"test@test.com\\\")\\n  1239→\\tif err != nil {\\n  1240→\\t\\tt.Fatalf(\\\"failed to create dummy commit: %v\\\", err)\\n  1241→\\t}\\n  1242→\\n  1243→\\t// Create a shadow branch\\n  1244→\\tshadowBranchName := \\\"entire/abc1234\\\"\\n  1245→\\trefName := plumbing.NewBranchReferenceName(shadowBranchName)\\n  1246→\\tref := plumbing.NewHashReference(refName, dummyCommitHash)\\n  1247→\\tif err := repo.Storer.SetReference(ref); err != nil {\\n  1248→\\t\\tt.Fatalf(\\\"failed to create shadow branch: %v\\\", err)\\n  1249→\\t}\\n  1250→\\n  1251→\\t// Verify branch exists\\n  1252→\\t_, err = repo.Reference(refName, true)\\n  1253→\\tif err != nil {\\n  1254→\\t\\tt.Fatalf(\\\"shadow branch should exist: %v\\\", err)\\n  1255→\\t}\\n  1256→\\n  1257→\\t// Delete the shadow branch\\n  1258→\\terr = deleteShadowBranch(context.Background(), repo, shado