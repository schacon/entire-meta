  317→\\t\\tt.Fatalf(\\\"Failed to close writer: %v\\\", err)\\n   318→\\t}\\n   319→\\tmetadataBlobHash, err := repo.Storer.SetEncodedObject(blob)\\n   320→\\tif err != nil {\\n   321→\\t\\tt.Fatalf(\\\"Failed to store blob: %v\\\", err)\\n   322→\\t}\\n   323→\\n   324→\\t// Create session log blob\\n   325→\\tlogBlob := repo.Storer.NewEncodedObject()\\n   326→\\tlogBlob.SetType(plumbing.BlobObject)\\n   327→\\tlogWriter, err := logBlob.Writer()\\n   328→\\tif err != nil {\\n   329→\\t\\tt.Fatalf(\\\"Failed to create log blob writer: %v\\\", err)\\n   330→\\t}\\n   331→\\tif _, err := logWriter.Write([]byte(`{\\\"type\\\":\\\"test\\\"}`)); err != nil {\\n   332→\\t\\tt.Fatalf(\\\"Failed to write log blob: %v\\\", err)\\n   333→\\t}\\n   334→\\tif err := logWriter.Close(); err != nil {\\n   335→\\t\\tt.Fatalf(\\\"Failed to close log writer: %v\\\", err)\\n   336→\\t}\\n   337→\\tlogBlobHash, err := repo.Storer.SetEncodedObject(logBlob)\\n   338→\\tif err != nil {\\n   339→\\t\\tt.Fatalf(\\\"Failed to store log blob: %v\\\", err)\\n   340→\\t}\\n   341→\\n   342→\\t// Build tree structure: <id[:2]>/<id[2:]>/metadata.json\\n   343→\\tshardedPath := checkpointID.Path()\\n   344→\\tcheckpointIDStr := checkpointID.String()\\n   345→\\n   346→\\t// Create checkpoint tree with metadata and transcript files\\n   347→\\t// Entries must be sorted alphabetically\\n   348→\\tcheckpointTree := object.Tree{\\n   349→\\t\\tEntries: []object.TreeEntry{\\n   350→\\t\\t\\t{Name: paths.TranscriptFileName, Mode: filemode.Regular, Hash: logBlobHash},\\n   351→\\t\\t\\t{Name: paths.MetadataFileName, Mode: filemode.Regular, Hash: metadataBlobHash},\\n   352→\\t\\t},\\n   353→\\t}\\n   354→\\tcheckpointTreeObj := repo.Storer.NewEncodedObject()\\n   355→\\tif err := checkpointTree.Encode(checkpointTreeObj); err != nil {\\n   356→\\t\\tt.Fatalf(\\\"Failed to encode checkpoint tree: %v\\\", err)\\n   357→\\t}\\n   358→\\tcheckpointTreeHash, err := repo.Storer.SetEncodedObject(checkpointTreeO