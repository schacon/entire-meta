\\\"s1: got prompt %q, want %q\\\", got[0].Prompt, \\\"s1-new\\\")\\n   539→\\t\\t}\\n   540→\\t\\tif got[1].SessionID != \\\"s2\\\" {\\n   541→\\t\\t\\tt.Errorf(\\\"got[1].SessionID = %q, want %q\\\", got[1].SessionID, \\\"s2\\\")\\n   542→\\t\\t}\\n   543→\\t\\tif got[2].SessionID != \\\"s3\\\" {\\n   544→\\t\\t\\tt.Errorf(\\\"got[2].SessionID = %q, want %q\\\", got[2].SessionID, \\\"s3\\\")\\n   545→\\t\\t}\\n   546→\\t})\\n   547→}\\n   548→\\n   549→// TestResumeMultipleCheckpoints_SortsByCreatedAt verifies that resumeMultipleCheckpoints\\n   550→// sorts checkpoints by CreatedAt ascending before restoring, so that the newest checkpoint\\n   551→// writes last and wins on disk. This fixes the git CLI squash merge bug where trailers\\n   552→// appear in reverse chronological order (newest first).\\n   553→func TestResumeMultipleCheckpoints_SortsByCreatedAt(t *testing.T) {\\n   554→\\ttmpDir := t.TempDir()\\n   555→\\tt.Chdir(tmpDir)\\n   556→\\n   557→\\trepo, _, _ := setupResumeTestRepo(t, tmpDir, false)\\n   558→\\n   559→\\t// Create checkpoints with different timestamps.\\n   560→\\t// Simulate git CLI squash merge order: newest first in the commit message.\\n   561→\\tt1 := time.Date(2025, 1, 1, 10, 0, 0, 0, time.UTC) // oldest\\n   562→\\tt2 := time.Date(2025, 1, 1, 11, 0, 0, 0, time.UTC)\\n   563→\\tt3 := time.Date(2025, 1, 1, 12, 0, 0, 0, time.UTC) // newest\\n   564→\\n   565→\\tcpID1 := createCheckpointOnMetadataBranchFull(t, repo, \\\"session-oldest\\\", id.MustCheckpointID(\\\"aaa111bbb222\\\"), t1)\\n   566→\\tcpID2 := createCheckpointOnMetadataBranchFull(t, repo, \\\"session-middle\\\", id.MustCheckpointID(\\\"ccc333ddd444\\\"), t2)\\n   567→\\tcpID3 := createCheckpointOnMetadataBranchFull(t, repo, \\\"session-newest\\\", id.MustCheckpointID(\\\"eee555fff666\\\"), t3)\\n   568→\\n   569→\\tmetadataTree, err := strategy.GetMetadataBranchTree(repo)\\n   570→\\tif err != nil {\\n   571→\\t\\tt.Fatalf(\\\"Failed to get metadata branch tree: %v\\\", er