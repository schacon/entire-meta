\") != \\\"\\\" && os.Getenv(\\\"CURSOR_API_KEY\\\") == \\\"\\\" {\\n    69→\\t\\treturn errors.New(\\\"CURSOR_API_KEY must be set on CI for cursor-cli E2E tests\\\")\\n    70→\\t}\\n    71→\\n    72→\\t// Pre-create the cursor config directory so the CLI doesn't fail with\\n    73→\\t// ENOENT when writing cli-config.json (e.g., after accepting workspace trust).\\n    74→\\thome, err := os.UserHomeDir()\\n    75→\\tif err != nil {\\n    76→\\t\\treturn fmt.Errorf(\\\"get home dir: %w\\\", err)\\n    77→\\t}\\n    78→\\tdir := filepath.Join(home, \\\".config\\\", \\\"cursor\\\")\\n    79→\\tif err := os.MkdirAll(dir, 0o755); err != nil {\\n    80→\\t\\treturn fmt.Errorf(\\\"mkdir %s: %w\\\", dir, err)\\n    81→\\t}\\n    82→\\n    83→\\t// Pre-seed cli-config.json so Cursor doesn't need to create it via\\n    84→\\t// atomic temp-file rename, which races under parallel tests.\\n    85→\\tconfigFile := filepath.Join(dir, \\\"cli-config.json\\\")\\n    86→\\tif _, err := os.Stat(configFile); errors.Is(err, os.ErrNotExist) {\\n    87→\\t\\tif err := os.WriteFile(configFile, []byte(\\\"{}\\\"), 0o644); err != nil {\\n    88→\\t\\t\\treturn fmt.Errorf(\\\"write %s: %w\\\", configFile, err)\\n    89→\\t\\t}\\n    90→\\t}\\n    91→\\treturn nil\\n    92→}\\n    93→\\n    94→func (a *CursorCLI) RunPrompt(ctx context.Context, dir string, prompt string, opts ...Option) (Output, error) {\\n    95→\\tcfg := &runConfig{}\\n    96→\\tfor _, o := range opts {\\n    97→\\t\\to(cfg)\\n    98→\\t}\\n    99→\\n   100→\\ttimeout := 90 * time.Second\\n   101→\\tif cfg.PromptTimeout > 0 {\\n   102→\\t\\ttimeout = cfg.PromptTimeout\\n   103→\\t}\\n   104→\\n   105→\\tdisplayCmd := a.Binary() + \\\" --force --workspace \\\" + dir + \\\" (interactive prompt: \\\" + prompt + \\\")\\\"\\n   106→\\n   107→\\t// Start an interactive tmux session so all hooks fire\\n   108→\\t// (beforeSubmitPrompt and stop don't fire in headless -p mode).\\n   109→\\ts, err := a.startInteractiveSession(dir)\\n 