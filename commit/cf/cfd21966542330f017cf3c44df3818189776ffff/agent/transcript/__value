\"\\n    10→  // Store transcripts in a temp directory — these are ephemeral handoff files\\n    11→  // between the plugin and the Go hook handler. Once checkpointed, the data\\n    12→  // lives on git refs and the file is disposable.\\n    13→  const sanitized = directory.replace(/[^a-zA-Z0-9]/g, \\\"-\\\")\\n    14→  const transcriptDir = `${tmpdir()}/entire-opencode/${sanitized}`\\n    15→  const seenUserMessages = new Set<string>()\\n    16→\\n    17→  // In-memory stores — used to write transcripts without relying on the SDK API,\\n    18→  // which may be unavailable during shutdown.\\n    19→  // messageStore: keyed by message ID, stores message metadata (role, time, tokens, etc.)\\n    20→  const messageStore = new Map<string, any>()\\n    21→  // partStore: keyed by message ID, stores accumulated parts from message.part.updated events\\n    22→  const partStore = new Map<string, any[]>()\\n    23→  let currentSessionID: string | null = null\\n    24→  // Full session info from session.created — needed for OpenCode export format on resume/rewind\\n    25→  let currentSessionInfo: any = null\\n    26→\\n    27→  // Ensure transcript directory exists\\n    28→  await $`mkdir -p ${transcriptDir}`.quiet().nothrow()\\n    29→\\n    30→  /**\\n    31→   * Pipe JSON payload to an entire hooks command.\\n    32→   * Errors are logged but never thrown — plugin failures must not crash OpenCode.\\n    33→   */\\n    34→  async function callHook(hookName: string, payload: Record<string, unknown>) {\\n    35→    try {\\n    36→      const json = JSON.stringify(payload)\\n    37→      await $`echo ${json} | ${ENTIRE_CMD} hooks opencode ${hookName}`.quiet().nothrow()\\n    38→    } catch {\\n    39→      // Silently ignore — plugin failures must not crash OpenCode\\n    40→    }\\n    41→  }\\n    42→\\n    43→  /** Extract text content from a list of parts. */\\n    44→  function textFromParts(parts: any[]): string {\\n    45→    return parts\\n    46→      .filter((p: any) => p.type === \\\"text\\\")\\n    47→      .map((p: any) => p.text ?? \\\"\\\")\\n    48→      .join(\\\"\\\\n\\\")\\n    49→  }\\n    50→\\n    51→  /** Format a message object from its accumulated parts. */\\n    52→  function formatMessageFromStore(msg: any) {\\n    53→    const parts = partStore.get(msg.id) ?? []\\n    54→    return {\\n    55→      id: msg.id,\\n    56→      role: msg.role,\\n    57→      content: textFromParts(parts),\\n    58→      time: msg.time,\\n    59→      ...(msg.role === \\\"assistant\\\" ? {\\n    60→        tokens: msg.tokens,\\n    61→        cost: msg.cost,\\n    62→        parts: parts.map((p: any) => ({\\n    63→          type: p.type,\\n    64→          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n    65→          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n    66→        })),\\n    67→      } : {}),\\n    68→    }\\n    69→  }\\n    70→\\n    71→  /** Format a message from an API response (which includes parts inline). */\\n    72→  function formatMessageFromAPI(info: any, parts: any[]) {\\n    73→    return {\\n    74→      id: info.id,\\n    75→      role: info.role,\\n    76→      content: textFromParts(parts),\\n    77→      time: info.time,\\n    78→      ...(info.role === \\\"assistant\\\" ? {\\n    79→        tokens: info.tokens,\\n    80→        cost: info.cost,\\n    81→        parts: parts.map((p: any) => ({\\n    82→          type: p.type,\\n    83→          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n    84→          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n    85→        })),\\n    86→      } : {}),\\n    87→    }\\n    88→  }\\n    89→\\n    90→  /**\\n    91→   * Write transcript as JSONL (one message per line) from in-memory stores.\\n    92→   * This does NOT call the SDK API, so it works even during shutdown.\\n    93→   */\\n    94→  async function writeTranscriptFromMemory(sessionID: string): Promise<string> {\\n    95→    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n    96→    try {\\n    97→      const messages = Array.from(messageStore.values())\\n    98→        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n    99→\\n   100→      const lines = messages.map(msg => JSON.stringify(formatMessageFromStore(msg)))\\n   101→      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n   102→    } catch {\\n   103→      // Silently ignore write failures\\n   104→    }\\n   105→    return transcriptPath\\n   106→  }\\n   107→\\n   108→  /**\\n   109→   * Try to fetch messages via the SDK API (returns messages with parts inline)\\n   110→   * and write transcript as JSONL. Falls back to in-memory stores if the API is unavailable.\\n   111→   */\\n   112→  async function writeTranscriptWithFallback(sessionID: string): Promise<string> {\\n   113→    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n   114→    try {\\n   115→      const response = await client.session.message.list({ path: { id: sessionID } })\\n   116→      // API returns Array<{ info: Message, parts: Array<Part> }>\\n   117→      const items = response.data ?? []\\n   118→\\n   119→      const lines = items.map((item: any) =>\\n   120→        JSON.stringify(formatMessageFromAPI(item.info, item.parts ?? []))\\n   121→      )\\n   122→      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n   123→      return transcriptPath\\n   124→    } catch {\\n   125→      // API unavailable (likely shutting down) — fall back to in-memory stores\\n   126→      return writeTranscriptFromMemory(sessionID)\\n   127→    }\\n   128→  }\\n   129→\\n   130→  /**\\n   131→   * Write session in OpenCode's native export format (JSON).\\n   132→   * This file is used by `opencode import` during resume/rewind to restore\\n   133→   * the session into OpenCode's SQLite database with the original session ID.\\n   134→   */\\n   135→  async function writeExportJSON(sessionID: string): Promise<string> {\\n   136→    const exportPath = `${transcriptDir}/${sessionID}.export.json`\\n   137→    try {\\n   138→      const messages = Array.from(messageStore.values())\\n   139→        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n   140→\\n   141→      const exportData = {\\n   142→        info: currentSessionInfo ?? { id: sessionID },\\n   143→        messages: messages.map(msg => ({\\n   144→          info: msg,\\n   145→          parts: (partStore.get(msg.id) ?? []),\\n   146→        })),\\n   147→      }\\n   148→      await Bun.write(exportPath, JSON.stringify(exportData))\\n   149→    } catch {\\n   150→      // Silently ignore — plugin failures must not crash OpenCode\\n   151→    }\\n   152→    return exportPath\\n   153→  }\\n   154→\\n   155→  return {\\n   156→    event: async ({ event }) => {\\n   157→      switch (event.type) {\\n   158→        case \\\"session.created\\\": {\\n   159→          const session = (event as any).properties?.info\\n   160→          if (!session?.id) break\\n   161→          currentSessionID = session.id\\n   162→          currentSessionInfo = session\\n   163→          await callHook(\\\"session-start\\\", {\\n   164→            session_id: session.id,\\n   165→            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n   166→          })\\n   167→          break\\n   168→        }\\n   169→\\n   170→        case \\\"message.updated\\\": {\\n   171→          const msg = (event as any).properties?.info\\n   172→          if (!msg) break\\n   173→          // Store message metadata (role, time, tokens, etc.)\\n   174→          // Content is NOT on the message — it arrives via message.part.updated events.\\n   175→          messageStore.set(msg.id, msg)\\n   176→          break\\n   177→        }\\n   178→\\n   179→        case \\\"message.part.updated\\\": {\\n   180→          const part = (event as any).properties?.part\\n   181→          if (!part?.messageID) break\\n   182→\\n   183→          // Accumulate parts per message\\n   184→          const existing = partStore.get(part.messageID) ?? []\\n   185→          // Replace existing part with same id, or append new one\\n   186→          const idx = existing.findIndex((p: any) => p.id === part.id)\\n   187→          if (idx >= 0) {\\n   188→            existing[idx] = part\\n   189→          } else {\\n   190→            existing.push(part)\\n   191→          }\\n   192→          partStore.set(part.messageID, existing)\\n   193→\\n   194→          // Fire turn-start on the first text part of a new user message\\n   195→          const msg = messageStore.get(part.messageID)\\n   196→          if (msg?.role === \\\"user\\\" && part.type === \\\"text\\\" && !seenUserMessages.has(msg.id)) {\\n   197→            seenUserMessages.add(msg.id)\\n   198→            const sessionID = msg.sessionID ?? currentSessionID\\n   199→            if (sessionID) {\\n   200→              await callHook(\\\"turn-start\\\", {\\n   201→                session_id: sessionID,\\n   202→                transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n   203→                prompt: part.text ?? \\\"\\\",\\n   204→              })\\n   205→            }\\n   206→          }\\n   207→          break\\n   208→        }\\n   209→\\n   210→        case \\\"session.idle\\\": {\\n   211→          const sessionID = (event as any).properties?.sessionID\\n   212→          if (!sessionID) break\\n   213→          const transcriptPath = await writeTranscriptWithFallback(sessionID)\\n   214→          await writeExportJSON(sessionID)\\n   215→          await callHook(\\\"turn-end\\\", {\\n   216→            session_id: sessionID,\\n   217→            transcript_path: transcriptPath,\\n   218→          })\\n   219→          break\\n   220→        }\\n   221→\\n   222→        case \\\"session.compacted\\\": {\\n   223→          const sessionID = (event as any).properties?.sessionID\\n   224→          if (!sessionID) break\\n   225→          await callHook(\\\"compaction\\\", {\\n   226→            session_id: sessionID,\\n   227→            transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n   228→          })\\n   229→          break\\n   230→        }\\n   231→\\n   232→        case \\\"session.deleted\\\": {\\n   233→          const session = (event as any).properties?.info\\n   234→          if (!session?.id) break\\n   235→          // Write final transcript + export JSON before signaling session end\\n   236→          if (messageStore.size > 0) {\\n   237→            await writeTranscriptFromMemory(session.id)\\n   238→            await writeExportJSON(session.id)\\n   239→          }\\n   240→          seenUserMessages.clear()\\n   241→          messageStore.clear()\\n   242→          partStore.clear()\\n   243→          currentSessionID = null\\n   244→          currentSessionInfo = null\\n   245→          await callHook(\\\"session-end\\\", {\\n   246→            session_id: session.id,\\n   247→            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n   248→          })\\n   249→          break\\n   250→        }\\n   251→      }\\n   252→    },\\n   253→  }\\n   254→}\\n   255→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"fe487ec0-c625-4fd4-b2ee-6cbda92698ec\",\"timestamp\":\"2026-02-20T12:06:33.770Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/agent/opencode/entire_plugin.ts\",\"content\":\"// Entire CLI plugin for OpenCode\\n// Auto-generated by `entire enable --agent opencode`\\n// Do not edit manually — changes will be overwritten on next install.\\n// Requires Bun runtime (used by OpenCode's plugin system for loading ESM plugins).\\nimport type { Plugin } from \\\"@opencode-ai/plugin\\\"\\nimport { tmpdir } from \\\"node:os\\\"\\n\\nexport const EntirePlugin: Plugin = async ({ client, directory, $ }) => {\\n  const ENTIRE_CMD = \\\"__ENTIRE_CMD__\\\"\\n  // Store transcripts in a temp directory — these are ephemeral handoff files\\n  // between the plugin and the Go hook handler. Once checkpointed, the data\\n  // lives on git refs and the file is disposable.\\n  const sanitized = directory.replace(/[^a-zA-Z0-9]/g, \\\"-\\\")\\n  const transcriptDir = `${tmpdir()}/entire-opencode/${sanitized}`\\n  const seenUserMessages = new Set<string>()\\n\\n  // In-memory stores — used to write transcripts without relying on the SDK API,\\n  // which may be unavailable during shutdown.\\n  // messageStore: keyed by message ID, stores message metadata (role, time, tokens, etc.)\\n  const messageStore = new Map<string, any>()\\n  // partStore: keyed by message ID, stores accumulated parts from message.part.updated events\\n  const partStore = new Map<string, any[]>()\\n  let currentSessionID: string | null = null\\n  // Full session info from session.created — needed for OpenCode export format on resume/rewind\\n  let currentSessionInfo: any = null\\n\\n  // Ensure transcript directory exists\\n  await $`mkdir -p ${transcriptDir}`.quiet().nothrow()\\n\\n  /**\\n   * Pipe JSON payload to an entire hooks command.\\n   * Errors are logged but never thrown — plugin failures must not crash OpenCode.\\n   */\\n  async function callHook(hookName: string, payload: Record<string, unknown>) {\\n    try {\\n      const json = JSON.stringify(payload)\\n      await $`echo ${json} | ${ENTIRE_CMD} hooks opencode ${hookName}`.quiet().nothrow()\\n    } catch {\\n      // Silently ignore — plugin failures must not crash OpenCode\\n    }\\n  }\\n\\n  /** Extract text content from a list of parts. */\\n  function textFromParts(parts: any[]): string {\\n    return parts\\n      .filter((p: any) => p.type === \\\"text\\\")\\n      .map((p: any) => p.text ?? \\\"\\\")\\n      .join(\\\"\\\\n\\\")\\n  }\\n\\n  /** Format a message object from its accumulated parts. */\\n  function formatMessageFromStore(msg: any) {\\n    const parts = partStore.get(msg.id) ?? []\\n    return {\\n      id: msg.id,\\n      role: msg.role,\\n      content: textFromParts(parts),\\n      time: msg.time,\\n      ...(msg.role === \\\"assistant\\\" ? {\\n        tokens: msg.tokens,\\n        cost: msg.cost,\\n        parts: parts.map((p: any) => ({\\n          type: p.type,\\n          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n        })),\\n      } : {}),\\n    }\\n  }\\n\\n  /** Format a message from an API response (which includes parts inline). */\\n  function formatMessageFromAPI(info: any, parts: any[]) {\\n    return {\\n      id: info.id,\\n      role: info.role,\\n      content: textFromParts(parts),\\n      time: info.time,\\n      ...(info.role === \\\"assistant\\\" ? {\\n        tokens: info.tokens,\\n        cost: info.cost,\\n        parts: parts.map((p: any) => ({\\n          type: p.type,\\n          ...(p.type === \\\"text\\\" ? { text: p.text } : {}),\\n          ...(p.type === \\\"tool\\\" ? { tool: p.tool, callID: p.callID, state: p.state } : {}),\\n        })),\\n      } : {}),\\n    }\\n  }\\n\\n  /**\\n   * Write transcript as JSONL (one message per line) from in-memory stores.\\n   * This does NOT call the SDK API, so it works even during shutdown.\\n   */\\n  async function writeTranscriptFromMemory(sessionID: string): Promise<string> {\\n    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n    try {\\n      const messages = Array.from(messageStore.values())\\n        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n\\n      const lines = messages.map(msg => JSON.stringify(formatMessageFromStore(msg)))\\n      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n    } catch {\\n      // Silently ignore write failures\\n    }\\n    return transcriptPath\\n  }\\n\\n  /**\\n   * Try to fetch messages via the SDK API (returns messages with parts inline)\\n   * and write transcript as JSONL. Falls back to in-memory stores if the API is unavailable.\\n   */\\n  async function writeTranscriptWithFallback(sessionID: string): Promise<string> {\\n    const transcriptPath = `${transcriptDir}/${sessionID}.jsonl`\\n    try {\\n      const response = await client.session.message.list({ path: { id: sessionID } })\\n      // API returns Array<{ info: Message, parts: Array<Part> }>\\n      const items = response.data ?? []\\n\\n      const lines = items.map((item: any) =>\\n        JSON.stringify(formatMessageFromAPI(item.info, item.parts ?? []))\\n      )\\n      await Bun.write(transcriptPath, lines.join(\\\"\\\\n\\\") + \\\"\\\\n\\\")\\n      return transcriptPath\\n    } catch {\\n      // API unavailable (likely shutting down) — fall back to in-memory stores\\n      return writeTranscriptFromMemory(sessionID)\\n    }\\n  }\\n\\n  /**\\n   * Write session in OpenCode's native export format (JSON).\\n   * This file is used by `opencode import` during resume/rewind to restore\\n   * the session into OpenCode's SQLite database with the original session ID.\\n   */\\n  async function writeExportJSON(sessionID: string): Promise<string> {\\n    const exportPath = `${transcriptDir}/${sessionID}.export.json`\\n    try {\\n      const messages = Array.from(messageStore.values())\\n        .sort((a, b) => (a.time?.created ?? 0) - (b.time?.created ?? 0))\\n\\n      const exportData = {\\n        info: currentSessionInfo ?? { id: sessionID },\\n        messages: messages.map(msg => ({\\n          info: msg,\\n          parts: (partStore.get(msg.id) ?? []),\\n        })),\\n      }\\n      await Bun.write(exportPath, JSON.stringify(exportData))\\n    } catch {\\n      // Silently ignore — plugin failures must not crash OpenCode\\n    }\\n    return exportPath\\n  }\\n\\n  return {\\n    event: async ({ event }) => {\\n      switch (event.type) {\\n        case \\\"session.created\\\": {\\n          const session = (event as any).properties?.info\\n          if (!session?.id) break\\n          currentSessionID = session.id\\n          currentSessionInfo = session\\n          await callHook(\\\"session-start\\\", {\\n            session_id: session.id,\\n            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n          })\\n          break\\n        }\\n\\n        case \\\"message.updated\\\": {\\n          const msg = (event as any).properties?.info\\n          if (!msg) break\\n          // Store message metadata (role, time, tokens, etc.)\\n          // Content is NOT on the message — it arrives via message.part.updated events.\\n          messageStore.set(msg.id, msg)\\n          break\\n        }\\n\\n        case \\\"message.part.updated\\\": {\\n          const part = (event as any).properties?.part\\n          if (!part?.messageID) break\\n\\n          // Accumulate parts per message\\n          const existing = partStore.get(part.messageID) ?? []\\n          // Replace existing part with same id, or append new one\\n          const idx = existing.findIndex((p: any) => p.id === part.id)\\n          if (idx >= 0) {\\n            existing[idx] = part\\n          } else {\\n            existing.push(part)\\n          }\\n          partStore.set(part.messageID, existing)\\n\\n          // Fire turn-start on the first text part of a new user message\\n          const msg = messageStore.get(part.messageID)\\n          if (msg?.role === \\\"user\\\" && part.type === \\\"text\\\" && !seenUserMessages.has(msg.id)) {\\n            seenUserMessages.add(msg.id)\\n            const sessionID = msg.sessionID ?? currentSessionID\\n            if (sessionID) {\\n              await callHook(\\\"turn-start\\\", {\\n                session_id: sessionID,\\n                transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n                prompt: part.text ?? \\\"\\\",\\n              })\\n            }\\n          }\\n          break\\n        }\\n\\n        case \\\"session.idle\\\": {\\n          const sessionID = (event as any).properties?.sessionID\\n          if (!sessionID) break\\n          const transcriptPath = await writeTranscriptWithFallback(sessionID)\\n          await writeExportJSON(sessionID)\\n          await callHook(\\\"turn-end\\\", {\\n            session_id: sessionID,\\n            transcript_path: transcriptPath,\\n          })\\n          break\\n        }\\n\\n        case \\\"session.compacted\\\": {\\n          const sessionID = (event as any).properties?.sessionID\\n          if (!sessionID) break\\n          await callHook(\\\"compaction\\\", {\\n            session_id: sessionID,\\n            transcript_path: `${transcriptDir}/${sessionID}.jsonl`,\\n          })\\n          break\\n        }\\n\\n        case \\\"session.deleted\\\": {\\n          const session = (event as any).properties?.info\\n          if (!session?.id) break\\n          // Write final transcript + export JSON before signaling session end\\n          if (messageStore.size > 0) {\\n            await writeTranscriptFromMemory(session.id)\\n            await writeExportJSON(session.id)\\n          }\\n          seenUserMessages.clear()\\n          messageStore.clear()\\n          partStore.clear()\\n          currentSessionID = null\\n          currentSessionInfo = null\\n          await callHook(\\\"session-end\\\", {\\n            session_id: session.id,\\n            transcript_path: `${transcriptDir}/${session.id}.jsonl`,\\n          })\\n          break\\n        }\\n      }\\n    },\\n  }\\n}\\n\",\"numLines\":255,\"startLine\":1,\"totalLines\":255}},\"sourceToolAssistantUUID\":\"5f14f8fa-3638-46fd-a050-bd74a8a64dfd\"}\n{\"parentUuid\":\"d147988b-2ede-4ae1-a6bc-0acb0b1f56d5\",\"isSidechain\":false,\"userType\":\"external\",\"cwd\":\"/Users/soph/Work/entire/devenv/cli\",\"sessionId\":\"e5813e1b-2fe5-4d88-905e-4debfdb35a44\",\"version\":\"2.1.17\",\"gitBranch\":\"soph/better-agent-agent-instructions\",\"slug\":\"clever-singing-wozniak\",\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"tool_use_id\":\"toolu_01RsLz38iAAPXzhq5Rk56Qx9\",\"type\":\"tool_result\",\"content\":\"     1→// lifecycle.go implements the generic lifecycle event dispatcher.\\n     2→// It routes normalized events from any agent to the appropriate framework actions.\\n     3→//\\n     4→// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n     5→// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n     6→// the dispatcher handles all orchestration: state transitions, strategy calls,\\n     7→// file change detection, metadata generation.\\n     8→package cli\\n     9→\\n    10→import (\\n    11→\\t\\\"context\\\"\\n    12→\\t\\\"errors\\\"\\n    13→\\t\\\"fmt\\\"\\n    14→\\t\\\"log/slog\\\"\\n    15→\\t\\\"os\\\"\\n    16→\\t\\\"path/filepath\\\"\\n    17→\\t\\\"strings\\\"\\n    18→\\t\\\"time\\\"\\n    19→\\n    20→\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n    21→\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n    22→\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n    23→\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n    24→\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n    25→\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n    26→\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n    27→)\\n    28→\\n    29→// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n    30→// Returns nil if the event was handled successfully.\\n    31→func DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n    32→\\tif ag == nil {\\n    33→\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n    34→\\t}\\n    35→\\tif event == nil {\\n    36→\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n    37→\\t}\\n    38→\\n    39→\\tswitch event.Type {\\n    40→\\tcase agent.SessionStart:\\n    41→\\t\\treturn handleLifecycleSessionStart(ag, event)\\n    42→\\tcase agent.TurnStart:\\n    43→\\t\\treturn handleLifecycleTurnStart(ag, event)\\n    44→\\tcase agent.TurnEnd:\\n    45→\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n    46→\\tcase agent.Compaction:\\n    47→\\t\\treturn handleLifecycleCompaction(ag, event)\\n    48→\\tcase agent.SessionEnd:\\n    49→\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n    50→\\tcase agent.SubagentStart:\\n    51→\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n    52→\\tcase agent.SubagentEnd:\\n    53→\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n    54→\\tdefault:\\n    55→\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n    56→\\t}\\n    57→}\\n    58→\\n    59→// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n    60→// fires state machine transition.\\n    61→func handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n    62→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n    63→\\tlogging.Info(logCtx, \\\"session-start\\\",\\n    64→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n    65→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n    66→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n    67→\\t)\\n    68→\\n    69→\\tif event.SessionID == \\\"\\\" {\\n    70→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n    71→\\t}\\n    72→\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n    73→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n    74→\\t}\\n    75→\\n    76→\\t// Build informational message\\n    77→\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n    78→\\n    79→\\t// Check for concurrent sessions and append count if any\\n    80→\\tstrat := GetStrategy()\\n    81→\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n    82→\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n    83→\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n    84→\\t\\t}\\n    85→\\t}\\n    86→\\n    87→\\t// Output informational message\\n    88→\\tif event.ResponseMessage != \\\"\\\" {\\n    89→\\t\\tmessage = event.ResponseMessage\\n    90→\\t}\\n    91→\\tif err := outputHookResponse(message); err != nil {\\n    92→\\t\\treturn err\\n    93→\\t}\\n    94→\\n    95→\\t// Fire EventSessionStart for the current session (if state exists).\\n    96→\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n    97→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n    98→\\t} else if state != nil {\\n    99→\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   100→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n   101→\\t\\t}\\n   102→\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n   103→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n   104→\\t\\t}\\n   105→\\t}\\n   106→\\n   107→\\treturn nil\\n   108→}\\n   109→\\n   110→// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n   111→// ensures strategy setup, initializes session.\\n   112→func handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n   113→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   114→\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n   115→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   116→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   117→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   118→\\t)\\n   119→\\n   120→\\tsessionID := event.SessionID\\n   121→\\tif sessionID == \\\"\\\" {\\n   122→\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n   123→\\t}\\n   124→\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n   125→\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n   126→\\t}\\n   127→\\n   128→\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n   129→\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n   130→\\t\\treturn err\\n   131→\\t}\\n   132→\\n   133→\\t// Ensure strategy setup and initialize session\\n   134→\\tstrat := GetStrategy()\\n   135→\\n   136→\\tif err := strat.EnsureSetup(); err != nil {\\n   137→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n   138→\\t}\\n   139→\\n   140→\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n   141→\\t\\tagentType := ag.Type()\\n   142→\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n   143→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n   144→\\t\\t}\\n   145→\\t}\\n   146→\\n   147→\\treturn nil\\n   148→}\\n   149→\\n   150→// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n   151→// detects file changes, saves step + checkpoint, transitions phase.\\n   152→//\\n   153→//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\n   154→func handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n   155→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   156→\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n   157→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   158→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   159→\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n   160→\\t)\\n   161→\\n   162→\\tsessionID := event.SessionID\\n   163→\\tif sessionID == \\\"\\\" {\\n   164→\\t\\tsessionID = unknownSessionID\\n   165→\\t}\\n   166→\\n   167→\\ttranscriptRef := event.SessionRef\\n   168→\\tif transcriptRef == \\\"\\\" {\\n   169→\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n   170→\\t}\\n   171→\\tif !fileExists(transcriptRef) {\\n   172→\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n   173→\\t}\\n   174→\\n   175→\\t// Early check: bail out quickly if the repo has no commits yet.\\n   176→\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n   177→\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n   178→\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n   179→\\t}\\n   180→\\n   181→\\t// Create session metadata directory\\n   182→\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n   183→\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n   184→\\tif err != nil {\\n   185→\\t\\tsessionDirAbs = sessionDir\\n   186→\\t}\\n   187→\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n   188→\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n   189→\\t}\\n   190→\\n   191→\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n   192→\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n   193→\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n   194→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n   195→\\t\\t}\\n   196→\\t}\\n   197→\\n   198→\\t// Copy transcript to session directory\\n   199→\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n   200→\\tif err != nil {\\n   201→\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   202→\\t}\\n   203→\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n   204→\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n   205→\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n   206→\\t}\\n   207→\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n   208→\\n   209→\\t// Copy export JSON if it exists alongside the transcript (written by OpenCode plugin).\\n   210→\\t// This is used by `opencode import` during resume/rewind to restore the session\\n   211→\\t// into OpenCode's SQLite database with the original session ID.\\n   212→\\texportSrc := strings.TrimSuffix(transcriptRef, filepath.Ext(transcriptRef)) + \\\".export.json\\\"\\n   213→\\tif exportData, readErr := os.ReadFile(exportSrc); readErr == nil { //nolint:gosec // Path derived from agent hook\\n   214→\\t\\texportDest := filepath.Join(sessionDirAbs, paths.ExportDataFileName)\\n   215→\\t\\tif writeErr := os.WriteFile(exportDest, exportData, 0o600); writeErr != nil {\\n   216→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to write export data: %v\\\\n\\\", writeErr)\\n   217→\\t\\t}\\n   218→\\t}\\n   219→\\n   220→\\t// Load pre-prompt state (captured on TurnStart)\\n   221→\\tpreState, err := LoadPrePromptState(sessionID)\\n   222→\\tif err != nil {\\n   223→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n   224→\\t}\\n   225→\\n   226→\\t// Determine transcript offset\\n   227→\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n   228→\\n   229→\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n   230→\\tvar allPrompts []string\\n   231→\\tvar summary string\\n   232→\\tvar modifiedFiles []string\\n   233→\\tvar newTranscriptPosition int\\n   234→\\n   235→\\t// Compute subagents directory for agents that support subagent extraction.\\n   236→\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n   237→\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n   238→\\n   239→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   240→\\t\\t// Extract prompts\\n   241→\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n   242→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n   243→\\t\\t} else {\\n   244→\\t\\t\\tallPrompts = prompts\\n   245→\\t\\t}\\n   246→\\n   247→\\t\\t// Extract summary\\n   248→\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n   249→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n   250→\\t\\t} else {\\n   251→\\t\\t\\tsummary = s\\n   252→\\t\\t}\\n   253→\\n   254→\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n   255→\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n   256→\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n   257→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n   258→\\t\\t\\t} else {\\n   259→\\t\\t\\t\\tmodifiedFiles = files\\n   260→\\t\\t\\t}\\n   261→\\t\\t\\t// Get position from basic analyzer\\n   262→\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n   263→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   264→\\t\\t\\t}\\n   265→\\t\\t} else {\\n   266→\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n   267→\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n   268→\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n   269→\\t\\t\\t} else {\\n   270→\\t\\t\\t\\tmodifiedFiles = files\\n   271→\\t\\t\\t\\tnewTranscriptPosition = pos\\n   272→\\t\\t\\t}\\n   273→\\t\\t}\\n   274→\\t}\\n   275→\\n   276→\\t// Write prompts file\\n   277→\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n   278→\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n   279→\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n   280→\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n   281→\\t}\\n   282→\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n   283→\\n   284→\\t// Write summary file\\n   285→\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n   286→\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n   287→\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n   288→\\t}\\n   289→\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n   290→\\n   291→\\t// Generate commit message from last prompt\\n   292→\\tlastPrompt := \\\"\\\"\\n   293→\\tif len(allPrompts) > 0 {\\n   294→\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n   295→\\t}\\n   296→\\tcommitMessage := generateCommitMessage(lastPrompt)\\n   297→\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n   298→\\n   299→\\t// Get repo root for path normalization\\n   300→\\trepoRoot, err := paths.RepoRoot()\\n   301→\\tif err != nil {\\n   302→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   303→\\t}\\n   304→\\n   305→\\tvar preUntrackedFiles []string\\n   306→\\tif preState != nil {\\n   307→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n   308→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   309→\\t}\\n   310→\\n   311→\\t// Detect file changes via git status\\n   312→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   313→\\tif err != nil {\\n   314→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   315→\\t}\\n   316→\\n   317→\\t// Filter and normalize all paths\\n   318→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   319→\\tvar relNewFiles, relDeletedFiles []string\\n   320→\\tif changes != nil {\\n   321→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   322→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   323→\\t}\\n   324→\\n   325→\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n   326→\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n   327→\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n   328→\\t// if it exists in HEAD with the same content as the working tree.\\n   329→\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n   330→\\n   331→\\t// Check if there are any changes\\n   332→\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n   333→\\tif totalChanges == 0 {\\n   334→\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n   335→\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n   336→\\t\\ttransitionSessionTurnEnd(sessionID)\\n   337→\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   338→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   339→\\t\\t}\\n   340→\\t\\treturn nil\\n   341→\\t}\\n   342→\\n   343→\\t// Log file changes\\n   344→\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n   345→\\n   346→\\t// Create context file\\n   347→\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n   348→\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n   349→\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n   350→\\t}\\n   351→\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n   352→\\n   353→\\t// Get git author\\n   354→\\tauthor, err := GetGitAuthor()\\n   355→\\tif err != nil {\\n   356→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   357→\\t}\\n   358→\\n   359→\\t// Get strategy and agent type\\n   360→\\tstrat := GetStrategy()\\n   361→\\tagentType := ag.Type()\\n   362→\\n   363→\\t// Get transcript position/identifier from pre-prompt state\\n   364→\\tvar transcriptIdentifierAtStart string\\n   365→\\tvar transcriptLinesAtStart int\\n   366→\\tif preState != nil {\\n   367→\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n   368→\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n   369→\\t}\\n   370→\\n   371→\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n   372→\\tvar tokenUsage *agent.TokenUsage\\n   373→\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n   374→\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n   375→\\t\\tif tokenErr != nil {\\n   376→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n   377→\\t\\t} else {\\n   378→\\t\\t\\ttokenUsage = usage\\n   379→\\t\\t}\\n   380→\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n   381→\\t\\t// Fall back to basic token calculation (main transcript only)\\n   382→\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n   383→\\t\\tif tokenErr != nil {\\n   384→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n   385→\\t\\t} else {\\n   386→\\t\\t\\ttokenUsage = usage\\n   387→\\t\\t}\\n   388→\\t}\\n   389→\\n   390→\\t// Build fully-populated step context and delegate to strategy\\n   391→\\tctx := strategy.StepContext{\\n   392→\\t\\tSessionID:                sessionID,\\n   393→\\t\\tModifiedFiles:            relModifiedFiles,\\n   394→\\t\\tNewFiles:                 relNewFiles,\\n   395→\\t\\tDeletedFiles:             relDeletedFiles,\\n   396→\\t\\tMetadataDir:              sessionDir,\\n   397→\\t\\tMetadataDirAbs:           sessionDirAbs,\\n   398→\\t\\tCommitMessage:            commitMessage,\\n   399→\\t\\tTranscriptPath:           transcriptRef,\\n   400→\\t\\tAuthorName:               author.Name,\\n   401→\\t\\tAuthorEmail:              author.Email,\\n   402→\\t\\tAgentType:                agentType,\\n   403→\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n   404→\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n   405→\\t\\tTokenUsage:               tokenUsage,\\n   406→\\t}\\n   407→\\n   408→\\tif err := strat.SaveStep(ctx); err != nil {\\n   409→\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n   410→\\t}\\n   411→\\n   412→\\t// Update session state transcript position for auto-commit strategy\\n   413→\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n   414→\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n   415→\\t}\\n   416→\\n   417→\\t// Transition session phase and cleanup\\n   418→\\ttransitionSessionTurnEnd(sessionID)\\n   419→\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n   420→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n   421→\\t}\\n   422→\\n   423→\\treturn nil\\n   424→}\\n   425→\\n   426→// handleLifecycleCompaction handles context compaction: saves current progress\\n   427→// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n   428→// Also resets the transcript offset since the transcript may be truncated.\\n   429→func handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n   430→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   431→\\tlogging.Info(logCtx, \\\"compaction\\\",\\n   432→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   433→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   434→\\t)\\n   435→\\n   436→\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n   437→\\tsessionID := event.SessionID\\n   438→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   439→\\tif loadErr != nil {\\n   440→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n   441→\\t}\\n   442→\\tif sessionState != nil {\\n   443→\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   444→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n   445→\\t\\t}\\n   446→\\n   447→\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n   448→\\t\\tsessionState.CheckpointTranscriptStart = 0\\n   449→\\n   450→\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n   451→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n   452→\\t\\t}\\n   453→\\t}\\n   454→\\n   455→\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n   456→\\treturn nil\\n   457→}\\n   458→\\n   459→// handleLifecycleSessionEnd handles session end: marks the session as ended.\\n   460→func handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n   461→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   462→\\tlogging.Info(logCtx, \\\"session-end\\\",\\n   463→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   464→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   465→\\t)\\n   466→\\n   467→\\tif event.SessionID == \\\"\\\" {\\n   468→\\t\\treturn nil // No session to update\\n   469→\\t}\\n   470→\\n   471→\\tif err := markSessionEnded(event.SessionID); err != nil {\\n   472→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n   473→\\t}\\n   474→\\treturn nil\\n   475→}\\n   476→\\n   477→// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\n   478→func handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n   479→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   480→\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n   481→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   482→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   483→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   484→\\t)\\n   485→\\n   486→\\t// Log context\\n   487→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n   488→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   489→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   490→\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n   491→\\n   492→\\t// Capture pre-task state\\n   493→\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n   494→\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n   495→\\t}\\n   496→\\n   497→\\treturn nil\\n   498→}\\n   499→\\n   500→// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\n   501→func handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n   502→\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n   503→\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n   504→\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n   505→\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n   506→\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n   507→\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n   508→\\t)\\n   509→\\n   510→\\t// Extract subagent type and description from tool input\\n   511→\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n   512→\\n   513→\\t// Determine subagent transcript path\\n   514→\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n   515→\\tvar subagentTranscriptPath string\\n   516→\\tif event.SubagentID != \\\"\\\" {\\n   517→\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n   518→\\t\\tif !fileExists(subagentTranscriptPath) {\\n   519→\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n   520→\\t\\t}\\n   521→\\t}\\n   522→\\n   523→\\t// Log context\\n   524→\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n   525→\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n   526→\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n   527→\\tif event.SubagentID != \\\"\\\" {\\n   528→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n   529→\\t}\\n   530→\\tif subagentTranscriptPath != \\\"\\\" {\\n   531→\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n   532→\\t}\\n   533→\\n   534→\\t// Extract modified files from subagent transcript\\n   535→\\tvar modifiedFiles []string\\n   536→\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n   537→\\t\\ttranscriptToScan := event.SessionRef\\n   538→\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n   539→\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n   540→\\t\\t}\\n   541→\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n   542→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n   543→\\t\\t} else {\\n   544→\\t\\t\\tmodifiedFiles = files\\n   545→\\t\\t}\\n   546→\\t}\\n   547→\\n   548→\\t// Load pre-task state and detect file changes\\n   549→\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n   550→\\tif err != nil {\\n   551→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n   552→\\t}\\n   553→\\tvar preUntrackedFiles []string\\n   554→\\tif preState != nil {\\n   555→\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n   556→\\t}\\n   557→\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n   558→\\tif err != nil {\\n   559→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n   560→\\t}\\n   561→\\n   562→\\t// Get repo root and normalize paths\\n   563→\\trepoRoot, err := paths.RepoRoot()\\n   564→\\tif err != nil {\\n   565→\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n   566→\\t}\\n   567→\\n   568→\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n   569→\\tvar relNewFiles, relDeletedFiles []string\\n   570→\\tif changes != nil {\\n   571→\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n   572→\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n   573→\\t}\\n   574→\\n   575→\\t// If no changes, skip\\n   576→\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n   577→\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n   578→\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   579→\\t\\treturn nil\\n   580→\\t}\\n   581→\\n   582→\\t// Find checkpoint UUID from main transcript (best-effort)\\n   583→\\tvar checkpointUUID string\\n   584→\\t// Use the existing CLI-level checkpoint UUID finder\\n   585→\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n   586→\\tif mainLines != nil {\\n   587→\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n   588→\\t}\\n   589→\\n   590→\\t// Get git author\\n   591→\\tauthor, err := GetGitAuthor()\\n   592→\\tif err != nil {\\n   593→\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n   594→\\t}\\n   595→\\n   596→\\t// Build task checkpoint context\\n   597→\\tstrat := GetStrategy()\\n   598→\\tagentType := ag.Type()\\n   599→\\n   600→\\tctx := strategy.TaskStepContext{\\n   601→\\t\\tSessionID:              event.SessionID,\\n   602→\\t\\tToolUseID:              event.ToolUseID,\\n   603→\\t\\tAgentID:                event.SubagentID,\\n   604→\\t\\tModifiedFiles:          relModifiedFiles,\\n   605→\\t\\tNewFiles:               relNewFiles,\\n   606→\\t\\tDeletedFiles:           relDeletedFiles,\\n   607→\\t\\tTranscriptPath:         event.SessionRef,\\n   608→\\t\\tSubagentTranscriptPath: subagentTranscriptPath,\\n   609→\\t\\tCheckpointUUID:         checkpointUUID,\\n   610→\\t\\tAuthorName:             author.Name,\\n   611→\\t\\tAuthorEmail:            author.Email,\\n   612→\\t\\tSubagentType:           subagentType,\\n   613→\\t\\tTaskDescription:        taskDescription,\\n   614→\\t\\tAgentType:              agentType,\\n   615→\\t}\\n   616→\\n   617→\\tif err := strat.SaveTaskStep(ctx); err != nil {\\n   618→\\t\\treturn fmt.Errorf(\\\"failed to save task step: %w\\\", err)\\n   619→\\t}\\n   620→\\n   621→\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n   622→\\treturn nil\\n   623→}\\n   624→\\n   625→// --- Helper functions ---\\n   626→\\n   627→// resolveTranscriptOffset determines the transcript offset to use for parsing.\\n   628→// Prefers pre-prompt state, falls back to session state.\\n   629→func resolveTranscriptOffset(preState *PrePromptState, sessionID string) int {\\n   630→\\tif preState != nil && preState.TranscriptOffset > 0 {\\n   631→\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state found: parsing transcript from offset %d\\\\n\\\", preState.TranscriptOffset)\\n   632→\\t\\treturn preState.TranscriptOffset\\n   633→\\t}\\n   634→\\n   635→\\t// Fall back to session state (e.g., auto-commit strategy updates it after each save)\\n   636→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   637→\\tif loadErr != nil {\\n   638→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   639→\\t\\treturn 0\\n   640→\\t}\\n   641→\\tif sessionState != nil && sessionState.CheckpointTranscriptStart > 0 {\\n   642→\\t\\tfmt.Fprintf(os.Stderr, \\\"Session state found: parsing transcript from offset %d\\\\n\\\", sessionState.CheckpointTranscriptStart)\\n   643→\\t\\treturn sessionState.CheckpointTranscriptStart\\n   644→\\t}\\n   645→\\n   646→\\treturn 0\\n   647→}\\n   648→\\n   649→// updateAutoCommitTranscriptPosition updates the session state with the new transcript position\\n   650→// for the auto-commit strategy.\\n   651→func updateAutoCommitTranscriptPosition(sessionID string, newPosition int) {\\n   652→\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n   653→\\tif loadErr != nil {\\n   654→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state: %v\\\\n\\\", loadErr)\\n   655→\\t\\treturn\\n   656→\\t}\\n   657→\\tif sessionState == nil {\\n   658→\\t\\tsessionState = &strategy.SessionState{\\n   659→\\t\\t\\tSessionID: sessionID,\\n   660→\\t\\t}\\n   661→\\t}\\n   662→\\tsessionState.CheckpointTranscriptStart = newPosition\\n   663→\\tsessionState.StepCount++\\n   664→\\tif updateErr := strategy.SaveSessionState(sessionState); updateErr != nil {\\n   665→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state: %v\\\\n\\\", updateErr)\\n   666→\\t} else {\\n   667→\\t\\tfmt.Fprintf(os.Stderr, \\\"Updated session state: transcript position=%d, checkpoint=%d\\\\n\\\",\\n   668→\\t\\t\\tnewPosition, sessionState.StepCount)\\n   669→\\t}\\n   670→}\\n   671→\\n   672→// createContextFile creates a context.md file for the session checkpoint.\\n   673→// This is a unified version that works for all agents.\\n   674→func createContextFile(contextFile, commitMessage, sessionID string, prompts []string, summary string) error {\\n   675→\\tvar sb strings.Builder\\n   676→\\n   677→\\tsb.WriteString(\\\"# Session Context\\\\n\\\\n\\\")\\n   678→\\tfmt.Fprintf(&sb, \\\"Session ID: %s\\\\n\\\", sessionID)\\n   679→\\tfmt.Fprintf(&sb, \\\"Commit Message: %s\\\\n\\\\n\\\", commitMessage)\\n   680→\\n   681→\\tif len(prompts) > 0 {\\n   682→\\t\\tsb.WriteString(\\\"## Prompts\\\\n\\\\n\\\")\\n   683→\\t\\tfor i, p := range prompts {\\n   684→\\t\\t\\tfmt.Fprintf(&sb, \\\"### Prompt %d\\\\n\\\\n%s\\\\n\\\\n\\\", i+1, p)\\n   685→\\t\\t}\\n   686→\\t}\\n   687→\\n   688→\\tif summary != \\\"\\\" {\\n   689→\\t\\tsb.WriteString(\\\"## Summary\\\\n\\\\n\\\")\\n   690→\\t\\tsb.WriteString(summary)\\n   691→\\t\\tsb.WriteString(\\\"\\\\n\\\")\\n   692→\\t}\\n   693→\\n   694→\\tif err := os.WriteFile(contextFile, []byte(sb.String()), 0o600); err != nil {\\n   695→\\t\\treturn fmt.Errorf(\\\"failed to write context file: %w\\\", err)\\n   696→\\t}\\n   697→\\treturn nil\\n   698→}\\n   699→\\n   700→// parseTranscriptForCheckpointUUID is a thin wrapper around transcript parsing for checkpoint UUID lookup.\\n   701→// Returns parsed transcript lines for use with FindCheckpointUUID.\\n   702→func parseTranscriptForCheckpointUUID(transcriptPath string) ([]transcriptLine, int, error) {\\n   703→\\tlines, total, err := transcript.ParseFromFileAtLine(transcriptPath, 0)\\n   704→\\tif err != nil {\\n   705→\\t\\treturn nil, 0, fmt.Errorf(\\\"parsing transcript for checkpoint UUID: %w\\\", err)\\n   706→\\t}\\n   707→\\treturn lines, total, nil\\n   708→}\\n   709→\\n   710→// transitionSessionTurnEnd transitions the session phase to IDLE and dispatches turn-end actions.\\n   711→func transitionSessionTurnEnd(sessionID string) {\\n   712→\\tturnState, loadErr := strategy.LoadSessionState(sessionID)\\n   713→\\tif loadErr != nil {\\n   714→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for turn end: %v\\\\n\\\", loadErr)\\n   715→\\t\\treturn\\n   716→\\t}\\n   717→\\tif turnState == nil {\\n   718→\\t\\treturn\\n   719→\\t}\\n   720→\\tif err := strategy.TransitionAndLog(turnState, session.EventTurnEnd, session.TransitionContext{}, session.NoOpActionHandler{}); err != nil {\\n   721→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end transition failed: %v\\\\n\\\", err)\\n   722→\\t}\\n   723→\\n   724→\\t// Always dispatch to strategy for turn-end handling. The strategy reads\\n   725→\\t// work items from state (e.g. TurnCheckpointIDs), not the action list.\\n   726→\\tstrat := GetStrategy()\\n   727→\\tif handler, ok := strat.(strategy.TurnEndHandler); ok {\\n   728→\\t\\tif err := handler.HandleTurnEnd(turnState); err != nil {\\n   729→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: turn-end action dispatch failed: %v\\\\n\\\", err)\\n   730→\\t\\t}\\n   731→\\t}\\n   732→\\n   733→\\tif updateErr := strategy.SaveSessionState(turnState); updateErr != nil {\\n   734→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session phase on turn end: %v\\\\n\\\", updateErr)\\n   735→\\t}\\n   736→}\\n   737→\\n   738→// markSessionEnded transitions the session to ENDED phase via the state machine.\\n   739→func markSessionEnded(sessionID string) error {\\n   740→\\tstate, err := strategy.LoadSessionState(sessionID)\\n   741→\\tif err != nil {\\n   742→\\t\\treturn fmt.Errorf(\\\"failed to load session state: %w\\\", err)\\n   743→\\t}\\n   744→\\tif state == nil {\\n   745→\\t\\treturn nil // No state file, nothing to update\\n   746→\\t}\\n   747→\\n   748→\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStop, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n   749→\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session stop transition failed: %v\\\\n\\\", transErr)\\n   750→\\t}\\n   751→\\n   752→\\tnow := time.Now()\\n   753→\\tstate.EndedAt = &now\\n   754→\\n   755→\\tif err := strategy.SaveSessionState(state); err != nil {\\n   756→\\t\\treturn fmt.Errorf(\\\"failed to save session state: %w\\\", err)\\n   757→\\t}\\n   758→\\treturn nil\\n   759→}\\n   760→\\n   761→// logFileChanges logs the files modified, created, and deleted during a session.\\n   762→func logFileChanges(modified, newFiles, deleted []string) {\\n   763→\\tfmt.Fprintf(os.Stderr, \\\"Files modified during session (%d):\\\\n\\\", len(modified))\\n   764→\\tfor _, file := range modified {\\n   765→\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   766→\\t}\\n   767→\\tif len(newFiles) > 0 {\\n   768→\\t\\tfmt.Fprintf(os.Stderr, \\\"New files created (%d):\\\\n\\\", len(newFiles))\\n   769→\\t\\tfor _, file := range newFiles {\\n   770→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   771→\\t\\t}\\n   772→\\t}\\n   773→\\tif len(deleted) > 0 {\\n   774→\\t\\tfmt.Fprintf(os.Stderr, \\\"Files deleted (%d):\\\\n\\\", len(deleted))\\n   775→\\t\\tfor _, file := range deleted {\\n   776→\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"  - %s\\\\n\\\", file)\\n   777→\\t\\t}\\n   778→\\t}\\n   779→}\\n   780→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"55efc3a1-f2ab-4a4f-a3de-32072d850a29\",\"timestamp\":\"2026-02-20T12:06:33.962Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/lifecycle.go\",\"content\":\"// lifecycle.go implements the generic lifecycle event dispatcher.\\n// It routes normalized events from any agent to the appropriate framework actions.\\n//\\n// The dispatcher inverts the current flow from \\\"agent handler calls framework functions\\\"\\n// to \\\"framework dispatcher calls agent methods.\\\" Agents are passive data providers;\\n// the dispatcher handles all orchestration: state transitions, strategy calls,\\n// file change detection, metadata generation.\\npackage cli\\n\\nimport (\\n\\t\\\"context\\\"\\n\\t\\\"errors\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"log/slog\\\"\\n\\t\\\"os\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\t\\\"time\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/agent\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/logging\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/paths\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/session\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/transcript\\\"\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/validation\\\"\\n)\\n\\n// DispatchLifecycleEvent routes a normalized lifecycle event to the appropriate handler.\\n// Returns nil if the event was handled successfully.\\nfunc DispatchLifecycleEvent(ag agent.Agent, event *agent.Event) error {\\n\\tif ag == nil {\\n\\t\\treturn errors.New(\\\"agent cannot be nil\\\")\\n\\t}\\n\\tif event == nil {\\n\\t\\treturn errors.New(\\\"event cannot be nil\\\")\\n\\t}\\n\\n\\tswitch event.Type {\\n\\tcase agent.SessionStart:\\n\\t\\treturn handleLifecycleSessionStart(ag, event)\\n\\tcase agent.TurnStart:\\n\\t\\treturn handleLifecycleTurnStart(ag, event)\\n\\tcase agent.TurnEnd:\\n\\t\\treturn handleLifecycleTurnEnd(ag, event)\\n\\tcase agent.Compaction:\\n\\t\\treturn handleLifecycleCompaction(ag, event)\\n\\tcase agent.SessionEnd:\\n\\t\\treturn handleLifecycleSessionEnd(ag, event)\\n\\tcase agent.SubagentStart:\\n\\t\\treturn handleLifecycleSubagentStart(ag, event)\\n\\tcase agent.SubagentEnd:\\n\\t\\treturn handleLifecycleSubagentEnd(ag, event)\\n\\tdefault:\\n\\t\\treturn fmt.Errorf(\\\"unknown lifecycle event type: %d\\\", event.Type)\\n\\t}\\n}\\n\\n// handleLifecycleSessionStart handles session start: shows banner, checks concurrent sessions,\\n// fires state machine transition.\\nfunc handleLifecycleSessionStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(event.SessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Build informational message\\n\\tmessage := \\\"\\\\n\\\\nPowered by Entire:\\\\n  This conversation will be linked to your next commit.\\\"\\n\\n\\t// Check for concurrent sessions and append count if any\\n\\tstrat := GetStrategy()\\n\\tif concurrentChecker, ok := strat.(strategy.ConcurrentSessionChecker); ok {\\n\\t\\tif count, err := concurrentChecker.CountOtherActiveSessionsWithCheckpoints(event.SessionID); err == nil && count > 0 {\\n\\t\\t\\tmessage += fmt.Sprintf(\\\"\\\\n  %d other active conversation(s) in this workspace will also be included.\\\\n  Use 'entire status' for more information.\\\", count)\\n\\t\\t}\\n\\t}\\n\\n\\t// Output informational message\\n\\tif event.ResponseMessage != \\\"\\\" {\\n\\t\\tmessage = event.ResponseMessage\\n\\t}\\n\\tif err := outputHookResponse(message); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Fire EventSessionStart for the current session (if state exists).\\n\\tif state, loadErr := strategy.LoadSessionState(event.SessionID); loadErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state on start: %v\\\\n\\\", loadErr)\\n\\t} else if state != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(state, session.EventSessionStart, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: session start transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\t\\tif saveErr := strategy.SaveSessionState(state); saveErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to update session state on start: %v\\\\n\\\", saveErr)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnStart handles turn start: captures pre-prompt state,\\n// ensures strategy setup, initializes session.\\nfunc handleLifecycleTurnStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\treturn fmt.Errorf(\\\"no session_id in %s event\\\", event.Type)\\n\\t}\\n\\tif err := validation.ValidateSessionID(sessionID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"invalid %s event: %w\\\", event.Type, err)\\n\\t}\\n\\n\\t// Capture pre-prompt state (including transcript position via TranscriptAnalyzer)\\n\\tif err := CapturePrePromptState(ag, sessionID, event.SessionRef); err != nil {\\n\\t\\treturn err\\n\\t}\\n\\n\\t// Ensure strategy setup and initialize session\\n\\tstrat := GetStrategy()\\n\\n\\tif err := strat.EnsureSetup(); err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to ensure strategy setup: %v\\\\n\\\", err)\\n\\t}\\n\\n\\tif initializer, ok := strat.(strategy.SessionInitializer); ok {\\n\\t\\tagentType := ag.Type()\\n\\t\\tif err := initializer.InitializeSession(sessionID, agentType, event.SessionRef, event.Prompt); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to initialize session state: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleTurnEnd handles turn end: validates transcript, extracts metadata,\\n// detects file changes, saves step + checkpoint, transitions phase.\\n//\\n//nolint:maintidx // high complexity due to sequential orchestration of 8 steps (validation, extraction, file detection, filtering, token calc, step save, phase transition, cleanup) - splitting would obscure the flow\\nfunc handleLifecycleTurnEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"turn-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"session_ref\\\", event.SessionRef),\\n\\t)\\n\\n\\tsessionID := event.SessionID\\n\\tif sessionID == \\\"\\\" {\\n\\t\\tsessionID = unknownSessionID\\n\\t}\\n\\n\\ttranscriptRef := event.SessionRef\\n\\tif transcriptRef == \\\"\\\" {\\n\\t\\treturn errors.New(\\\"transcript file not specified\\\")\\n\\t}\\n\\tif !fileExists(transcriptRef) {\\n\\t\\treturn fmt.Errorf(\\\"transcript file not found: %s\\\", transcriptRef)\\n\\t}\\n\\n\\t// Early check: bail out quickly if the repo has no commits yet.\\n\\tif repo, err := strategy.OpenRepository(); err == nil && strategy.IsEmptyRepository(repo) {\\n\\t\\tfmt.Fprintln(os.Stderr, \\\"Entire: skipping checkpoint. Will activate after first commit.\\\")\\n\\t\\treturn NewSilentError(strategy.ErrEmptyRepository)\\n\\t}\\n\\n\\t// Create session metadata directory\\n\\tsessionDir := paths.SessionMetadataDirFromSessionID(sessionID)\\n\\tsessionDirAbs, err := paths.AbsPath(sessionDir)\\n\\tif err != nil {\\n\\t\\tsessionDirAbs = sessionDir\\n\\t}\\n\\tif err := os.MkdirAll(sessionDirAbs, 0o750); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session directory: %w\\\", err)\\n\\t}\\n\\n\\t// If agent implements TranscriptPreparer, wait for transcript to be ready\\n\\tif preparer, ok := ag.(agent.TranscriptPreparer); ok {\\n\\t\\tif err := preparer.PrepareTranscript(transcriptRef); err != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to prepare transcript: %v\\\\n\\\", err)\\n\\t\\t}\\n\\t}\\n\\n\\t// Copy transcript to session directory\\n\\ttranscriptData, err := ag.ReadTranscript(transcriptRef)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n\\t}\\n\\tlogFile := filepath.Join(sessionDirAbs, paths.TranscriptFileName)\\n\\tif err := os.WriteFile(logFile, transcriptData, 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write transcript: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Copied transcript to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.TranscriptFileName)\\n\\n\\t// Copy export JSON if it exists alongside the transcript (written by OpenCode plugin).\\n\\t// This is used by `opencode import` during resume/rewind to restore the session\\n\\t// into OpenCode's SQLite database with the original session ID.\\n\\texportSrc := strings.TrimSuffix(transcriptRef, filepath.Ext(transcriptRef)) + \\\".export.json\\\"\\n\\tif exportData, readErr := os.ReadFile(exportSrc); readErr == nil { //nolint:gosec // Path derived from agent hook\\n\\t\\texportDest := filepath.Join(sessionDirAbs, paths.ExportDataFileName)\\n\\t\\tif writeErr := os.WriteFile(exportDest, exportData, 0o600); writeErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to write export data: %v\\\\n\\\", writeErr)\\n\\t\\t}\\n\\t}\\n\\n\\t// Load pre-prompt state (captured on TurnStart)\\n\\tpreState, err := LoadPrePromptState(sessionID)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-prompt state: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Determine transcript offset\\n\\ttranscriptOffset := resolveTranscriptOffset(preState, sessionID)\\n\\n\\t// Extract metadata via agent interface (prompts, summary, modified files)\\n\\tvar allPrompts []string\\n\\tvar summary string\\n\\tvar modifiedFiles []string\\n\\tvar newTranscriptPosition int\\n\\n\\t// Compute subagents directory for agents that support subagent extraction.\\n\\t// Subagent transcripts live in <transcriptDir>/<modelSessionID>/subagents/\\n\\tsubagentsDir := filepath.Join(filepath.Dir(transcriptRef), event.SessionID, \\\"subagents\\\")\\n\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\t// Extract prompts\\n\\t\\tif prompts, promptErr := analyzer.ExtractPrompts(transcriptRef, transcriptOffset); promptErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract prompts: %v\\\\n\\\", promptErr)\\n\\t\\t} else {\\n\\t\\t\\tallPrompts = prompts\\n\\t\\t}\\n\\n\\t\\t// Extract summary\\n\\t\\tif s, sumErr := analyzer.ExtractSummary(transcriptRef); sumErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract summary: %v\\\\n\\\", sumErr)\\n\\t\\t} else {\\n\\t\\t\\tsummary = s\\n\\t\\t}\\n\\n\\t\\t// Extract modified files - prefer SubagentAwareExtractor if available to include subagent files\\n\\t\\tif subagentExtractor, subOk := ag.(agent.SubagentAwareExtractor); subOk {\\n\\t\\t\\tif files, fileErr := subagentExtractor.ExtractAllModifiedFiles(transcriptRef, transcriptOffset, subagentsDir); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files (with subagents): %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t}\\n\\t\\t\\t// Get position from basic analyzer\\n\\t\\t\\tif _, pos, posErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); posErr == nil {\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t} else {\\n\\t\\t\\t// Fall back to basic extraction (main transcript only)\\n\\t\\t\\tif files, pos, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptRef, transcriptOffset); fileErr != nil {\\n\\t\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files: %v\\\\n\\\", fileErr)\\n\\t\\t\\t} else {\\n\\t\\t\\t\\tmodifiedFiles = files\\n\\t\\t\\t\\tnewTranscriptPosition = pos\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n\\n\\t// Write prompts file\\n\\tpromptFile := filepath.Join(sessionDirAbs, paths.PromptFileName)\\n\\tpromptContent := strings.Join(allPrompts, \\\"\\\\n\\\\n---\\\\n\\\\n\\\")\\n\\tif err := os.WriteFile(promptFile, []byte(promptContent), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write prompt file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted %d prompt(s) to: %s\\\\n\\\", len(allPrompts), sessionDir+\\\"/\\\"+paths.PromptFileName)\\n\\n\\t// Write summary file\\n\\tsummaryFile := filepath.Join(sessionDirAbs, paths.SummaryFileName)\\n\\tif err := os.WriteFile(summaryFile, []byte(summary), 0o600); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write summary file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Extracted summary to: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.SummaryFileName)\\n\\n\\t// Generate commit message from last prompt\\n\\tlastPrompt := \\\"\\\"\\n\\tif len(allPrompts) > 0 {\\n\\t\\tlastPrompt = allPrompts[len(allPrompts)-1]\\n\\t}\\n\\tcommitMessage := generateCommitMessage(lastPrompt)\\n\\tfmt.Fprintf(os.Stderr, \\\"Using commit message: %s\\\\n\\\", commitMessage)\\n\\n\\t// Get repo root for path normalization\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n\\t}\\n\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Pre-prompt state: %d pre-existing untracked files\\\\n\\\", len(preState.UntrackedFiles))\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\n\\t// Detect file changes via git status\\n\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Filter and normalize all paths\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t}\\n\\n\\t// Filter transcript-extracted files to exclude files already committed to HEAD.\\n\\t// When an agent commits files mid-turn, those files are condensed by PostCommit\\n\\t// and should not be re-added to FilesTouched by SaveStep. A file is \\\"committed\\\"\\n\\t// if it exists in HEAD with the same content as the working tree.\\n\\trelModifiedFiles = filterToUncommittedFiles(relModifiedFiles, repoRoot)\\n\\n\\t// Check if there are any changes\\n\\ttotalChanges := len(relModifiedFiles) + len(relNewFiles) + len(relDeletedFiles)\\n\\tif totalChanges == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"No files were modified during this session\\\\n\\\")\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Skipping commit\\\\n\\\")\\n\\t\\ttransitionSessionTurnEnd(sessionID)\\n\\t\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n\\t\\t}\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Log file changes\\n\\tlogFileChanges(relModifiedFiles, relNewFiles, relDeletedFiles)\\n\\n\\t// Create context file\\n\\tcontextFile := filepath.Join(sessionDirAbs, paths.ContextFileName)\\n\\tif err := createContextFile(contextFile, commitMessage, sessionID, allPrompts, summary); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create context file: %w\\\", err)\\n\\t}\\n\\tfmt.Fprintf(os.Stderr, \\\"Created context file: %s\\\\n\\\", sessionDir+\\\"/\\\"+paths.ContextFileName)\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Get strategy and agent type\\n\\tstrat := GetStrategy()\\n\\tagentType := ag.Type()\\n\\n\\t// Get transcript position/identifier from pre-prompt state\\n\\tvar transcriptIdentifierAtStart string\\n\\tvar transcriptLinesAtStart int\\n\\tif preState != nil {\\n\\t\\ttranscriptIdentifierAtStart = preState.LastTranscriptIdentifier\\n\\t\\ttranscriptLinesAtStart = preState.TranscriptOffset\\n\\t}\\n\\n\\t// Calculate token usage - prefer SubagentAwareExtractor to include subagent tokens\\n\\tvar tokenUsage *agent.TokenUsage\\n\\tif subagentExtractor, ok := ag.(agent.SubagentAwareExtractor); ok {\\n\\t\\tusage, tokenErr := subagentExtractor.CalculateTotalTokenUsage(transcriptRef, transcriptLinesAtStart, subagentsDir)\\n\\t\\tif tokenErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage (with subagents): %v\\\\n\\\", tokenErr)\\n\\t\\t} else {\\n\\t\\t\\ttokenUsage = usage\\n\\t\\t}\\n\\t} else if calculator, ok := ag.(agent.TokenCalculator); ok {\\n\\t\\t// Fall back to basic token calculation (main transcript only)\\n\\t\\tusage, tokenErr := calculator.CalculateTokenUsage(transcriptRef, transcriptLinesAtStart)\\n\\t\\tif tokenErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to calculate token usage: %v\\\\n\\\", tokenErr)\\n\\t\\t} else {\\n\\t\\t\\ttokenUsage = usage\\n\\t\\t}\\n\\t}\\n\\n\\t// Build fully-populated step context and delegate to strategy\\n\\tctx := strategy.StepContext{\\n\\t\\tSessionID:                sessionID,\\n\\t\\tModifiedFiles:            relModifiedFiles,\\n\\t\\tNewFiles:                 relNewFiles,\\n\\t\\tDeletedFiles:             relDeletedFiles,\\n\\t\\tMetadataDir:              sessionDir,\\n\\t\\tMetadataDirAbs:           sessionDirAbs,\\n\\t\\tCommitMessage:            commitMessage,\\n\\t\\tTranscriptPath:           transcriptRef,\\n\\t\\tAuthorName:               author.Name,\\n\\t\\tAuthorEmail:              author.Email,\\n\\t\\tAgentType:                agentType,\\n\\t\\tStepTranscriptIdentifier: transcriptIdentifierAtStart,\\n\\t\\tStepTranscriptStart:      transcriptLinesAtStart,\\n\\t\\tTokenUsage:               tokenUsage,\\n\\t}\\n\\n\\tif err := strat.SaveStep(ctx); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to save step: %w\\\", err)\\n\\t}\\n\\n\\t// Update session state transcript position for auto-commit strategy\\n\\tif strat.Name() == strategy.StrategyNameAutoCommit && newTranscriptPosition > 0 {\\n\\t\\tupdateAutoCommitTranscriptPosition(sessionID, newTranscriptPosition)\\n\\t}\\n\\n\\t// Transition session phase and cleanup\\n\\ttransitionSessionTurnEnd(sessionID)\\n\\tif cleanupErr := CleanupPrePromptState(sessionID); cleanupErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to cleanup pre-prompt state: %v\\\\n\\\", cleanupErr)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleCompaction handles context compaction: saves current progress\\n// but stays in ACTIVE phase (unlike TurnEnd which transitions to IDLE).\\n// Also resets the transcript offset since the transcript may be truncated.\\nfunc handleLifecycleCompaction(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"compaction\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\t// Fire EventCompaction to trigger ActionCondenseIfFilesTouched (stays in ACTIVE)\\n\\tsessionID := event.SessionID\\n\\tsessionState, loadErr := strategy.LoadSessionState(sessionID)\\n\\tif loadErr != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load session state for compaction: %v\\\\n\\\", loadErr)\\n\\t}\\n\\tif sessionState != nil {\\n\\t\\tif transErr := strategy.TransitionAndLog(sessionState, session.EventCompaction, session.TransitionContext{}, session.NoOpActionHandler{}); transErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: compaction transition failed: %v\\\\n\\\", transErr)\\n\\t\\t}\\n\\n\\t\\t// Reset transcript offset since the transcript may be truncated/reorganized\\n\\t\\tsessionState.CheckpointTranscriptStart = 0\\n\\n\\t\\tif saveErr := strategy.SaveSessionState(sessionState); saveErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to save session state after compaction: %v\\\\n\\\", saveErr)\\n\\t\\t}\\n\\t}\\n\\n\\tfmt.Fprintf(os.Stderr, \\\"Context compaction: transcript offset reset\\\\n\\\")\\n\\treturn nil\\n}\\n\\n// handleLifecycleSessionEnd handles session end: marks the session as ended.\\nfunc handleLifecycleSessionEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"session-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t)\\n\\n\\tif event.SessionID == \\\"\\\" {\\n\\t\\treturn nil // No session to update\\n\\t}\\n\\n\\tif err := markSessionEnded(event.SessionID); err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to mark session ended: %v\\\\n\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentStart handles subagent start: captures pre-task state.\\nfunc handleLifecycleSubagentStart(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"subagent-start\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t)\\n\\n\\t// Log context\\n\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent started\\\\n\\\")\\n\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n\\tfmt.Fprintf(os.Stderr, \\\"  Transcript: %s\\\\n\\\", event.SessionRef)\\n\\n\\t// Capture pre-task state\\n\\tif err := CapturePreTaskState(event.ToolUseID); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to capture pre-task state: %w\\\", err)\\n\\t}\\n\\n\\treturn nil\\n}\\n\\n// handleLifecycleSubagentEnd handles subagent end: detects changes, saves task checkpoint.\\nfunc handleLifecycleSubagentEnd(ag agent.Agent, event *agent.Event) error {\\n\\tlogCtx := logging.WithAgent(logging.WithComponent(context.Background(), \\\"lifecycle\\\"), ag.Name())\\n\\tlogging.Info(logCtx, \\\"subagent-end\\\",\\n\\t\\tslog.String(\\\"event\\\", event.Type.String()),\\n\\t\\tslog.String(\\\"session_id\\\", event.SessionID),\\n\\t\\tslog.String(\\\"tool_use_id\\\", event.ToolUseID),\\n\\t\\tslog.String(\\\"subagent_id\\\", event.SubagentID),\\n\\t)\\n\\n\\t// Extract subagent type and description from tool input\\n\\tsubagentType, taskDescription := ParseSubagentTypeAndDescription(event.ToolInput)\\n\\n\\t// Determine subagent transcript path\\n\\ttranscriptDir := filepath.Dir(event.SessionRef)\\n\\tvar subagentTranscriptPath string\\n\\tif event.SubagentID != \\\"\\\" {\\n\\t\\tsubagentTranscriptPath = AgentTranscriptPath(transcriptDir, event.SubagentID)\\n\\t\\tif !fileExists(subagentTranscriptPath) {\\n\\t\\t\\tsubagentTranscriptPath = \\\"\\\"\\n\\t\\t}\\n\\t}\\n\\n\\t// Log context\\n\\tfmt.Fprintf(os.Stderr, \\\"[entire] Subagent completed\\\\n\\\")\\n\\tfmt.Fprintf(os.Stderr, \\\"  Session ID: %s\\\\n\\\", event.SessionID)\\n\\tfmt.Fprintf(os.Stderr, \\\"  Tool Use ID: %s\\\\n\\\", event.ToolUseID)\\n\\tif event.SubagentID != \\\"\\\" {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"  Agent ID: %s\\\\n\\\", event.SubagentID)\\n\\t}\\n\\tif subagentTranscriptPath != \\\"\\\" {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"  Subagent Transcript: %s\\\\n\\\", subagentTranscriptPath)\\n\\t}\\n\\n\\t// Extract modified files from subagent transcript\\n\\tvar modifiedFiles []string\\n\\tif analyzer, ok := ag.(agent.TranscriptAnalyzer); ok {\\n\\t\\ttranscriptToScan := event.SessionRef\\n\\t\\tif subagentTranscriptPath != \\\"\\\" {\\n\\t\\t\\ttranscriptToScan = subagentTranscriptPath\\n\\t\\t}\\n\\t\\tif files, _, fileErr := analyzer.ExtractModifiedFilesFromOffset(transcriptToScan, 0); fileErr != nil {\\n\\t\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to extract modified files from subagent: %v\\\\n\\\", fileErr)\\n\\t\\t} else {\\n\\t\\t\\tmodifiedFiles = files\\n\\t\\t}\\n\\t}\\n\\n\\t// Load pre-task state and detect file changes\\n\\tpreState, err := LoadPreTaskState(event.ToolUseID)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to load pre-task state: %v\\\\n\\\", err)\\n\\t}\\n\\tvar preUntrackedFiles []string\\n\\tif preState != nil {\\n\\t\\tpreUntrackedFiles = preState.PreUntrackedFiles()\\n\\t}\\n\\tchanges, err := DetectFileChanges(preUntrackedFiles)\\n\\tif err != nil {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"Warning: failed to compute file changes: %v\\\\n\\\", err)\\n\\t}\\n\\n\\t// Get repo root and normalize paths\\n\\trepoRoot, err := paths.RepoRoot()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get repo root: %w\\\", err)\\n\\t}\\n\\n\\trelModifiedFiles := FilterAndNormalizePaths(modifiedFiles, repoRoot)\\n\\tvar relNewFiles, relDeletedFiles []string\\n\\tif changes != nil {\\n\\t\\trelNewFiles = FilterAndNormalizePaths(changes.New, repoRoot)\\n\\t\\trelDeletedFiles = FilterAndNormalizePaths(changes.Deleted, repoRoot)\\n\\t}\\n\\n\\t// If no changes, skip\\n\\tif len(relModifiedFiles) == 0 && len(relNewFiles) == 0 && len(relDeletedFiles) == 0 {\\n\\t\\tfmt.Fprintf(os.Stderr, \\\"[entire] No file changes detected, skipping task checkpoint\\\\n\\\")\\n\\t\\t_ = CleanupPreTaskState(event.ToolUseID) //nolint:errcheck // best-effort cleanup\\n\\t\\treturn nil\\n\\t}\\n\\n\\t// Find checkpoint UUID from main transcript (best-effort)\\n\\tvar checkpointUUID string\\n\\t// Use the existing CLI-level checkpoint UUID finder\\n\\tmainLines, _, _ := parseTranscriptForCheckpointUUID(event.SessionRef) //nolint:errcheck // best-effort\\n\\tif mainLines != nil {\\n\\t\\tcheckpointUUID, _ = FindCheckpointUUID(mainLines, event.ToolUseID)\\n\\t}\\n\\n\\t// Get git author\\n\\tauthor, err := GetGitAuthor()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to get git author: %w\\\", err)\\n\\t}\\n\\n\\t// Build task checkpoint context\\n\\tstrat := GetStrategy()\\n\\tagentType := ag.Type()\\n\\n\\tctx := strategy.TaskStepContext{\\n\\t\\tSessionID:              event.SessionID,\\n\\t\\tToolUseID:              event.ToolUseID,\\n\\t\\tAgentID:                event.SubagentID,\\n\\t\\tModifiedFiles:          relModifiedFiles,\\n\\t\\tNewFiles:               relNewFiles,\\n\\t\\tDeletedFiles:           relDeletedFiles,\\n\\t\\tTranscriptPath:         e