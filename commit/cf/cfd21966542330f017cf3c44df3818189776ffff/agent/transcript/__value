s a transcript file and returns the last message's ID.\\n   244→// Returns empty string if the file doesn't exist, is empty, or has no messages with IDs.\\n   245→func GetLastMessageIDFromFile(path string) (string, error) {\\n   246→\\tif path == \\\"\\\" {\\n   247→\\t\\treturn \\\"\\\", nil\\n   248→\\t}\\n   249→\\n   250→\\tdata, err := os.ReadFile(path) //nolint:gosec // Reading from controlled transcript path\\n   251→\\tif err != nil {\\n   252→\\t\\tif os.IsNotExist(err) {\\n   253→\\t\\t\\treturn \\\"\\\", nil\\n   254→\\t\\t}\\n   255→\\t\\treturn \\\"\\\", fmt.Errorf(\\\"failed to read transcript: %w\\\", err)\\n   256→\\t}\\n   257→\\n   258→\\tif len(data) == 0 {\\n   259→\\t\\treturn \\\"\\\", nil\\n   260→\\t}\\n   261→\\n   262→\\treturn GetLastMessageID(data)\\n   263→}\\n   264→\\n   265→// SliceFromMessage returns a Gemini transcript scoped to messages starting from\\n   266→// startMessageIndex. This is the Gemini equivalent of transcript.SliceFromLine —\\n   267→// for Gemini's single JSON blob, scoping is done by message index rather than line offset.\\n   268→// Returns the original data if startMessageIndex <= 0.\\n   269→// Returns nil if startMessageIndex exceeds the number of messages.\\n   270→func SliceFromMessage(data []byte, startMessageIndex int) []byte {\\n   271→\\tif len(data) == 0 || startMessageIndex <= 0 {\\n   272→\\t\\treturn data\\n   273→\\t}\\n   274→\\n   275→\\tt, err := ParseTranscript(data)\\n   276→\\tif err != nil {\\n   277→\\t\\treturn nil\\n   278→\\t}\\n   279→\\n   280→\\tif startMessageIndex >= len(t.Messages) {\\n   281→\\t\\treturn nil\\n   282→\\t}\\n   283→\\n   284→\\tscoped := &GeminiTranscript{\\n   285→\\t\\tMessages: t.Messages[startMessageIndex:],\\n   286→\\t}\\n   287→\\n   288→\\tout, err := json.Marshal(scoped)\\n   289→\\tif err != nil {\\n   290→\\t\\treturn nil\\n   291→\\t}\\n   292→\\treturn out\\n   293→}\\n   294→\\n   295→// CalculateTokenUsage calculates token usage from a Gemini transcrip