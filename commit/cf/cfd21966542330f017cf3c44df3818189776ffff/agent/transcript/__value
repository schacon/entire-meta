ilepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   375→\\n   376→\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n   377→\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n   378→\\t}\\n   379→\\treturn nil\\n   380→}\\n   381→\\n   382→// HookOutput contains the result of running a hook.\\n   383→type HookOutput struct {\\n   384→\\tStdout []byte\\n   385→\\tStderr []byte\\n   386→\\tErr    error\\n   387→}\\n   388→\\n   389→// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\n   390→func (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   391→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n   392→\\tcmd.Dir = r.RepoDir\\n   393→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   394→\\tcmd.Env = append(os.Environ(),\\n   395→\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n   396→\\t)\\n   397→\\n   398→\\tvar stdout, stderr bytes.Buffer\\n   399→\\tcmd.Stdout = &stdout\\n   400→\\tcmd.Stderr = &stderr\\n   401→\\n   402→\\terr := cmd.Run()\\n   403→\\treturn HookOutput{\\n   404→\\t\\tStdout: stdout.Bytes(),\\n   405→\\t\\tStderr: stderr.Bytes(),\\n   406→\\t\\tErr:    err,\\n   407→\\t}\\n   408→}\\n   409→\\n   410→// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output.\\n   411→func (r *HookRunner) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   412→\\tr.T.Helper()\\n   413→\\n   414→\\tinput := map[string]string{\\n   415→\\t\\t\\\"session_id\\\":      sessionID,\\n   416→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   417→\\t}\\n   418→\\n   419→\\tinputJSON, err := json.Marshal(input)\\n   420→\\tif err != nil {\\n   421→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   422→\\t}\\n   423→\\n   424→\\treturn r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n   425→}\\n   426→\\n   427→// SimulateUserPromptSubmitWithOutput is a convenience method on TestEnv.\\n   428→func (env *TestEnv) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n   429→\\tenv.T.Helper()\\n   430→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   431→\\treturn runner.SimulateUserPromptSubmitWithOutput(sessionID)\\n   432→}\\n   433→\\n   434→// SimulateSessionStartWithOutput simulates the SessionStart hook and returns the output.\\n   435→func (r *HookRunner) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n   436→\\tr.T.Helper()\\n   437→\\n   438→\\tinput := map[string]string{\\n   439→\\t\\t\\\"session_id\\\":      sessionID,\\n   440→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   441→\\t}\\n   442→\\n   443→\\tinputJSON, err := json.Marshal(input)\\n   444→\\tif err != nil {\\n   445→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   446→\\t}\\n   447→\\n   448→\\treturn r.runHookWithOutput(\\\"session-start\\\", inputJSON)\\n   449→}\\n   450→\\n   451→// SimulateSessionStartWithOutput is a convenience method on TestEnv.\\n   452→func (env *TestEnv) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n   453→\\tenv.T.Helper()\\n   454→\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n   455→\\treturn runner.SimulateSessionStartWithOutput(sessionID)\\n   456→}\\n   457→\\n   458→// GetSessionState reads and returns the session state for the given session ID.\\n   459→func (env *TestEnv) GetSessionState(sessionID string) (*strategy.SessionState, error) {\\n   460→\\tenv.T.Helper()\\n   461→\\n   462→\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n   463→\\n   464→\\tdata, err := os.ReadFile(stateFile)\\n   465→\\tif os.IsNotExist(err) {\\n   466→\\t\\treturn nil, nil\\n   467→\\t}\\n   468→\\tif err != nil {\\n   469→\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n   470→\\t}\\n   471→\\n   472→\\tvar state strategy.SessionState\\n   473→\\tif err := json.Unmarshal(data, &state); err != nil {\\n   474→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n   475→\\t}\\n   476→\\treturn &state, nil\\n   477→}\\n   478→\\n   479→// WriteSessionState writes the session state for the given session ID.\\n   480→// This is useful for tests that need to manipulate session state directly.\\n   481→func (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n   482→\\tenv.T.Helper()\\n   483→\\n   484→\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n   485→\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n   486→\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n   487→\\t}\\n   488→\\n   489→\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n   490→\\n   491→\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n   492→\\tif err != nil {\\n   493→\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n   494→\\t}\\n   495→\\n   496→\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n   497→\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n   498→\\t}\\n   499→\\treturn nil\\n   500→}\\n   501→\\n   502→// GeminiHookRunner executes Gemini CLI hooks in the test environment.\\n   503→type GeminiHookRunner struct {\\n   504→\\tRepoDir          string\\n   505→\\tGeminiProjectDir string\\n   506→\\tT                interface {\\n   507→\\t\\tHelper()\\n   508→\\t\\tFatalf(format string, args ...interface{})\\n   509→\\t\\tLogf(format string, args ...interface{})\\n   510→\\t}\\n   511→}\\n   512→\\n   513→// NewGeminiHookRunner creates a new Gemini hook runner for the given repo directory.\\n   514→func NewGeminiHookRunner(repoDir, geminiProjectDir string, t interface {\\n   515→\\tHelper()\\n   516→\\tFatalf(format string, args ...interface{})\\n   517→\\tLogf(format string, args ...interface{})\\n   518→}) *GeminiHookRunner {\\n   519→\\treturn &GeminiHookRunner{\\n   520→\\t\\tRepoDir:          repoDir,\\n   521→\\t\\tGeminiProjectDir: geminiProjectDir,\\n   522→\\t\\tT:                t,\\n   523→\\t}\\n   524→}\\n   525→\\n   526→// runGeminiHookWithInput runs a Gemini hook with the given input.\\n   527→func (r *GeminiHookRunner) runGeminiHookWithInput(hookName string, input interface{}) error {\\n   528→\\tr.T.Helper()\\n   529→\\n   530→\\tinputJSON, err := json.Marshal(input)\\n   531→\\tif err != nil {\\n   532→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   533→\\t}\\n   534→\\n   535→\\treturn r.runGeminiHookInRepoDir(hookName, inputJSON)\\n   536→}\\n   537→\\n   538→func (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n   539→\\t// Run using the shared test binary\\n   540→\\t// Command structure: entire hooks gemini <hook-name>\\n   541→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   542→\\tcmd.Dir = r.RepoDir\\n   543→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   544→\\tcmd.Env = append(os.Environ(),\\n   545→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   546→\\t)\\n   547→\\n   548→\\toutput, err := cmd.CombinedOutput()\\n   549→\\tif err != nil {\\n   550→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   551→\\t\\t\\thookName, err, inputJSON, output)\\n   552→\\t}\\n   553→\\n   554→\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n   555→\\treturn nil\\n   556→}\\n   557→\\n   558→// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\n   559→func (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n   560→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n   561→\\tcmd.Dir = r.RepoDir\\n   562→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   563→\\tcmd.Env = append(os.Environ(),\\n   564→\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n   565→\\t)\\n   566→\\n   567→\\tvar stdout, stderr bytes.Buffer\\n   568→\\tcmd.Stdout = &stdout\\n   569→\\tcmd.Stderr = &stderr\\n   570→\\n   571→\\terr := cmd.Run()\\n   572→\\treturn HookOutput{\\n   573→\\t\\tStdout: stdout.Bytes(),\\n   574→\\t\\tStderr: stderr.Bytes(),\\n   575→\\t\\tErr:    err,\\n   576→\\t}\\n   577→}\\n   578→\\n   579→// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n   580→// This is equivalent to Claude Code's UserPromptSubmit.\\n   581→func (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n   582→\\tr.T.Helper()\\n   583→\\n   584→\\tinput := map[string]string{\\n   585→\\t\\t\\\"session_id\\\":      sessionID,\\n   586→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   587→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   588→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   589→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   590→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   591→\\t}\\n   592→\\n   593→\\treturn r.runGeminiHookWithInput(\\\"before-agent\\\", input)\\n   594→}\\n   595→\\n   596→// SimulateGeminiBeforeAgentWithOutput simulates the BeforeAgent hook and returns the output.\\n   597→func (r *GeminiHookRunner) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   598→\\tr.T.Helper()\\n   599→\\n   600→\\tinput := map[string]string{\\n   601→\\t\\t\\\"session_id\\\":      sessionID,\\n   602→\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n   603→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   604→\\t\\t\\\"hook_event_name\\\": \\\"BeforeAgent\\\",\\n   605→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   606→\\t\\t\\\"prompt\\\":          \\\"test prompt\\\",\\n   607→\\t}\\n   608→\\n   609→\\tinputJSON, err := json.Marshal(input)\\n   610→\\tif err != nil {\\n   611→\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n   612→\\t}\\n   613→\\n   614→\\treturn r.runGeminiHookWithOutput(\\\"before-agent\\\", inputJSON)\\n   615→}\\n   616→\\n   617→// SimulateGeminiAfterAgent simulates the AfterAgent hook for Gemini CLI.\\n   618→// This is the primary checkpoint creation hook, equivalent to Claude Code's Stop hook.\\n   619→func (r *GeminiHookRunner) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   620→\\tr.T.Helper()\\n   621→\\n   622→\\tinput := map[string]string{\\n   623→\\t\\t\\\"session_id\\\":      sessionID,\\n   624→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   625→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   626→\\t\\t\\\"hook_event_name\\\": \\\"AfterAgent\\\",\\n   627→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   628→\\t}\\n   629→\\n   630→\\treturn r.runGeminiHookWithInput(\\\"after-agent\\\", input)\\n   631→}\\n   632→\\n   633→// SimulateGeminiSessionEnd simulates the SessionEnd hook for Gemini CLI.\\n   634→// This is a cleanup/fallback hook that fires on explicit exit.\\n   635→func (r *GeminiHookRunner) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   636→\\tr.T.Helper()\\n   637→\\n   638→\\tinput := map[string]string{\\n   639→\\t\\t\\\"session_id\\\":      sessionID,\\n   640→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   641→\\t\\t\\\"cwd\\\":             r.RepoDir,\\n   642→\\t\\t\\\"hook_event_name\\\": \\\"SessionEnd\\\",\\n   643→\\t\\t\\\"timestamp\\\":       \\\"2025-01-01T00:00:00Z\\\",\\n   644→\\t\\t\\\"reason\\\":          \\\"exit\\\",\\n   645→\\t}\\n   646→\\n   647→\\treturn r.runGeminiHookWithInput(\\\"session-end\\\", input)\\n   648→}\\n   649→\\n   650→// GeminiSession represents a simulated Gemini CLI session.\\n   651→type GeminiSession struct {\\n   652→\\tID             string // Raw model session ID (e.g., \\\"gemini-session-1\\\")\\n   653→\\tTranscriptPath string\\n   654→\\tenv            *TestEnv\\n   655→}\\n   656→\\n   657→// NewGeminiSession creates a new simulated Gemini session.\\n   658→func (env *TestEnv) NewGeminiSession() *GeminiSession {\\n   659→\\tenv.T.Helper()\\n   660→\\n   661→\\tenv.SessionCounter++\\n   662→\\tsessionID := fmt.Sprintf(\\\"gemini-session-%d\\\", env.SessionCounter)\\n   663→\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".json\\\")\\n   664→\\n   665→\\treturn &GeminiSession{\\n   666→\\t\\tID:             sessionID,\\n   667→\\t\\tTranscriptPath: transcriptPath,\\n   668→\\t\\tenv:            env,\\n   669→\\t}\\n   670→}\\n   671→\\n   672→// CreateGeminiTranscript creates a Gemini JSON transcript file for the session.\\n   673→func (s *GeminiSession) CreateGeminiTranscript(prompt string, changes []FileChange) string {\\n   674→\\t// Build Gemini-format transcript (JSON, not JSONL)\\n   675→\\tmessages := []map[string]interface{}{\\n   676→\\t\\t{\\n   677→\\t\\t\\t\\\"type\\\":    \\\"user\\\",\\n   678→\\t\\t\\t\\\"content\\\": prompt,\\n   679→\\t\\t},\\n   680→\\t\\t{\\n   681→\\t\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   682→\\t\\t\\t\\\"content\\\": \\\"I'll help you with that.\\\",\\n   683→\\t\\t},\\n   684→\\t}\\n   685→\\n   686→\\tfor _, change := range changes {\\n   687→\\t\\tmessages = append(messages, map[string]interface{}{\\n   688→\\t\\t\\t\\\"type\\\": \\\"tool_use\\\",\\n   689→\\t\\t\\t\\\"name\\\": \\\"write_file\\\",\\n   690→\\t\\t\\t\\\"input\\\": map[string]string{\\n   691→\\t\\t\\t\\t\\\"path\\\":    change.Path,\\n   692→\\t\\t\\t\\t\\\"content\\\": change.Content,\\n   693→\\t\\t\\t},\\n   694→\\t\\t})\\n   695→\\t\\tmessages = append(messages, map[string]interface{}{\\n   696→\\t\\t\\t\\\"type\\\":   \\\"tool_result\\\",\\n   697→\\t\\t\\t\\\"output\\\": \\\"File written successfully\\\",\\n   698→\\t\\t})\\n   699→\\t}\\n   700→\\n   701→\\tmessages = append(messages, map[string]interface{}{\\n   702→\\t\\t\\\"type\\\":    \\\"assistant\\\",\\n   703→\\t\\t\\\"content\\\": \\\"Done!\\\",\\n   704→\\t})\\n   705→\\n   706→\\ttranscript := map[string]interface{}{\\n   707→\\t\\t\\\"sessionId\\\": s.ID,\\n   708→\\t\\t\\\"messages\\\":  messages,\\n   709→\\t}\\n   710→\\n   711→\\t// Ensure directory exists\\n   712→\\tif err := os.MkdirAll(filepath.Dir(s.TranscriptPath), 0o755); err != nil {\\n   713→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript dir: %v\\\", err)\\n   714→\\t}\\n   715→\\n   716→\\t// Write transcript\\n   717→\\tdata, err := json.MarshalIndent(transcript, \\\"\\\", \\\"  \\\")\\n   718→\\tif err != nil {\\n   719→\\t\\ts.env.T.Fatalf(\\\"failed to marshal transcript: %v\\\", err)\\n   720→\\t}\\n   721→\\tif err := os.WriteFile(s.TranscriptPath, data, 0o644); err != nil {\\n   722→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   723→\\t}\\n   724→\\n   725→\\treturn s.TranscriptPath\\n   726→}\\n   727→\\n   728→// SimulateGeminiBeforeAgent is a convenience method on TestEnv.\\n   729→func (env *TestEnv) SimulateGeminiBeforeAgent(sessionID string) error {\\n   730→\\tenv.T.Helper()\\n   731→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   732→\\treturn runner.SimulateGeminiBeforeAgent(sessionID)\\n   733→}\\n   734→\\n   735→// SimulateGeminiBeforeAgentWithOutput is a convenience method on TestEnv.\\n   736→func (env *TestEnv) SimulateGeminiBeforeAgentWithOutput(sessionID string) HookOutput {\\n   737→\\tenv.T.Helper()\\n   738→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   739→\\treturn runner.SimulateGeminiBeforeAgentWithOutput(sessionID)\\n   740→}\\n   741→\\n   742→// SimulateGeminiAfterAgent is a convenience method on TestEnv.\\n   743→func (env *TestEnv) SimulateGeminiAfterAgent(sessionID, transcriptPath string) error {\\n   744→\\tenv.T.Helper()\\n   745→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   746→\\treturn runner.SimulateGeminiAfterAgent(sessionID, transcriptPath)\\n   747→}\\n   748→\\n   749→// SimulateGeminiSessionEnd is a convenience method on TestEnv.\\n   750→func (env *TestEnv) SimulateGeminiSessionEnd(sessionID, transcriptPath string) error {\\n   751→\\tenv.T.Helper()\\n   752→\\trunner := NewGeminiHookRunner(env.RepoDir, env.GeminiProjectDir, env.T)\\n   753→\\treturn runner.SimulateGeminiSessionEnd(sessionID, transcriptPath)\\n   754→}\\n   755→\\n   756→// --- OpenCode Hook Runner ---\\n   757→\\n   758→// OpenCodeHookRunner executes OpenCode hooks in the test environment.\\n   759→type OpenCodeHookRunner struct {\\n   760→\\tRepoDir            string\\n   761→\\tOpenCodeProjectDir string\\n   762→\\tT                  interface {\\n   763→\\t\\tHelper()\\n   764→\\t\\tFatalf(format string, args ...interface{})\\n   765→\\t\\tLogf(format string, args ...interface{})\\n   766→\\t}\\n   767→}\\n   768→\\n   769→// NewOpenCodeHookRunner creates a new OpenCode hook runner for the given repo directory.\\n   770→func NewOpenCodeHookRunner(repoDir, openCodeProjectDir string, t interface {\\n   771→\\tHelper()\\n   772→\\tFatalf(format string, args ...interface{})\\n   773→\\tLogf(format string, args ...interface{})\\n   774→}) *OpenCodeHookRunner {\\n   775→\\treturn &OpenCodeHookRunner{\\n   776→\\t\\tRepoDir:            repoDir,\\n   777→\\t\\tOpenCodeProjectDir: openCodeProjectDir,\\n   778→\\t\\tT:                  t,\\n   779→\\t}\\n   780→}\\n   781→\\n   782→func (r *OpenCodeHookRunner) runOpenCodeHookWithInput(hookName string, input interface{}) error {\\n   783→\\tr.T.Helper()\\n   784→\\n   785→\\tinputJSON, err := json.Marshal(input)\\n   786→\\tif err != nil {\\n   787→\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n   788→\\t}\\n   789→\\n   790→\\treturn r.runOpenCodeHookInRepoDir(hookName, inputJSON)\\n   791→}\\n   792→\\n   793→func (r *OpenCodeHookRunner) runOpenCodeHookInRepoDir(hookName string, inputJSON []byte) error {\\n   794→\\t// Command structure: entire hooks opencode <hook-name>\\n   795→\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"opencode\\\", hookName)\\n   796→\\tcmd.Dir = r.RepoDir\\n   797→\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n   798→\\tcmd.Env = append(os.Environ(),\\n   799→\\t\\t\\\"ENTIRE_TEST_OPENCODE_PROJECT_DIR=\\\"+r.OpenCodeProjectDir,\\n   800→\\t)\\n   801→\\n   802→\\toutput, err := cmd.CombinedOutput()\\n   803→\\tif err != nil {\\n   804→\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n   805→\\t\\t\\thookName, err, inputJSON, output)\\n   806→\\t}\\n   807→\\n   808→\\tr.T.Logf(\\\"OpenCode hook %s output: %s\\\", hookName, output)\\n   809→\\treturn nil\\n   810→}\\n   811→\\n   812→// SimulateOpenCodeSessionStart simulates the session-start hook for OpenCode.\\n   813→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionStart(sessionID, transcriptPath string) error {\\n   814→\\tr.T.Helper()\\n   815→\\n   816→\\tinput := map[string]string{\\n   817→\\t\\t\\\"session_id\\\":      sessionID,\\n   818→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   819→\\t}\\n   820→\\n   821→\\treturn r.runOpenCodeHookWithInput(\\\"session-start\\\", input)\\n   822→}\\n   823→\\n   824→// SimulateOpenCodeTurnStart simulates the turn-start hook for OpenCode.\\n   825→// This is equivalent to Claude Code's UserPromptSubmit.\\n   826→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnStart(sessionID, transcriptPath, prompt string) error {\\n   827→\\tr.T.Helper()\\n   828→\\n   829→\\tinput := map[string]string{\\n   830→\\t\\t\\\"session_id\\\":      sessionID,\\n   831→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   832→\\t\\t\\\"prompt\\\":          prompt,\\n   833→\\t}\\n   834→\\n   835→\\treturn r.runOpenCodeHookWithInput(\\\"turn-start\\\", input)\\n   836→}\\n   837→\\n   838→// SimulateOpenCodeTurnEnd simulates the turn-end hook for OpenCode.\\n   839→// This is equivalent to Claude Code's Stop hook.\\n   840→func (r *OpenCodeHookRunner) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n   841→\\tr.T.Helper()\\n   842→\\n   843→\\tinput := map[string]string{\\n   844→\\t\\t\\\"session_id\\\":      sessionID,\\n   845→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   846→\\t}\\n   847→\\n   848→\\treturn r.runOpenCodeHookWithInput(\\\"turn-end\\\", input)\\n   849→}\\n   850→\\n   851→// SimulateOpenCodeSessionEnd simulates the session-end hook for OpenCode.\\n   852→func (r *OpenCodeHookRunner) SimulateOpenCodeSessionEnd(sessionID, transcriptPath string) error {\\n   853→\\tr.T.Helper()\\n   854→\\n   855→\\tinput := map[string]string{\\n   856→\\t\\t\\\"session_id\\\":      sessionID,\\n   857→\\t\\t\\\"transcript_path\\\": transcriptPath,\\n   858→\\t}\\n   859→\\n   860→\\treturn r.runOpenCodeHookWithInput(\\\"session-end\\\", input)\\n   861→}\\n   862→\\n   863→// OpenCodeSession represents a simulated OpenCode session.\\n   864→type OpenCodeSession struct {\\n   865→\\tID             string // Raw session ID (e.g., \\\"opencode-session-1\\\")\\n   866→\\tTranscriptPath string\\n   867→\\tenv            *TestEnv\\n   868→\\tmsgCounter     int\\n   869→}\\n   870→\\n   871→// NewOpenCodeSession creates a new simulated OpenCode session.\\n   872→func (env *TestEnv) NewOpenCodeSession() *OpenCodeSession {\\n   873→\\tenv.T.Helper()\\n   874→\\n   875→\\tenv.SessionCounter++\\n   876→\\tsessionID := fmt.Sprintf(\\\"opencode-session-%d\\\", env.SessionCounter)\\n   877→\\ttranscriptPath := filepath.Join(env.OpenCodeProjectDir, sessionID+\\\".jsonl\\\")\\n   878→\\n   879→\\treturn &OpenCodeSession{\\n   880→\\t\\tID:             sessionID,\\n   881→\\t\\tTranscriptPath: transcriptPath,\\n   882→\\t\\tenv:            env,\\n   883→\\t}\\n   884→}\\n   885→\\n   886→// CreateOpenCodeTranscript creates an OpenCode JSONL transcript file for the session.\\n   887→// Each line is a JSON message in OpenCode's format (id, role, content, time, tokens, parts).\\n   888→func (s *OpenCodeSession) CreateOpenCodeTranscript(prompt string, changes []FileChange) string {\\n   889→\\tvar lines []string\\n   890→\\n   891→\\t// User message\\n   892→\\ts.msgCounter++\\n   893→\\tuserMsg := map[string]interface{}{\\n   894→\\t\\t\\\"id\\\":      fmt.Sprintf(\\\"msg-%d\\\", s.msgCounter),\\n   895→\\t\\t\\\"role\\\":    \\\"user\\\",\\n   896→\\t\\t\\\"content\\\": prompt,\\n   897→\\t\\t\\\"time\\\":    map[string]interface{}{\\\"created\\\": 1708300000 + s.msgCounter},\\n   898→\\t}\\n   899→\\tuserJSON, _ := json.Marshal(userMsg)\\n   900→\\tlines = append(lines, string(userJSON))\\n   901→\\n   902→\\t// Assistant message with tool calls for file changes\\n   903→\\ts.msgCounter++\\n   904→\\tvar parts []map[string]interface{}\\n   905→\\tparts = append(parts, map[string]interface{}{\\n   906→\\t\\t\\\"type\\\": \\\"text\\\",\\n   907→\\t\\t\\\"text\\\": \\\"I'll help you with that.\\\",\\n   908→\\t})\\n   909→\\tfor i, change := range changes {\\n   910→\\t\\tparts = append(parts, map[string]interface{}{\\n   911→\\t\\t\\t\\\"type\\\":   \\\"tool\\\",\\n   912→\\t\\t\\t\\\"tool\\\":   \\\"write\\\",\\n   913→\\t\\t\\t\\\"callID\\\": fmt.Sprintf(\\\"call-%d\\\", i+1),\\n   914→\\t\\t\\t\\\"state\\\": map[string]interface{}{\\n   915→\\t\\t\\t\\t\\\"status\\\": \\\"completed\\\",\\n   916→\\t\\t\\t\\t\\\"input\\\":  map[string]string{\\\"file_path\\\": change.Path},\\n   917→\\t\\t\\t\\t\\\"output\\\": \\\"File written: \\\" + change.Path,\\n   918→\\t\\t\\t},\\n   919→\\t\\t})\\n   920→\\t}\\n   921→\\n   922→\\tasstMsg := map[string]interface{}{\\n   923→\\t\\t\\\"id\\\":      fmt.Sprintf(\\\"msg-%d\\\", s.msgCounter),\\n   924→\\t\\t\\\"role\\\":    \\\"assistant\\\",\\n   925→\\t\\t\\\"content\\\": \\\"Done!\\\",\\n   926→\\t\\t\\\"time\\\": map[string]interface{}{\\n   927→\\t\\t\\t\\\"created\\\":   1708300000 + s.msgCounter,\\n   928→\\t\\t\\t\\\"completed\\\": 1708300000 + s.msgCounter + 5,\\n   929→\\t\\t},\\n   930→\\t\\t\\\"tokens\\\": map[string]interface{}{\\n   931→\\t\\t\\t\\\"input\\\":     150,\\n   932→\\t\\t\\t\\\"output\\\":    80,\\n   933→\\t\\t\\t\\\"reasoning\\\": 10,\\n   934→\\t\\t\\t\\\"cache\\\":     map[string]int{\\\"read\\\": 5, \\\"write\\\": 15},\\n   935→\\t\\t},\\n   936→\\t\\t\\\"cost\\\":  0.003,\\n   937→\\t\\t\\\"parts\\\": parts,\\n   938→\\t}\\n   939→\\tasstJSON, _ := json.Marshal(asstMsg)\\n   940→\\tlines = append(lines, string(asstJSON))\\n   941→\\n   942→\\t// Ensure directory exists\\n   943→\\tif err := os.MkdirAll(filepath.Dir(s.TranscriptPath), 0o755); err != nil {\\n   944→\\t\\ts.env.T.Fatalf(\\\"failed to create transcript dir: %v\\\", err)\\n   945→\\t}\\n   946→\\n   947→\\t// Write JSONL transcript (one message per line)\\n   948→\\tcontent := strings.Join(lines, \\\"\\\\n\\\") + \\\"\\\\n\\\"\\n   949→\\tif err := os.WriteFile(s.TranscriptPath, []byte(content), 0o644); err != nil {\\n   950→\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n   951→\\t}\\n   952→\\n   953→\\treturn s.TranscriptPath\\n   954→}\\n   955→\\n   956→// SimulateOpenCodeSessionStart is a convenience method on TestEnv.\\n   957→func (env *TestEnv) SimulateOpenCodeSessionStart(sessionID, transcriptPath string) error {\\n   958→\\tenv.T.Helper()\\n   959→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n   960→\\treturn runner.SimulateOpenCodeSessionStart(sessionID, transcriptPath)\\n   961→}\\n   962→\\n   963→// SimulateOpenCodeTurnStart is a convenience method on TestEnv.\\n   964→func (env *TestEnv) SimulateOpenCodeTurnStart(sessionID, transcriptPath, prompt string) error {\\n   965→\\tenv.T.Helper()\\n   966→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n   967→\\treturn runner.SimulateOpenCodeTurnStart(sessionID, transcriptPath, prompt)\\n   968→}\\n   969→\\n   970→// SimulateOpenCodeTurnEnd is a convenience method on TestEnv.\\n   971→func (env *TestEnv) SimulateOpenCodeTurnEnd(sessionID, transcriptPath string) error {\\n   972→\\tenv.T.Helper()\\n   973→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n   974→\\treturn runner.SimulateOpenCodeTurnEnd(sessionID, transcriptPath)\\n   975→}\\n   976→\\n   977→// SimulateOpenCodeSessionEnd is a convenience method on TestEnv.\\n   978→func (env *TestEnv) SimulateOpenCodeSessionEnd(sessionID, transcriptPath string) error {\\n   979→\\tenv.T.Helper()\\n   980→\\trunner := NewOpenCodeHookRunner(env.RepoDir, env.OpenCodeProjectDir, env.T)\\n   981→\\treturn runner.SimulateOpenCodeSessionEnd(sessionID, transcriptPath)\\n   982→}\\n   983→\\n\\n<system-reminder>\\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\\n</system-reminder>\\n\"}]},\"uuid\":\"1e6819e1-46d0-4b3e-b819-377e181cbf2c\",\"timestamp\":\"2026-02-20T12:13:20.686Z\",\"toolUseResult\":{\"type\":\"text\",\"file\":{\"filePath\":\"/Users/soph/Work/entire/devenv/cli/cmd/entire/cli/integration_test/hooks.go\",\"content\":\"//go:build integration\\n\\npackage integration\\n\\nimport (\\n\\t\\\"bytes\\\"\\n\\t\\\"encoding/json\\\"\\n\\t\\\"fmt\\\"\\n\\t\\\"os\\\"\\n\\t\\\"os/exec\\\"\\n\\t\\\"path/filepath\\\"\\n\\t\\\"strings\\\"\\n\\n\\t\\\"github.com/entireio/cli/cmd/entire/cli/strategy\\\"\\n)\\n\\n// HookRunner executes CLI hooks in the test environment.\\ntype HookRunner struct {\\n\\tRepoDir          string\\n\\tClaudeProjectDir string\\n\\tT                interface {\\n\\t\\tHelper()\\n\\t\\tFatalf(format string, args ...interface{})\\n\\t\\tLogf(format string, args ...interface{})\\n\\t}\\n}\\n\\n// NewHookRunner creates a new hook runner for the given repo directory.\\nfunc NewHookRunner(repoDir, claudeProjectDir string, t interface {\\n\\tHelper()\\n\\tFatalf(format string, args ...interface{})\\n\\tLogf(format string, args ...interface{})\\n}) *HookRunner {\\n\\treturn &HookRunner{\\n\\t\\tRepoDir:          repoDir,\\n\\t\\tClaudeProjectDir: claudeProjectDir,\\n\\t\\tT:                t,\\n\\t}\\n}\\n\\n// HookResponse represents the JSON response from Claude Code hooks.\\ntype HookResponse struct {\\n\\tContinue   bool   `json:\\\"continue\\\"`\\n\\tStopReason string `json:\\\"stopReason,omitempty\\\"`\\n}\\n\\n// SimulateUserPromptSubmit simulates the UserPromptSubmit hook.\\n// This captures pre-prompt state (untracked files).\\nfunc (r *HookRunner) SimulateUserPromptSubmit(sessionID string) error {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": \\\"\\\", // Not used for user-prompt-submit\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"user-prompt-submit\\\", input)\\n}\\n\\n// SimulateUserPromptSubmitWithTranscriptPath simulates the UserPromptSubmit hook\\n// with an explicit transcript path. This is needed for mid-session commit detection\\n// which reads the live transcript to detect ongoing sessions.\\nfunc (r *HookRunner) SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath string) error {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": transcriptPath,\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"user-prompt-submit\\\", input)\\n}\\n\\n// SimulateUserPromptSubmitWithResponse simulates the UserPromptSubmit hook\\n// and returns the parsed hook response (for testing blocking behavior).\\nfunc (r *HookRunner) SimulateUserPromptSubmitWithResponse(sessionID string) (*HookResponse, error) {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": \\\"\\\", // Not used for user-prompt-submit\\n\\t}\\n\\n\\tinputJSON, err := json.Marshal(input)\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n\\t}\\n\\n\\toutput := r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n\\n\\t// If hook failed with an error, return the error\\n\\tif output.Err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"hook failed: %w\\\\nStderr: %s\\\\nStdout: %s\\\",\\n\\t\\t\\toutput.Err, output.Stderr, output.Stdout)\\n\\t}\\n\\n\\t// Parse JSON response from stdout\\n\\tvar resp HookResponse\\n\\tif len(output.Stdout) > 0 {\\n\\t\\tif err := json.Unmarshal(output.Stdout, &resp); err != nil {\\n\\t\\t\\treturn nil, fmt.Errorf(\\\"failed to parse hook response: %w\\\\nStdout: %s\\\",\\n\\t\\t\\t\\terr, output.Stdout)\\n\\t\\t}\\n\\t}\\n\\n\\treturn &resp, nil\\n}\\n\\n// SimulateStop simulates the Stop hook with session transcript info.\\nfunc (r *HookRunner) SimulateStop(sessionID, transcriptPath string) error {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": transcriptPath,\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"stop\\\", input)\\n}\\n\\n// SimulateSessionEnd simulates the Claude Code session-end hook.\\n// This transitions a session from IDLE (or ACTIVE) to ENDED phase.\\nfunc (r *HookRunner) SimulateSessionEnd(sessionID string) error {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"session-end\\\", input)\\n}\\n\\n// PreTaskInput contains the input for PreToolUse[Task] hook.\\ntype PreTaskInput struct {\\n\\tSessionID      string\\n\\tTranscriptPath string\\n\\tToolUseID      string\\n\\tSubagentType   string // Optional: type of subagent (e.g., \\\"dev\\\", \\\"reviewer\\\")\\n\\tDescription    string // Optional: task description\\n}\\n\\n// SimulatePreTask simulates the PreToolUse[Task] hook.\\nfunc (r *HookRunner) SimulatePreTask(sessionID, transcriptPath, toolUseID string) error {\\n\\tr.T.Helper()\\n\\n\\treturn r.SimulatePreTaskWithInput(PreTaskInput{\\n\\t\\tSessionID:      sessionID,\\n\\t\\tTranscriptPath: transcriptPath,\\n\\t\\tToolUseID:      toolUseID,\\n\\t})\\n}\\n\\n// SimulatePreTaskWithInput simulates the PreToolUse[Task] hook with full input.\\nfunc (r *HookRunner) SimulatePreTaskWithInput(input PreTaskInput) error {\\n\\tr.T.Helper()\\n\\n\\thookInput := map[string]interface{}{\\n\\t\\t\\\"session_id\\\":      input.SessionID,\\n\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n\\t\\t\\\"tool_input\\\": map[string]string{\\n\\t\\t\\t\\\"subagent_type\\\": input.SubagentType,\\n\\t\\t\\t\\\"description\\\":   input.Description,\\n\\t\\t},\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"pre-task\\\", hookInput)\\n}\\n\\n// PostTaskInput contains the input for PostToolUse[Task] hook.\\ntype PostTaskInput struct {\\n\\tSessionID      string\\n\\tTranscriptPath string\\n\\tToolUseID      string\\n\\tAgentID        string\\n}\\n\\n// SimulatePostTask simulates the PostToolUse[Task] hook.\\nfunc (r *HookRunner) SimulatePostTask(input PostTaskInput) error {\\n\\tr.T.Helper()\\n\\n\\thookInput := map[string]interface{}{\\n\\t\\t\\\"session_id\\\":      input.SessionID,\\n\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n\\t\\t\\\"tool_input\\\":      map[string]string{},\\n\\t\\t\\\"tool_response\\\": map[string]string{\\n\\t\\t\\t\\\"agentId\\\": input.AgentID,\\n\\t\\t},\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"post-task\\\", hookInput)\\n}\\n\\nfunc (r *HookRunner) runHookWithInput(flag string, input interface{}) error {\\n\\tr.T.Helper()\\n\\n\\tinputJSON, err := json.Marshal(input)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n\\t}\\n\\n\\treturn r.runHookInRepoDir(flag, inputJSON)\\n}\\n\\nfunc (r *HookRunner) runHookInRepoDir(hookName string, inputJSON []byte) error {\\n\\t// Run using the shared test binary\\n\\t// Command structure: entire hooks claude-code <hook-name>\\n\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n\\tcmd.Dir = r.RepoDir\\n\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n\\tcmd.Env = append(os.Environ(),\\n\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n\\t)\\n\\n\\toutput, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n\\t\\t\\thookName, err, inputJSON, output)\\n\\t}\\n\\n\\tr.T.Logf(\\\"Hook %s output: %s\\\", hookName, output)\\n\\treturn nil\\n}\\n\\n// Session represents a simulated Claude Code session.\\ntype Session struct {\\n\\tID                string // Raw model session ID (e.g., \\\"test-session-1\\\")\\n\\tTranscriptPath    string\\n\\tTranscriptBuilder *TranscriptBuilder\\n\\tenv               *TestEnv\\n}\\n\\n// FileChange represents a file modification in a session.\\ntype FileChange struct {\\n\\tPath    string\\n\\tContent string\\n}\\n\\n// NewSession creates a new simulated session.\\nfunc (env *TestEnv) NewSession() *Session {\\n\\tenv.T.Helper()\\n\\n\\tenv.SessionCounter++\\n\\tsessionID := fmt.Sprintf(\\\"test-session-%d\\\", env.SessionCounter)\\n\\n\\ttranscriptPath := filepath.Join(env.RepoDir, \\\".entire\\\", \\\"tmp\\\", sessionID+\\\".jsonl\\\")\\n\\n\\treturn &Session{\\n\\t\\tID:                sessionID,\\n\\t\\tTranscriptPath:    transcriptPath,\\n\\t\\tTranscriptBuilder: NewTranscriptBuilder(),\\n\\t\\tenv:               env,\\n\\t}\\n}\\n\\n// CreateTranscript builds and writes a transcript for the session.\\nfunc (s *Session) CreateTranscript(prompt string, changes []FileChange) string {\\n\\ts.TranscriptBuilder.AddUserMessage(prompt)\\n\\ts.TranscriptBuilder.AddAssistantMessage(\\\"I'll help you with that.\\\")\\n\\n\\tfor _, change := range changes {\\n\\t\\ttoolID := s.TranscriptBuilder.AddToolUse(\\\"mcp__acp__Write\\\", change.Path, change.Content)\\n\\t\\ts.TranscriptBuilder.AddToolResult(toolID)\\n\\t}\\n\\n\\ts.TranscriptBuilder.AddAssistantMessage(\\\"Done!\\\")\\n\\n\\tif err := s.TranscriptBuilder.WriteToFile(s.TranscriptPath); err != nil {\\n\\t\\ts.env.T.Fatalf(\\\"failed to write transcript: %v\\\", err)\\n\\t}\\n\\n\\treturn s.TranscriptPath\\n}\\n\\n// SimulateUserPromptSubmit is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateUserPromptSubmit(sessionID string) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateUserPromptSubmit(sessionID)\\n}\\n\\n// SimulateUserPromptSubmitWithTranscriptPath is a convenience method on TestEnv.\\n// This is needed for mid-session commit detection which reads the live transcript.\\nfunc (env *TestEnv) SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath string) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateUserPromptSubmitWithTranscriptPath(sessionID, transcriptPath)\\n}\\n\\n// SimulateUserPromptSubmitWithResponse is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateUserPromptSubmitWithResponse(sessionID string) (*HookResponse, error) {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateUserPromptSubmitWithResponse(sessionID)\\n}\\n\\n// SimulateStop is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateStop(sessionID, transcriptPath string) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateStop(sessionID, transcriptPath)\\n}\\n\\n// SimulateSessionEnd is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateSessionEnd(sessionID string) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateSessionEnd(sessionID)\\n}\\n\\n// SimulatePreTask is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulatePreTask(sessionID, transcriptPath, toolUseID string) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulatePreTask(sessionID, transcriptPath, toolUseID)\\n}\\n\\n// SimulatePostTask is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulatePostTask(input PostTaskInput) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulatePostTask(input)\\n}\\n\\n// Todo represents a single todo item in the PostTodoInput.\\ntype Todo struct {\\n\\tContent    string `json:\\\"content\\\"`\\n\\tStatus     string `json:\\\"status\\\"`\\n\\tActiveForm string `json:\\\"activeForm\\\"`\\n}\\n\\n// PostTodoInput contains the input for PostToolUse[TodoWrite] hook.\\ntype PostTodoInput struct {\\n\\tSessionID      string\\n\\tTranscriptPath string\\n\\tToolUseID      string // The TodoWrite tool use ID\\n\\tTodos          []Todo // The todo list\\n}\\n\\n// SimulatePostTodo simulates the PostToolUse[TodoWrite] hook.\\nfunc (r *HookRunner) SimulatePostTodo(input PostTodoInput) error {\\n\\tr.T.Helper()\\n\\n\\thookInput := map[string]interface{}{\\n\\t\\t\\\"session_id\\\":      input.SessionID,\\n\\t\\t\\\"transcript_path\\\": input.TranscriptPath,\\n\\t\\t\\\"tool_name\\\":       \\\"TodoWrite\\\",\\n\\t\\t\\\"tool_use_id\\\":     input.ToolUseID,\\n\\t\\t\\\"tool_input\\\": map[string]interface{}{\\n\\t\\t\\t\\\"todos\\\": input.Todos,\\n\\t\\t},\\n\\t\\t\\\"tool_response\\\": map[string]interface{}{},\\n\\t}\\n\\n\\treturn r.runHookWithInput(\\\"post-todo\\\", hookInput)\\n}\\n\\n// SimulatePostTodo is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulatePostTodo(input PostTodoInput) error {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulatePostTodo(input)\\n}\\n\\n// ClearSessionState removes the session state file for the given session ID.\\n// This simulates what happens when a user commits their changes (session is \\\"completed\\\").\\n// Used in tests to allow sequential sessions to run without triggering concurrent session warnings.\\nfunc (env *TestEnv) ClearSessionState(sessionID string) error {\\n\\tenv.T.Helper()\\n\\n\\t// Session state is stored in .git/entire-sessions/<session-id>.json\\n\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n\\n\\tif err := os.Remove(stateFile); err != nil && !os.IsNotExist(err) {\\n\\t\\treturn fmt.Errorf(\\\"failed to clear session state: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// HookOutput contains the result of running a hook.\\ntype HookOutput struct {\\n\\tStdout []byte\\n\\tStderr []byte\\n\\tErr    error\\n}\\n\\n// runHookWithOutput runs a hook and returns both stdout and stderr separately.\\nfunc (r *HookRunner) runHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"claude-code\\\", hookName)\\n\\tcmd.Dir = r.RepoDir\\n\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n\\tcmd.Env = append(os.Environ(),\\n\\t\\t\\\"ENTIRE_TEST_CLAUDE_PROJECT_DIR=\\\"+r.ClaudeProjectDir,\\n\\t)\\n\\n\\tvar stdout, stderr bytes.Buffer\\n\\tcmd.Stdout = &stdout\\n\\tcmd.Stderr = &stderr\\n\\n\\terr := cmd.Run()\\n\\treturn HookOutput{\\n\\t\\tStdout: stdout.Bytes(),\\n\\t\\tStderr: stderr.Bytes(),\\n\\t\\tErr:    err,\\n\\t}\\n}\\n\\n// SimulateUserPromptSubmitWithOutput simulates the UserPromptSubmit hook and returns the output.\\nfunc (r *HookRunner) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n\\t}\\n\\n\\tinputJSON, err := json.Marshal(input)\\n\\tif err != nil {\\n\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n\\t}\\n\\n\\treturn r.runHookWithOutput(\\\"user-prompt-submit\\\", inputJSON)\\n}\\n\\n// SimulateUserPromptSubmitWithOutput is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateUserPromptSubmitWithOutput(sessionID string) HookOutput {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateUserPromptSubmitWithOutput(sessionID)\\n}\\n\\n// SimulateSessionStartWithOutput simulates the SessionStart hook and returns the output.\\nfunc (r *HookRunner) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\t\\t\\\"session_id\\\":      sessionID,\\n\\t\\t\\\"transcript_path\\\": \\\"\\\",\\n\\t}\\n\\n\\tinputJSON, err := json.Marshal(input)\\n\\tif err != nil {\\n\\t\\treturn HookOutput{Err: fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)}\\n\\t}\\n\\n\\treturn r.runHookWithOutput(\\\"session-start\\\", inputJSON)\\n}\\n\\n// SimulateSessionStartWithOutput is a convenience method on TestEnv.\\nfunc (env *TestEnv) SimulateSessionStartWithOutput(sessionID string) HookOutput {\\n\\tenv.T.Helper()\\n\\trunner := NewHookRunner(env.RepoDir, env.ClaudeProjectDir, env.T)\\n\\treturn runner.SimulateSessionStartWithOutput(sessionID)\\n}\\n\\n// GetSessionState reads and returns the session state for the given session ID.\\nfunc (env *TestEnv) GetSessionState(sessionID string) (*strategy.SessionState, error) {\\n\\tenv.T.Helper()\\n\\n\\tstateFile := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\", sessionID+\\\".json\\\")\\n\\n\\tdata, err := os.ReadFile(stateFile)\\n\\tif os.IsNotExist(err) {\\n\\t\\treturn nil, nil\\n\\t}\\n\\tif err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to read session state: %w\\\", err)\\n\\t}\\n\\n\\tvar state strategy.SessionState\\n\\tif err := json.Unmarshal(data, &state); err != nil {\\n\\t\\treturn nil, fmt.Errorf(\\\"failed to parse session state: %w\\\", err)\\n\\t}\\n\\treturn &state, nil\\n}\\n\\n// WriteSessionState writes the session state for the given session ID.\\n// This is useful for tests that need to manipulate session state directly.\\nfunc (env *TestEnv) WriteSessionState(sessionID string, state *strategy.SessionState) error {\\n\\tenv.T.Helper()\\n\\n\\tstateDir := filepath.Join(env.RepoDir, \\\".git\\\", \\\"entire-sessions\\\")\\n\\tif err := os.MkdirAll(stateDir, 0o755); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to create session state dir: %w\\\", err)\\n\\t}\\n\\n\\tstateFile := filepath.Join(stateDir, sessionID+\\\".json\\\")\\n\\n\\tdata, err := json.MarshalIndent(state, \\\"\\\", \\\"  \\\")\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal session state: %w\\\", err)\\n\\t}\\n\\n\\tif err := os.WriteFile(stateFile, data, 0o644); err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to write session state: %w\\\", err)\\n\\t}\\n\\treturn nil\\n}\\n\\n// GeminiHookRunner executes Gemini CLI hooks in the test environment.\\ntype GeminiHookRunner struct {\\n\\tRepoDir          string\\n\\tGeminiProjectDir string\\n\\tT                interface {\\n\\t\\tHelper()\\n\\t\\tFatalf(format string, args ...interface{})\\n\\t\\tLogf(format string, args ...interface{})\\n\\t}\\n}\\n\\n// NewGeminiHookRunner creates a new Gemini hook runner for the given repo directory.\\nfunc NewGeminiHookRunner(repoDir, geminiProjectDir string, t interface {\\n\\tHelper()\\n\\tFatalf(format string, args ...interface{})\\n\\tLogf(format string, args ...interface{})\\n}) *GeminiHookRunner {\\n\\treturn &GeminiHookRunner{\\n\\t\\tRepoDir:          repoDir,\\n\\t\\tGeminiProjectDir: geminiProjectDir,\\n\\t\\tT:                t,\\n\\t}\\n}\\n\\n// runGeminiHookWithInput runs a Gemini hook with the given input.\\nfunc (r *GeminiHookRunner) runGeminiHookWithInput(hookName string, input interface{}) error {\\n\\tr.T.Helper()\\n\\n\\tinputJSON, err := json.Marshal(input)\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"failed to marshal hook input: %w\\\", err)\\n\\t}\\n\\n\\treturn r.runGeminiHookInRepoDir(hookName, inputJSON)\\n}\\n\\nfunc (r *GeminiHookRunner) runGeminiHookInRepoDir(hookName string, inputJSON []byte) error {\\n\\t// Run using the shared test binary\\n\\t// Command structure: entire hooks gemini <hook-name>\\n\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n\\tcmd.Dir = r.RepoDir\\n\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n\\tcmd.Env = append(os.Environ(),\\n\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n\\t)\\n\\n\\toutput, err := cmd.CombinedOutput()\\n\\tif err != nil {\\n\\t\\treturn fmt.Errorf(\\\"hook %s failed: %w\\\\nInput: %s\\\\nOutput: %s\\\",\\n\\t\\t\\thookName, err, inputJSON, output)\\n\\t}\\n\\n\\tr.T.Logf(\\\"Gemini hook %s output: %s\\\", hookName, output)\\n\\treturn nil\\n}\\n\\n// runGeminiHookWithOutput runs a Gemini hook and returns both stdout and stderr separately.\\nfunc (r *GeminiHookRunner) runGeminiHookWithOutput(hookName string, inputJSON []byte) HookOutput {\\n\\tcmd := exec.Command(getTestBinary(), \\\"hooks\\\", \\\"gemini\\\", hookName)\\n\\tcmd.Dir = r.RepoDir\\n\\tcmd.Stdin = bytes.NewReader(inputJSON)\\n\\tcmd.Env = append(os.Environ(),\\n\\t\\t\\\"ENTIRE_TEST_GEMINI_PROJECT_DIR=\\\"+r.GeminiProjectDir,\\n\\t)\\n\\n\\tvar stdout, stderr bytes.Buffer\\n\\tcmd.Stdout = &stdout\\n\\tcmd.Stderr = &stderr\\n\\n\\terr := cmd.Run()\\n\\treturn HookOutput{\\n\\t\\tStdout: stdout.Bytes(),\\n\\t\\tStderr: stderr.Bytes(),\\n\\t\\tErr:    err,\\n\\t}\\n}\\n\\n// SimulateGeminiBeforeAgent simulates the BeforeAgent hook for Gemini CLI.\\n// This is equivalent to Claude Code's UserPromptSubmit.\\nfunc (r *GeminiHookRunner) SimulateGeminiBeforeAgent(sessionID string) error {\\n\\tr.T.Helper()\\n\\n\\tinput := map[string]string{\\n\\