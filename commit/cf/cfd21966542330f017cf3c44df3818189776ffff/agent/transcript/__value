→\\t}\\n    47→\\n    48→\\tif err := json.Unmarshal(data, aux); err != nil {\\n    49→\\t\\treturn fmt.Errorf(\\\"failed to unmarshal message: %w\\\", err)\\n    50→\\t}\\n    51→\\n    52→\\tif len(aux.Content) == 0 || string(aux.Content) == \\\"null\\\" {\\n    53→\\t\\tm.Content = \\\"\\\"\\n    54→\\t\\treturn nil\\n    55→\\t}\\n    56→\\n    57→\\t// Try string first (most common for gemini messages)\\n    58→\\tvar strContent string\\n    59→\\tif err := json.Unmarshal(aux.Content, &strContent); err == nil {\\n    60→\\t\\tm.Content = strContent\\n    61→\\t\\treturn nil\\n    62→\\t}\\n    63→\\n    64→\\t// Try array of objects with \\\"text\\\" fields (user messages)\\n    65→\\tvar parts []struct {\\n    66→\\t\\tText string `json:\\\"text\\\"`\\n    67→\\t}\\n    68→\\tif err := json.Unmarshal(aux.Content, &parts); err == nil {\\n    69→\\t\\tvar texts []string\\n    70→\\t\\tfor _, p := range parts {\\n    71→\\t\\t\\tif p.Text != \\\"\\\" {\\n    72→\\t\\t\\t\\ttexts = append(texts, p.Text)\\n    73→\\t\\t\\t}\\n    74→\\t\\t}\\n    75→\\t\\tm.Content = strings.Join(texts, \\\"\\\\n\\\")\\n    76→\\t\\treturn nil\\n    77→\\t}\\n    78→\\n    79→\\t// Unknown format - leave content empty\\n    80→\\treturn nil\\n    81→}\\n    82→\\n    83→// GeminiToolCall represents a tool call in a gemini message\\n    84→type GeminiToolCall struct {\\n    85→\\tID     string                 `json:\\\"id\\\"`\\n    86→\\tName   string                 `json:\\\"name\\\"`\\n    87→\\tArgs   map[string]interface{} `json:\\\"args\\\"`\\n    88→\\tStatus string                 `json:\\\"status,omitempty\\\"`\\n    89→}\\n    90→\\n    91→// ParseTranscript parses raw JSON content into a transcript structure\\n    92→func ParseTranscript(data []byte) (*GeminiTranscript, error) {\\n    93→\\tvar transcript GeminiTranscript\\n    94→\\tif err := json.Unmarshal(data, &transcript); err != nil {\\n    95→\\t\\treturn nil, fmt.Errorf(\\\"failed to parse transcript: %w\\\", err)\\n    96→\\t}\\n    97→\\treturn &transcript, nil\\n    98→}\\n    99→\\n   100→// ExtractModifiedFiles extracts files modified by tool calls from transcript data\\n   101→func ExtractModifiedFiles(data []byte) ([]string, error) {\\n   102→\\ttranscript, err := ParseTranscript(data)\\n   103→\\tif err != nil {\\n   104→\\t\\treturn nil, err\\n   105→\\t}\\n   106→\\n   107→\\treturn ExtractModifiedFilesFromTranscript(transcript), nil\\n   108→}\\n   109→\\n   110→// ExtractModifiedFilesFromTranscript extracts files from a parsed transcript\\n   111→func ExtractModifiedFilesFromTranscript(transcript *GeminiTranscript) []string {\\n   112→\\tfileSet := make(map[string]bool)\\n   113→\\tvar files []string\\n   114→\\n   115→\\tfor _, msg := range transcript.Messages {\\n   116→\\t\\t// Only process gemini messages (assistant messages)\\n   117→\\t\\tif msg.Type != MessageTypeGemini {\\n   118→\\t\\t\\tcontinue\\n   119→\\t\\t}\\n   120→\\n   121→\\t\\t// Process tool calls in this message\\n   122→\\t\\tfor _, toolCall := range msg.ToolCalls {\\n   123→\\t\\t\\t// Check if it's a file modification tool\\n   124→\\t\\t\\tisModifyTool := false\\n   125→\\t\\t\\tfor _, name := range FileModificationTools {\\n   126→\\t\\t\\t\\tif toolCall.Name == name {\\n   127→\\t\\t\\t\\t\\tisModifyTool = true\\n   128→\\t\\t\\t\\t\\tbreak\\n   129→\\t\\t\\t\\t}\\n   130→\\t\\t\\t}\\n   131→\\n   132→\\t\\t\\tif !isModifyTool {\\n   133→\\t\\t\\t\\tcontinue\\n   134→\\t\\t\\t}\\n   135→\\n   136→\\t\\t\\t// Extract file path from args map\\n   137→\\t\\t\\tvar file string\\n   138→\\t\\t\\tif fp, ok := toolCall.Args[\\\"file_path\\\"].(string); ok && fp != \\\"\\\" {\\n   139→\\t\\t\\t\\tfile = fp\\n   140→\\t\\t\\t} else if p, ok := toolCall.Args[\\\"path\\\"].(string); ok && p != \\\"\\\" {\\n   141→\\t\\t\\t\\tfile = p\\n   142→\\t\\t\\t} else if fn, ok := toolCall.Args[\\\"filename\\\"].(string); ok && fn != \\\"\\\" {\\n   143→\\t\\t\\t\\tfile = fn\\n   144→\\t\\t\\t}\\n   145→\\n   146→\\t\\t\\tif file != \\\"\\\" && !fileSet[file] {\\n   147→\\t\\t\\t\\tfileSet[file] = true\\n   148→\\t\\t\\t\\tfiles = append(files, file)\\n   149→\\t\\t\\t}\\n   150→\\t\\t}\\n   151→\\t}\\n   152→\\n   153→\\treturn files\\n   154→}\\n   155→\\n   156→// ExtractLastUserPrompt extracts the last user message from transcript data\\n   157→func ExtractLastUserPrompt(data []byte) (string, error) {\\n   158→\\ttranscript, err := ParseTranscript(data)\\n   159→\\tif err != nil {\\n   160→\\t\\treturn \\\"\\\", err\\n   161→\\t}\\n   162→\\n   163→\\treturn ExtractLastUserPromptFromTranscript(transcript), nil\\n   164→}\\n   165→\\n   166→// ExtractLastUserPromptFromTranscript extracts the last user prompt from a parsed transcript\\n   167→func ExtractLastUserPromptFromTranscript(transcript *GeminiTranscript) string {\\n   168→\\tfor i := len(transcript.Messages) - 1; i >= 0; i-- {\\n   169→\\t\\tmsg := transcript.Messages[i]\\n   170→\\t\\tif msg.Type != MessageTypeUser {\\n   171→\\t\\t\\tcontinue\\n   172→\\t\\t}\\n   173→\\n   174→\\t\\t// Content is now a string field\\n   175→\\t\\tif msg.Content != \\\"\\\" {\\n   176→\\t\\t\\treturn msg.Content\\n   177→\\t\\t}\\n   178→\\t}\\n   179→\\treturn \\\"\\\"\\n   180→}\\n   181→\\n   182→// ExtractAllUserPrompts extracts all user messages from transcript data\\n   183→func ExtractAllUserPrompts(data []byte) ([]string, error) {\\n   184→\\ttranscript, err := ParseTranscript(data)\\n   185→\\tif err != nil {\\n   186→\\t\\treturn nil, err\\n   187→\\t}\\n   188→\\n   189→\\treturn ExtractAllUserPromptsFromTranscript(transcript), nil\\n   190→}\\n   191→\\n   192→// ExtractAllUserPromptsFromTranscript extracts all user prompts from a parsed transcript\\n   193→func ExtractAllUserPromptsFromTranscript(transcript *GeminiTranscript) []string {\\n   194→\\tvar prompts []string\\n   195→\\tfor _, msg := range transcript.Messages {\\n   196→\\t\\tif msg.Type == MessageTypeUser && msg.Content != \\\"\\\" {\\n   197→\\t